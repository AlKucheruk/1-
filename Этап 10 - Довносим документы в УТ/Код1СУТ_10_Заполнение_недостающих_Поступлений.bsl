// BSLLS-off
// Модуль формы внешней обработки «Заполнение недостающих поступлений (Приобретение услуг и прочих активов)»
// Этап 10. Файл: Код1СУТ_10_Заполнение_недостающих_Поступлений.bsl
//
// Ожидаемая ТаблицаДанных (реквизит обработки): НомерСтроки, Дата, Контрагент, Статья (Строка 50), ИНН, Сумма,
//   Выбрать, КонтрагентСсылка, Договор (строка из Excel/представление), НайденКонтрагент, НайденДоговор,
//   ДоговорСсылка, Статус, Комментарий.
// Реквизиты формы (отбор при чтении Excel, по колонке «Дата» в файле): ДатаНачала, ДатаОкончания — как в этапе 6 (платежки).
// Документ: Документ.ПриобретениеУслугПрочихАктивов, ТЧ «Расходы».
// В ТЧ «Сумма» — с НДС (как в Excel): Сумма = Цена = сумма с НДС; СуммаНДС/СуммаСНДС — расклад; нетто для шапки = Сумма − СуммаНДС.
//
// Журнал: D:\1с\КАА\Лог_10_Заполнение_недостающих_Поступлений.txt

#Область Клиентские_процедуры

&НаКлиенте
Процедура ВыбратьФайл(Команда)
	ОписаниеОповещения = Новый ОписаниеОповещения("ВыбратьФайлЗавершение", ЭтаФорма);
	НачатьПомещениеФайла(
		ОписаниеОповещения,
		,
		,
		Истина,
		ЭтаФорма.УникальныйИдентификатор);
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьФайлЗавершение(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт
	Если НЕ Результат Тогда
		Возврат;
	КонецЕсли;

	ЭтаФорма.АдресФайла = Адрес;
	ЭтаФорма.ИмяФайла   = ВыбранноеИмяФайла;

	НачалоЗагрузки = ТекущаяУниверсальнаяДатаВМиллисекундах();
	ЗагрузитьПредпросмотрСервер(Адрес, ВыбранноеИмяФайла, НачалоЗагрузки);

КонецПроцедуры

&НаКлиенте
Функция ПопыткаУстановитьСвойствоСтроки(СтрокаТаблицы, ИмяСвойства, Значение)
	Попытка
		Выполнить("СтрокаТаблицы." + ИмяСвойства + " = Значение;");
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
КонецФункции

&НаКлиенте
Функция ЭлементТаблицыДанныхНаФорме()
	Возврат НайтиЭлементТаблицыДанныхРекурсивно(Элементы);
КонецФункции

&НаКлиенте
Функция НайтиЭлементТаблицыДанныхРекурсивно(КоллекцияЭлементов)
	Для Каждого Элемент Из КоллекцияЭлементов Цикл
		Подчиненные = Неопределено;
		Попытка
			Подчиненные = Элемент.ПодчиненныеЭлементы;
		Исключение
			Подчиненные = Неопределено;
		КонецПопытки;
		Если Элемент.Имя = "ТаблицаДанных" Тогда
			Попытка
				Если ТипЗнч(Элемент) = Тип("ТаблицаФормы") Тогда
					Возврат Элемент;
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЕсли;
		Попытка
			Если ТипЗнч(Элемент) = Тип("ТаблицаФормы") Тогда
				ПутьКДаннымЭлемента = Элемент.ПутьКДанным;
				Если НЕ ПустаяСтрока(ПутьКДаннымЭлемента) Тогда
					Если ПутьКДаннымЭлемента = "ТаблицаДанных"
						ИЛИ ПутьКДаннымЭлемента = "Объект.ТаблицаДанных"
						ИЛИ СтрЗаканчиваетсяНа(ПутьКДаннымЭлемента, ".ТаблицаДанных")
						ИЛИ СтрЗаканчиваетсяНа(ПутьКДаннымЭлемента, "ТаблицаДанных") Тогда
						Возврат Элемент;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
		Если Подчиненные <> Неопределено Тогда
			Найденный = НайтиЭлементТаблицыДанныхРекурсивно(Подчиненные);
			Если Найденный <> Неопределено Тогда
				Возврат Найденный;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

&НаКлиенте
Функция СтрокаТаблицыДанныхВиднаПоОтборуТаблицыФормы(ТаблицаФормы, СтрокаТаблицы)
	Попытка
		СтрокаДляПроверки = Неопределено;
		Попытка
			СтрокаДляПроверки = СтрокаТаблицы.ПолучитьИдентификатор();
		Исключение
			СтрокаДляПроверки = Неопределено;
		КонецПопытки;
		Если СтрокаДляПроверки = Неопределено Тогда
			Попытка
				СтрокаДляПроверки = ТаблицаДанных.Индекс(СтрокаТаблицы);
			Исключение
				СтрокаДляПроверки = Неопределено;
			КонецПопытки;
		КонецЕсли;
		Если СтрокаДляПроверки = Неопределено Тогда
			СтрокаДляПроверки = СтрокаТаблицы;
		КонецЕсли;
		РезультатПроверки = ТаблицаФормы.ПроверитьСтроку(СтрокаДляПроверки);
		Если РезультатПроверки = Истина Тогда
			Возврат Истина;
		ИначеЕсли РезультатПроверки = Ложь Тогда
			Возврат Ложь;
		Иначе
			Возврат Истина;
		КонецЕсли;
	Исключение
		Возврат Истина;
	КонецПопытки;
КонецФункции

&НаКлиенте
Функция СтрокаОтмеченаКЗагрузкеКлиент(СтрокаТаблицы)
	Попытка
		Возврат СтрокаТаблицы.Выбрать;
	Исключение
		Возврат Истина;
	КонецПопытки;
КонецФункции

&НаКлиенте
Процедура ВыбратьВсе(Команда)
	Если ТаблицаДанных.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Нет данных для выбора.");
		Возврат;
	КонецЕсли;
	ТаблицаФормы = ЭлементТаблицыДанныхНаФорме();
	Если ТаблицаФормы = Неопределено Тогда
		Для Каждого СтрокаТаблицы Из ТаблицаДанных Цикл
			ПопыткаУстановитьСвойствоСтроки(СтрокаТаблицы, "Выбрать", Истина);
		КонецЦикла;
		ПоказатьПредупреждение(,
			"Элемент таблицы с привязкой к «ТаблицаДанных» не найден — отмечены все строки без учёта фильтра."
			+ " Проверьте имя элемента и ПутьКДанным в конфигураторе.", 0);
	Иначе
		Для Каждого СтрокаТаблицы Из ТаблицаДанных Цикл
			Если СтрокаТаблицыДанныхВиднаПоОтборуТаблицыФормы(ТаблицаФормы, СтрокаТаблицы) Тогда
				ПопыткаУстановитьСвойствоСтроки(СтрокаТаблицы, "Выбрать", Истина);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Элементы.ТаблицаДанных.Обновить();
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсе(Команда)
	Если ТаблицаДанных.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Нет данных для снятия выбора.");
		Возврат;
	КонецЕсли;
	ТаблицаФормы = ЭлементТаблицыДанныхНаФорме();
	Если ТаблицаФормы = Неопределено Тогда
		Для Каждого СтрокаТаблицы Из ТаблицаДанных Цикл
			ПопыткаУстановитьСвойствоСтроки(СтрокаТаблицы, "Выбрать", Ложь);
		КонецЦикла;
		ПоказатьПредупреждение(,
			"Элемент таблицы с привязкой к «ТаблицаДанных» не найден — сняты отметки со всех строк.", 0);
	Иначе
		Для Каждого СтрокаТаблицы Из ТаблицаДанных Цикл
			Если СтрокаТаблицыДанныхВиднаПоОтборуТаблицыФормы(ТаблицаФормы, СтрокаТаблицы) Тогда
				ПопыткаУстановитьСвойствоСтроки(СтрокаТаблицы, "Выбрать", Ложь);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Элементы.ТаблицаДанных.Обновить();
КонецПроцедуры

&НаКлиенте
Процедура ОценитьВремяЗагрузки(Команда)
	ТекстОценки = ОценитьВремяЗагрузкиСервер();
	ЗаголовокОкна = "Оценка времени загрузки (этап 10)";
	ТекстВсегоДляПользователя = ЗаголовокОкна + Символы.ПС + Символы.ПС + ТекстОценки;
	ПоказатьПредупреждение(, ТекстВсегоДляПользователя, 0);
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьВБазу(Команда)
	Если ТаблицаДанных.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Таблица данных пуста. Сначала загрузите файл Excel.");
		Возврат;
	КонецЕсли;
	КоличествоГотовых = 0;
	КоличествоОшибок  = 0;
	КоличествоВыбранных = 0;
	Для Каждого СтрокаТаблицы Из ТаблицаДанных Цикл
		Если НЕ СтрокаОтмеченаКЗагрузкеКлиент(СтрокаТаблицы) Тогда
			Продолжить;
		КонецЕсли;
		КоличествоВыбранных = КоличествоВыбранных + 1;
		Если СтрокаТаблицы.Статус = "Готов" Тогда
			КоличествоГотовых = КоличествоГотовых + 1;
		ИначеЕсли СтрокаТаблицы.Статус = "Ошибка" Тогда
			КоличествоОшибок = КоличествоОшибок + 1;
		КонецЕсли;
	КонецЦикла;
	Если КоличествоВыбранных = 0 Тогда
		ПоказатьПредупреждение(, "Не выбрано ни одной строки для загрузки.");
		Возврат;
	КонецЕсли;
	Если КоличествоГотовых = 0 Тогда
		ПоказатьПредупреждение(, "Среди выбранных строк нет статуса ""Готов"" для загрузки."
			+ Символы.ПС + "Ошибок/не готово: " + Строка(КоличествоОшибок));
		Возврат;
	КонецЕсли;
	ТекстВопроса = "Выбрано строк: " + Строка(КоличествоВыбранных)
		+ Символы.ПС + "Будет создано документов: " + Строка(КоличествоГотовых)
		+ Символы.ПС + Символы.ПС + "Продолжить загрузку?";
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузитьВБазуПодтверждение", ЭтотОбъект);
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет, "Загрузка в базу");
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьВБазуПодтверждение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	Состояние("Создание документов «Приобретение услуг…»…");
	НачалоЗагрузки = ТекущаяУниверсальнаяДатаВМиллисекундах();
	ЗагрузитьВБазуСервер(НачалоЗагрузки);
	Элементы.ТаблицаДанных.Обновить();
	Сообщить("Загрузка в базу завершена.", СтатусСообщения.Информация);
КонецПроцедуры

#КонецОбласти

#Область Вспомогательные_функции_заголовков_Excel

&НаСервереБезКонтекста
Функция НормализоватьТекстДляСравнения(Текст)
	Результат = ВРег(СокрЛП(Строка(Текст)));
	Результат = СтрЗаменить(Результат, Символ(160), "");
	Результат = СтрЗаменить(Результат, Символы.Таб, "");
	Результат = СтрЗаменить(Результат, " ", "");
	Результат = СтрЗаменить(Результат, "_", "");
	Результат = СтрЗаменить(Результат, "-", "");
	Результат = СтрЗаменить(Результат, ".", "");
	Возврат Результат;
КонецФункции

&НаСервереБезКонтекста
Функция НайтиНомерКолонкиПоЗаголовку(ТабДок, НомерСтрокиЗаголовка, ИмяЗаголовка)
	ИскомоеИмя = НормализоватьТекстДляСравнения(ИмяЗаголовка);
	Для НомерКолонки = 1 По ТабДок.ШиринаТаблицы Цикл
		ТекстЯчейки = НормализоватьТекстДляСравнения(ТабДок.Область(НомерСтрокиЗаголовка, НомерКолонки).Текст);
		Если ТекстЯчейки = ИскомоеИмя Тогда
			Возврат НомерКолонки;
		КонецЕсли;
	КонецЦикла;
	Возврат 0;
КонецФункции

&НаСервереБезКонтекста
Функция СформироватьВариантыЗаголовков(СписокЧерезЗапятую)
	Результат = Новый Массив;
	Для Каждого ЭлементСписка Из СтрРазделить(СписокЧерезЗапятую, ",") Цикл
		Вариант = СокрЛП(ЭлементСписка);
		Если НЕ ПустаяСтрока(Вариант) Тогда
			Результат.Добавить(Вариант);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

&НаСервереБезКонтекста
Функция ОпределитьКолонкуПоВариантам(ТабДок, НомерСтрокиЗаголовка, НомерПоУмолчанию, ВариантыЗаголовков)
	Если ВариантыЗаголовков <> Неопределено Тогда
		Для Каждого ВариантЗаголовка Из ВариантыЗаголовков Цикл
			НайденнаяКолонка = НайтиНомерКолонкиПоЗаголовку(ТабДок, НомерСтрокиЗаголовка, ВариантЗаголовка);
			Если НайденнаяКолонка > 0 Тогда
				Возврат НайденнаяКолонка;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Возврат НомерПоУмолчанию;
КонецФункции

#КонецОбласти

#Область Сервис_формы

&НаСервере
Функция ПолучитьЗначениеРеквизитаФормыЕслиЕсть(ИмяРеквизита, ЗначениеПоУмолчанию = Неопределено)
	ЗначениеРеквизита = ЗначениеПоУмолчанию;
	Попытка
		Выполнить("ЗначениеРеквизита = ЭтаФорма." + ИмяРеквизита + ";");
		Возврат ЗначениеРеквизита;
	Исключение
	КонецПопытки;
	Попытка
		Выполнить("ЗначениеРеквизита = " + ИмяРеквизита + ";");
		Возврат ЗначениеРеквизита;
	Исключение
	КонецПопытки;
	Возврат ЗначениеРеквизита;
КонецФункции

#КонецОбласти

#Область Чтение_Excel_и_предпросмотр

&НаСервереБезКонтекста
Функция ПрочитатьExcelВТаблицуПоступлений(Адрес, ИмяФайла, ДатаНачалаФильтра = Неопределено, ДатаОкончанияФильтра = Неопределено)

	Попытка
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(Адрес);
	Исключение
		Возврат "ОШИБКА: Не удалось получить файл из хранилища. " + ОписаниеОшибки();
	КонецПопытки;

	ВремФайл = ПолучитьИмяВременногоФайла("xlsx");
	Попытка
		ДвоичныеДанные.Записать(ВремФайл);
	Исключение
		Возврат "ОШИБКА: Не удалось записать временный файл. " + ОписаниеОшибки();
	КонецПопытки;

	ТабДок = Новый ТабличныйДокумент;
	Попытка
		ТабДок.Прочитать(ВремФайл, СпособЧтенияЗначенийТабличногоДокумента.Значение);
	Исключение
		Попытка УдалитьФайлы(ВремФайл); Исключение КонецПопытки;
		Возврат "ОШИБКА: Не удалось прочитать Excel. " + ОписаниеОшибки();
	КонецПопытки;
	Попытка УдалитьФайлы(ВремФайл); Исключение КонецПопытки;

	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("НомерСтроки",  Новый ОписаниеТипов("Число",  , , Новый КвалификаторыЧисла(8, 0)));
	ТЗ.Колонки.Добавить("Дата",         Новый ОписаниеТипов("Дата"));
	ТЗ.Колонки.Добавить("Контрагент",   Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(250)));
	ТЗ.Колонки.Добавить("Статья",       Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(150)));
	ТЗ.Колонки.Добавить("ИНН",          Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(20)));
	ТЗ.Колонки.Добавить("Сумма",        Новый ОписаниеТипов("Число",  , , Новый КвалификаторыЧисла(15, 2)));

	СтрокаЗаголовка = 1;
	НомКолДата   = 1;
	НомКолКонтр  = 2;
	НомКолСтатья = 3;
	НомКолИНН    = 4;
	НомКолСумма  = 5;
	НомКолДата   = ОпределитьКолонкуПоВариантам(ТабДок, СтрокаЗаголовка, НомКолДата,   СформироватьВариантыЗаголовков("Дата"));
	НомКолКонтр  = ОпределитьКолонкуПоВариантам(ТабДок, СтрокаЗаголовка, НомКолКонтр,  СформироватьВариантыЗаголовков("Контрагент"));
	НомКолСтатья = ОпределитьКолонкуПоВариантам(ТабДок, СтрокаЗаголовка, НомКолСтатья, СформироватьВариантыЗаголовков("Статья"));
	НомКолИНН    = ОпределитьКолонкуПоВариантам(ТабДок, СтрокаЗаголовка, НомКолИНН,    СформироватьВариантыЗаголовков("ИНН"));
	НомКолСумма  = ОпределитьКолонкуПоВариантам(ТабДок, СтрокаЗаголовка, НомКолСумма,  СформироватьВариантыЗаголовков("Сумма,СуммаДокумента,Суммадокумента"));

	Если НомКолДата = 0 Или НомКолКонтр = 0 Или НомКолИНН = 0 Или НомКолСумма = 0 Тогда
		Возврат "В файле не найдены обязательные колонки (нужны заголовки: Дата, Контрагент, ИНН, Сумма или СуммаДокумента).";
	КонецЕсли;
	Если НомКолСтатья = 0 Тогда
		Возврат "В файле не найдена колонка «Статья».";
	КонецЕсли;

	НомерДанных = 0;
	СтрокФайлаНепустых = 0;
	Для НомерСтр = СтрокаЗаголовка + 1 По ТабДок.ВысотаТаблицы Цикл
		СуммаЯч  = ТабДок.Область(НомерСтр, НомКолСумма).Текст;
		ДатаЯч   = ТабДок.Область(НомерСтр, НомКолДата).Текст;
		КонтрЯч  = ТабДок.Область(НомерСтр, НомКолКонтр).Текст;
		ИННЯч   = ТабДок.Область(НомерСтр, НомКолИНН).Текст;
		СтатьяЯч = ТабДок.Область(НомерСтр, НомКолСтатья).Текст;
		Если ПустаяСтрока(СуммаЯч) И ПустаяСтрока(ДатаЯч) И ПустаяСтрока(КонтрЯч) И ПустаяСтрока(ИННЯч) Тогда
			Продолжить;
		КонецЕсли;
		СтрокФайлаНепустых = СтрокФайлаНепустых + 1;

		Дт = '00010101';
		Попытка
			Дт = Дата(ДатаЯч);
		Исключение
			Попытка
				Дт = XMLЗначение(Тип("Дата"), СокрЛП(ДатаЯч));
			Исключение
				Дт = '00010101';
			КонецПопытки;
		КонецПопытки;
		// Фильтр по колонке «Дата» (как в этапе 8, Код1СУТ_08_Загрузка Платежек: НачалоДня / КонецДня)
		Если ЗначениеЗаполнено(ДатаНачалаФильтра) И ЗначениеЗаполнено(Дт) И Дт <> '00010101' Тогда
			Если Дт < НачалоДня(ДатаНачалаФильтра) Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(ДатаОкончанияФильтра) И ЗначениеЗаполнено(Дт) И Дт <> '00010101' Тогда
			Если Дт > КонецДня(ДатаОкончанияФильтра) Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;

		НовСтр = ТЗ.Добавить();
		НовСтр.НомерСтроки = НомерДанных + 1;
		НовСтр.Сумма = 0;
		Попытка
			НовСтр.Сумма = Число(СтрЗаменить(СуммаЯч, " ", ""));
		Исключение
		КонецПопытки;
		НовСтр.Дата = Дт;
		НовСтр.Контрагент = СокрЛП(КонтрЯч);
		НовСтр.ИНН        = СокрЛП(ИННЯч);
		НовСтр.Статья     = Лев(СокрЛП(СтатьяЯч), 50);
		НомерДанных = НомерДанных + 1;
	КонецЦикла;

	Если ТЗ.Количество() = 0 Тогда
		Если СтрокФайлаНепустых > 0 И (ЗначениеЗаполнено(ДатаНачалаФильтра) Или ЗначениеЗаполнено(ДатаОкончанияФильтра)) Тогда
			Возврат "По датам на форме (Дата начала / Дата окончания) не осталось ни одной строки: "
				+ "все " + Строка(СтрокФайлаНепустых) + " непустых строк Excel не попали в период по полю «Дата».";
		КонецЕсли;
		Возврат "В файле нет заполненных строк данных (под заголовком).";
	КонецЕсли;
	Возврат ТЗ;
КонецФункции

&НаСервере
Процедура ЗагрузитьПредпросмотрСервер(Адрес, ИмяФайла, НачальноеВремя = Неопределено)

	ТаблицаДанных.Очистить();

	ДатаНачалаФильтра    = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("ДатаНачала");
	ДатаОкончанияФильтра = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("ДатаОкончания");
	Результат = ПрочитатьExcelВТаблицуПоступлений(Адрес, ИмяФайла, ДатаНачалаФильтра, ДатаОкончанияФильтра);
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		Сообщить(Результат, СтатусСообщения.Важное);
		Возврат;
	КонецЕсли;
	ТЗ = Результат;

	Попытка
		Для Каждого Стр Из ТЗ Цикл
			НовСтр = ТаблицаДанных.Добавить();
			НовСтр.НомерСтроки    = Стр.НомерСтроки;
			НовСтр.Дата           = Стр.Дата;
			НовСтр.Контрагент     = Стр.Контрагент;
			НовСтр.Статья         = Стр.Статья;
			НовСтр.ИНН            = Стр.ИНН;
			НовСтр.Сумма          = Стр.Сумма;
			Попытка НовСтр.Выбрать = Истина; Исключение КонецПопытки;
		КонецЦикла;
	Исключение
		Сообщить("Ошибка переноса в таблицу формы: " + ОписаниеОшибки(), СтатусСообщения.Важное);
		Возврат;
	КонецПопытки;

	УстановитьСтатусыПослеПоискаПоТаблице(ТаблицаДанных);

	Если НачальноеВремя <> Неопределено Тогда
		ВремяМс = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачальноеВремя;
		Сообщить("Предпросмотр загружен за " + Формат(ВремяМс / 1000, "ЧДЦ=2") + " сек.", СтатусСообщения.Информация);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область Поиск_контрагентов_и_договоров

&НаСервереБезКонтекста
Функция СоответствиеКонтрагентовПоМассивуИНН(МассивИНН)
	Соотв = Новый Соответствие; // Ключ: ИНН (без КПП), Значение: СправочникСсылка.Контрагенты
	Если МассивИНН.Количество() = 0 Тогда
		Возврат Соотв;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Контрагенты.ИНН КАК ИНН,
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ИНН В(&МассивИНН)
	|	И НЕ Контрагенты.ПометкаУдаления";
	Запрос.УстановитьПараметр("МассивИНН", МассивИНН);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Кл = СокрЛП(Выборка.ИНН);
		Если Соотв.Получить(Кл) = Неопределено Тогда
			Соотв.Вставить(Кл, Выборка.Ссылка);
		КонецЕсли;
	КонецЦикла;
	Возврат Соотв;
КонецФункции

&НаСервереБезКонтекста
Функция НайтиДоговорЗакупкиПоПоставщику(КонтрагентСсылка)
	Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Тогда
		Возврат Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Договоры.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК Договоры
	|ГДЕ
	|	Договоры.Контрагент = &Контрагент
	|	И НЕ Договоры.ПометкаУдаления
	|	И Договоры.ТипДоговора = ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.СПоставщиком)
	|	И Договоры.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщика)
	|УПОРЯДОЧИТЬ ПО
	|	Договоры.Наименование";
	Запрос.УстановитьПараметр("Контрагент", КонтрагентСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	Возврат Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
КонецФункции

&НаСервере
Процедура УстановитьСтатусыПослеПоискаПоТаблице(Таблица)

	МассивИНН = Новый Массив;
	Для Каждого Стр Из Таблица Цикл
		инн = СокрЛП(Строка(Стр.ИНН));
		Если НЕ ПустаяСтрока(инн) Тогда
			МассивИНН.Добавить(инн);
		КонецЕсли;
	КонецЦикла;
	Соотв = СоответствиеКонтрагентовПоМассивуИНН(МассивИНН);

	Для Каждого Стр Из Таблица Цикл
		Стр.Статус    = "Не готов";
		Стр.Комментарий = "";
		инн = СокрЛП(Строка(Стр.ИНН));
		Если ПустаяСтрока(инн) Тогда
			Стр.НайденКонтрагент = Ложь;
			Стр.НайденДоговор    = Ложь;
			Стр.Комментарий      = "Нет ИНН. ";
			Продолжить;
		КонецЕсли;
		Конт = Соотв.Получить(инн);
		Если НЕ ЗначениеЗаполнено(Конт) Тогда
			Стр.КонтрагентСсылка = Справочники.Контрагенты.ПустаяСсылка();
			Стр.НайденКонтрагент  = Ложь;
			Стр.НайденДоговор     = Ложь;
			Стр.ДоговорСсылка     = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
			Стр.Договор           = "";
			Стр.Комментарий       = "Контрагент с ИНН не найден. ";
		Иначе
			Стр.КонтрагентСсылка  = Конт;
			Стр.НайденКонтрагент  = Истина;
			Дог = НайтиДоговорЗакупкиПоПоставщику(Конт);
			Если НЕ ЗначениеЗаполнено(Дог) Тогда
				Стр.ДоговорСсылка  = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
				Стр.НайденДоговор  = Ложь;
				Стр.Договор        = "";
				Стр.Комментарий    = "Нет договора с типом поставщика и хоз. операцией «Закупка у поставщика». ";
			Иначе
				Стр.ДоговорСсылка  = Дог;
				Стр.НайденДоговор  = Истина;
				Стр.Договор        = Строка(Дог);
			КонецЕсли;
		КонецЕсли;
		Если НайтиСтатьюРасходовПоТексту(Стр.Статья) = Неопределено Тогда
			Стр.Комментарий = Стр.Комментарий + "Не сопоставлена статья расходов по тексту «" + СокрЛП(Стр.Статья) + "». ";
		КонецЕсли;
		Если Стр.Сумма = 0 Тогда
			Стр.Комментарий = Стр.Комментарий + "Сумма 0. ";
		КонецЕсли;
		Если Стр.НайденКонтрагент И Стр.НайденДоговор И НайтиСтатьюРасходовПоТексту(Стр.Статья) <> Неопределено
			И Стр.Сумма <> 0 Тогда
			Стр.Статус = "Готов";
			Если ПустаяСтрока(Стр.Комментарий) Тогда
				Стр.Комментарий = "Готово к загрузке. ";
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область Статьи_расходов_и_создание_документа

&НаСервереБезКонтекста
Функция НайтиСтатьюРасходовПоТексту(ТекстСтатьи50)
	Т = СокрЛП(Строка(ТекстСтатьи50));
	Если ПустаяСтрока(Т) Тогда
		Возврат Неопределено;
	КонецЕсли;
	СсылкаПВХ = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоНаименованию(Т, Истина);
	Если НЕ ЗначениеЗаполнено(СсылкаПВХ) Тогда
		СсылкаПВХ = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоНаименованию(Т, Ложь);
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(СсылкаПВХ) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		Если СсылкаПВХ.ПометкаУдаления Тогда
			Возврат Неопределено;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Возврат СсылкаПВХ;
КонецФункции

&НаСервереБезКонтекста
// Основная ставка НДС РФ по дате документа (для сопоставления с периодом: не хардкодить 22%).
// 18% до 01.01.2019, 20% до 01.01.2026, 22% с 01.01.2026.
Функция ОсновнаяСтавкаНДСПроцентовПоДате(ДатаДок)
	Д = НачалоДня(ДатаДок);
	Если Д < Дата(2019, 1, 1) Тогда
		Возврат 18;
	ИначеЕсли Д < Дата(2026, 1, 1) Тогда
		Возврат 20;
	КонецЕсли;
	Возврат 22;
КонецФункции

&НаСервереБезКонтекста
// Возвращает ссылку для реквизита СтавкаНДС: в УТ 11.4 часто Перечисление, в 11.5+ — Справочник.СтавкиНДС.
// Ищем в справочнике по наименованиям «18%», «18/118»… затем в перечислении (прямой доступ и по имени).
Функция НайтиЗначениеСтавкиНДСПоПроценту(Процент)
	ПустВ = Неопределено;

	// 1) Справочник СтавкиНДС (типовая УТ 11.5+)
	Попытка
		ПустСпр = Справочники.СтавкиНДС.ПустаяСсылка();
		МВариантов = Новый Массив;
		С = Строка(Процент);
		Зн = 100 + Процент;
		МВариантов.Добавить(С + "%");
		МВариантов.Добавить(С + " %");
		МВариантов.Добавить(С + "/" + Строка(Зн));
		МВариантов.Добавить("НДС " + С + "%");
		МВариантов.Добавить(С + ",00%");
		МВариантов.Добавить(С + ".00%");
		Для Каждого ТекстНаим Из МВариантов Цикл
			Ссыл = Справочники.СтавкиНДС.НайтиПоНаименованию(ТекстНаим, Истина);
			Если Ссыл <> ПустСпр И ЗначениеЗаполнено(Ссыл) Тогда
				Возврат Ссыл;
			КонецЕсли;
			Ссыл = Справочники.СтавкиНДС.НайтиПоНаименованию(ТекстНаим, Ложь);
			Если Ссыл <> ПустСпр И ЗначениеЗаполнено(Ссыл) Тогда
				Возврат Ссыл;
			КонецЕсли;
		КонецЦикла;
		// код элемента в типовой справочник: «18», «НДС18», «20»…
		МКодов = СтрРазделить(С + ",НДС" + С + ",Н" + С + ",P" + С, ",");
		Для Каждого КодПрот Из МКодов Цикл
			Если ПустаяСтрока(КодПрот) Тогда
				Продолжить;
			КонецЕсли;
			Ссыл = Справочники.СтавкиНДС.НайтиПоКоду(КодПрот);
			Если Ссыл <> ПустСпр И ЗначениеЗаполнено(Ссыл) Тогда
				Возврат Ссыл;
			КонецЕсли;
		КонецЦикла;
	Исключение
		// нет справочника / другая схема
	КонецПопытки;

	// 2) Перечисление — прямые имена (как в метаданных)
	Попытка
		Если Процент = 18 Тогда
			Попытка Возврат Перечисления.СтавкиНДС.НДС18; Исключение КонецПопытки;
		ИначеЕсли Процент = 20 Тогда
			Попытка Возврат Перечисления.СтавкиНДС.НДС20; Исключение КонецПопытки;
		ИначеЕсли Процент = 22 Тогда
			Попытка Возврат Перечисления.СтавкиНДС.НДС22; Исключение КонецПопытки;
		КонецЕсли;
	Исключение
	КонецПопытки;

	// 3) Перечисление — обращение по строковому имени значения
	Им = Строка(Процент);
	Попытка
		Возврат Перечисления.СтавкиНДС["НДС" + Им];
	Исключение
	КонецПопытки;
	Попытка
		Возврат Перечисления.СтавкиНДС["Ставка" + Им];
	Исключение
	КонецПопытки;
	Попытка
		Возврат Перечисления.СтавкиНДС["НДС_" + Им];
	Исключение
	КонецПопытки;
	// 4) Обход метаданных перечисления
	Попытка
		Префиксы = СтрРазделить("НДС,Ставка,НДС_,СтавкаНДС", ",");
		Для Каждого МетаЗначение Из Метаданные.Перечисления.СтавкиНДС.ЗначенияПеречисления Цикл
			ИмЗ = МетаЗначение.Имя;
			Для Каждого Преф Из Префиксы Цикл
				Если ИмЗ = Преф + Им Или ИмЗ = "НДС" + Им Тогда
					Попытка
						Возврат Перечисления.СтавкиНДС[ИмЗ];
					Исключение
					КонецПопытки;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	Исключение
	КонецПопытки;

	Возврат ПустВ;
КонецФункции

&НаСервереБезКонтекста
// «Без НДС» — сначала справочник, затем перечисление.
Функция НайтиЗначениеСтавкиНДСБезНДС()
	Попытка
		ПустСпр = Справочники.СтавкиНДС.ПустаяСсылка();
		Для Каждого Т Из СтрРазделить("Без НДС,БезНДС,0%,НДС 0%", ",") Цикл
			Сс = Справочники.СтавкиНДС.НайтиПоНаименованию(Т, Истина);
			Если Сс <> ПустСпр И ЗначениеЗаполнено(Сс) Тогда
				Возврат Сс;
			КонецЕсли;
		КонецЦикла;
	Исключение
	КонецПопытки;
	Попытка
		Возврат Перечисления.СтавкиНДС.БезНДС;
	Исключение
	КонецПопытки;
	Попытка
		Возврат Перечисления.СтавкиНДС.НДС0;
	Исключение
	КонецПопытки;
	Возврат Неопределено;
КонецФункции

&НаСервере
Функция СоздатьИПровестиПриобретениеПоСтроке(Знач ДатаДок, Знач СуммаСтроки, Знач ТекстСодержаниеСтатьи, Знач СтатьяРасходовСсылка, Знач КонтрагентСсылка, Знач ДоговорСсылка)

	Док = Документы.ПриобретениеУслугПрочихАктивов.СоздатьДокумент();
	Док.Дата = ДатаДок;
	Док.Контрагент = КонтрагентСсылка;
	Попытка
		Док.Партнер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КонтрагентСсылка, "Партнер");
	Исключение
	КонецПопытки;
	Док.Организация = ЗначениеНастроекПовтИсп.ПолучитьОрганизациюПоУмолчанию(Справочники.Организации.ПустаяСсылка());
	Если НЕ ЗначениеЗаполнено(Док.Организация) Тогда
		ВызватьИсключение "Не удалось определить организацию по умолчанию.";
	КонецЕсли;
	Док.Валюта = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Док.Организация);
	Док.ВалютаВзаиморасчетов = Док.Валюта;
	Док.Договор = ДоговорСсылка;
	Док.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика;
	Док.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов;
	Док.ФормаОплаты = Перечисления.ФормыОплаты.Безналичная;
	// До вызовов УчетНДСУП по шапке документа.
	Док.ЦенаВключаетНДС = Истина;

	ПараметрыН = Документы.ПриобретениеУслугПрочихАктивов.ПараметрыЗаполненияНалогообложенияНДСЗакупки(Док);
	УчетНДСУП.ЗаполнитьНалогообложениеНДСЗакупки(Док.НалогообложениеНДС, ПараметрыН);
	ПарамВ = Документы.ПриобретениеУслугПрочихАктивов.ПараметрыЗаполненияВидаДеятельностиНДС(Док);
	УчетНДСУП.ЗаполнитьВидДеятельностиНДС(Док.ЗакупкаПодДеятельность, ПарамВ);
	Док.Комментарий = "Этап 10: авто-загрузка.";

	Нов = Док.Расходы.Добавить();
	Нов.Содержание     = Лев(СокрЛП(ТекстСодержаниеСтатьи), 250);
	Нов.СтатьяРасходов = СтатьяРасходовСсылка;
	Нов.Количество     = 1;

	СумФ = Окр(СуммаСтроки, 2);
	Прц  = ОсновнаяСтавкаНДСПроцентовПоДате(ДатаДок);
	Знм  = 100 + Прц;
	Ств  = НайтиЗначениеСтавкиНДСПоПроценту(Прц);
	Если ЗначениеЗаполнено(Ств) Тогда
		Нов.СтавкаНДС  = Ств;
		сБ = Окр(СумФ * 100 / Знм, 2);
		сН = СумФ - сБ;
		// Сумма в ТЧ — с НДС (= сумма из файла = цена при К=1 = итог «в деньгах» в колонке).
		Нов.Цена         = СумФ;
		Нов.Сумма        = СумФ;
		Нов.СуммаНДС     = сН;
		Нов.СуммаСНДС    = СумФ;
	Иначе
		СтБез = НайтиЗначениеСтавкиНДСБезНДС();
		Если ЗначениеЗаполнено(СтБез) Тогда
			Нов.СтавкаНДС = СтБез;
		КонецЕсли;
		Нов.Цена         = СумФ;
		Нов.Сумма        = СумФ;
		Нов.СуммаНДС     = 0;
		Нов.СуммаСНДС    = СумФ;
	КонецЕсли;

	// Запись → пересчёт шапки, затем одна сверка: СуммаДокумента = колонка «Сумма» строки в предварительной таблице.
	Док.Записать(РежимЗаписиДокумента.Запись);
	Если Окр(Док.СуммаДокумента, 2) <> Окр(СуммаСтроки, 2) Тогда
		ВызватьИсключение "СуммаДокумента " + Формат(Док.СуммаДокумента, "ЧДЦ=2")
			+ " не совпала с суммой в колонке «Сумма» таблицы обработки (строка) " + Формат(СуммаСтроки, "ЧДЦ=2");
	КонецЕсли;
	Док.Записать(РежимЗаписиДокумента.Проведение);
	Возврат Док.Ссылка;

КонецФункции

#КонецОбласти

#Область Лог_файл_этап10

&НаСервереБезКонтекста
Функция КаталогЛоговКААЭтап10()
	Возврат "D:\1с\КАА";
КонецФункции

&НаСервереБезКонтекста
Функция ПолныйПутьФайлаЛогаЭтап10()
	Возврат КаталогЛоговКААЭтап10() + "\Лог_10_Заполнение_недостающих_Поступлений.txt";
КонецФункции

&НаСервереБезКонтекста
Процедура ОбеспечитьКаталогЛоговКААЭтап10()
	КаталогЛогов = КаталогЛоговКААЭтап10();
	Попытка
		ФайлКаталогаЛогов = Новый Файл(КаталогЛогов);
		Если НЕ ФайлКаталогаЛогов.Существует() Тогда
			СоздатьКаталог(КаталогЛогов);
		КонецЕсли;
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьСтрокуВЛогЭтап10(ТекстСообщения)
	ОбеспечитьКаталогЛоговКААЭтап10();
	ПолныйПуть = ПолныйПутьФайлаЛогаЭтап10();
	СтрокаЛога = Формат(ТекущаяДата(), "ДЛФ=DT") + " | " + ТекстСообщения;
	Попытка
		ТД = Новый ТекстовыйДокумент;
		ФайлЛога = Новый Файл(ПолныйПуть);
		Если ФайлЛога.Существует() Тогда
			ТД.Прочитать(ПолныйПуть, КодировкаТекста.UTF8);
		КонецЕсли;
		ТД.ДобавитьСтроку(СтрокаЛога);
		ТД.Записать(ПолныйПуть, КодировкаТекста.UTF8);
	Исключение
		Сообщить("Не удалось записать лог (" + ПолныйПуть + "): " + ОписаниеОшибки(), СтатусСообщения.Внимание);
	КонецПопытки;
КонецПроцедуры

#КонецОбласти

#Область Оценка_времени_и_загрузка

&НаСервере
Функция ОценитьВремяЗагрузкиСервер()
	РазмерБанча = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("РазмерБанчаЗагрузки", 10);
	Если ТипЗнч(РазмерБанча) <> Тип("Число") Или РазмерБанча <= 0 Тогда
		РазмерБанча = 10;
	КонецЕсли;
	СекНаСтр = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("ОценкаСекундНаОдинПлатеж", 5);
	Если ТипЗнч(СекНаСтр) <> Тип("Число") Или СекНаСтр <= 0 Тогда
		СекНаСтр = 5;
	КонецЕсли;
	КолГотов = 0;
	КолВыб   = 0;
	Для Каждого Стр Из ТаблицаДанных Цикл
		Попытка
			В = Истина;
			Попытка В = Стр.Выбрать; Исключение В = Истина; КонецПопытки;
			Если НЕ В Тогда
				Продолжить;
			КонецЕсли;
		Исключение
		КонецПопытки;
		КолВыб = КолВыб + 1;
		Если Стр.Статус = "Готов" Тогда
			КолГотов = КолГотов + 1;
		КонецЕсли;
	КонецЦикла;
	Если КолГотов = 0 Тогда
		Возврат "Нет строк со статусом «Готов» среди отмеченных. Отмечено: " + Строка(КолВыб);
	КонецЕсли;
	КолБ = Цел((КолГотов - 1) / РазмерБанча) + 1;
	ОцСек = КолГотов * СекНаСтр;
	Возврат "Строк «Готов»: " + Строка(КолГотов) + Символы.ПС
		+ "Размер банча: " + Строка(РазмерБанча) + " | Банчей: ~" + Строка(КолБ) + Символы.ПС
		+ "Сек. на строку: " + Формат(СекНаСтр, "ЧДЦ=1") + " | Оценка, сек: " + Формат(ОцСек, "ЧДЦ=0");
КонецФункции

&НаСервере
Функция СтрокаОтмеченаКЗагрузкеСервер(СтрокаТаблицы)
	Попытка
		Возврат СтрокаТаблицы.Выбрать;
	Исключение
		Возврат Истина;
	КонецПопытки;
КонецФункции

&НаСервере
Функция ТекстПрогнозаОставшегосяЭтап10(ПланСтрокГотов, ПопытокЗавершено, МоментСтартаЗагрузкиМс)
	Если ПланСтрокГотов <= 0 Тогда
		Возврат "план=0";
	КонецЕсли;
	ПрошлоСек = (ТекущаяУниверсальнаяДатаВМиллисекундах() - МоментСтартаЗагрузкиМс) / 1000;
	Если ПопытокЗавершено <= 0 Или ПрошлоСек <= 0 Тогда
		Возврат "статистика накопится после обработок";
	КонецЕсли;
	Сред = ПрошлоСек / ПопытокЗавершено;
	Ост  = ПланСтрокГотов - ПопытокЗавершено;
	Если Ост < 0 Тогда
		Ост = 0;
	КонецЕсли;
	Возврат "сред.сек/стр: " + Формат(Сред, "ЧДЦ=2") + " | осталось ~" + Строка(Ост) + " | ост.сек~ " + Формат(Ост * Сред, "ЧДЦ=0");
КонецФункции

&НаСервере
Процедура ЗагрузитьВБазуСервер(НачальноеВремя = Неопределено)
	Создано   = 0;
	Ошибок    = 0;
	Пропущено = 0;
	РазмерБанча = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("РазмерБанчаЗагрузки", 10);
	Если ТипЗнч(РазмерБанча) <> Тип("Число") Или РазмерБанча <= 0 Тогда
		РазмерБанча = 10;
	КонецЕсли;
	ПланГотов = 0;
	Для Каждого СтрП Из ТаблицаДанных Цикл
		Если НЕ СтрокаОтмеченаКЗагрузкеСервер(СтрП) Тогда
			Продолжить;
		КонецЕсли;
		Если СтрП.Статус = "Готов" Тогда
			ПланГотов = ПланГотов + 1;
		КонецЕсли;
	КонецЦикла;
	ПланБ = 0;
	Если ПланГотов > 0 Тогда
		ПланБ = Цел((ПланГотов - 1) / РазмерБанча) + 1;
	КонецЕсли;
	НомерБ     = 0;
	ВБанче     = 0;
	НачБ       = ТекущаяУниверсальнаяДатаВМиллисекундах();
	МоментСтарта = НачБ;
	Попыток    = 0;
	ИмяФ = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("ИмяФайла", "");
	ЗаписатьСтрокуВЛогЭтап10("СТАРТ | Файл: " + Строка(ИмяФ)
		+ " | К обработке (Готов): " + Строка(ПланГотов) + " | банч " + Строка(РазмерБанча) + " | план банчей ~" + Строка(ПланБ));

	Для Каждого Стр Из ТаблицаДанных Цикл
		Если НЕ СтрокаОтмеченаКЗагрузкеСервер(Стр) Тогда
			Продолжить;
		КонецЕсли;
		Если Стр.Статус <> "Готов" Тогда
			Пропущено = Пропущено + 1;
			Продолжить;
		КонецЕсли;
		Попыток = Попыток + 1;
		Ссыл = Неопределено;
		Попытка
			СтСсыл = НайтиСтатьюРасходовПоТексту(Стр.Статья);
			Если НЕ ЗначениеЗаполнено(СтСсыл) Тогда
				ВызватьИсключение "Статья расходов не найдена";
			КонецЕсли;
			Ссыл = СоздатьИПровестиПриобретениеПоСтроке(
				Стр.Дата,
				Стр.Сумма,
				Стр.Статья,
				СтСсыл,
				Стр.КонтрагентСсылка,
				Стр.ДоговорСсылка);
			Стр.Статус = "Загружено";
			Стр.Комментарий = "Создан: " + Строка(Ссыл) + " ";
			Создано = Создано + 1;
		Исключение
			Ошибок = Ошибок + 1;
			Стр.Статус = "Ошибка";
			Стр.Комментарий = Стр.Комментарий + "Ошибка: " + ОписаниеОшибки();
			ЗаписатьСтрокуВЛогЭтап10("ОШИБКА нстр " + Строка(Стр.НомерСтроки) + ": " + ОписаниеОшибки());
		КонецПопытки;
		ВБанче = ВБанче + 1;
		Если ВБанче >= РазмерБанча Тогда
			НомерБ = НомерБ + 1;
			Вр = (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачБ) / 1000;
			Пр = ТекстПрогнозаОставшегосяЭтап10(ПланГотов, Попыток, МоментСтарта);
			Св = "[Банч " + Строка(НомерБ) + "] Созд: " + Строка(Создано) + " | Ош: " + Строка(Ошибок)
				+ " | Сек: " + Формат(Вр, "ЧДЦ=2") + " | " + Пр;
			Сообщить(Св, СтатусСообщения.Информация);
			ЗаписатьСтрокуВЛогЭтап10(Св);
			ВБанче = 0;
			НачБ = ТекущаяУниверсальнаяДатаВМиллисекундах();
		КонецЕсли;
	КонецЦикла;

	Если ВБанче > 0 Тогда
		НомерБ = НомерБ + 1;
		Вр = (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачБ) / 1000;
		Св = "[Банч " + Строка(НомерБ) + " финал] Созд: " + Строка(Создано) + " | Ош: " + Строка(Ошибок) + " | Сек: " + Формат(Вр, "ЧДЦ=2");
		ЗаписатьСтрокуВЛогЭтап10(Св);
	КонецЕсли;
	Полное = (ТекущаяУниверсальнаяДатаВМиллисекундах() - МоментСтарта) / 1000;
	ЗаписатьСтрокуВЛогЭтап10("ФИНИШ | Создано: " + Строка(Создано) + " | Ошибок: " + Строка(Ошибок)
		+ " | Пропущено: " + Строка(Пропущено) + " | Сек: " + Формат(Полное, "ЧДЦ=2"));
КонецПроцедуры

#КонецОбласти
