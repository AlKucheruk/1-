    Функция НайтиОрганизациюПоДанным(ИННОрг, КППОрг, НашСчет)
        ИННОрг  = СокрЛП(ИННОрг);
        КППОрг  = СокрЛП(КППОрг);
        НашСчет = СокрЛП(НашСчет);

        Если ПустаяСтрока(ИННОрг) И ПустаяСтрока(КППОрг) И ПустаяСтрока(НашСчет) Тогда
            Возврат Справочники.Организации.ПустаяСсылка();
        КонецЕсли;

        // Сначала по расчётному счёту
        Если НЕ ПустаяСтрока(НашСчет) Тогда
            Попытка
                Запрос = Новый Запрос;
                Запрос.Текст =
                "ВЫБРАТЬ ПЕРВЫЕ 1
                |   БанковскиеСчетаОрганизаций.Владелец КАК Организация
                |ИЗ
                |   Справочник.БанковскиеСчетаОрганизаций КАК БанковскиеСчетаОрганизаций
                |ГДЕ
                |   БанковскиеСчетаОрганизаций.НомерСчета = &НомерСчета
                |   И НЕ БанковскиеСчетаОрганизаций.ПометкаУдаления";

                Запрос.УстановитьПараметр("НомерСчета", НашСчет);
                Выборка = Запрос.Выполнить().Выбрать();
                Если Выборка.Следующий() Тогда
                    Возврат Выборка.Организация;
                КонецЕсли;
            Исключение
            КонецПопытки;
        КонецЕсли;

        // Затем по ИНН/КПП
        Если НЕ ПустаяСтрока(ИННОрг) Тогда
            Попытка
                Запрос = Новый Запрос;
                Запрос.Текст =
                "ВЫБРАТЬ ПЕРВЫЕ 1
                |   Организации.Ссылка КАК Ссылка
                |ИЗ
                |   Справочник.Организации КАК Организации
                |ГДЕ
                |   Организации.ИНН = &ИНН
                |   И (&КПП = """" ИЛИ Организации.КПП = &КПП)
                |   И НЕ Организации.ПометкаУдаления";

                Запрос.УстановитьПараметр("ИНН", ИННОрг);
                Запрос.УстановитьПараметр("КПП", КППОрг);
                Выборка = Запрос.Выполнить().Выбрать();
                Если Выборка.Следующий() Тогда
                    Возврат Выборка.Ссылка;
                КонецЕсли;
            Исключение
            КонецПопытки;
        КонецЕсли;

        Возврат Справочники.Организации.ПустаяСсылка();
    КонецФункции

