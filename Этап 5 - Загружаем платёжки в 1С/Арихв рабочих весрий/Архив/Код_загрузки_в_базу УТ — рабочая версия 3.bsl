    //
    // Параметры:
    //   КонтрагентСсылка - СправочникСсылка.Контрагенты - контрагент
    //   НомерСчета       - Строка - номер расчётного счёта
    //   БИК              - Строка - БИК банка контрагента
    //
    // Возвращаемое значение:
    //   СправочникСсылка.БанковскиеСчетаКонтрагентов - созданный счёт, или пустая ссылка
    //
    &НаСервереБезКонтекста
    Функция ПопытатьсяСоздатьСчетКонтрагента(КонтрагентСсылка, НомерСчета, БИК)
        
        Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Или ПустаяСтрока(НомерСчета) Тогда
            Возврат Справочники.БанковскиеСчетаКонтрагентов.ПустаяСсылка();
        КонецЕсли;
        
        Попытка
            НовыйСчет = Справочники.БанковскиеСчетаКонтрагентов.СоздатьЭлемент();
            НовыйСчет.Владелец   = КонтрагентСсылка;
            НовыйСчет.НомерСчета = НомерСчета;
            НовыйСчет.Наименование = "р/с " + НомерСчета;
            
            // Пытаемся найти банк по БИК
            Если НЕ ПустаяСтрока(БИК) Тогда
                Попытка
                    БанкСсылка = Справочники.КлассификаторБанков.НайтиПоКоду(БИК);
                    Если ЗначениеЗаполнено(БанкСсылка) Тогда
                        НовыйСчет.Банк = БанкСсылка;
                    КонецЕсли;
                Исключение
                КонецПопытки;
            КонецЕсли;
            
            НовыйСчет.Записать();

            Возврат НовыйСчет.Ссылка;
        Исключение
            Возврат Справочники.БанковскиеСчетаКонтрагентов.ПустаяСсылка();
        КонецПопытки;
        
    КонецФункции

    #КонецОбласти //Попытаться_Создать_Счет_Контрагента

    #Область Распределение_денег
    // ОБЛАСТЬ: Распределение денег — распределение по расчётным документам (FIFO)
    // ────────────────────────────────────────────────────────────────────────────
    // Для поступлений: ищет "Реализация товаров и услуг" по договору с долгом
    // Для списаний: ищет "Поступление товаров" или "Акты" по договору с долгом
    // Распределяет сумму по FIFO (сначала самые ранние документы)
    // Остаток — как аванс
    // ────────────────────────────────────────────────────────────────────────────
    // Процедура распределяет денежные средства по расчётным документам (FIFO).
    // Заполняет табличную часть "РасшифровкаПлатежа" документа.
    //
    // Для поступлений от клиентов:
    //   - Ищет документы "Реализация товаров и услуг" по договору с остатком долга
    //   - Сортирует по дате (сначала самые ранние)
    //   - Заполняет строки табличной части, распределяя сумму
    //   - Если денег больше чем долг — остаток как аванс
    //
    // Для списаний (оплата поставщикам):
    //   - Ищет "Поступление товаров" по договору с остатком долга
    //   - Распределяет по FIFO
    //   - Остаток как аванс поставщику
    //
    // Параметры:
    //   ДокОбъект       - ДокументОбъект - создаваемый документ (с ТЧ РасшифровкаПлатежа)
    //   ДоговорСсылка   - СправочникСсылка.ДоговорыКонтрагентов - договор
    //   СуммаДокумента  - Число - сумма для распределения
    //   ЭтоПоступление  - Булево - Истина для поступления, Ложь для списания
    //   ПартнерСсылка   - СправочникСсылка.Партнеры - партнёр контрагента
    //   СтатьяДДССсылка - СправочникСсылка.СтатьиДвиженияДенежныхСредств - статья ДДС
    //
    // Возвращаемое значение:
    //   Строка - информация о результате распределения
    //
    &НаСервереБезКонтекста
    Функция РаспределитьДеньгиПоДокументам(ДокОбъект, ДоговорСсылка, СуммаДокумента, ЭтоПоступление, ПартнерСсылка = Неопределено, СтатьяДДССсылка = Неопределено)
        
        Если НЕ ЗначениеЗаполнено(ДоговорСсылка) Или СуммаДокумента <= 0 Тогда
            Возврат "Нет данных для распределения (договор или сумма пусты). ";
        КонецЕсли;
        
        Попытка
            Если ЭтоПоступление Тогда
                // Поступление оплаты от клиента
                ТекстЗапроса =
                "ВЫБРАТЬ
                |   ВзаиморасчетыОстатки.ОбъектРасчетов КАК ОбъектРасчетов,
                |   ВзаиморасчетыОстатки.ДолгОстаток КАК Долг,
                |   ВзаиморасчетыОстатки.ОбъектРасчетов.Дата КАК ДатаДокумента
                |ИЗ
                |   РегистрНакопления.РасчетыСКлиентами.Остатки КАК ВзаиморасчетыОстатки
                |ГДЕ
                |   ВзаиморасчетыОстатки.ОбъектРасчетов = &ОбъектРасчетов
                |   И ВзаиморасчетыОстатки.ДолгОстаток > 0
                |УПОРЯДОЧИТЬ ПО
                |   ДатаДокумента ВОЗР";
            Иначе
                // Списание (оплата поставщику)
                ТекстЗапроса =
                "ВЫБРАТЬ
                |   ВзаиморасчетыОстатки.ОбъектРасчетов КАК ОбъектРасчетов,
                |   ВзаиморасчетыОстатки.ДолгОстаток КАК Долг,
                |   ВзаиморасчетыОстатки.ОбъектРасчетов.Дата КАК ДатаДокумента
                |ИЗ
                |   РегистрНакопления.РасчетыСПоставщиками.Остатки КАК ВзаиморасчетыОстатки
                |ГДЕ
                |   ВзаиморасчетыОстатки.ОбъектРасчетов = &ОбъектРасчетов
                |   И ВзаиморасчетыОстатки.ДолгОстаток > 0
                |УПОРЯДОЧИТЬ ПО
                |   ДатаДокумента ВОЗР";
            КонецЕсли;
            
            Запрос = Новый Запрос;
            Запрос.Текст = ТекстЗапроса;
            Запрос.УстановитьПараметр("ОбъектРасчетов", ДоговорСсылка);   // ← Ключевой момент
            
            РезультатЗапроса = Запрос.Выполнить();
            
            Если РезультатЗапроса.Пустой() Тогда
                Возврат "Вся сумма распределена как аванс (нет документов с долгом). ";
            КонецЕсли;
            
            Выборка = РезультатЗапроса.Выбрать();
            ОстатокСуммы = СуммаДокумента;
            КоличествоРаспределено = 0;
            
            Пока Выборка.Следующий() И ОстатокСуммы > 0 Цикл
                СуммаКРаспределению = Мин(ОстатокСуммы, Выборка.Долг);
                
                НоваяСтрока = ДокОбъект.РасшифровкаПлатежа.Добавить();
                НоваяСтрока.Сумма = СуммаКРаспределению;
                НоваяСтрока.СуммаВзаиморасчетов = СуммаКРаспределению;
                НоваяСтрока.ОснованиеПлатежа = Выборка.ОбъектРасчетов;
                
                Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
                    НоваяСтрока.Партнер = ПартнерСсылка;
                КонецЕсли;
                Если ЗначениеЗаполнено(СтатьяДДССсылка) Тогда
                    НоваяСтрока.СтатьяДвиженияДенежныхСредств = СтатьяДДССсылка;
                КонецЕсли;
                
                ОстатокСуммы = ОстатокСуммы - СуммаКРаспределению;
                КоличествоРаспределено = КоличествоРаспределено + 1;
            КонецЦикла;
            
            ТекстРезультата = "Распределено по " + Строка(КоличествоРаспределено) + " документам. ";
            Если ОстатокСуммы > 0 Тогда
                ТекстРезультата = ТекстРезультата + "Остаток " + Формат(ОстатокСуммы, "ЧДЦ=2") + " руб. как аванс.";
            КонецЕсли;
            
            Возврат ТекстРезультата;
            
        Исключение
            Возврат "Ошибка распределения денег: " + ОписаниеОшибки();
        КонецПопытки;
        
    КонецФункции

    #КонецОбласти // Распределение_денег

    #Область Автозаполнение_обязательных_полей
// ОБЛАСТЬ: Автозаполнение обязательных полей
// ────────────────────────────────────────────────────────────────────────────
// - ОчередностьПлатежа = 5 (для списаний)
// - СтатьяРасходов = "Импорт из банка" (создать если нет)
// - Налог = "Единый налоговый платеж" (для налоговых операций)
// ────────────────────────────────────────────────────────────────────────────
// Функция находит или создаёт статью расходов "Импорт из банка" в справочнике СтатьиРасходов.
//
// Возвращаемое значение:
//   СправочникСсылка.СтатьиРасходов - найденная или созданная статья
//
&НаСервереБезКонтекста
Функция ПолучитьСтатьюРасходовИмпортИзБанка()
    
    Попытка
        // Сначала ищем существующую статью
        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   СтатьиРасходов.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.СтатьиРасходов КАК СтатьиРасходов
        |ГДЕ
        |   СтатьиРасходов.Наименование = &Наименование
        |   И НЕ СтатьиРасходов.ПометкаУдаления";
        
        Запрос.УстановитьПараметр("Наименование", "Импорт из банка");
        Выборка = Запрос.Выполнить().Выбрать();
        
        Если Выборка.Следующий() Тогда
            Возврат Выборка.Ссылка;
        КонецЕсли;
        
        // Не нашли — создаём новую
        НоваяСтатья = Справочники.СтатьиРасходов.СоздатьЭлемент();
        НоваяСтатья.Наименование = "Импорт из банка";
        НоваяСтатья.Записать();
        
        Возврат НоваяСтатья.Ссылка;
    Исключение
        Возврат Неопределено;
    КонецПопытки;
    
КонецФункции

// Функция находит вид налога "Единый налоговый платеж".
//
// Возвращаемое значение:
//   СправочникСсылка.ВидыНалоговВзносов - найденный вид налога или Неопределено
//
&НаСервереБезКонтекста
Функция ПолучитьНалогЕНП()
    
    Попытка
        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   ВидыНалоговВзносов.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.ВидыНалоговВзносов КАК ВидыНалоговВзносов
        |ГДЕ
        |   ВидыНалоговВзносов.Наименование ПОДОБНО &Наименование
        |   И НЕ ВидыНалоговВзносов.ПометкаУдаления";
        
        Запрос.УстановитьПараметр("Наименование", "%Единый налоговый платеж%");
        Выборка = Запрос.Выполнить().Выбрать();
        
        Если Выборка.Следующий() Тогда
            Возврат Выборка.Ссылка;
        КонецЕсли;
        
        // Пробуем альтернативные наименования
        Запрос.УстановитьПараметр("Наименование", "%ЕНП%");
        Выборка = Запрос.Выполнить().Выбрать();
        
        Если Выборка.Следующий() Тогда
            Возврат Выборка.Ссылка;
        КонецЕсли;
        
    Исключение
    КонецПопытки;
    
    Возврат Неопределено;
    
КонецФункции

// Процедура заполняет обязательные поля документа Списание:
//   - ОчередностьПлатежа = 5
//   - СтатьяРасходов = "Импорт из банка"
//   - ТипНалога (Налог) = "Единый налоговый платеж" для налоговых операций
//
// Параметры:
//   ДокОбъект    - ДокументОбъект.СписаниеБезналичныхДенежныхСредств
//   ХозОперация  - Перечисления.ХозяйственныеОперации - хозяйственная операция
//
// Возвращаемое значение:
//   Строка - информация о заполненных полях
//
&НаСервереБезКонтекста
Функция ЗаполнитьОбязательныеПоляСписания(ДокОбъект, ХозОперация)
    
    ТекстЛог = "";
    
    Попытка
        // 1. Очередность платежа = 5 (для всех списаний)
        Попытка
            ДокОбъект.ОчередностьПлатежа = 5;
            ТекстЛог = ТекстЛог + "Очередность=5; ";
        Исключение
        КонецПопытки;
        
        // 2. Статья расходов = "Импорт из банка"
        Попытка
            СтатьяРасходов = ПолучитьСтатьюРасходовИмпортИзБанка();
            Если ЗначениеЗаполнено(СтатьяРасходов) Тогда
                ДокОбъект.СтатьяРасходов = СтатьяРасходов;
                ТекстЛог = ТекстЛог + "СтатьяРасходов=ИмпортИзБанка; ";
            КонецЕсли;
        Исключение
        КонецПопытки;
        
        // 3. Налог = "Единый налоговый платеж" для налоговых операций
        //    (Перечисление в бюджет, Перечисление налога)
        ЭтоНалоговаяОперация = Ложь;
        Попытка
            ЭтоНалоговаяОперация = (ХозОперация = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет);
        Исключение
        КонецПопытки;
        
        Если ЭтоНалоговаяОперация Тогда
            Попытка
                НалогЕНП = ПолучитьНалогЕНП();
                Если ЗначениеЗаполнено(НалогЕНП) Тогда
                    ДокОбъект.ТипНалога = НалогЕНП;
                    ТекстЛог = ТекстЛог + "Налог=ЕНП; ";
                Иначе
                    ТекстЛог = ТекстЛог + "Налог ЕНП не найден в справочнике; ";
                КонецЕсли;
            Исключение
            КонецПопытки;
        КонецЕсли;
        
    Исключение
        ТекстЛог = ТекстЛог + "Ошибка автозаполнения: " + ОписаниеОшибки() + "; ";
    КонецПопытки;
    
    Возврат ТекстЛог;
    
КонецФункции

// Процедура заполняет обязательные поля документа Поступление:
//   - СтатьяРасходов = "Импорт из банка" (если есть реквизит)
//
// Параметры:
//   ДокОбъект    - ДокументОбъект.ПоступлениеБезналичныхДенежныхСредств
//
// Возвращаемое значение:
//   Строка - информация о заполненных полях
//
&НаСервереБезКонтекста
Функция ЗаполнитьОбязательныеПоляПоступления(ДокОбъект)
    
    ТекстЛог = "";
    
    Попытка
        // Статья расходов = "Импорт из банка"
        Попытка
            СтатьяРасходов = ПолучитьСтатьюРасходовИмпортИзБанка();
            Если ЗначениеЗаполнено(СтатьяРасходов) Тогда
                ДокОбъект.СтатьяРасходов = СтатьяРасходов;
                ТекстЛог = ТекстЛог + "СтатьяРасходов=ИмпортИзБанка; ";
            КонецЕсли;
        Исключение
        КонецПопытки;       
    Исключение
    КонецПопытки;
    
    Возврат ТекстЛог;
    
КонецФункции

#КонецОбласти // Автозаполнение_обязательных_полей

#КонецОбласти // Загрузка_В_Базу_Вспомогательные

#Область ЛогикаДоговоров

// Определяет тип договора по операции из Excel
&НаСервере
Функция ОпределитьТипДоговораПоОперации(ОперацияУТ)
	
	ОперацияУТ = СокрЛП(ОперацияУТ);
	
	// --- Приход ---
	Если ОперацияУТ = "ПоступлениеОплатыОтКлиента" Тогда
		Возврат Перечисления.ТипыДоговоров.СПокупателем;
		
	ИначеЕсли ОперацияУТ = "ВозвратДенежныхСредствОтПоставщика" Тогда
		Возврат Перечисления.ТипыДоговоров.СПоставщиком;
		
	ИначеЕсли ОперацияУТ = "ПоступлениеДенежныхСредствПоДепозитам" Тогда
		Возврат Перечисления.ТипыДоговоров.СПокупателем; // банк как покупатель
		
	ИначеЕсли ОперацияУТ = "ПрочееПоступлениеДенежныхСредств" Тогда
		Возврат Перечисления.ТипыДоговоров.СПокупателем;
		
	// --- Расход ---
	ИначеЕсли ОперацияУТ = "ОплатаПоставщику" Тогда
		Возврат Перечисления.ТипыДоговоров.СПоставщиком;
		
	ИначеЕсли ОперацияУТ = "ВозвратОплатыПокупателю" Тогда
		Возврат Перечисления.ТипыДоговоров.СПокупателем;
		
	ИначеЕсли ОперацияУТ = "ПеречислениеВБюджет" Тогда
		Возврат Неопределено; // договор не нужен
		
	ИначеЕсли ОперацияУТ = "ПрочееСписаниеДенежныхСредств" Тогда
		Возврат Перечисления.ТипыДоговоров.СПоставщиком;
		
	Иначе
		// Неизвестная операция — по умолчанию как раньше
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

#КонецОбласти // ЛогикаДоговоров

#Область Загрузка_В_Базу// Загрузка в базу — основная процедура
&НаСервере
Процедура ЗагрузитьВБазуСервер()
    
    КоличествоСоздано     = 0;
    КоличествоОшибок      = 0;
    КоличествоПропущено   = 0;
    СписокОшибок          = Новый Массив;
    ИмяФайлаИсточника     = ЭтаФорма.ИмяФайла;
    
    Для Каждого СтрокаДанных Из ТаблицаДанных Цикл
        
        Если СтрокаДанных.Статус <> "Готов" Тогда
            КоличествоПропущено = КоличествоПропущено + 1;
            Продолжить;
        КонецЕсли;
        
        Попытка
            ЭтапОбработки = "Определение типа документа";
            
            // Определение типа документа
            НаправлениеВРег = ВРег(СокрЛП(СтрокаДанных.НаправлениеДенег));
            ЭтоПоступление = (СтрНайти(НаправлениеВРег, "ПРИХОД") > 0);
            ЭтоСписание    = (СтрНайти(НаправлениеВРег, "РАСХОД") > 0);
            
            Если НЕ ЭтоПоступление И НЕ ЭтоСписание Тогда
                КоличествоОшибок = КоличествоОшибок + 1;
                СписокОшибок.Добавить("Строка " + СтрокаДанных.НомерСтроки + ": не определён тип документа");
                СтрокаДанных.Статус = "Ошибка";
                СтрокаДанных.Комментарий = СтрокаДанных.Комментарий + "Не определён тип документа. ";
                Продолжить;
            КонецЕсли;
            
            // Хозяйственная операция
            ЭтапОбработки = "Определение хозяйственной операции";
            ХозОперация = Неопределено;
            Если ЗначениеЗаполнено(СтрокаДанных.ОперацияУТ) Тогда
                Попытка
                    ХозОперация = Перечисления.ХозяйственныеОперации[СтрокаДанных.ОперацияУТ];
                Исключение
                    Для Каждого ЗначениеПереч Из Метаданные.Перечисления.ХозяйственныеОперации.ЗначенияПеречисления Цикл
                    Если ВРег(СокрЛП(ЗначениеПереч.Синоним)) = ВРег(СокрЛП(СтрокаДанных.ОперацияУТ)) Тогда
                    ХозОперация = Перечисления.ХозяйственныеОперации[ЗначениеПереч.Имя];
                    Прервать;
                    КонецЕсли;
                    КонецЦикла;
                КонецПопытки;
            КонецЕсли;
            
            Если НЕ ЗначениеЗаполнено(ХозОперация) Тогда
                СтрокаДанных.Комментарий = СтрокаДанных.Комментарий 
                    + "Не удалось определить хозяйственную операцию (" + СтрокаДанных.ОперацияУТ + "). ";
            КонецЕсли;
            
            // Общие данные
            ВалютаДокумента = ОпределитьВалюту(СтрокаДанных.Валюта);
      
            // === НОВАЯ ЛОГИКА: определение типа договора ===
            ТипДоговора = ОпределитьТипДоговораПоОперации(СтрокаДанных.ОперацияУТ);
            Если ТипДоговора = Неопределено Тогда
                ДоговорСсылка = Неопределено;
            Иначе
                ДоговорСсылка = НайтиИлиСоздатьДоговор(СтрокаДанных.КонтрагентСсылка, СтрокаДанных.ОрганизацияСсылка, ТипДоговора, СтрокаДанных.Дата, СтрокаДанных.СтатьяДДССсылка);
            КонецЕсли;
            // === /НОВАЯ ЛОГИКА ===

            ПартнерСсылка = ПолучитьПартнераКонтрагента(СтрокаДанных.КонтрагентСсылка);
            
            СчетКонтрагентаСсылка = СтрокаДанных.БанковскийСчетКонтрагента;
            Если НЕ ЗначениеЗаполнено(СчетКонтрагентаСсылка) И ЗначениеЗаполнено(СтрокаДанных.КонтрагентСсылка) Тогда
                СчетКонтрагентаСсылка = ПопытатьсяСоздатьСчетКонтрагента(
                    СтрокаДанных.КонтрагентСсылка, СтрокаДанных.СчетКонтр, СтрокаДанных.БИККонтр);
            КонецЕсли;
            
            // === Создание документа ===
            ЭтапОбработки = "Создание документа";
            НачатьТранзакцию();
            
            Если ЭтоПоступление Тогда
                ДокОбъект = Документы.ПоступлениеБезналичныхДенежныхСредств.СоздатьДокумент();
                ЗаполнитьОбязательныеПоляПоступления(ДокОбъект);
            Иначе
                ДокОбъект = Документы.СписаниеБезналичныхДенежныхСредств.СоздатьДокумент();
                ЗаполнитьОбязательныеПоляСписания(ДокОбъект, ХозОперация);
            КонецЕсли;
            
            // Заполнение основных реквизитов
            ЭтапОбработки = "Заполнение реквизитов";
            ДокОбъект.Дата                     = СтрокаДанных.Дата;
            ДокОбъект.Организация              = СтрокаДанных.ОрганизацияСсылка;
            ДокОбъект.БанковскийСчет           = СтрокаДанных.БанковскийСчетОрганизации;
            ДокОбъект.ХозяйственнаяОперация    = ХозОперация;
            ДокОбъект.СуммаДокумента           = СтрокаДанных.Сумма;
            ДокОбъект.Контрагент               = СтрокаДанных.КонтрагентСсылка;
            ДокОбъект.Валюта                   = ВалютаДокумента;
            ДокОбъект.ТипПлатежногоДокумента   = Перечисления.ТипыПлатежныхДокументов.ПлатежноеПоручение;
            ДокОбъект.НазначениеПлатежа        = СтрокаДанных.Назначение;
            ДокОбъект.НомерВходящегоДокумента  = СтрокаДанных.НомерПП;
            ДокОбъект.ДатаВходящегоДокумента   = СтрокаДанных.Дата;
            ДокОбъект.Комментарий              = "Автообмен";
            ДокОбъект.ПроведеноБанком          = Истина;
            ДокОбъект.ДатаПроведенияБанком     = СтрокаДанных.Дата;
            ДокОбъект.ИмяКонтрагента           = СтрокаДанных.Контрагент;
            
            Если ЗначениеЗаполнено(ДоговорСсылка) Тогда
                ДокОбъект.Договор = ДоговорСсылка;
            КонецЕсли;
            Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
                ДокОбъект.Партнер = ПартнерСсылка;
            КонецЕсли;
            Если ЗначениеЗаполнено(СчетКонтрагентаСсылка) Тогда
                ДокОбъект.БанковскийСчетКонтрагента = СчетКонтрагентаСсылка;
            КонецЕсли;
            
            // Статья ДДС
            ЭтапОбработки = "Установка статьи ДДС";
            Если ЗначениеЗаполнено(СтрокаДанных.СтатьяДДССсылка) Тогда
                Попытка
                    ДокОбъект.СтатьяДвиженияДенежныхСредств = СтрокаДанных.СтатьяДДССсылка;
                    Если ДокОбъект.РасшифровкаПлатежа.Количество() = 0 Тогда
                    НоваяСтрока = ДокОбъект.РасшифровкаПлатежа.Добавить();
                    НоваяСтрока.Сумма = СтрокаДанных.Сумма;
                    НоваяСтрока.СуммаВзаиморасчетов = СтрокаДанных.Сумма;
                    КонецЕсли;
                    ДокОбъект.РасшифровкаПлатежа[0].СтатьяДвиженияДенежныхСредств = СтрокаДанных.СтатьяДДССсылка;
                Исключение
                    СтрокаДанных.Комментарий = СтрокаДанных.Комментарий + "Не удалось установить статью ДДС. ";
                КонецПопытки;
            Иначе
                СтрокаДанных.Комментарий = СтрокаДанных.Комментарий + "Статья ДДС не заполнена. ";
            КонецЕсли;

            // === РасшифровкаПлатежа — разные сценарии для Поступления и Списания ===
            ЭтапОбработки = "Заполнение РасшифровкаПлатежа";           
            Попытка
                ДокОбъект.РасшифровкаПлатежа.Очистить();
                
                НоваяСтрока = ДокОбъект.РасшифровкаПлатежа.Добавить();
                
                НоваяСтрока.Сумма               = СтрокаДанных.Сумма;
                НоваяСтрока.СуммаВзаиморасчетов = СтрокаДанных.Сумма;
                
                // Статья ДДС — общая для обоих сценариев
                Если ЗначениеЗаполнено(СтрокаДанных.СтатьяДДССсылка) Тогда
                    НоваяСтрока.СтатьяДвиженияДенежныхСредств = СтрокаДанных.СтатьяДДССсылка;
                    ДокОбъект.СтатьяДвиженияДенежныхСредств   = СтрокаДанных.СтатьяДДССсылка;
                КонецЕсли;
                
                Если ЭтоПоступление Тогда
                    // --- Поступление от покупателя ---
                    // НоваяСтрока.Контрагент НЕ заполняем — в ТЧ поступления его нет
                    // Заполняем Партнер и ОснованиеПлатежа (договор как объект расчётов)
                    Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
                        Попытка НоваяСтрока.Партнер = ПартнерСсылка; Исключение КонецПопытки;
                    КонецЕсли;
                    Если ЗначениеЗаполнено(ДоговорСсылка) Тогда
                        Попытка НоваяСтрока.ОснованиеПлатежа = ДоговорСсылка; Исключение КонецПопытки;
                    КонецЕсли;
                    
                Иначе
                    // --- Списание поставщику ---
                    // Контрагент в ТЧ списания допустим
                    Если ЗначениеЗаполнено(СтрокаДанных.КонтрагентСсылка) Тогда
                        Попытка НоваяСтрока.Контрагент = СтрокаДанных.КонтрагентСсылка; Исключение КонецПопытки;
                    КонецЕсли;
                    Если ЗначениеЗаполнено(ДоговорСсылка) Тогда
                        Попытка НоваяСтрока.Договор = ДоговорСсылка; Исключение КонецПопытки;
                    КонецЕсли;

                    Попытка
                        СтатьяРасходов = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоНаименованию("Прочие расходы");

                        Если ЗначениеЗаполнено(СтатьяРасходов) Тогда
                            НоваяСтрока.СтатьяРасходов = СтатьяРасходов;
                        КонецЕсли;
                    Исключение
                    КонецПопытки;

                КонецЕсли;
                
            Исключение
                СтрокаДанных.Комментарий = СтрокаДанных.Комментарий + "Ошибка заполнения расшифровки платежа. ";
            КонецПопытки;


            // Запись
            ЭтапОбработки = "Запись и проведение";
            ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
            ЗафиксироватьТранзакцию();
            
            ЗаписатьСвязьДокумента(ДокОбъект.Ссылка, СтрокаДанных.УИД, ИмяФайлаИсточника);
            
            СтрокаДанных.Статус = "Загружено";
            СтрокаДанных.Комментарий = СтрокаДанных.Комментарий 
                + "Документ " + Строка(ДокОбъект.Ссылка) + " создан и проведён. ";
            
            КоличествоСоздано = КоличествоСоздано + 1;
            
        Исключение
            Попытка ОтменитьТранзакцию(); Исключение КонецПопытки;
            
            ТекстОшибки = ОписаниеОшибки();
            КоличествоОшибок = КоличествоОшибок + 1;
            СтрокаДанных.Статус = "Ошибка";
            СтрокаДанных.Комментарий = СтрокаДанных.Комментарий 
                + "Ошибка на этапе [" + ЭтапОбработки + "]: " + ТекстОшибки;
            
            СписокОшибок.Добавить("Строка " + СтрокаДанных.НомерСтроки + ": " + ТекстОшибки);
        КонецПопытки;
        
    КонецЦикла;
    
    // Итог
    ТекстИтога = "Загрузка завершена." + Символы.ПС +
                 "Создано: " + КоличествоСоздано + Символы.ПС +
                 "Пропущено: " + КоличествоПропущено + Символы.ПС +
                 "Ошибок: " + КоличествоОшибок;
    
    Если КоличествоОшибок = 0 Тогда
        Сообщить(ТекстИтога, СтатусСообщения.Информация);
    Иначе
        Сообщить(ТекстИтога, СтатусСообщения.Важное);
    КонецЕсли;
    
КонецПроцедуры
#КонецОбласти // Загрузка_В_Базу