    #Область Записать_Связь_Документа
        // Процедура записывает связь загруженного документа в регистр сведений
        // КАА_СвязиДокументовБП для контроля дублей.
        //
        // Параметры:
        //   ДокументУТ     - ДокументСсылка - ссылка на созданный документ
        //   ИдентификаторБП - Строка - УИД из исходной системы
        //   ИмяФайла       - Строка - имя файла-источника
        //
        &НаСервереБезКонтекста
        Процедура ЗаписатьСвязьДокумента(ДокументУТ, ИдентификаторБП, ИмяФайла)
            
            Если ПустаяСтрока(ИдентификаторБП) Тогда
                Возврат;
            КонецЕсли;
            
            Попытка
                НаборЗаписей = РегистрыСведений.КАА_СвязиДокументовБП.СоздатьНаборЗаписей();
                НаборЗаписей.Отбор.ИдентификаторБП.Установить(ИдентификаторБП);
                
                НоваяЗапись = НаборЗаписей.Добавить();
                НоваяЗапись.ИдентификаторБП = ИдентификаторБП;
                НоваяЗапись.ДокументУТ      = ДокументУТ;
                НоваяЗапись.ДатаЗагрузки    = ТекущаяДата();
                НоваяЗапись.ИмяФайла        = ИмяФайла;
                
                НаборЗаписей.Записать(Истина);
            Исключение

            КонецПопытки;
            
        КонецПроцедуры

