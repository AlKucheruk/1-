#Область Клиентские_процедуры

    &НаКлиенте
    Процедура ВыбратьФайл(Команда)
        ОписаниеОповещения = Новый ОписаниеОповещения("ВыбратьФайлЗавершение", ЭтаФорма);
        НачатьПомещениеФайла(
            ОписаниеОповещения,
            ,
            ,
            Истина,
            ЭтаФорма.УникальныйИдентификатор);
    КонецПроцедуры

    &НаКлиенте
    Процедура ВыбратьФайлЗавершение(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт
        Если НЕ Результат Тогда
            Возврат;
        КонецЕсли;

        ЭтаФорма.АдресФайла = Адрес;
        ЭтаФорма.ИмяФайла   = ВыбранноеИмяФайла;
        ЗагрузитьПредпросмотрСервер(Адрес, ВыбранноеИмяФайла);
        
    КонецПроцедуры

    &НаКлиенте
    Процедура ЗагрузитьВБазу(Команда)
        
        // Проверяем, что таблица заполнена
        Если ТаблицаДанных.Количество() = 0 Тогда
            ПоказатьПредупреждение(, "Таблица данных пуста. Сначала загрузите файл Excel.");
            Возврат;
        КонецЕсли;
        
        // Подсчитываем количество строк к загрузке
        КоличествоГотовых = 0;
        КоличествоДублей  = 0;
        КоличествоОшибок  = 0;
        
        Для Каждого СтрокаТаблицы Из ТаблицаДанных Цикл
            Если        СтрокаТаблицы.Статус = "Готов"  Тогда   КоличествоГотовых = КоличествоГотовых + 1;
            ИначеЕсли   СтрокаТаблицы.Статус = "Дубль"  Тогда   КоличествоДублей = КоличествоДублей + 1;
            ИначеЕсли   СтрокаТаблицы.Статус = "Ошибка" Тогда   КоличествоОшибок = КоличествоОшибок + 1;
            КонецЕсли;
        КонецЦикла;
        
        Если КоличествоГотовых = 0 Тогда
            ПоказатьПредупреждение(, "Нет строк со статусом ""Готов"" для загрузки."
                + Символы.ПС + "Дублей: " + Строка(КоличествоДублей)
                + Символы.ПС + "Ошибок: " + Строка(КоличествоОшибок));
            Возврат;
        КонецЕсли;
        
        // Запрашиваем подтверждение
        ТекстВопроса = "Будет создано документов: " + Строка(КоличествоГотовых)
            + Символы.ПС + "Пропущено (дубли): " + Строка(КоличествоДублей)
            + Символы.ПС + "Пропущено (ошибки): " + Строка(КоличествоОшибок)
            + Символы.ПС + Символы.ПС + "Продолжить загрузку?";
        
        ОписаниеОповещения = Новый ОписаниеОповещения(
            "ЗагрузитьВБазуПодтверждение", ЭтотОбъект);
        
        ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет, ,
            КодВозвратаДиалога.Нет, "Загрузка в базу");
        
    КонецПроцедуры
  
    &НаКлиенте  // Обработчик ответа на вопрос подтверждения загрузки
    Процедура ЗагрузитьВБазуПодтверждение(РезультатВопроса, ДополнительныеПараметры) Экспорт
        
        Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
            Возврат;
        КонецЕсли;
               
        Состояние("Загрузка документов в базу..."); // Показываем пользователю статус       
        ЗагрузитьВБазуСервер(); // Вызываем серверную процедуру
        Элементы.ТаблицаДанных.Обновить(); // Обновляем отображение таблицы на форме
        
    КонецПроцедуры

#КонецОбласти //Клиентские_процедуры

#Область Чтение_Excel_И_Заполнение_таблицы 
// ЧТЕНИЕ EXCEL И ЗАПОЛНЕНИЕ ПРЕДВАРИТЕЛЬНОЙ ТАБЛИЦЫ

    &НаСервере
    Процедура ЗагрузитьПредпросмотрСервер(Адрес, ИмяФайла)

        ТаблицаДанных.Очистить();

        Результат = ПрочитатьExcelВТаблицу(Адрес, ИмяФайла);

        Если ТипЗнч(Результат) = Тип("Строка") Тогда
            Сообщить(Результат, СтатусСообщения.Важное);
            Возврат;
        КонецЕсли;

        ТЗ = Результат;

        Попытка // соотносим колонки в новой таблице
            Для Каждого Стр Из ТЗ Цикл
                НовСтр = ТаблицаДанных.Добавить();

                НовСтр.НомерСтроки              = Стр.НомерСтроки;
                НовСтр.УИД                      = Стр.УИД;
                НовСтр.ТипДокумента             = Стр.ТипДокумента;
                НовСтр.ОперацияУТ               = Стр.ОперацияУТ;
                НовСтр.Дата                     = Стр.Дата;
                НовСтр.НомерПП                  = Стр.НомерПП;
                НовСтр.Сумма                    = Стр.Сумма;
                НовСтр.Валюта                   = Стр.Валюта;
                НовСтр.Организация              = Стр.Организация;
                НовСтр.ИННОрг                   = Стр.ИННОрг;
                НовСтр.КППОрг                   = Стр.КППОрг;
                НовСтр.НашСчет                  = Стр.НашСчет;
                НовСтр.НашБанк                  = Стр.НашБанк;
                НовСтр.НашБИК                   = Стр.НашБИК;
                НовСтр.Контрагент               = Стр.Контрагент;
                НовСтр.ИНН                      = Стр.ИНН;
                НовСтр.КППКонтр                 = Стр.КППКонтр;
                НовСтр.ДокОснование             = Стр.ДокОснование;
                НовСтр.Назначение               = Стр.Назначение;
                НовСтр.СчетРасчетов             = Стр.СчетРасчетов;
                НовСтр.СчетКонтр                = Стр.СчетКонтр;
                НовСтр.БанкКонтр                = Стр.БанкКонтр;
                НовСтр.БИККонтр                 = Стр.БИККонтр;
                НовСтр.СтатьяДДС                = Стр.СтатьяДДС;
                НовСтр.НаправлениеДенег         = Стр.НаправлениеДенег;
                НовСтр.НайденКонтрагент         = Стр.НайденКонтрагент;
                НовСтр.КонтрагентСсылка         = Стр.КонтрагентСсылка;
                НовСтр.НайденаОрганизация       = Стр.НайденаОрганизация;
                НовСтр.ОрганизацияСсылка        = Стр.ОрганизацияСсылка;
                НовСтр.НайденДоговор            = Стр.НайденДоговор;
                НовСтр.ДоговорСсылка            = Стр.ДоговорСсылка;
                НовСтр.НайденаСтатья            = Стр.НайденаСтатья;
                НовСтр.СтатьяДДССсылка          = Стр.СтатьяДДССсылка;
                НовСтр.НайденСчетОрганизации    = Стр.НайденСчетОрганизации;
                НовСтр.БанковскийСчетОрганизации = Стр.БанковскийСчетОрганизации;
                НовСтр.НайденСчетКонтрагента    = Стр.НайденСчетКонтрагента;
                НовСтр.БанковскийСчетКонтрагента = Стр.БанковскийСчетКонтрагента;
                НовСтр.ЭтоДубль                 = Стр.ЭтоДубль;
                НовСтр.КомментарийДубля         = Стр.КомментарийДубля;
                НовСтр.Статус                   = Стр.Статус;
                НовСтр.Комментарий              = Стр.Комментарий;
            КонецЦикла;
        Исключение
            Сообщить("Ошибка при переносе данных в форму: " + ОписаниеОшибки(), СтатусСообщения.Важное);
        КонецПопытки;

    КонецПроцедуры

    &НаСервереБезКонтекста
    Функция ПрочитатьExcelВТаблицу(Адрес, ИмяФайла)

        // --- Получение файла ---
        Попытка
            ДвоичныеДанные = ПолучитьИзВременногоХранилища(Адрес);
        Исключение
            Возврат "ОШИБКА: Не удалось получить файл из хранилища. " + ОписаниеОшибки();
        КонецПопытки;

        ВремФайл = ПолучитьИмяВременногоФайла("xlsx");

        Попытка
            ДвоичныеДанные.Записать(ВремФайл);
        Исключение
            Возврат "ОШИБКА: Не удалось записать временный файл. " + ОписаниеОшибки();
        КонецПопытки;

        // --- Чтение Excel ---
        ТабДок = Новый ТабличныйДокумент;
        Попытка
            ТабДок.Прочитать(ВремФайл, СпособЧтенияЗначенийТабличногоДокумента.Значение);
        Исключение
            Попытка УдалитьФайлы(ВремФайл); Исключение КонецПопытки;
            Возврат "ОШИБКА: Не удалось прочитать Excel. " + ОписаниеОшибки();
        КонецПопытки;

        Попытка УдалитьФайлы(ВремФайл); Исключение КонецПопытки;

        // --- Структура таблицы значений ---
        ТЗ = Новый ТаблицаЗначений;

        // Служебные
        ТЗ.Колонки.Добавить("НомерСтроки",               Новый ОписаниеТипов("Число",  , , Новый КвалификаторыЧисла(6, 0)));
        ТЗ.Колонки.Добавить("УИД",                       Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(150)));
        ТЗ.Колонки.Добавить("ТипДокумента",              Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)));
        ТЗ.Колонки.Добавить("ОперацияУТ",                Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(150)));

        // Основные реквизиты документа
        ТЗ.Колонки.Добавить("Дата",                      Новый ОписаниеТипов("Дата"));
        ТЗ.Колонки.Добавить("НомерПП",                   Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
        ТЗ.Колонки.Добавить("Сумма",                     Новый ОписаниеТипов("Число",  , , Новый КвалификаторыЧисла(15, 2)));
        ТЗ.Колонки.Добавить("Валюта",                    Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(20)));

        // Наша организация
        ТЗ.Колонки.Добавить("Организация",               Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(250)));
        ТЗ.Колонки.Добавить("ИННОрг",                    Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(12)));
        ТЗ.Колонки.Добавить("КППОрг",                    Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(9)));
        ТЗ.Колонки.Добавить("НашСчет",                   Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
        ТЗ.Колонки.Добавить("НашБанк",                   Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(250)));
        ТЗ.Колонки.Добавить("НашБИК",                    Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(20)));

        // Контрагент
        ТЗ.Колонки.Добавить("Контрагент",                Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(250)));
        ТЗ.Колонки.Добавить("ИНН",                       Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(12)));
        ТЗ.Колонки.Добавить("КППКонтр",                  Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(9)));
        ТЗ.Колонки.Добавить("ДокОснование",              Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(500)));
        ТЗ.Колонки.Добавить("Назначение",                Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(1000)));
        ТЗ.Колонки.Добавить("СчетРасчетов",              Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
        ТЗ.Колонки.Добавить("СчетКонтр",                 Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
        ТЗ.Колонки.Добавить("БанкКонтр",                 Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(250)));
        ТЗ.Колонки.Добавить("БИККонтр",                  Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(20)));

        // ДДС
        ТЗ.Колонки.Добавить("СтатьяДДС",                 Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(200)));
        ТЗ.Колонки.Добавить("НаправлениеДенег",          Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(20)));

        // Найденные ссылки — контрагент
        ТЗ.Колонки.Добавить("НайденКонтрагент",          Новый ОписаниеТипов("Булево"));
        ТЗ.Колонки.Добавить("КонтрагентСсылка",          Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));

        // Найденные ссылки — организация
        ТЗ.Колонки.Добавить("НайденаОрганизация",        Новый ОписаниеТипов("Булево"));
        ТЗ.Колонки.Добавить("ОрганизацияСсылка",         Новый ОписаниеТипов("СправочникСсылка.Организации"));

        // Найденные ссылки — договор
        ТЗ.Колонки.Добавить("НайденДоговор",             Новый ОписаниеТипов("Булево"));
        ТЗ.Колонки.Добавить("ДоговорСсылка",             Новый ОписаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));

        // Найденные ссылки — статья ДДС
        ТЗ.Колонки.Добавить("НайденаСтатья",             Новый ОписаниеТипов("Булево"));
        ТЗ.Колонки.Добавить("СтатьяДДССсылка",           Новый ОписаниеТипов("СправочникСсылка.СтатьиДвиженияДенежныхСредств"));

        // Найденные ссылки — банковские счета
        ТЗ.Колонки.Добавить("НайденСчетОрганизации",     Новый ОписаниеТипов("Булево"));
        ТЗ.Колонки.Добавить("БанковскийСчетОрганизации", Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчетаОрганизаций"));
        ТЗ.Колонки.Добавить("НайденСчетКонтрагента",     Новый ОписаниеТипов("Булево"));
        ТЗ.Колонки.Добавить("БанковскийСчетКонтрагента", Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчетаКонтрагентов"));

        // Дубли
        ТЗ.Колонки.Добавить("ЭтоДубль",                  Новый ОписаниеТипов("Булево"));
        ТЗ.Колонки.Добавить("КомментарийДубля",          Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(300)));

        // Итог
        ТЗ.Колонки.Добавить("Статус",                    Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(20)));
        ТЗ.Колонки.Добавить("Комментарий",               Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(1000)));

        // --- Номера колонок Excel (по структуре prepared.xlsx) ---
        НомКол_УИД                = 1;
        НомКол_ТипДокумента       = 2;
        НомКол_НомерПП            = 5;
        НомКол_Дата               = 6;
        НомКол_Организация        = 7;
        НомКол_ИННОрг             = 8;
        НомКол_КППОрг             = 9;
        НомКол_НашСчет            = 10;
        НомКол_НашБанк            = 11;
        НомКол_НашБИК             = 12;
        НомКол_ОперацияУТ         = 31;
        НомКол_Контр              = 14;
        НомКол_ИНН                = 15;
        НомКол_КППКонтр           = 16;
        НомКол_ДокОснование       = 19;
        НомКол_Сумма              = 20;
        НомКол_Валюта             = 21;
        НомКол_Назначение         = 22;
        НомКол_СчетРасчетов       = 23;
        НомКол_СчетКонтр          = 24;
        НомКол_БанкКонтр          = 25;
        НомКол_БИККонтр           = 26;
        НомКол_СтатьяДДС          = 37;
        НомКол_НаправлениеДенег   = 32;

        СтрокаЗаголовка = 1;
        КоличествоЗагружено = 0;
        КоличествоПропущено = 0;
        КоличествоОшибок    = 0;
        КоличествоДублей    = 0;

        // --- Цикл по строкам ---
        Для НомСтр = (СтрокаЗаголовка + 1) По ТабДок.ВысотаТаблицы Цикл

            // --- Сначала считываем основные текстовые значения ---
            ТекстУИД =              ?(НомКол_УИД <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_УИД).Текст), "");
            ТекстТипДокумента =     ?(НомКол_ТипДокумента <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_ТипДокумента).Текст), "");
            ТекстОперацияУТ =       ?(НомКол_ОперацияУТ <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_ОперацияУТ).Текст), "");
            ТекстОрганизация =      ?(НомКол_Организация <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_Организация).Текст), "");
            ТекстНашБанк =          ?(НомКол_НашБанк <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_НашБанк).Текст), "");
            ТекстБанкКонтр =        ?(НомКол_БанкКонтр <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_БанкКонтр).Текст), "");
            ТекстКонтрагент =       ?(НомКол_Контр <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_Контр).Текст), "");
            ТекстДокОснование =     ?(НомКол_ДокОснование <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_ДокОснование).Текст), "");
            ТекстНазначение =       ?(НомКол_Назначение <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_Назначение).Текст), "");
            ТекстСчетРасчетов =     ?(НомКол_СчетРасчетов <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_СчетРасчетов).Текст), "");
            ТекстВалюта =           ?(НомКол_Валюта <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_Валюта).Текст), "");
            ТекстСтатьяДДС =        ?(НомКол_СтатьяДДС <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_СтатьяДДС).Текст), "");
            ТекстНаправлениеДенег = ?(НомКол_НаправлениеДенег <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_НаправлениеДенег).Текст), "");
            ТекстНомерПП =          ?(НомКол_НомерПП <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_НомерПП).Текст), "");
            ТекстДата =             ?(НомКол_Дата <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_Дата).Текст), "");
            ТекстСумма =            ?(НомКол_Сумма <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_Сумма).Текст), "");
            // ТекстДоговор = ?(НомКол_Договор <= ТабДок.ШиринаТаблицы, СокрЛП(ТабДок.Область(НомСтр, НомКол_Договор).Текст), "");

            // --- Пропускаем только совсем пустые технические строки ---
            Если ПустаяСтрока(ТекстУИД)
                И ПустаяСтрока(ТекстТипДокумента)
                И ПустаяСтрока(ТекстНомерПП)
                И ПустаяСтрока(ТекстДата)
                И ПустаяСтрока(ТекстКонтрагент)
                И ПустаяСтрока(ТекстСумма)
                И ПустаяСтрока(ТекстНазначение)
                И ПустаяСтрока(ТекстНаправлениеДенег) Тогда

                КоличествоПропущено = КоличествоПропущено + 1;
                Продолжить;
            КонецЕсли;

            НовСтр = ТЗ.Добавить();
            НовСтр.НомерСтроки      = НомСтр - СтрокаЗаголовка;
            НовСтр.Комментарий      = "";
            НовСтр.НаправлениеДенег = ТекстНаправлениеДенег;

            // --- Заполнение текстовых полей ---
            НовСтр.УИД          = ТекстУИД;
            НовСтр.ТипДокумента = ТекстТипДокумента;
            НовСтр.ОперацияУТ   = ТекстОперацияУТ;
            НовСтр.Организация  = ТекстОрганизация;
            НовСтр.НашБанк      = ТекстНашБанк;
            НовСтр.БанкКонтр    = ТекстБанкКонтр;
            НовСтр.Контрагент   = ТекстКонтрагент;
            НовСтр.ДокОснование = ТекстДокОснование;
            НовСтр.Назначение   = ТекстНазначение;
            НовСтр.СчетРасчетов = ТекстСчетРасчетов;
            НовСтр.Валюта       = ТекстВалюта;
            НовСтр.СтатьяДДС    = ТекстСтатьяДДС;
            // НовСтр.Договор      = ТекстДоговор;

            // --- Нормализация цифровых реквизитов ---
            НовСтр.НомерПП   = НормализоватьЦифровойКод(ТекстНомерПП);
            НовСтр.ИННОрг    = ДобавитьВедущийНольЕслиНужно(НормализоватьЦифровойКод(?(НомКол_ИННОрг <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_ИННОрг).Текст, "")));
            НовСтр.КППОрг    = НормализоватьЦифровойКод(?(НомКол_КППОрг <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_КППОрг).Текст, ""));
            НовСтр.НашСчет   = НормализоватьЦифровойКод(?(НомКол_НашСчет <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_НашСчет).Текст, ""));
            НовСтр.НашБИК    = НормализоватьЦифровойКод(?(НомКол_НашБИК <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_НашБИК).Текст, ""));
            НовСтр.ИНН       = ДобавитьВедущийНольЕслиНужно(НормализоватьЦифровойКод(?(НомКол_ИНН <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_ИНН).Текст, "")));
            НовСтр.КППКонтр  = НормализоватьЦифровойКод(?(НомКол_КППКонтр <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_КППКонтр).Текст, ""));
            НовСтр.СчетКонтр = НормализоватьЦифровойКод(?(НомКол_СчетКонтр <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_СчетКонтр).Текст, ""));
            НовСтр.БИККонтр  = НормализоватьЦифровойКод(?(НомКол_БИККонтр <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_БИККонтр).Текст, ""));
            
            Попытка// --- Дата ---
                НовСтр.Дата = ПарситьДату(ТекстДата);
            Исключение
                НовСтр.Дата = '00010101';
            КонецПопытки;
            
            Попытка// --- Сумма ---
                НовСтр.Сумма = НормализоватьСумму(ТекстСумма);
            Исключение
                НовСтр.Сумма = 0;
            КонецПопытки;
           
            Попытка // --- Поиск контрагента ---
                НовСтр.КонтрагентСсылка = НайтиКонтрагентаПоИНН(НовСтр.ИНН);
                НовСтр.НайденКонтрагент = ЗначениеЗаполнено(НовСтр.КонтрагентСсылка);
                Если НЕ НовСтр.НайденКонтрагент Тогда
                    НовСтр.Комментарий = НовСтр.Комментарий + "Контрагент не найден (ИНН=" + НовСтр.ИНН + "). ";
                КонецЕсли;
            Исключение
                НовСтр.НайденКонтрагент = Ложь;
                НовСтр.Комментарий = НовСтр.Комментарий + "Ошибка поиска контрагента. ";
            КонецПопытки;
            
            Попытка// --- Поиск организации ---
                НовСтр.ОрганизацияСсылка = НайтиОрганизациюПоДанным(НовСтр.ИННОрг, НовСтр.КППОрг, НовСтр.НашСчет);
                НовСтр.НайденаОрганизация = ЗначениеЗаполнено(НовСтр.ОрганизацияСсылка);
                Если НЕ НовСтр.НайденаОрганизация Тогда
                    НовСтр.Комментарий = НовСтр.Комментарий + "Организация не найдена. ";
                КонецЕсли;
            Исключение
                НовСтр.НайденаОрганизация = Ложь;
                НовСтр.Комментарий = НовСтр.Комментарий + "Ошибка поиска организации. ";
            КонецПопытки;
            
            Если НовСтр.НайденаОрганизация Тогда// --- Поиск банковского счёта организации ---
                Попытка
                    НовСтр.БанковскийСчетОрганизации = НайтиБанковскийСчетОрганизации(НовСтр.ОрганизацияСсылка, НовСтр.НашСчет);
                    НовСтр.НайденСчетОрганизации = ЗначениеЗаполнено(НовСтр.БанковскийСчетОрганизации);
                    Если НЕ НовСтр.НайденСчетОрганизации Тогда
                        НовСтр.Комментарий = НовСтр.Комментарий + "Банк. счёт организации не найден. ";
                    КонецЕсли;
                Исключение
                    НовСтр.НайденСчетОрганизации = Ложь;
                    НовСтр.Комментарий = НовСтр.Комментарий + "Ошибка поиска банк. счёта организации. ";
                КонецПопытки;
            КонецЕсли;
           
            Если НовСтр.НайденКонтрагент И НЕ ПустаяСтрока(НовСтр.СчетКонтр) Тогда // --- Поиск банковского счёта контрагента ---
                Попытка
                    НовСтр.БанковскийСчетКонтрагента = НайтиБанковскийСчетКонтрагента(НовСтр.КонтрагентСсылка, НовСтр.СчетКонтр);
                    НовСтр.НайденСчетКонтрагента = ЗначениеЗаполнено(НовСтр.БанковскийСчетКонтрагента);
                Исключение
                    НовСтр.НайденСчетКонтрагента = Ложь;
                КонецПопытки;
            КонецЕсли;
            
            Попытка// --- Поиск статьи ДДС ---
                НовСтр.СтатьяДДССсылка = НайтиСтатьюДДС(НовСтр.СтатьяДДС);
                НовСтр.НайденаСтатья = ЗначениеЗаполнено(НовСтр.СтатьяДДССсылка);
                Если НЕ НовСтр.НайденаСтатья Тогда
                    НовСтр.Комментарий = НовСтр.Комментарий + "Статья ДДС не найдена. ";
                КонецЕсли;
            Исключение
                НовСтр.НайденаСтатья = Ложь;
                НовСтр.Комментарий = НовСтр.Комментарий + "Ошибка поиска статьи ДДС. ";
            КонецПопытки;

            Попытка// --- Проверка дубля по УИД ---
                Если ПустаяСтрока(НовСтр.УИД) Тогда 
                    НовСтр.ЭтоДубль = Ложь;
                    НовСтр.Комментарий = НовСтр.Комментарий + "УИД пустой. ";
                Иначе
                    СвязанныйДок = НайтиДубльПоУИД(НовСтр.УИД);
                    Если СвязанныйДок <> Неопределено Тогда
                        НовСтр.ЭтоДубль = Истина;
                        НовСтр.КомментарийДубля = "Загружен " + Формат(СвязанныйДок.ДатаЗагрузки, "ДЛФ=DD") + " из " + СвязанныйДок.ИмяФайла;
                        КоличествоДублей = КоличествоДублей + 1;
                    Иначе
                        НовСтр.ЭтоДубль = Ложь;
                    КонецЕсли;
                КонецЕсли;
            Исключение
                НовСтр.ЭтоДубль = Ложь;
                НовСтр.Комментарий = НовСтр.Комментарий + "Ошибка проверки дубля. ";
            КонецПопытки;
            
            Если НовСтр.ЭтоДубль Тогда НовСтр.Статус = "Дубль";// --- Определение статуса ---
            ИначеЕсли НовСтр.НайденКонтрагент
                    И НовСтр.НайденаСтатья   // временно заблокировал
                    И НовСтр.НайденаОрганизация
                    И НовСтр.НайденСчетОрганизации
                    И ЗначениеЗаполнено(НовСтр.Дата)
                    И НовСтр.Дата <> '00010101'
                    И НовСтр.Сумма > 0
                    И НЕ ПустаяСтрока(НовСтр.УИД) Тогда
                НовСтр.Статус = "Готов";
            Иначе
                НовСтр.Статус = "Ошибка";
                КоличествоОшибок = КоличествоОшибок + 1;
            КонецЕсли;

            КоличествоЗагружено = КоличествоЗагружено + 1;

        КонецЦикла;

        Возврат ТЗ;

    КонецФункции

#КонецОбласти //Чтение_Excel_И_Заполнение_таблицы

#Область Вспомогательные_функции_нормализация 
// НОРМАЛИЗАЦИЯ - ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ // BSLLS-off

&НаСервереБезКонтекста
Функция НормализоватьЦифровойКод(ЗначениеЯчейки)
    Если НЕ ЗначениеЗаполнено(ЗначениеЯчейки) Тогда
        Возврат "";
    КонецЕсли;

    Текст = СокрЛП(Строка(ЗначениеЯчейки));
    Текст = СтрЗаменить(Текст, Символ(160), "");
    Текст = СтрЗаменить(Текст, " ", "");

    Если СтрНайти(Текст, ".") > 0 Тогда
        Части = СтрРазделить(Текст, ".");
        Если Части.Количество() = 2 Тогда
            ДробнаяЧасть = Части[1];
            ЕстьТолькоНули = Истина;
            Для Сч = 1 По СтрДлина(ДробнаяЧасть) Цикл
                Если Сред(ДробнаяЧасть, Сч, 1) <> "0" Тогда
                    ЕстьТолькоНули = Ложь;
                    Прервать;
                КонецЕсли;
            КонецЦикла;
            Если ЕстьТолькоНули Тогда
                Текст = Части[0];
            КонецЕсли;
        КонецЕсли;
    КонецЕсли;

    Если СтрНайти(ВРег(Текст), "E") > 0 Тогда
        Попытка
            ЧисловоеЗначение = Число(СтрЗаменить(Текст, "E", "e"));
            Текст = Формат(ЧисловоеЗначение, "ЧДЦ=0; ЧРД=.; ЧГ=0");
            Если СтрНайти(Текст, ".") > 0 Тогда
                Текст = СтрРазделить(Текст, ".")[0];
            КонецЕсли;
        Исключение
        КонецПопытки;
    КонецЕсли;

    Результат = "";
    Для Сч = 1 По СтрДлина(Текст) Цикл
        Симв = Сред(Текст, Сч, 1);
        Если Найти("0123456789", Симв) > 0 Тогда
            Результат = Результат + Симв;
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;
КонецФункции

&НаСервереБезКонтекста
Функция ПарситьДату(ТекстДата)
    Текст = СокрЛП(ТекстДата);
    Если ПустаяСтрока(Текст) Тогда
        Возврат '00010101';
    КонецЕсли;

    Если СтрДлина(Текст) >= 10 И Сред(Текст, 3, 1) = "." И Сред(Текст, 6, 1) = "." Тогда
        День  = Лев(Текст, 2);
        Месяц = Сред(Текст, 4, 2);
        Год   = Сред(Текст, 7, 4);
        Попытка
            Возврат Дата(Год + Месяц + День);
        Исключение
        КонецПопытки;
    КонецЕсли;

    Если СтрДлина(Текст) >= 10 И Сред(Текст, 5, 1) = "-" И Сред(Текст, 8, 1) = "-" Тогда
        Год   = Лев(Текст, 4);
        Месяц = Сред(Текст, 6, 2);
        День  = Сред(Текст, 9, 2);
        Попытка
            Возврат Дата(Год + Месяц + День);
        Исключение
        КонецПопытки;
    КонецЕсли;

    Если СтрДлина(Текст) = 8 Тогда
        Попытка
            Возврат Дата(Текст);
        Исключение
        КонецПопытки;
    КонецЕсли;

    Возврат '00010101';
КонецФункции

&НаСервереБезКонтекста
Функция НормализоватьСумму(ТекстСумма)
    Текст = СокрЛП(ТекстСумма);
    Текст = СтрЗаменить(Текст, Символ(160), "");
    Текст = СтрЗаменить(Текст, " ", "");
    Текст = СтрЗаменить(Текст, ",", ".");
    Попытка
        Возврат Число(Текст);
    Исключение
        Возврат 0;
    КонецПопытки;
КонецФункции

&НаСервереБезКонтекста
Функция ДобавитьВедущийНольЕслиНужно(ИНН)
    ИНН = СокрЛП(ИНН);
    Если ПустаяСтрока(ИНН) Тогда
        Возврат ИНН;
    КонецЕсли;
    ДлинаИНН = СтрДлина(ИНН);
    Если ДлинаИНН = 9 Или ДлинаИНН = 11 Тогда
        Возврат "0" + ИНН;
    КонецЕсли;
    Возврат ИНН;
КонецФункции

#КонецОбласти  //Вспомогательные_функции_нормализация

#Область Поиск_Объектов_В_Базе
// ПОИСК ОБЪЕКТОВ В БАЗЕ

    &НаСервереБезКонтекста
    Функция НайтиКонтрагентаПоИНН(ИНН)
        Если ПустаяСтрока(ИНН) Тогда
            Возврат Справочники.Контрагенты.ПустаяСсылка();
        КонецЕсли;

        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Контрагенты.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Контрагенты КАК Контрагенты
        |ГДЕ
        |   Контрагенты.ИНН = &ИНН
        |   И НЕ Контрагенты.ПометкаУдаления";

        Запрос.УстановитьПараметр("ИНН", ИНН);
        Выборка = Запрос.Выполнить().Выбрать();
        Если Выборка.Следующий() Тогда
            Возврат Выборка.Ссылка;
        КонецЕсли;

        Возврат Справочники.Контрагенты.ПустаяСсылка();
    КонецФункции

    &НаСервереБезКонтекста
    Функция ПолучитьДоговорДляКонтрагента(КонтрагентСсылка, НаименованиеДоговора)
        Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Тогда
            Возврат Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
        КонецЕсли;

        // Сначала ищем по наименованию
        Если НЕ ПустаяСтрока(НаименованиеДоговора) Тогда
            Попытка
                Запрос = Новый Запрос;
                Запрос.Текст =
                "ВЫБРАТЬ ПЕРВЫЕ 1
                |   ДоговорыКонтрагентов.Ссылка КАК Ссылка
                |ИЗ
                |   Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
                |ГДЕ
                |   ДоговорыКонтрагентов.Контрагент = &Контрагент
                |   И ДоговорыКонтрагентов.Наименование ПОДОБНО &Наим
                |   И НЕ ДоговорыКонтрагентов.ПометкаУдаления";

                Запрос.УстановитьПараметр("Контрагент", КонтрагентСсылка);
                Запрос.УстановитьПараметр("Наим", "%" + НаименованиеДоговора + "%");

                Выборка = Запрос.Выполнить().Выбрать();
                Если Выборка.Следующий() Тогда
                    Возврат Выборка.Ссылка;
                КонецЕсли;
            Исключение
            КонецПопытки;
        КонецЕсли;

        // Если по имени не нашли — берём первый договор контрагента
        Попытка
            Запрос = Новый Запрос;
            Запрос.Текст =
            "ВЫБРАТЬ ПЕРВЫЕ 1
            |   ДоговорыКонтрагентов.Ссылка КАК Ссылка
            |ИЗ
            |   Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
            |ГДЕ
            |   ДоговорыКонтрагентов.Контрагент = &Контрагент
            |   И НЕ ДоговорыКонтрагентов.ПометкаУдаления";

