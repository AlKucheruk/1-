// В этой весрии была реализована возможность загружать варианты Либо закуп либо реализация.
// В последующих версиях я решил разделить эти два направления. 

&НаСервере
Процедура ЗаписатьЛог(Текст) Экспорт
    
    ПутьКФайлу = "D:\1с\КАА\Лог_Обработка_Соглашения.txt";
    
    Попытка
        Запись = Новый ЗаписьТекста(ПутьКФайлу, КодировкаТекста.UTF8, , Истина); // добавлять в конец
        
        СтрокаЛога = Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd HH:mm:ss") + " | " + Текст;
        Запись.ЗаписатьСтроку(СтрокаЛога);
        Запись.Закрыть();
        
    Исключение
        // Если даже лог не записался — хотя бы выведем в окно сообщений
        Попытка
            Сообщить("ОШИБКА ЗАПИСИ ЛОГА: " + ОписаниеОшибки());
        Исключение
        КонецПопытки;
    КонецПопытки;
    
КонецПроцедуры


&НаКлиенте
Процедура ЗагрузитьПредпросмотрНаКлиенте()
	ЗагрузитьПредпросмотрНаСервере()
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьПредпросмотрНаСервере()
    
    ЗаписатьЛог("=== Старт загрузки предпросмотра ===");
    
    Попытка
        
        ТаблицаДанных.Очистить();
        ЗаписатьЛог("ТаблицаДанных очищена");
        
        ЗаписатьЛог("Контрагент: " + Строка(Контрагент));
        ЗаписатьЛог("Направление: " + Строка(Направление));
        ЗаписатьЛог("ДатаНачала: " + Формат(ДатаНачала, "ДФ=yyyy-MM-dd"));
        ЗаписатьЛог("ДатаОкончания: " + Формат(ДатаОкончания, "ДФ=yyyy-MM-dd"));
        
        Запрос = Новый Запрос;
        
        Если Направление = "Реализация" Тогда
            
            ЗаписатьЛог("Загружаем только Реализации");
            Запрос.Текст = 
            "ВЫБРАТЬ ПЕРВЫЕ 100
            |    Док.Ссылка          КАК Ссылка,
            |    Док.Номер           КАК Номер,
            |    Док.Дата            КАК Дата,
            |    Док.Контрагент      КАК Контрагент,
            |    Док.СуммаДокумента  КАК СуммаДокумента,
            |    Док.Соглашение      КАК Соглашение,
            |    Док.Договор         КАК Договор,
            |    Док.Статус          КАК Статус,          // есть только в реализации
            |    ""Реализация""     КАК ВидДокумента
            |ИЗ
            |    Документ.РеализацияТоваровУслуг КАК Док
            |ГДЕ
            |    Док.Проведен
            |    И Док.Дата >= &ДатаНачала
            |    И Док.Дата <= &ДатаОкончания";
            
        ИначеЕсли Направление = "Закупка" Тогда
            
            ЗаписатьЛог("Загружаем только Закупки");
            Запрос.Текст = 
            "ВЫБРАТЬ ПЕРВЫЕ 100
            |    Док.Ссылка          КАК Ссылка,
            |    Док.Номер           КАК Номер,
            |    Док.Дата            КАК Дата,
            |    Док.Контрагент      КАК Контрагент,
            |    Док.СуммаДокумента  КАК СуммаДокумента,
            |    Док.Соглашение      КАК Соглашение,
            |    Док.Договор         КАК Договор,
            |    НЕОПРЕДЕЛЕНО        КАК Статус,          // в закупке нет Статуса
            |    ""Закупка""        КАК ВидДокумента
            |ИЗ
            |    Документ.ПриобретениеТоваровУслуг КАК Док
            |ГДЕ
            |    Док.Проведен
            |    И Док.Дата >= &ДатаНачала
            |    И Док.Дата <= &ДатаОкончания";
            
        Иначе
            // Оба направления
            ЗаписатьЛог("Загружаем оба направления (Реализация + Закупка)");
            Запрос.Текст = 
            "ВЫБРАТЬ ПЕРВЫЕ 100
            |    Док.Ссылка          КАК Ссылка,
            |    Док.Номер           КАК Номер,
            |    Док.Дата            КАК Дата,
            |    Док.Контрагент      КАК Контрагент,
            |    Док.СуммаДокумента  КАК СуммаДокумента,
            |    Док.Соглашение      КАК Соглашение,
            |    Док.Договор         КАК Договор,
            |    Док.Статус          КАК Статус,
            |    ""Реализация""     КАК ВидДокумента
            |ИЗ
            |    Документ.РеализацияТоваровУслуг КАК Док
            |ГДЕ
            |    Док.Проведен
            |    И Док.Дата >= &ДатаНачала
            |    И Док.Дата <= &ДатаОкончания
            |
            |ОБЪЕДИНИТЬ ВСЕ
            |
            |ВЫБРАТЬ ПЕРВЫЕ 100
            |    Док.Ссылка,
            |    Док.Номер,
            |    Док.Дата,
            |    Док.Контрагент,
            |    Док.СуммаДокумента,
            |    Док.Соглашение,
            |    Док.Договор,
            |    НЕОПРЕДЕЛЕНО        КАК Статус,
            |    ""Закупка""
            |ИЗ
            |    Документ.ПриобретениеТоваровУслуг КАК Док
            |ГДЕ
            |    Док.Проведен
            |    И Док.Дата >= &ДатаНачала
            |    И Док.Дата <= &ДатаОкончания";
        КонецЕсли;
        
        // Добавляем фильтр по контрагенту, если выбран
        Если ЗначениеЗаполнено(Контрагент) Тогда
            Запрос.Текст = Запрос.Текст + "
            |    И Док.Контрагент = &Контрагент";
        КонецЕсли;
        
        Запрос.Текст = Запрос.Текст + "
        |
        |УПОРЯДОЧИТЬ ПО
        |    Док.Дата УБЫВ";
        
        // Параметры
        Запрос.УстановитьПараметр("ДатаНачала",   ?(ЗначениеЗаполнено(ДатаНачала), НачалоДня(ДатаНачала), '00010101'));
        Запрос.УстановитьПараметр("ДатаОкончания",?(ЗначениеЗаполнено(ДатаОкончания), КонецДня(ДатаОкончания), '39991231'));
        
        Если ЗначениеЗаполнено(Контрагент) Тогда
            Запрос.УстановитьПараметр("Контрагент", Контрагент);
        КонецЕсли;
        
        ЗаписатьЛог("Запрос подготовлен, выполняем...");
        
        Результат = Запрос.Выполнить();
        Выборка = Результат.Выбрать();
        
        ЗаписатьЛог("Запрос выполнен. Найдено строк: " + Строка(Выборка.Количество()));
        
        Пока Выборка.Следующий() Цикл
            
            ЗаписатьЛог("Обработка: " + Выборка.ВидДокумента + " " + Строка(Выборка.Ссылка));
            
            НоваяСтрока = ТаблицаДанных.Добавить();
            
            НоваяСтрока.Выбрать     = Ложь;
            НоваяСтрока.Реализация  = ?(Выборка.ВидДокумента = "Реализация", Выборка.Ссылка, Неопределено);
            НоваяСтрока.Заказ       = Выборка.Ссылка; // временно
            НоваяСтрока.Сумма       = Выборка.СуммаДокумента;
            НоваяСтрока.Соглашение  = Выборка.Соглашение;
            НоваяСтрока.Договор     = Выборка.Договор;
            НоваяСтрока.СФ          = Неопределено;
            НоваяСтрока.ТТН         = Неопределено;
            НоваяСтрока.Контрагент  = Выборка.Контрагент;
            
            Если НЕ ЗначениеЗаполнено(Выборка.Соглашение) Тогда
                НоваяСтрока.Комментарий = "Нет соглашения";
            КонецЕсли;
            
        КонецЦикла;
        
        ЗаписатьЛог("Завершение загрузки. Обработано строк: " + Строка(ТаблицаДанных.Количество()));
        
    Исключение
        ТекстОшибки = "КРИТИЧЕСКАЯ ОШИБКА: " + ОписаниеОшибки() + Символы.ПС + 
                      "Подробное описание: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
        
        ЗаписатьЛог(ТекстОшибки);
        Сообщить(ТекстОшибки);
    КонецПопытки;
    
КонецПроцедуры