// 1=ИНН покупателя, 2=КПП покупателя, 0=не трогать
Функция ВидПоляИннКппПокупателяВСчетФактуре(ИмяРек)
	в = ВРег(СокрЛП(ИмяРек));
	Если в = "" Тогда
		Возврат 0;
	КонецЕсли;
	Если СтрНайти(в, "ПРОДАВ") > 0 Тогда
		Возврат 0;
	КонецЕсли;
	Если (СтрНайти(в, "ОРГАН") > 0 Или СтрНайти(в, "СОБСТ") > 0) И СтрНайти(в, "ПОКУП") = 0 Тогда
		Возврат 0;
	КонецЕсли;
	Если СтрНайти(в, "БАНК") > 0 Тогда
		Возврат 0;
	КонецЕсли;
	ФлИ = (СтрНайти(в, "ИНН") > 0);
	ФлК = (СтрНайти(в, "КПП") > 0);
	Если Не ФлИ И Не ФлК Тогда
		Возврат 0;
	КонецЕсли;
	Если ФлИ Тогда
		Возврат 1;
	КонецЕсли;
	Возврат 2;
КонецФункции

&НаСервере
Процедура ПодставитьИннКппПокупателяВСчетФактуреПоМетаданным(СфДок, ИНН, КПП)
	Инн = СокрЛП(Строка(ИНН));
	Кпп = СокрЛП(Строка(КПП));
	Если ПустаяСтрока(Инн) И ПустаяСтрока(Кпп) Тогда
		Возврат;
	КонецЕсли;
	Попытка
		Мет = Метаданные.Документы.СчетФактураВыданный;
		Для Каждого Мр Из Мет.Реквизиты Цикл
			Вид = ВидПоляИннКппПокупателяВСчетФактуре(Мр.Имя);
			Если Вид = 0 Тогда
				Продолжить;
			КонецЕсли;
			Попытка
				ОТ = Мр.Тип;
				Если Вид = 1 Тогда
					Если ОТ.СодержитТип(Тип("Строка")) И Не ПустаяСтрока(Инн) Тогда
						СфДок[Мр.Имя] = Инн;
					КонецЕсли;
				ИначеЕсли Вид = 2 Тогда
					Если ОТ.СодержитТип(Тип("Строка")) И Не ПустаяСтрока(Кпп) Тогда
						СфДок[Мр.Имя] = Кпп;
					КонецЕсли;
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЦикла;
	Исключение
	КонецПопытки;
КонецПроцедуры

