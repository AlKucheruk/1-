	Запрос.УстановитьПараметр("Наим", П);
	Т = Запрос.Выполнить().Выгрузить();
	Если Т.Количество() = 1 Тогда
		Возврат Т[0].Ссылка;
	КонецЕсли;
	Возврат Справочники.Номенклатура.ПустаяСсылка();
КонецФункции

&НаСервере
Процедура УстановитьСтатусыПослеПоискаПоТаблице(Таблица)

	МассивИНН = Новый Массив;
	Для Каждого Стр Из Таблица Цикл
		инн = СокрЛП(Строка(Стр.ИНН));
		Если НЕ ПустаяСтрока(инн) Тогда
			МассивИНН.Добавить(инн);
		КонецЕсли;
	КонецЦикла;
	Соотв = СоответствиеКонтрагентовПоМассивуИНН(МассивИНН);

	Для Каждого Стр Из Таблица Цикл
		Стр.Статус = "Не готов";
		Стр.Комментарий = "";
		Попытка Стр.НайденоСоглашение = Ложь; Исключение КонецПопытки;
		Попытка Стр.НайденСклад = Ложь; Исключение КонецПопытки;
		Попытка Стр.НайденаНоменклатура = Ложь; Исключение КонецПопытки;
		инн = СокрЛП(Строка(Стр.ИНН));
		Если ПустаяСтрока(инн) Тогда
			Стр.НайденКонтрагент = Ложь;
			Стр.НайденДоговор    = Ложь;
			Стр.Комментарий      = "Нет ИНН. ";
			Продолжить;
		КонецЕсли;
		Конт = Соотв.Получить(инн);
		Если НЕ ЗначениеЗаполнено(Конт) Тогда
			Стр.КонтрагентСсылка = Справочники.Контрагенты.ПустаяСсылка();
			Стр.НайденКонтрагент  = Ложь;
			Стр.НайденДоговор     = Ложь;
			Стр.ДоговорСсылка     = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
			Попытка Стр.СоглашениеСсылка = Справочники.СоглашенияСКлиентами.ПустаяСсылка(); Исключение КонецПопытки;
			Попытка Стр.СкладСсылка = Справочники.Склады.ПустаяСсылка(); Исключение КонецПопытки;
			Попытка Стр.НоменклатураСсылка = Справочники.Номенклатура.ПустаяСсылка(); Исключение КонецПопытки;
			Стр.Комментарий = "Контрагент с ИНН не найден. ";
		Иначе
			Стр.КонтрагентСсылка = Конт;
			Стр.НайденКонтрагент  = Истина;

			// Договор: из ячейки либо подбор СПокупателем
			ТекстДог = СокрЛП(Строка(Стр.Договор));
			Дог = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
			Если ПустаяСтрока(ТекстДог) Тогда
				Дог = НайтиДоговорСПокупателемПоПравилуМинимальнаяСсылка(Конт);
				Если НЕ ЗначениеЗаполнено(Дог) Тогда
					Стр.ДоговорСсылка = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
					Стр.НайденДоговор  = Ложь;
					Стр.Комментарий    = Стр.Комментарий + "Нет договора с типом «С покупателем» у контрагента. ";
				Иначе
					Стр.ДоговорСсылка = Дог;
					Стр.НайденДоговор  = Истина;
					Попытка Стр.Договор = Строка(Дог); Исключение КонецПопытки;
				КонецЕсли;
			Иначе
				Дог = НайтиДоговорСПокупателемПоНаименованию(Конт, ТекстДог);
				Если НЕ ЗначениеЗаполнено(Дог) Тогда
					Стр.ДоговорСсылка = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
					Стр.НайденДоговор  = Ложь;
					Стр.Комментарий    = Стр.Комментарий + "Договор «" + ТекстДог + "» не найден (СПокупателем, точное имя). ";
				Иначе
					Стр.ДоговорСсылка = Дог;
					Стр.НайденДоговор  = Истина;
				КонецЕсли;
			КонецЕсли;

			// Соглашение: пусто в Excel → дефолт
			ТекСог = СокрЛП(Строка(Стр.Соглашение));
			Если ПустаяСтрока(ТекСог) Тогда
				ТекСог = ИмяСоглашенияПоУмолчаниюЭтап11();
			КонецЕсли;
			Сог = НайтиСоглашениеСКлиентомПоНаименованию(ТекСог);
			Если НЕ ЗначениеЗаполнено(Сог) Тогда
				Попытка Стр.СоглашениеСсылка = Справочники.СоглашенияСКлиентами.ПустаяСсылка(); Исключение КонецПопытки;
				Стр.Комментарий = Стр.Комментарий + "Соглашение «" + ТекСог + "» не найдено. ";
			Иначе
				Попытка Стр.СоглашениеСсылка = Сог; Исключение КонецПопытки;
				Попытка Стр.Соглашение = ТекСог; Исключение КонецПопытки;
				Попытка Стр.НайденоСоглашение = Истина; Исключение КонецПопытки;
			КонецЕсли;

			// Склад: пусто в Excel → дефолт
			ТекСкл = СокрЛП(Строка(Стр.Склад));
			Если ПустаяСтрока(ТекСкл) Тогда
				ТекСкл = ИмяСкладаПоУмолчаниюЭтап11();
			КонецЕсли;
			Ск = НайтиСкладПоПолномуНаименованию(ТекСкл);
			Если НЕ ЗначениеЗаполнено(Ск) Тогда
				Попытка Стр.СкладСсылка = Справочники.Склады.ПустаяСсылка(); Исключение КонецПопытки;
				Стр.Комментарий = Стр.Комментарий + "Склад «" + ТекСкл + "» не найден. ";
			Иначе
				Попытка Стр.СкладСсылка = Ск; Исключение КонецПопытки;
				Попытка Стр.Склад = ТекСкл; Исключение КонецПопытки;
				Попытка Стр.НайденСклад = Истина; Исключение КонецПопытки;
			КонецЕсли;

			// Номенклатура
			Ном = НайтиНоменклатуруПоПолномуНаименованию(СокрЛП(Строка(Стр.Номенклатура)));
			Если НЕ ЗначениеЗаполнено(Ном) Тогда
				Попытка Стр.НоменклатураСсылка = Справочники.Номенклатура.ПустаяСсылка(); Исключение КонецПопытки;
				Стр.Комментарий = Стр.Комментарий + "Номенклатура не найдена (точное наименование). ";
			Иначе
				Попытка Стр.НоменклатураСсылка = Ном; Исключение КонецПопытки;
				Попытка Стр.НайденаНоменклатура = Истина; Исключение КонецПопытки;
			КонецЕсли;

			// Ед. изм.: контроль
			ТекЕд = СокрЛП(Строка(Стр.ЕдИзм));
			Если НЕ ПустаяСтрока(ТекЕд) Тогда
				Попытка
					ПредмЕд = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ном, "ЕдиницаИзмерения");
					НаимБаз = СокрЛП(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПредмЕд, "Наименование"));
					Если ПустаяСтрока(НаимБаз) Или ВРег(НаимБаз) <> ВРег(ТекЕд) Тогда
						Стр.Комментарий = Стр.Комментарий + "Ед.изм. в Excel («" + ТекЕд + "») не совпадает с «"
							+ ?(ПустаяСтрока(НаимБаз), "не определена в карточке", НаимБаз) + "»). ";
					КонецЕсли;
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		Если Стр.Сумма = 0 Тогда
			Стр.Комментарий = Стр.Комментарий + "Сумма 0. ";
		КонецЕсли;
		Попытка
			Если Стр.Количество = 0 Тогда
				Стр.Комментарий = Стр.Комментарий + "Количество 0. ";
			КонецЕсли;
		Исключение
		КонецПопытки;
		Попытка
			Дт0 = Стр.Дата;
			Если НЕ ЗначениеЗаполнено(Дт0) Или Дт0 = '00010101' Тогда
				Стр.Комментарий = Стр.Комментарий + "Нет корректной даты. ";
			КонецЕсли;
		Исключение
		КонецПопытки;

		Ус = Ложь;
		Попытка
			Ус = Стр.НайденКонтрагент И Стр.НайденДоговор И Стр.НайденоСоглашение
				И Стр.НайденСклад И Стр.НайденаНоменклатура И Стр.Сумма <> 0;
			Попытка
				Ус = Ус И (Стр.Количество > 0);
			Исключение
			КонецПопытки;
		Исключение
		КонецПопытки;
		Если Ус Тогда
			Попытка
				Дт0 = Стр.Дата;
				Ус2 = (ЗначениеЗаполнено(Дт0) И Дт0 <> '00010101');
			Исключение
				Ус2 = Ложь;
			КонецПопытки;
			Если Ус2 Тогда
				Стр.Статус = "Готов";
				Если ПустаяСтрока(Стр.Комментарий) Тогда
					Стр.Комментарий = "Готово к загрузке. ";
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область НДС_и_создание_заказа_и_реализации

&НаСервереБезКонтекста
// Основная ставка НДС РФ по дате документа (для сопоставления с периодом: не хардкодить 22%).
// 18% до 01.01.2019, 20% до 01.01.2026, 22% с 01.01.2026.
Функция ОсновнаяСтавкаНДСПроцентовПоДате(ДатаДок)
	Д = НачалоДня(ДатаДок);
	Если Д < Дата(2019, 1, 1) Тогда
		Возврат 18;
	ИначеЕсли Д < Дата(2026, 1, 1) Тогда
		Возврат 20;
	КонецЕсли;
	Возврат 22;
КонецФункции

&НаСервереБезКонтекста
// Возвращает ссылку для реквизита СтавкаНДС: в УТ 11.4 часто Перечисление, в 11.5+ — Справочник.СтавкиНДС.
// Ищем в справочнике по наименованиям «18%», «18/118»… затем в перечислении (прямой доступ и по имени).
Функция НайтиЗначениеСтавкиНДСПоПроценту(Процент)
	ПустВ = Неопределено;

	// 1) Справочник СтавкиНДС (типовая УТ 11.5+)
	Попытка
		ПустСпр = Справочники.СтавкиНДС.ПустаяСсылка();
		МВариантов = Новый Массив;
		С = Строка(Процент);
		Зн = 100 + Процент;
		МВариантов.Добавить(С + "%");
		МВариантов.Добавить(С + " %");
		МВариантов.Добавить(С + "/" + Строка(Зн));
		МВариантов.Добавить("НДС " + С + "%");
		МВариантов.Добавить(С + ",00%");
		МВариантов.Добавить(С + ".00%");
		Для Каждого ТекстНаим Из МВариантов Цикл
			Ссыл = Справочники.СтавкиНДС.НайтиПоНаименованию(ТекстНаим, Истина);
			Если Ссыл <> ПустСпр И ЗначениеЗаполнено(Ссыл) Тогда
				Возврат Ссыл;
			КонецЕсли;
			Ссыл = Справочники.СтавкиНДС.НайтиПоНаименованию(ТекстНаим, Ложь);
			Если Ссыл <> ПустСпр И ЗначениеЗаполнено(Ссыл) Тогда
				Возврат Ссыл;
			КонецЕсли;
		КонецЦикла;
		// код элемента в типовой справочник: «18», «НДС18», «20»…
		МКодов = СтрРазделить(С + ",НДС" + С + ",Н" + С + ",P" + С, ",");
		Для Каждого КодПрот Из МКодов Цикл
			Если ПустаяСтрока(КодПрот) Тогда
				Продолжить;
			КонецЕсли;
			Ссыл = Справочники.СтавкиНДС.НайтиПоКоду(КодПрот);
			Если Ссыл <> ПустСпр И ЗначениеЗаполнено(Ссыл) Тогда
				Возврат Ссыл;
			КонецЕсли;
		КонецЦикла;
	Исключение
		// нет справочника / другая схема
	КонецПопытки;

	// 2) Перечисление — прямые имена (как в метаданных)
	Попытка
		Если Процент = 18 Тогда
			Попытка Возврат Перечисления.СтавкиНДС.НДС18; Исключение КонецПопытки;
		ИначеЕсли Процент = 20 Тогда
			Попытка Возврат Перечисления.СтавкиНДС.НДС20; Исключение КонецПопытки;
		ИначеЕсли Процент = 22 Тогда
			Попытка Возврат Перечисления.СтавкиНДС.НДС22; Исключение КонецПопытки;
		КонецЕсли;
	Исключение
	КонецПопытки;

	// 3) Перечисление — обращение по строковому имени значения
	Им = Строка(Процент);
	Попытка
		Возврат Перечисления.СтавкиНДС["НДС" + Им];
	Исключение
	КонецПопытки;
	Попытка
		Возврат Перечисления.СтавкиНДС["Ставка" + Им];
	Исключение
	КонецПопытки;
	Попытка
		Возврат Перечисления.СтавкиНДС["НДС_" + Им];
	Исключение
	КонецПопытки;
	// 4) Обход метаданных перечисления
	Попытка
		Префиксы = СтрРазделить("НДС,Ставка,НДС_,СтавкаНДС", ",");
		Для Каждого МетаЗначение Из Метаданные.Перечисления.СтавкиНДС.ЗначенияПеречисления Цикл
			ИмЗ = МетаЗначение.Имя;
			Для Каждого Преф Из Префиксы Цикл
				Если ИмЗ = Преф + Им Или ИмЗ = "НДС" + Им Тогда
					Попытка
						Возврат Перечисления.СтавкиНДС[ИмЗ];
					Исключение
					КонецПопытки;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	Исключение
	КонецПопытки;

	Возврат ПустВ;
КонецФункции

&НаСервереБезКонтекста
// «Без НДС» — сначала справочник, затем перечисление.
Функция НайтиЗначениеСтавкиНДСБезНДС()
	Попытка
		ПустСпр = Справочники.СтавкиНДС.ПустаяСсылка();
		Для Каждого Т Из СтрРазделить("Без НДС,БезНДС,0%,НДС 0%", ",") Цикл
			Сс = Справочники.СтавкиНДС.НайтиПоНаименованию(Т, Истина);
			Если Сс <> ПустСпр И ЗначениеЗаполнено(Сс) Тогда
				Возврат Сс;
			КонецЕсли;
		КонецЦикла;
	Исключение
	КонецПопытки;
	Попытка
		Возврат Перечисления.СтавкиНДС.БезНДС;
	Исключение
	КонецПопытки;
	Попытка
		Возврат Перечисления.СтавкиНДС.НДС0;
	Исключение
	КонецПопытки;
	Возврат Неопределено;
КонецФункции

&НаСервере
// Резерв, если глобальное «создание на основании» не сработало: копия шапки/ТЧ с заказа.
Процедура ЗаполнитьРеализациюПоДокументуЗаказа(Р, СсылкаЗаказ, СкладСсыл, ДатДок)
	Зо = СсылкаЗаказ.ПолучитьОбъект();
	Попытка
		Р.Контрагент = Зо.Контрагент;
	Исключение
	КонецПопытки;
	Попытка
		Р.Партнер = Зо.Партнер;
	Исключение
	КонецПопытки;
	Попытка
		Р.Соглашение = Зо.Соглашение;
	Исключение
	КонецПопытки;
	Попытка
		Р.Договор = Зо.Договор;
	Исключение
	КонецПопытки;
	Попытка
		Р.Организация = Зо.Организация;
	Исключение
	КонецПопытки;
	Попытка
		Р.Валюта = Зо.Валюта;
	Исключение
	КонецПопытки;
	Попытка
		Р.ВалютаВзаиморасчетов = Зо.ВалютаВзаиморасчетов;
	Исключение
		Попытка
			Р.ВалютаВзаиморасчетов = Зо.Валюта;
		Исключение
		КонецПопытки;
	КонецПопытки;
	Попытка
		Р.ЦенаВключаетНДС = Зо.ЦенаВключаетНДС;
	Исключение
	КонецПопытки;
	Попытка
		Р.НалогообложениеНДС = Зо.НалогообложениеНДС;
	Исключение
	КонецПопытки;
	Попытка
		Р.ХозяйственнаяОперация = Зо.ХозяйственнаяОперация;
	Исключение
	КонецПопытки;
	Попытка
		Р.ПорядокРасчетов = Зо.ПорядокРасчетов;
	Исключение
	КонецПопытки;
	Попытка
		Р.ЗаказКлиента = СсылкаЗаказ;
	Исключение
	КонецПопытки;
	Попытка
		Р.Склад = СкладСсыл;
	Исключение
	КонецПопытки;
	Попытка
		Р.СкладОтгрузки = СкладСсыл;
	Исключение
	КонецПопытки;
	Попытка
		Р.Дата = ДатДок;
	Исключение
	КонецПопытки;
	Попытка
		Р.Товары.Очистить();
	Исключение
	КонецПопытки;
	Для Каждого з Из Зо.Товары Цикл
		н = Р.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(н, з);
		Попытка
			н.Склад = СкладСсыл;
		Исключение
		КонецПопытки;
	КонецЦикла;
	// Редкие варианты метаданных: строки только в «Услуги» заказа или в «Услуги» реализации
	Если Р.Товары.Количество() = 0 Тогда
		Попытка
			Для Каждого з Из Зо.Услуги Цикл
				н = Р.Товары.Добавить();
				ЗаполнитьЗначенияСвойств(н, з);
				Попытка
					н.Склад = СкладСсыл;
				Исключение
				КонецПопытки;
			КонецЦикла;
		Исключение
		КонецПопытки;
	КонецЕсли;
	Если Р.Товары.Количество() = 0 Тогда
		Попытка
			Для Каждого з Из Зо.Товары Цикл
				н = Р.Услуги.Добавить();
				ЗаполнитьЗначенияСвойств(н, з);
			КонецЦикла;
		Исключение
		КонецПопытки;
	КонецЕсли;
	Если Р.Товары.Количество() = 0 Тогда
		Попытка
			Для Каждого з Из Зо.Услуги Цикл
				н = Р.Услуги.Добавить();
				ЗаполнитьЗначенияСвойств(н, з);
			КонецЦикла;
		Исключение
		КонецПопытки;
	КонецЕсли;
	// Вариант оформления продажи — с заказа, если в заказе реквизит «ВариантОформленияПродажи» заполнен
	Попытка
