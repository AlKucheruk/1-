&НаСервереБезКонтекста
Функция СоответствиеКонтрагентовПоМассивуИНН(МассивИНН)
	Соотв = Новый Соответствие; // Ключ: ИНН (без КПП), Значение: СправочникСсылка.Контрагенты
	Если МассивИНН.Количество() = 0 Тогда
		Возврат Соотв;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Контрагенты.ИНН КАК ИНН,
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ИНН В(&МассивИНН)
	|	И НЕ Контрагенты.ПометкаУдаления";
	Запрос.УстановитьПараметр("МассивИНН", МассивИНН);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Кл = СокрЛП(Выборка.ИНН);
		Если Соотв.Получить(Кл) = Неопределено Тогда
			Соотв.Вставить(Кл, Выборка.Ссылка);
		КонецЕсли;
	КонецЦикла;
	Возврат Соотв;
КонецФункции

&НаСервереБезКонтекста
Функция НайтиДоговорСПокупателемПоПравилуМинимальнаяСсылка(КонтрагентСсылка)
	Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Тогда
		Возврат Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	МИНИМУМ(Договоры.Ссылка) КАК Ссылка
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК Договоры
	|ГДЕ
	|	Договоры.Контрагент = &Контрагент
	|	И НЕ Договоры.ПометкаУдаления
	|	И Договоры.ТипДоговора = ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.СПокупателем)";
	Запрос.УстановитьПараметр("Контрагент", КонтрагентСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	Возврат Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
КонецФункции

&НаСервереБезКонтекста
Функция НайтиДоговорСПокупателемПоНаименованию(КонтрагентСсылка, НаименованиеДоговора)
	Пустая = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	Им = СокрЛП(Строка(НаименованиеДоговора));
	Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Или ПустаяСтрока(Им) Тогда
		Возврат Пустая;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 2
	|	Договоры.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК Договоры
	|ГДЕ
	|	Договоры.Контрагент = &Контрагент
	|	И НЕ Договоры.ПометкаУдаления
	|	И Договоры.ТипДоговора = ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.СПокупателем)
	|	И Договоры.Наименование = &Наим";
	Запрос.УстановитьПараметр("Контрагент", КонтрагентСсылка);
	Запрос.УстановитьПараметр("Наим", Им);
	Рд = Запрос.Выполнить().Выгрузить();
	Если Рд.Количество() = 1 Тогда
		Возврат Рд[0].Ссылка;
	КонецЕсли;
	Возврат Пустая;
КонецФункции

