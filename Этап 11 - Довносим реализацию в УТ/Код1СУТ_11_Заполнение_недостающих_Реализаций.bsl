Функция ПеречислениеПохожеНаВысокийСреднийНизкий(МетПер)
	// Эвристика: три уровня приоритета в типовой форме
	ЕстьВ = Ложь;
	ЕстьС = Ложь;
	ЕстьН = Ложь;
	Для Каждого МетЗн Из МетПер.ЗначенияПеречисления Цикл
		з = ВРег(МетЗн.Имя);
		Если СтрНайти(з, "ВЫСОК") > 0 Или СтрНайти(з, "HIGH") > 0 Тогда
			ЕстьВ = Истина;
		КонецЕсли;
		Если СтрНайти(з, "СРЕДН") > 0 Или СтрНайти(з, "MED") > 0 Или СтрНайти(з, "MIDD") > 0 Тогда
			ЕстьС = Истина;
		КонецЕсли;
		Если СтрНайти(з, "НИЗК") > 0 Или СтрНайти(з, "LOW") > 0 Тогда
			ЕстьН = Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат ЕстьВ И ЕстьС И ЕстьН;
КонецФункции

