// В реестре «Документы продажи (все)» колонка «Склад» у СФ — тот же Справочник.Склады, что у РТУ и заказа.
// СкладКакВЦепочке — та же ссылка, что в обработке (заказ/строка); если пусто — из РТУ, затем с заказа клиента.
Процедура ПодставитьСкладВСчетФактуреПоРеализации(СфДок, СсылкаРеализация, СкладКакВЦепочке = Неопределено)
	Ск = Неопределено;
	Если ЗначениеЗаполнено(СкладКакВЦепочке) Тогда
		Ск = СкладКакВЦепочке;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Ск) Тогда
		Попытка
			РекСкл = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаРеализация, "Склад, СкладОтгрузки");
			Ск = РекСкл.Склад;
			Если Не ЗначениеЗаполнено(Ск) Тогда
				Ск = РекСкл.СкладОтгрузки;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Ск) Тогда
		Попытка
			Зк = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаРеализация, "ЗаказКлиента");
			Если ЗначениеЗаполнено(Зк) Тогда
				Рс = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Зк, "Склад, СкладОтгрузки");
				Ск = Рс.Склад;
				Если Не ЗначениеЗаполнено(Ск) Тогда
					Ск = Рс.СкладОтгрузки;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Ск) Тогда
		Возврат;
	КонецЕсли;
	Попытка
		СфДок.Склад = Ск;
	Исключение
	КонецПопытки;
	Попытка
		СфДок.СкладОтгрузки = Ск;
	Исключение
	КонецПопытки;
	Попытка
		Тс = ТипЗнч(Ск);
		Для Каждого Мр Из Метаданные.Документы.СчетФактураВыданный.Реквизиты Цикл
			Попытка
				н = ВРег(СокрЛП(Мр.Имя));
				Если СтрНайти(н, "СКЛАД") = 0 Тогда
					Продолжить;
				КонецЕсли;
				Если СтрНайти(н, "ПОЛУЧ") > 0 Тогда
					Продолжить;
				КонецЕсли;
				Если Мр.Тип.СодержитТип(Тс) Тогда
					СфДок[Мр.Имя] = Ск;
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЦикла;
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервере
// После «Заполнить(основание)» в УТ часто не копируются контрагент, ИНН/КПП, дата выставления.
Процедура ДозаполнитьСчетФактуруПоРеализации(СфДок, СсылкаРеализация, СкладКакВЦепочке = Неопределено)

	СписокР = "Контрагент,Партнер,Организация,Договор,Дата";
	РекР = Неопределено;
	Попытка
		РекР = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаРеализация, СписокР);
	Исключение
		Возврат;
	КонецПопытки;
	Конт = Неопределено;
	Попытка
		Конт = РекР.Контрагент;
	Исключение
	КонецПопытки;
	// Контрагент из договора, если в шапке РТУ пусто
	Если НЕ ЗначениеЗаполнено(Конт) Тогда
		Попытка
			Если ЗначениеЗаполнено(РекР.Договор) Тогда
				Конт = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РекР.Договор, "Контрагент");
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	// Доп. источник не вызываем: сигнатуры ПартнерыИКонтрагенты в релизах отличаются

	Попытка
		Если ЗначениеЗаполнено(Конт) Тогда
			СфДок.Контрагент = Конт;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Попытка
		Если ЗначениеЗаполнено(РекР.Партнер) Тогда
			СфДок.Партнер = РекР.Партнер;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Попытка
		Если ЗначениеЗаполнено(РекР.Организация) Тогда
			СфДок.Организация = РекР.Организация;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Попытка
		Если ЗначениеЗаполнено(РекР.Договор) Тогда
			СфДок.Договор = РекР.Договор;
		КонецЕсли;
	Исключение
	КонецПопытки;
	// Дублирующие ссылки, встречающиеся в отдельных релизах/формах
	Попытка
		Если ЗначениеЗаполнено(Конт) Тогда
			СфДок.Покупатель = Конт;
		КонецЕсли;
	Исключение
	КонецПопытки;

	// ИНН/КПП: из контрагента и (если пусто) с партнёра; плюс обход шапки по метаданным СФ
	СнИк = ПолучитьИннКппПокупателя(Конт, РекР.Партнер);
	ПодставитьИннКппПокупателяВСчетФактуреПоМетаданным(СфДок, СнИк.Инн, СнИк.Кпп);
	Попытка
		Если Не ПустаяСтрока(СнИк.Инн) Тогда
			СфДок.ИНН = СнИк.Инн;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Попытка
		Если Не ПустаяСтрока(СнИк.Кпп) Тогда
			СфДок.КПП = СнИк.Кпп;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Попытка
		Если Не ПустаяСтрока(СнИк.Инн) Тогда
			СфДок.ИННПокупателя = СнИк.Инн;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Попытка
		Если Не ПустаяСтрока(СнИк.Кпп) Тогда
			СфДок.КПППокупателя = СнИк.Кпп;
		КонецЕсли;
	Исключение
	КонецПопытки;

	ПодставитьСкладВСчетФактуреПоРеализации(СфДок, СсылкаРеализация, СкладКакВЦепочке);

	// Дата документа СФ = дата РТУ; дата «выставлен» — та же, не «сегодня»
	ДтСф = Неопределено;
	Попытка
		ДтСф = РекР.Дата;
	Исключение
	КонецПопытки;
	Если НЕ ЗначениеЗаполнено(ДтСф) Тогда
		Попытка
			ДтСф = СфДок.Дата;
		Исключение
		КонецПопытки;
	КонецЕсли;
	Если ЗначениеЗаполнено(ДтСф) Тогда
		Попытка
			СфДок.Дата = ДтСф;
		Исключение
		КонецПопытки;
		Попытка
			// Иначе при «Выставлен = Истина» в модуле подставляется дата сессии
			СфДок.ДатаВыставления = НачалоДня(ДтСф);
		Исключение
		КонецПопытки;
		Попытка
			СфДок.ДатаСчетФактура = НачалоДня(ДтСф);
		Исключение
		КонецПопытки;
	КонецЕсли;
	Попытка
		СфДок.Выставлен = Истина;
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервере
// Повторное типовое Заполнить с разными именами ключа (обработчики в УТ ожидают разные параметры).
Процедура ЗаполнитьСчетФактуруПоКлючуОснования(СфДок, СсылкаРеализация)
	Кл = Новый Массив;
	Кл.Добавить("Основание");
	Кл.Добавить("ДокументОснование");
	Кл.Добавить("ПервичныйДокумент");
	Кл.Добавить("ДокументПродажи");
	Кл.Добавить("Ссылка");
	Для Каждого ИмК Из Кл Цикл
		Попытка
			Пар = Новый Структура;
			Пар.Вставить(ИмК, СсылкаРеализация);
			СфДок.Заполнить(Пар);
		Исключение
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

&НаСервере
// Создание и проведение «Счёт-фактура выданный» по проведённой РТУ.
// Предпочтительно — только шаги платформы/конфигурации: «Создать на основании» + одно проведение.
// Многократные «Заполнить», вторая перепроводка и перепроведение РТУ после СФ нередко ломают/помечают СФ в УТ.
// Документ метаданных: Документы.СчетФактураВыданный (1С:УТ 11).
// Ищите в модуле по имени: СоздатьПровестиСчетФактуруВыданныйПоРеализации
Функция СоздатьПровестиСчетФактуруВыданныйПоРеализации(СсылкаРеализация, СкладКакВЦепочке = Неопределено)

	СфДок = Неопределено;

	// 1) Штатно, как в форме «Создать на основании» от РТУ
	Попытка
		СфДок = Документы.СчетФактураВыданный.СоздатьДокументНаОсновании(СсылкаРеализация);
	Исключение
		СфДок = Неопределено;
	КонецПопытки;

	// 2) Запас, если ссылка/обмен не вернули документ
	Если СфДок = Неопределено Тогда
		Попытка
			СфДок = Документы.СчетФактураВыданный.СоздатьДокумент();
			СфДок.Заполнить(СсылкаРеализация);
		Исключение
			Попытка
				СфДок = Документы.СчетФактураВыданный.СоздатьДокумент();
				ПарамО = Новый Структура;
				ПарамО.Вставить("Основание", СсылкаРеализация);
				СфДок.Заполнить(ПарамО);
			Исключение
				СфДок = Неопределено;
			КонецПопытки;
		КонецПопытки;
		Если СфДок <> Неопределено Тогда
			// для «ручного» пути — дотянуть шаблон, как раньше
			ЗаполнитьСчетФактуруПоКлючуОснования(СфДок, СсылкаРеализация);
			ПривязатьСчетФактуруКРеализации(СфДок, СсылкаРеализация);
		КонецЕсли;
	Иначе
		// Штатное создание: только страховка ТЧ оснований, без пяти вызовов «Заполнить» (они перерисовывают шапку/сбрасывают СФ)
		ПривязатьСчетФактуруКРеализации(СфДок, СсылкаРеализация);
	КонецЕсли;

	Если СфДок = Неопределено Тогда
		ВызватьИсключение "Не удалось создать объект «Счёт-фактура выданный» (СоздатьДокументНаОсновании/СоздатьДокумент).";
	КонецЕсли;

	// Наше: даты выставления, ИНН/КПП, склад (как у РТУ/заказа/строки обработки)
	ДозаполнитьСчетФактуруПоРеализации(СфДок, СсылкаРеализация, СкладКакВЦепочке);
	// Одна запись: проведение (без «Запись»+«Проведение»+снова «Проведение» — уменьшает риск служебной отмены)
	СфДок.Записать(РежимЗаписиДокумента.Проведение);

	Возврат СфДок.Ссылка;

КонецФункции

#КонецОбласти

&НаСервере
// Возврат: структура с ключами Заказ, Реализация, СчетФактура — ссылки на проведённые документы.
Функция СоздатьПровестиЗаказИРеализациюПоСтроке(Знач Стр)

	Дт        = Стр.Дата;
	СуммОжид  = Окр(Стр.Сумма, 2);
	Кол       = Стр.Количество;
	Конт      = Стр.КонтрагентСсылка;
	Дог       = Стр.ДоговорСсылка;
	Согл      = Стр.СоглашениеСсылка;
	Скл       = Стр.СкладСсылка;
	Ном       = Стр.НоменклатураСсылка;
	ПрдЦена   = 0;
	Попытка
		ПрдЦена = Окр(Стр.ЦенаСНДС, 2);
	Исключение
		ПрдЦена = 0;
	КонецПопытки;

	Если НЕ ЗначениеЗаполнено(Конт) Или НЕ ЗначениеЗаполнено(Дог) Или НЕ ЗначениеЗаполнено(Согл)
		Или НЕ ЗначениеЗаполнено(Скл) Или НЕ ЗначениеЗаполнено(Ном) Тогда
		ВызватьИсключение "Перед созданием документов не заполнены ссылки: контрагент, договор, соглашение, склад или номенклатура.";
	КонецЕсли;
	Если Кол <= 0 Тогда
		ВызватьИсключение "Количество должно быть > 0.";
	КонецЕсли;
	Прц = ОсновнаяСтавкаНДСПроцентовПоДате(Дт);
	Знм = 100 + Прц;
	Ств = НайтиЗначениеСтавкиНДСПоПроценту(Прц);
	СуммСНДС = СуммОжид;
	сБ     = Окр(СуммСНДС * 100 / Знм, 2);
	сН     = СуммСНДС - сБ;
	Если НЕ ЗначениеЗаполнено(Ств) Тогда
		ВызватьИсключение "Не удалось сопоставить ставку НДС для " + Формат(Прц, "ЧН=0; ЧГ=") + "% (проверьте справочник/перечисление).";
	КонецЕсли;
	// Цена с НДС за ед.: из файла, иначе из суммы/количества
	ЦенаСН = ?(ПрдЦена > 0, ПрдЦена, ?(Кол > 0, Окр(СуммСНДС / Кол, 4), 0));

	НачатьТранзакцию();
	Попытка

		Зак = Документы.ЗаказКлиента.СоздатьДокумент();
		Зак.Дата = ?(НЕ ЗначениеЗаполнено(Дт) Или Дт = '00010101', ТекущаяДатаСеанса(), Дт);
		Попытка
			Зак.Контрагент = Конт;
		Исключение
			ВызватьИсключение "Реквизит заказа «Контрагент»: " + ОписаниеОшибки();
		КонецПопытки;
		Попытка
			Зак.Партнер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Конт, "Партнер");
		Исключение
		КонецПопытки;
		Зак.Соглашение = Согл;
		Зак.Договор    = Дог;
		Зак.Организация = ЗначениеНастроекПовтИсп.ПолучитьОрганизациюПоУмолчанию(Справочники.Организации.ПустаяСсылка());
		Если НЕ ЗначениеЗаполнено(Зак.Организация) Тогда
			ВызватьИсключение "Не удалось определить организацию по умолчанию.";
		КонецЕсли;
		Зак.Валюта = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(Зак.Организация);
		Попытка
			Зак.ВалютаВзаиморасчетов = Зак.Валюта;
		Исключение
		КонецПопытки;
		Попытка
			Зак.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.РеализацияКлиенту;
		Исключение
		КонецПопытки;
		Попытка
			Зак.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов;
		Исключение
		КонецПопытки;
		Попытка
			Зак.ФормаОплаты = Перечисления.ФормыОплаты.Безналичная;
		Исключение
		КонецПопытки;
		Зак.ЦенаВключаетНДС = Истина;
		Попытка
			ПарНал = Документы.ЗаказКлиента.ПараметрыЗаполненияНалогообложенияНДСПродажи(Зак);
			УчетНДСУП.ЗаполнитьНалогообложениеНДСПродажи(Зак.НалогообложениеНДС, ПарНал);
		Исключение
		КонецПопытки;
		Попытка
			ПарВд = Документы.ЗаказКлиента.ПараметрыЗаполненияВидаДеятельностиНДС(Зак);
			УчетНДСУП.ЗаполнитьВидДеятельностиНДС(Зак.ПродажаПодДеятельность, ПарВд);
		Исключение
			Попытка
				ПарВд = Документы.ЗаказКлиента.ПараметрыЗаполненияВидаДеятельностиНДС(Зак);
				УчетНДСУП.ЗаполнитьВидДеятельностиНДС(Зак.ВидДеятельностиНДС, ПарВд);
			Исключение
			КонецПопытки;
		КонецПопытки;
		Попытка
			Зак.Склад = Скл;
		Исключение
			Попытка
				Зак.СкладОтгрузки = Скл;
			Исключение
			КонецПопытки;
		КонецПопытки;
		// Статусы, чтобы упростить проведение (если перечисление доступно)
		Попытка
			Зак.Статус = Перечисления.СтатусыЗаказовКлиентов.Согласован;
		Исключение
			Попытка
				Зак.Статус = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению;
			Исключение
			КонецПопытки;
		КонецПопытки;
		Зак.Комментарий = "Этап 11: авто-загрузка (заказ/реализация).";
		УстановитьПриоритетЗаказаСредний(Зак);
		УстановитьДатыОтгрузкиВШапкеЗаказа(Зак, НачалоДня(Зак.Дата));

		СтрТ = Зак.Товары.Добавить();
		ЗаполнитьСтрокуЗаказаТоварыОтгрузка(СтрТ, Ном, Кол, Зак.Дата, Скл, Ств, ЦенаСН, сБ, сН, СуммСНДС);

		Зак.Записать(РежимЗаписиДокумента.Запись);
		// Первая запись соглашения/обработчики иногда сбрасывают «Приоритет» — заполняем и фиксируем снова
		УстановитьПриоритетЗаказаСредний(Зак);
		Зак.Записать(РежимЗаписиДокумента.Запись);
		Если Окр(Зак.СуммаДокумента, 2) <> СуммОжид Тогда
			ВызватьИсключение "СуммаДокумента заказа " + Формат(Зак.СуммаДокумента, "ЧДЦ=2")
				+ " не равна сумме в таблице обработки " + Формат(СуммОжид, "ЧДЦ=2");
		КонецЕсли;
		УстановитьПриоритетЗаказаСредний(Зак);
		Зак.Записать(РежимЗаписиДокумента.Проведение);

		// --- Реализация товаров и услуг
		Р = Неопределено;
		Попытка
			Р = Документы.РеализацияТоваровУслуг.СоздатьДокументНаОсновании(Зак.Ссылка);
		Исключение
			Попытка
				Р = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
				ПарамЗ = Новый Структура;
				ПарамЗ.Вставить("Основание", Зак.Ссылка);
				Р.Заполнить(ПарамЗ);
			Исключение
				Попытка
					Р = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
					Р.Заполнить(Зак.Ссылка);
				Исключение
					Попытка
						Р = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
						ЗаполнитьРеализациюПоДокументуЗаказа(Р, Зак.Ссылка, Скл, Зак.Дата);
					Исключение
						ВызватьИсключение "Не удалось сформировать «Реализацию товаров и услуг» на основании заказа. "
							+ "Проверьте версию УТ. Детали: " + ОписаниеОшибки();
					КонецПопытки;
				КонецПопытки;
			КонецПопытки;
		КонецПопытки;
		Если Р = Неопределено Тогда
			ВызватьИсключение "Пустой объект «Реализация товаров и услуг» при создании.";
		КонецЕсли;
		// «Создать на основании» в УТ часто не переносит строки (остаток/варианты) — вручную с заказа
		Если Р.Товары.Количество() = 0 Тогда
			ЗаполнитьРеализациюПоДокументуЗаказа(Р, Зак.Ссылка, Скл, Зак.Дата);
		КонецЕсли;
		Попытка
			Р.Дата = Зак.Дата;
		Исключение
		КонецПопытки;
		Попытка
			// Дата отгрузки (если реквизит есть) — в один день с заказом и с датой реализации
			Р.ДатаОтгрузки = НачалоДня(Р.Дата);
		Исключение
		КонецПопытки;
		Попытка
			Р.СкладОтгрузки = Скл;
		Исключение
			Попытка
				Р.Склад = Скл;
			Исключение
			КонецПопытки;
		КонецПопытки;
		Попытка
			ПарПрод = Документы.РеализацияТоваровУслуг.ПараметрыЗаполненияНалогообложенияНДСПродажи(Р);
			УчетНДСУП.ЗаполнитьНалогообложениеНДСПродажи(Р.НалогообложениеНДС, ПарПрод);
		Исключение
		КонецПопытки;
		Попытка
			ПарВдР = Документы.РеализацияТоваровУслуг.ПараметрыЗаполненияВидаДеятельностиНДС(Р);
			УчетНДСУП.ЗаполнитьВидДеятельностиНДС(Р.ПродажаПодДеятельность, ПарВдР);
		Исключение
			Попытка
				ПарВдР = Документы.РеализацияТоваровУслуг.ПараметрыЗаполненияВидаДеятельностиНДС(Р);
				УчетНДСУП.ЗаполнитьВидДеятельностиНДС(Р.ВидДеятельностиНДС, ПарВдР);
			Исключение
			КонецПопытки;
		КонецПопытки;
		Р.Комментарий = "Этап 11: авто-загрузка (по заказу).";
		СинхронизироватьПорядокРасчетовРеализацияСЗаказом(Р, Зак);
		УстановитьВариантОформленияПродажиРеализация(Р);

		Если Р.Товары.Количество() = 0 Тогда
			ЗаполнитьРеализациюПоДокументуЗаказа(Р, Зак.Ссылка, Скл, Зак.Дата);
			УстановитьВариантОформленияПродажиРеализация(Р);
		КонецЕсли;
		// Заказ + флажок «по заказу»; при срабатывании типовой логики ТЧ могла обнулиться — добираем снова
		ВосстановитьСвязьРеализацииСЗаказомКлиента(Р, Зак.Ссылка);
		Если Р.Товары.Количество() = 0 Тогда
			ЗаполнитьРеализациюПоДокументуЗаказа(Р, Зак.Ссылка, Скл, Зак.Дата);
			ВосстановитьСвязьРеализацииСЗаказомКлиента(Р, Зак.Ссылка);
			УстановитьВариантОформленияПродажиРеализация(Р);
		КонецЕсли;
		КолСтрРеал = Р.Товары.Количество();
		Попытка
			КолСтрРеал = КолСтрРеал + Р.Услуги.Количество();
		Исключение
		КонецПопытки;
		Если КолСтрРеал = 0 Тогда
			ВызватьИсключение "В реализации нет строк («Товары»/«Услуги»): в заказе нет переносимых строк или отличается структура ТЧ.";
		КонецЕсли;
		ВосстановитьСвязьРеализацииСЗаказомКлиента(Р, Зак.Ссылка);
		УстановитьВариантОформленияПродажиРеализация(Р);

		Р.Записать(РежимЗаписиДокумента.Запись);
		УстановитьВариантОформленияПродажиРеализация(Р);
		Р.Записать(РежимЗаписиДокумента.Запись);
		Если Окр(Р.СуммаДокумента, 2) <> СуммОжид Тогда
			ВызватьИсключение "СуммаДокумента реализации " + Формат(Р.СуммаДокумента, "ЧДЦ=2")
				+ " не равна сумме в таблице обработки (ожидалось " + Формат(СуммОжид, "ЧДЦ=2") + ").";
		КонецЕсли;
		Р.Записать(РежимЗаписиДокумента.Проведение);

		// -----------------------------------------------------------------
		// 3-й документ цепочки: Счёт-фактура выданный (Документы.СчетФактураВыданный)
		// Функция: СоздатьПровестиСчетФактуруВыданныйПоРеализации (область #Счет_фактура_выданный_по_реализации)
		// -----------------------------------------------------------------
		СфСсылка = СоздатьПровестиСчетФактуруВыданныйПоРеализации(Р.Ссылка, Скл);

		Сн = Новый Структура;
		Сн.Вставить("Заказ",         Зак.Ссылка);
		Сн.Вставить("Реализация",    Р.Ссылка);
		Сн.Вставить("СчетФактура",   СфСсылка);

		ЗафиксироватьТранзакцию();
		Возврат Сн;

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение(ОписаниеОшибки());
	КонецПопытки;

КонецФункции

#КонецОбласти

#Область Лог_файл_этап11

&НаСервереБезКонтекста
Функция КаталогЛоговКААЭтап11()
	Возврат "D:\1с\КАА";
КонецФункции

&НаСервереБезКонтекста
Функция ПолныйПутьФайлаЛогаЭтап11()
	Возврат КаталогЛоговКААЭтап11() + "\Лог_11_Заполнение_недостающих_Реализаций.txt";
КонецФункции

&НаСервереБезКонтекста
Процедура ОбеспечитьКаталогЛоговКААЭтап11()
	КаталогЛогов = КаталогЛоговКААЭтап11();
	Попытка
		ФайлКаталогаЛогов = Новый Файл(КаталогЛогов);
		Если НЕ ФайлКаталогаЛогов.Существует() Тогда
			СоздатьКаталог(КаталогЛогов);
		КонецЕсли;
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьСтрокуВЛогЭтап11(ТекстСообщения)
	ОбеспечитьКаталогЛоговКААЭтап11();
	ПолныйПуть = ПолныйПутьФайлаЛогаЭтап11();
	СтрокаЛога = Формат(ТекущаяДата(), "ДЛФ=DT") + " | " + ТекстСообщения;
	Попытка
		ТД = Новый ТекстовыйДокумент;
		ФайлЛога = Новый Файл(ПолныйПуть);
		Если ФайлЛога.Существует() Тогда
			ТД.Прочитать(ПолныйПуть, КодировкаТекста.UTF8);
		КонецЕсли;
		ТД.ДобавитьСтроку(СтрокаЛога);
		ТД.Записать(ПолныйПуть, КодировкаТекста.UTF8);
	Исключение
		Сообщить("Не удалось записать лог (" + ПолныйПуть + "): " + ОписаниеОшибки(), СтатусСообщения.Внимание);
	КонецПопытки;
КонецПроцедуры

#КонецОбласти

#Область Оценка_времени_и_загрузка

&НаСервере
Функция ОценитьВремяЗагрузкиСервер()
	РазмерБанча = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("РазмерБанчаЗагрузки", 10);
	Если ТипЗнч(РазмерБанча) <> Тип("Число") Или РазмерБанча <= 0 Тогда
		РазмерБанча = 10;
	КонецЕсли;
	СекНаСтр = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("ОценкаСекундНаОдинПлатеж", 5);
	Если ТипЗнч(СекНаСтр) <> Тип("Число") Или СекНаСтр <= 0 Тогда
		СекНаСтр = 5;
	КонецЕсли;
	КолГотов = 0;
	КолВыб   = 0;
	Для Каждого Стр Из ТаблицаДанных Цикл
		Попытка
			В = Истина;
			Попытка В = Стр.Выбрать; Исключение В = Истина; КонецПопытки;
			Если НЕ В Тогда
				Продолжить;
			КонецЕсли;
		Исключение
		КонецПопытки;
		КолВыб = КолВыб + 1;
		Если Стр.Статус = "Готов" Тогда
			КолГотов = КолГотов + 1;
		КонецЕсли;
	КонецЦикла;
	Если КолГотов = 0 Тогда
		Возврат "Нет строк со статусом «Готов» среди отмеченных. Отмечено: " + Строка(КолВыб);
	КонецЕсли;
	КолБ = Цел((КолГотов - 1) / РазмерБанча) + 1;
	ОцСек = КолГотов * СекНаСтр;
	Возврат "Строк «Готов»: " + Строка(КолГотов) + Символы.ПС
		+ "Размер банча: " + Строка(РазмерБанча) + " | Банчей: ~" + Строка(КолБ) + Символы.ПС
		+ "Сек. на строку: " + Формат(СекНаСтр, "ЧДЦ=1") + " | Оценка, сек: " + Формат(ОцСек, "ЧДЦ=0");
КонецФункции

&НаСервере
Функция СтрокаОтмеченаКЗагрузкеСервер(СтрокаТаблицы)
	Попытка
		Возврат СтрокаТаблицы.Выбрать;
	Исключение
		Возврат Истина;
	КонецПопытки;
КонецФункции

&НаСервере
Функция ТекстПрогнозаОставшегосяЭтап11(ПланСтрокГотов, ПопытокЗавершено, МоментСтартаЗагрузкиМс)
	Если ПланСтрокГотов <= 0 Тогда
		Возврат "план=0";
	КонецЕсли;
	ПрошлоСек = (ТекущаяУниверсальнаяДатаВМиллисекундах() - МоментСтартаЗагрузкиМс) / 1000;
	Если ПопытокЗавершено <= 0 Или ПрошлоСек <= 0 Тогда
		Возврат "статистика накопится после обработок";
	КонецЕсли;
	Сред = ПрошлоСек / ПопытокЗавершено;
	Ост  = ПланСтрокГотов - ПопытокЗавершено;
	Если Ост < 0 Тогда
		Ост = 0;
	КонецЕсли;
	Возврат "сред.сек/стр: " + Формат(Сред, "ЧДЦ=2") + " | осталось ~" + Строка(Ост) + " | ост.сек~ " + Формат(Ост * Сред, "ЧДЦ=0");
КонецФункции

&НаСервере
Процедура ЗагрузитьВБазуСервер(НачальноеВремя = Неопределено)
	Создано   = 0;
	Ошибок    = 0;
	Пропущено = 0;
	РазмерБанча = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("РазмерБанчаЗагрузки", 10);
	Если ТипЗнч(РазмерБанча) <> Тип("Число") Или РазмерБанча <= 0 Тогда
		РазмерБанча = 10;
	КонецЕсли;
	ПланГотов = 0;
	Для Каждого СтрП Из ТаблицаДанных Цикл
		Если НЕ СтрокаОтмеченаКЗагрузкеСервер(СтрП) Тогда
			Продолжить;
		КонецЕсли;
		Если СтрП.Статус = "Готов" Тогда
			ПланГотов = ПланГотов + 1;
		КонецЕсли;
	КонецЦикла;
	ПланБ = 0;
	Если ПланГотов > 0 Тогда
		ПланБ = Цел((ПланГотов - 1) / РазмерБанча) + 1;
	КонецЕсли;
	НомерБ     = 0;
	ВБанче     = 0;
	НачБ       = ТекущаяУниверсальнаяДатаВМиллисекундах();
	МоментСтарта = НачБ;
	Попыток    = 0;
	ИмяФ = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("ИмяФайла", "");
	ЗаписатьСтрокуВЛогЭтап11("СТАРТ | Файл: " + Строка(ИмяФ)
		+ " | К обработке (Готов): " + Строка(ПланГотов) + " | банч " + Строка(РазмерБанча) + " | план банчей ~" + Строка(ПланБ));

	Для Каждого Стр Из ТаблицаДанных Цикл
		Если НЕ СтрокаОтмеченаКЗагрузкеСервер(Стр) Тогда
			Продолжить;
		КонецЕсли;
		Если Стр.Статус <> "Готов" Тогда
			Пропущено = Пропущено + 1;
			Продолжить;
		КонецЕсли;
		Попыток = Попыток + 1;
		Попытка
			Созд = СоздатьПровестиЗаказИРеализациюПоСтроке(Стр);
			Стр.Статус = "Загружено";
			Стр.Комментарий = "Заказ: " + Строка(Созд.Заказ) + " | Реализация: " + Строка(Созд.Реализация)
				+ " | Счёт-фактура: " + Строка(Созд.СчетФактура) + " ";
			Создано = Создано + 1;
		Исключение
			Ошибок = Ошибок + 1;
			Стр.Статус = "Ошибка";
			Стр.Комментарий = Стр.Комментарий + "Ошибка: " + ОписаниеОшибки();
			ЗаписатьСтрокуВЛогЭтап11("ОШИБКА нстр " + Строка(Стр.НомерСтроки) + ": " + ОписаниеОшибки());
		КонецПопытки;
		ВБанче = ВБанче + 1;
		Если ВБанче >= РазмерБанча Тогда
			НомерБ = НомерБ + 1;
			Вр = (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачБ) / 1000;
			Пр = ТекстПрогнозаОставшегосяЭтап11(ПланГотов, Попыток, МоментСтарта);
			Св = "[Банч " + Строка(НомерБ) + "] Созд: " + Строка(Создано) + " | Ош: " + Строка(Ошибок)
				+ " | Сек: " + Формат(Вр, "ЧДЦ=2") + " | " + Пр;
			Сообщить(Св, СтатусСообщения.Информация);
			ЗаписатьСтрокуВЛогЭтап11(Св);
			ВБанче = 0;
			НачБ = ТекущаяУниверсальнаяДатаВМиллисекундах();
		КонецЕсли;
	КонецЦикла;

	Если ВБанче > 0 Тогда
		НомерБ = НомерБ + 1;
		Вр = (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачБ) / 1000;
		Св = "[Банч " + Строка(НомерБ) + " финал] Созд: " + Строка(Создано) + " | Ош: " + Строка(Ошибок) + " | Сек: " + Формат(Вр, "ЧДЦ=2");
		ЗаписатьСтрокуВЛогЭтап11(Св);
	КонецЕсли;
	Полное = (ТекущаяУниверсальнаяДатаВМиллисекундах() - МоментСтарта) / 1000;
	ЗаписатьСтрокуВЛогЭтап11("ФИНИШ | Создано: " + Строка(Создано) + " | Ошибок: " + Строка(Ошибок)
		+ " | Пропущено: " + Строка(Пропущено) + " | Сек: " + Формат(Полное, "ЧДЦ=2"));
КонецПроцедуры

#КонецОбласти
