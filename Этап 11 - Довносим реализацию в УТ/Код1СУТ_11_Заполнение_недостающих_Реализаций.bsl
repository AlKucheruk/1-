// Ссылка на предустановленный вариант «Реализация товаров и услуг» (и аналоги)
Функция НайтиСправочникВариантыОформленияПродажРеализацияТоваровУслуг()
	Мен = МенеджерСправочникаПоВариантуОформленияПродажи();
	Если Мен = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Мт = Новый Массив;
	Мт.Добавить("Реализация товаров и услуг");
	Мт.Добавить("Реализация товаров и услуг ");
	Мт.Добавить("Реализация");
	Попытка
		Для Каждого Тн Из Мт Цикл
			Тс = СокрЛП(Тн);
			Сл = Мен.НайтиПоНаименованию(Тс, Истина);
			Если ЗначениеЗаполнено(Сл) Тогда
				Возврат Сл;
			КонецЕсли;
			Сл = Мен.НайтиПоНаименованию(Тс, Ложь);
			Если ЗначениеЗаполнено(Сл) Тогда
				Возврат Сл;
			КонецЕсли;
		КонецЦикла;
	Исключение
	КонецПопытки;
	Попытка
		ИмяСпр = Мен.ПустаяСсылка().Метаданные().Имя;
		Зап = Новый Запрос;
		Зап.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Спр.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник." + ИмяСпр + " КАК Спр
		|ГДЕ
		|	НЕ Спр.ПометкаУдаления
		|	И Спр.Наименование ПОДОБНО &ПоШаблон";
		Зап.УстановитьПараметр("ПоШаблон", "%Реализация%товар%");
		Выб = Зап.Выполнить().Выбрать();
		Если Выб.Следующий() Тогда
			Возврат Выб.Ссылка;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Возврат Мен.ПустаяСсылка();
КонецФункции

