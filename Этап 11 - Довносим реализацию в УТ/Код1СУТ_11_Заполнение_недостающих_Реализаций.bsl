// Объект.Приоритет — тип из метаданных: перечисление или справочник (не угадываем имя перечисления).
Функция УстановитьПриоритетСреднийПоРеквизитуПриоритет_Метаданные(ДокЗаказ)
	МетРек = Неопределено;
	Попытка
		Для Каждого м Из Метаданные.Документы.ЗаказКлиента.Реквизиты Цикл
			Если м.Имя = "Приоритет" Тогда
				МетРек = м;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	Исключение
		Возврат Ложь;
	КонецПопытки;
	Если МетРек = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	ОТ = МетРек.Тип;
	Для Каждого КодТипа Из ОТ.Типы() Цикл
		Мето = Метаданные.НайтиПоТипу(КодТипа);
		Если Мето = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ПолИм = "";
		Попытка
			ПолИм = Мето.ПолноеИмя();
		Исключение
			Продолжить;
		КонецПопытки;
		Если СтрНайти(ПолИм, "Перечисление.") = 1 Тогда
			Для Каждого мз Из Мето.ЗначенияПеречисления Цикл
				нз = ВРег(мз.Имя);
				СтрСин = "";
				Попытка
					СтрСин = НРег(Строка(мз.Синоним));
				Исключение
					СтрСин = "";
				КонецПопытки;
				ЭтоСредний = (нз = "СРЕДНИЙ")
					Или (нз = "СРЕДНЯЯ")
					Или (нз = "СРЕДНЕЕ")
					Или (СтрСин <> "" И СтрНайти(СтрСин, "средн") > 0);
				Если ЭтоСредний Тогда
					Попытка
						ДокЗаказ.Приоритет = Вычислить("Перечисления." + Мето.Имя + "." + мз.Имя);
						Возврат Истина;
					Исключение
					КонецПопытки;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если СтрНайти(ПолИм, "Справочник.") = 1 Тогда
			Попытка
				Зап = Новый Запрос;
				Зап.Текст =
				"ВЫБРАТЬ ПЕРВЫЕ 1
				|	Спр.Ссылка КАК Ссылка
				|ИЗ
				|	Справочник." + Мето.Имя + " КАК Спр
				|ГДЕ
				|	(Спр.Наименование = &н1 Или Спр.Наименование = &н2)
				|	И НЕ Спр.ПометкаУдаления";
				Зап.УстановитьПараметр("н1", "Средний");
				Зап.УстановитьПараметр("н2", "Средняя");
				Вр = Зап.Выполнить().Выбрать();
				Если Вр.Следующий() Тогда
					Попытка
						ДокЗаказ.Приоритет = Вр.Ссылка;
						Возврат Истина;
					Исключение
					КонецПопытки;
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

