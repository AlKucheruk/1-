// Порядок: номенклатура → «Отгрузить»/даты отгрузки → упаковка → количество → цены/НДС/суммы.
Процедура ЗаполнитьСтрокуЗаказаТоварыОтгрузка(СтрТ, Ном, Кол, ДтДок, Знач Скл, ЗначениеСтавкиНДС, ЦенаСН, сБ, сН, СуммСНДС)

	ДтНач = НачалоДня(ДтДок);
	ЗнО = ЗначениеПеречисленияОтгрузитьДляЗаказа();

	СтрТ.Номенклатура = Ном;
	// Сначала действие/вариант обеспечения и даты (штатная логика УТ: иначе количество не «присваивается»)
	Если ЗнО <> Неопределено Тогда
		Попытка
			СтрТ.ВариантОбеспечения = ЗнО;
		Исключение
		КонецПопытки;
		Попытка
			СтрТ.Действие = ЗнО;
		Исключение
		КонецПопытки;
	КонецЕсли;
	// Если «Действие» в конфигурации — строка (не перечисление)
	Попытка
		Если НЕ ЗначениеЗаполнено(СтрТ.Действие) Тогда
			СтрТ.Действие = "Отгрузить";
		КонецЕсли;
	Исключение
	КонецПопытки;
	Попытка
		СтрТ.ДатаОтгрузки = ДтНач;
	Исключение
	КонецПопытки;
	Попытка
		СтрТ.ДатаСоСклада = ДтНач;
	Исключение
	КонецПопытки;
	Попытка
		СтрТ.ЖелаемаяДатаОтгрузки = ДтНач;
	Исключение
	КонецПопытки;

	Уп = УпаковкаНоменклатурыПоУмолчанию(Ном);
	Если ЗначениеЗаполнено(Уп) Тогда
		Попытка
			СтрТ.Упаковка = Уп;
		Исключение
		КонецПопытки;
	КонецЕсли;
	// Количество: и в «упаковках», и в базовой ед. (как в типовых формах)
	Попытка
		СтрТ.КоличествоУпаковок = Кол;
	Исключение
	КонецПопытки;
	Попытка
		СтрТ.Количество = Кол;
	Исключение
	КонецПопытки;
	// Если после упаковки требуется хранимое фактически кол-во
	Попытка
		Если СтрТ.Количество = 0 Тогда
			СтрТ.Количество = СтрТ.КоличествоУпаковок;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Попытка
		Если СтрТ.КоличествоУпаковок = 0 Тогда
			СтрТ.КоличествоУпаковок = Кол;
		КонецЕсли;
	Исключение
	КонецПопытки;

	СтрТ.СтавкаНДС  = ЗначениеСтавкиНДС;
	СтрТ.Цена       = ЦенаСН;
	СтрТ.Сумма      = сБ;
	СтрТ.СуммаНДС   = сН;
	СтрТ.СуммаСНДС = СуммСНДС;
	Попытка
		СтрТ.Склад = Скл;
	Исключение
	КонецПопытки;

КонецПроцедуры

#Область Счет_фактура_выданный_по_реализации

&НаСервере
// Явная связь СФ с РТУ: шапка + ТЧ «Документ*Основан*» (в типовой УТ основания часто в таблице, не в одном реквизите).
Процедура ПривязатьСчетФактуруКРеализации(СфДок, СсылкаРеализация)
	// Шапка: типовые имена
	Попытка
		СфДок.ДокументОснование = СсылкаРеализация;
	Исключение
	КонецПопытки;
	Попытка
		СфДок.ДокументОтгрузки = СсылкаРеализация;
	Исключение
	КонецПопытки;
	Попытка
		СфДок.ПервичныйДокумент = СсылкаРеализация;
	Исключение
	КонецПопытки;
	Попытка
		СфДок.ДокументПродажи = СсылкаРеализация;
	Исключение
	КонецПопытки;
	// Табличные части с основаниями: одна строка = РТУ
	Попытка
		МетД = Метаданные.Документы.СчетФактураВыданный;
		Для Каждого МетТч Из МетД.ТабличныеЧасти Цикл
			ИмТ = ВРег(МетТч.Имя);
			// «ДокументыОснования», «...Первичн...» и т.п.
			Если СтрНайти(ИмТ, "ОСНОВ") = 0 И СтрНайти(ИмТ, "ПЕРВИЧН") = 0 Тогда
				Продолжить;
			КонецЕсли;
			Попытка
				тч = СфДок[МетТч.Имя];
			Исключение
				Продолжить;
			КонецПопытки;
			// Не сбрасывать, если на основании УЖЕ подставилось из «Создать на основании» (иначе пустой ряд/потеря наполнения)
			ТипР = ТипЗнч(СсылкаРеализация);
			УжеСвязан = Ложь;
			Для Каждого Сб Из тч Цикл
				Для Каждого Мр0 Из МетТч.Реквизиты Цикл
					Попытка
						ОТ0 = Мр0.Тип;
						Если Не ОТ0.СодержитТип(ТипР) Тогда
							Продолжить;
						КонецЕсли;
						Зн = Сб[Мр0.Имя];
						Если Зн = СсылкаРеализация Тогда
							УжеСвязан = Истина;
						КонецЕсли;
					Исключение
					КонецПопытки;
					Если УжеСвязан Тогда
						Прервать;
					КонецЕсли;
				КонецЦикла;
				Если УжеСвязан Тогда
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если УжеСвязан Тогда
				Продолжить;
			КонецЕсли;
			тч.Очистить();
			Стр = тч.Добавить();
			Поставлен = Ложь;
			Для Каждого Мр Из МетТч.Реквизиты Цикл
				Попытка
					ОТ = Мр.Тип;
					// Составной тип: Типы() может не совпасть с «ДокументСсылка.Реализация...»; нужен СодержитТип
					Если Не ОТ.СодержитТип(ТипР) Тогда
						Продолжить;
					КонецЕсли;
					Стр[Мр.Имя] = СсылкаРеализация;
					Поставлен = Истина;
				Исключение
				КонецПопытки;
			КонецЦикла;
		КонецЦикла;
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервере
// 1) из контрагента; 2) с партнёра (в УТ ИНН/КПП нередко в карточке партнёра)
Функция ПолучитьИннКппПокупателя(Конт, Партнер)
	Сн = Новый Структура;
	Сн.Вставить("Инн", "");
	Сн.Вставить("Кпп", "");
	Попытка
		Если ЗначениеЗаполнено(Конт) Тогда
			Рк = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Конт, "ИНН, КПП");
			Сн.Инн = СокрЛП(Строка(Рк.ИНН));
			Сн.Кпп = СокрЛП(Строка(Рк.КПП));
		КонецЕсли;
	Исключение
	КонецПопытки;
	Попытка
		Если ЗначениеЗаполнено(Партнер) Тогда
			Рп = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Партнер, "ИНН, КПП");
			Если Сн.Инн = "" Тогда
				Сн.Инн = СокрЛП(Строка(Рп.ИНН));
			КонецЕсли;
			Если Сн.Кпп = "" Тогда
				Сн.Кпп = СокрЛП(Строка(Рп.КПП));
			КонецЕсли;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Возврат Сн;
КонецФункции

