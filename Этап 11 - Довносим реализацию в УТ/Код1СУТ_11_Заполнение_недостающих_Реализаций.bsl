// Реквизит «Приоритет» (Высокий/Средний/Низкий): ищем по метаданным документа, не угадывая имя перечисления.
Процедура УстановитьПриоритетЗаказаСредний(ДокЗаказ)
	Попытка
		Если УстановитьПриоритетСреднийПоРеквизитуПриоритет_Метаданные(ДокЗаказ) Тогда
			Возврат;
		КонецЕсли;
	Исключение
	КонецПопытки;
	//
	МетДок = Метаданные.Документы.ЗаказКлиента;
	Для Каждого МетРек Из МетДок.Реквизиты Цикл
		ИмяР = МетРек.Имя;
		Подх = (ВРег(ИмяР) = "ПРИОРИТЕТ");
		Если Не Подх Тогда
			Подх = (СтрНайти(ВРег(ИмяР), "ПРИОРИТ") > 0) Или (СтрНайти(ВРег(ИмяР), "СРОЧН") > 0) Или (СтрНайти(ВРег(ИмяР), "ВАЖН") > 0);
		КонецЕсли;
		Если Не Подх Тогда
			Попытка
				Син = Строка(МетРек.Синоним);
				Если Син <> "" Тогда
					Подх = (СтрНайти(ВРег(Син), "ПРИОРИТ") > 0);
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЕсли;
		Если Не Подх Тогда
			Продолжить;
		КонецЕсли;
		ОТ = МетРек.Тип;
		Для Каждого МетПер Из Метаданные.Перечисления Цикл
			Попытка
				ТестТип = Тип("ПеречислениеСсылка." + МетПер.Имя);
				Если Не ОТ.СодержитТип(ТестТип) Тогда
					Продолжить;
				КонецЕсли;
			Исключение
				Продолжить;
			КонецПопытки;
			Для Каждого МетЗн Из МетПер.ЗначенияПеречисления Цикл
				нз = ВРег(МетЗн.Имя);
				Если нз = "СРЕДНИЙ" Или нз = "СРЕДНЯЯ" Тогда
					Попытка
						ДокЗаказ[ИмяР] = Вычислить("Перечисления." + МетПер.Имя + "." + МетЗн.Имя);
						Возврат;
					Исключение
					КонецПопытки;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	// Второй проход: реквизит с «чужим» именем, но перечисление с тройкой, как в подписи формы
	Для Каждого МетРек2 Из МетДок.Реквизиты Цикл
		ИмяР2  = МетРек2.Имя;
		ОТ2    = МетРек2.Тип;
		Для Каждого МетПер2 Из Метаданные.Перечисления Цикл
			Попытка
				ТестТип2 = Тип("ПеречислениеСсылка." + МетПер2.Имя);
				Если Не ОТ2.СодержитТип(ТестТип2) Тогда
					Продолжить;
				КонецЕсли;
			Исключение
				Продолжить;
			КонецПопытки;
			Если Не ПеречислениеПохожеНаВысокийСреднийНизкий(МетПер2) Тогда
				Продолжить;
			КонецЕсли;
			Для Каждого МетЗн2 Из МетПер2.ЗначенияПеречисления Цикл
				нз2 = ВРег(МетЗн2.Имя);
				Если нз2 = "СРЕДНИЙ" Или нз2 = "СРЕДНЯЯ" Тогда
					Попытка
						ДокЗаказ[ИмяР2] = Вычислить("Перечисления." + МетПер2.Имя + "." + МетЗн2.Имя);
						Возврат;
					Исключение
					КонецПопытки;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	// Запас: жёсткое «Приоритет» и типовой перечислитель
	Спис = Новый Массив;
	Спис.Добавить("Перечисления.Приоритеты.Средний");
	Спис.Добавить("Перечисления.ПриоритетыЗаказа.Средний");
	Спис.Добавить("Перечисления.ВажностьЗаказа.Средний");
	Спис.Добавить("Перечисления.Срочность.Средняя");
	Спис.Добавить("Перечисления.Срочность.Средний");
	Спис.Добавить("Перечисления.Важность.Средняя");
	Спис.Добавить("Перечисления.Важность.Средний");
	Для Каждого СтрП Из Спис Цикл
		Попытка
			ДокЗаказ.Приоритет = Вычислить(СтрП);
			Возврат;
		Исключение
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

