				КонецПопытки;
			КонецЕсли;
		КонецЦикла;
	Исключение
	КонецПопытки;
	// Резерв: по имени справочника в метаданных (другая поставка)
	Попытка
		Для Каждого СО Из Метаданные.Справочники Цикл
