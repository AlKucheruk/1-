// В типовой УТ 11.4+ реквизит — часто ПЕРЕЧИСЛЕНИЕ (список: РеализацияТоваровУслуг, АктНаПередачуПрав), не справочник.
Функция ЗначениеПеречисленияВариантОформленияРеализация(Мето)
	// Мето — ОбъектМетаданных: Перечисление; нужное значение — «Реализация…», не «Акт…»
	ИмяПер = Мето.Имя;
	// Идентификаторы в конфигураторе (см. список выбора формы), плюс распространённые варианты написания
	Пред = Новый Массив;
	Пред.Добавить("РеализацияТоваровУслуг");
	Пред.Добавить("RealizaciyaTovarovUslug");
	Пред.Добавить("TovaryIUslug");
	Для Каждого ид Из Пред Цикл
		Попытка
			Зап = Новый Запрос;
			Зап.Текст =
			"ВЫБРАТЬ
			|	ЗНАЧЕНИЕ(Перечисление." + ИмяПер + "." + ид + ") КАК Зн";
			рз = Зап.Выполнить().Выбрать();
			Если рз.Следующий() Тогда
				Возврат рз.Зн;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЦикла;
	// По метаданным: пропустить «АктНа…», взять первый «релевантный» (обычно одно остаётся)
	Попытка
		Для Каждого мз Из Мето.ЗначенияПеречисления Цикл
			н = ВРег(мз.Имя);
			// «Акт на передачу прав» — не тот вариант
			Если н = "АКТНАПЕРЕДАЧУПРАВ" Или н = "AKTNAPEREDACHUPRAV" Тогда
				Продолжить;
			КонецЕсли;
			Если СтрНайти(н, "АКТ") > 0 И СтрНайти(н, "ПРАВ") > 0 Тогда
				Продолжить;
			КонецЕсли;
			Если СтрНайти(н, "ACT") = 1 Или (СтрНайти(н, "AKT") > 0 И СтрНайти(н, "PRAV") > 0) Тогда
				Продолжить;
			КонецЕсли;
			Попытка
				Зап = Новый Запрос;
				Зап.Текст =
				"ВЫБРАТЬ
				|	ЗНАЧЕНИЕ(Перечисление." + ИмяПер + "." + мз.Имя + ") КАК Зн";
				рз = Зап.Выполнить().Выбрать();
				Если рз.Следующий() Тогда
					Возврат рз.Зн;
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЦикла;
	Исключение
	КонецПопытки;
	Возврат Неопределено;
КонецФункции

