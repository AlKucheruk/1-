// Упаковка/ед. изм. по умолчанию для номенклатуры (нужна для «Количество»/«КоличествоУпаковок»).
Функция УпаковкаНоменклатурыПоУмолчанию(СсылкаНом)
	// Поиск первой не помеченной на удаление упаковки по владельцу-номенклатуре.
	Пуст = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
	Попытка
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	У.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.УпаковкиЕдиницыИзмерения КАК У
		|ГДЕ
		|	У.Владелец = &Ном
		|	И НЕ У.ПометкаУдаления
		|УПОРЯДОЧИТЬ ПО
		|	У.Коэффициент,
		|	У.Наименование";
		Запрос.УстановитьПараметр("Ном", СсылкаНом);
		Вк = Запрос.Выполнить().Выбрать();
