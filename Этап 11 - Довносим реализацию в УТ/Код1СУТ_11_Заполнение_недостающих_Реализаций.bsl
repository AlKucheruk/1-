// Флажок «Реализация по заказу» (вкладка Основной) — без него УТ ведёт себя как отгрузка без заказа (лишние «Статус» и т.д.).
Процедура УстановитьРежимРеализацияПоЗаказу(Р)
	Попытка
		Р.РеализацияПоЗаказам = Истина;
		Возврат;
	Исключение
	КонецПопытки;
	Попытка
		Р.РеализацияПоЗаказу = Истина;
		Возврат;
	Исключение
	КонецПопытки;
	Попытка
		МетДок = Метаданные.Документы.РеализацияТоваровУслуг;
		Для Каждого МетРек Из МетДок.Реквизиты Цикл
			Попытка
				Если Не МетРек.Тип.СодержитТип(Тип("Булево")) Тогда
					Продолжить;
				КонецЕсли;
			Исключение
				Продолжить;
			КонецПопытки;
			н = ВРег(МетРек.Имя);
			Если СтрНайти(н, "РЕАЛИЗ") = 0 Тогда
				Продолжить;
			КонецЕсли;
			Если СтрНайти(н, "ЗАКАЗ") = 0 Тогда
				Продолжить;
			КонецЕсли;
			Если СтрНайти(н, "ПО") = 0 Тогда
				Продолжить;
			КонецЕсли;
			Попытка
				Р[МетРек.Имя] = Истина;
				Возврат;
			Исключение
			КонецПопытки;
		КонецЦикла;
	Исключение
	КонецПопытки;
КонецПроцедуры

