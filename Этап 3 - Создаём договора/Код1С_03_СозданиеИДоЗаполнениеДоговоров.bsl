// BSLLS-off
// =============================================================================
// Внешняя обработка: Этап 3 - Создание и аудит договоров контрагентов
// Назначение:
//   1) Загрузить из Excel список контрагентов (Наименование, ИНН, КПП, Код).
//   2) Найти контрагентов в УТ, заполнить предпросмотр и дать выбрать строки.
//   3) Проверить/создать договоры Реализации/Закупки и привести поля к стандарту.
//
// РЕКВИЗИТЫ ФОРМЫ (создать вручную в конфигураторе):
//
//   ПутьКФайлуExcel - Строка(500)
//   ИнфоТаймер      - Строка(500)
//
//   ТаблицаПредварительныхДанных - ТаблицаЗначений:
//     Обработать                  - Булево
//     НаименованиеКонтрагента     - Строка(250)
//     ИНН                         - Строка(12)
//     КПП                         - Строка(9)
//     Код                         - Строка(30)
//     Контрагент                  - СправочникСсылка.Контрагенты
//     Клиент                      - Строка(3)   // Да/Нет
//     Поставщик                   - Строка(3)   // Да/Нет
//     ПометкаУдалКонтрагента      - Строка(3)   // Да/Нет
//     Комментарий                 - Строка(1000)
//
// КОМАНДЫ ФОРМЫ:
//   ЗагрузитьДанныеИзExcel
//   ОбновитьДанныеВ1С
//   ВыделитьВсе
//   СнятьВсе
//
// ЛОГИРОВАНИЕ:
//   - Перед стартом каждой сессии обработки в лог добавляются 2 пустые строки.
//   - В конце сессии формируется отдельный блок "Контрагенты с ошибками" для ручной доработки.
//   - Формат строки ошибки: "Клиент <Наименование> | ИНН <ИНН> | обновление договора не состоялось. <Причина>".
// =============================================================================

#Область Инициализация

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

    Если НЕ ЗначениеЗаполнено(ПутьКФайлуExcel) Тогда
        ПутьКФайлуExcel = "";
    КонецЕсли;
    
    ИнфоТаймер = "Готово к загрузке данных";

КонецПроцедуры

#КонецОбласти // Инициализация

#Область КомандыФормы

&НаКлиенте
Процедура ЗагрузитьДанныеИзExcel(Команда)

    ДиалогОткрытия = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
    ДиалогОткрытия.Заголовок = "Выберите файл Excel (Лист_1)";
    ДиалогОткрытия.Фильтр = "Файлы Excel (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*";
    ДиалогОткрытия.МножественныйВыбор = Ложь;
    
    Если ЗначениеЗаполнено(ПутьКФайлуExcel) Тогда
        ДиалогОткрытия.ПолноеИмяФайла = ПутьКФайлуExcel;
    КонецЕсли;
    
    Если НЕ ДиалогОткрытия.Выбрать() Тогда
        Возврат;
    КонецЕсли;
    
    ПутьКФайлуExcel = ДиалогОткрытия.ПолноеИмяФайла;
    
    ВремяНачалаКлиент = ТекущаяДата();
    МассивСтрок = ПрочитатьExcelНаКлиенте(ПутьКФайлуExcel);
    Если МассивСтрок = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    СекундExcelНаКлиенте = ТекущаяДата() - ВремяНачалаКлиент;
    ЗагрузитьДанныеИзExcelНаСервере(МассивСтрок, ПутьКФайлуExcel, СекундExcelНаКлиенте);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеВ1С(Команда)

    КоличествоКОбработке = 0;
    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        Если СтрокаТаблицы.Обработать Тогда
            КоличествоКОбработке = КоличествоКОбработке + 1;
        КонецЕсли;
    КонецЦикла;
    
    Если КоличествоКОбработке = 0 Тогда
        Сообщить("Нет отмеченных строк для обработки.");
        Возврат;
    КонецЕсли;
    
    ТекстВопроса = "Будет обработано строк: " + Строка(КоличествоКОбработке) + ". Продолжить?";
    Если Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
        Возврат;
    КонецЕсли;
    
    ОбновитьДанныеВ1СНаСервере();
    
КонецПроцедуры

&НаКлиенте
Процедура ВыделитьВсе(Команда)

    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        СтрокаТаблицы.Обработать = Истина;
    КонецЦикла;
    
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсе(Команда)

    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        СтрокаТаблицы.Обработать = Ложь;
    КонецЦикла;
    
КонецПроцедуры

#КонецОбласти // КомандыФормы

#Область ЗагрузкаИзExcel

&НаКлиенте
Функция ПрочитатьExcelНаКлиенте(ПутьКФайлу) // BSLLS:CognitiveComplexity-off

    ОжидаемыеКолонки = Новый Массив;
    ОжидаемыеКолонки.Добавить("НаименованиеКонтрагента");
    ОжидаемыеКолонки.Добавить("ИНН");
    ОжидаемыеКолонки.Добавить("КПП");
    ОжидаемыеКолонки.Добавить("Код");
    
    Excel = Неопределено;
    Книга = Неопределено;
    
    Попытка
        Excel = Новый COMОбъект("Excel.Application");
        Excel.Visible = Ложь;
        Excel.DisplayAlerts = Ложь;
        
        Книга = Excel.Workbooks.Open(ПутьКФайлу);
        Лист = Книга.Sheets(1); // ожидается Лист_1
        
        Диапазон = Лист.UsedRange;
        КолСтрок = Диапазон.Rows.Count;
        КолКолонок = Диапазон.Columns.Count;
        НачСтрока = Диапазон.Row;
        НачКолонка = Диапазон.Column;
        
        СоответствиеКолонок = Новый Соответствие;
        Для Инд = 0 По КолКолонок - 1 Цикл
            НомерКолонки = НачКолонка + Инд;
            Заголовок = СокрЛП(Строка(Лист.Cells(НачСтрока, НомерКолонки).Text));
            Если ЗначениеЗаполнено(Заголовок) Тогда
                СоответствиеКолонок.Вставить(Заголовок, НомерКолонки);
            КонецЕсли;
        КонецЦикла;
        
        Для Каждого ИмяКолонки Из ОжидаемыеКолонки Цикл
            Если СоответствиеКолонок.Получить(ИмяКолонки) = Неопределено Тогда
                Книга.Close(Ложь);
                Excel.Quit();
                Сообщить("В файле отсутствует обязательная колонка: " + ИмяКолонки);
                Возврат Неопределено;
            КонецЕсли;
        КонецЦикла;
        
        Результат = Новый Массив;
        КонечнаяСтрока = НачСтрока + КолСтрок - 1;
        
        Для НомСтроки = НачСтрока + 1 По КонечнаяСтрока Цикл
            СтрокаExcel = Новый Структура;
            Для Каждого ИмяКолонки Из ОжидаемыеКолонки Цикл
                НомерКолонки = СоответствиеКолонок[ИмяКолонки];
                ЗначениеЯчейки = СокрЛП(Строка(Лист.Cells(НомСтроки, НомерКолонки).Text));
                СтрокаExcel.Вставить(ИмяКолонки, ЗначениеЯчейки);
            КонецЦикла;
            
            // Пустые строки пропускаем
            Если НЕ ЗначениеЗаполнено(СтрокаExcel.Код)
                И НЕ ЗначениеЗаполнено(СтрокаExcel.ИНН)
                И НЕ ЗначениеЗаполнено(СтрокаExcel.НаименованиеКонтрагента) Тогда
                Продолжить;
            КонецЕсли;
            
            Результат.Добавить(СтрокаExcel);
        КонецЦикла;
        
        Книга.Close(Ложь);
        Excel.Quit();
        
        Возврат Результат;
        
    Исключение
        ТекстОшибки = ОписаниеОшибки();
        Попытка
            Если Книга <> Неопределено Тогда
                Книга.Close(Ложь);
            КонецЕсли;
            Если Excel <> Неопределено Тогда
                Excel.Quit();
            КонецЕсли;
        Исключение // BSLLS:MissingCodeTryCatchEx-off
        КонецПопытки;
        Сообщить("Ошибка чтения Excel: " + ТекстОшибки);
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

&НаСервере
Процедура ЗагрузитьДанныеИзExcelНаСервере(МассивСтрок, ПутьКФайлу, СекундExcelНаКлиенте = 0)

    ВремяНачалаСервер = ТекущаяДатаСеанса();
    ЗаписатьЛог("=== Загрузка данных из Excel ===");
    ЗаписатьЛог("Файл: " + ПутьКФайлу);
    
    ТаблицаПредварительныхДанных.Очистить();
    
    // 1) Заполняем таблицу формы
    Для Каждого СтрокаExcel Из МассивСтрок Цикл
        СтрокаТаблицы = ТаблицаПредварительныхДанных.Добавить();
        СтрокаТаблицы.Обработать = Истина;
        СтрокаТаблицы.НаименованиеКонтрагента = СтрокаExcel.НаименованиеКонтрагента;
        СтрокаТаблицы.ИНН = СтрокаExcel.ИНН;
        СтрокаТаблицы.КПП = СтрокаExcel.КПП;
        СтрокаТаблицы.Код = СтрокаExcel.Код;
        СтрокаТаблицы.Контрагент = Справочники.Контрагенты.ПустаяСсылка();
        СтрокаТаблицы.Клиент = "Нет";
        СтрокаТаблицы.Поставщик = "Нет";
        СтрокаТаблицы.ПометкаУдалКонтрагента = "";
        СтрокаТаблицы.Комментарий = "";
    КонецЦикла;
    
    // 2) Пакетный поиск контрагентов
    ЗаполнитьКонтрагентовИПризнаки();
    
    СекундСервер = ТекущаяДатаСеанса() - ВремяНачалаСервер;
    СекундВсего = СекундExcelНаКлиенте + СекундСервер;
    
    ИнфоТаймер = "Excel: " + Строка(СекундExcelНаКлиенте) + " сек; Сервер: "
        + Строка(СекундСервер) + " сек; Итого: " + Строка(СекундВсего) + " сек";
    
    ЗаписатьЛог("Строк загружено: " + Строка(ТаблицаПредварительныхДанных.Количество()));
    ЗаписатьЛог(ИнфоТаймер);
    Сообщить("Данные загружены. " + ИнфоТаймер);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКонтрагентовИПризнаки()

    МассивКодов = Новый Массив;
    МассивИНН = Новый Массив;
    
    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        Если ЗначениеЗаполнено(СтрокаТаблицы.Код) Тогда
            МассивКодов.Добавить(СокрЛП(СтрокаТаблицы.Код));
        КонецЕсли;
        Если ЗначениеЗаполнено(СтрокаТаблицы.ИНН) Тогда
            МассивИНН.Добавить(СокрЛП(СтрокаТаблицы.ИНН));
        КонецЕсли;
    КонецЦикла;
    
    СоответствиеПоКоду = ПолучитьСоответствиеКонтрагентовПоКодам(МассивКодов);
    СоответствиеПоИННКПП = ПолучитьСоответствиеКонтрагентовПоИННКПП(МассивИНН);
    
    // Собираем все найденные ссылки, чтобы одной пачкой получить признаки
    МассивСсылокКонтрагентов = Новый Массив;
    
    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        
        КонтрагентСсылка = Неопределено;
        
        Если ЗначениеЗаполнено(СтрокаТаблицы.Код) Тогда
            КонтрагентСсылка = СоответствиеПоКоду.Получить(СокрЛП(СтрокаТаблицы.Код));
        КонецЕсли;
        
        Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) И ЗначениеЗаполнено(СтрокаТаблицы.ИНН) Тогда
            КлючИННКПП = СокрЛП(СтрокаТаблицы.ИНН) + "|" + СокрЛП(СтрокаТаблицы.КПП);
            КонтрагентСсылка = СоответствиеПоИННКПП.Получить(КлючИННКПП);
        КонецЕсли;
        
        Если ЗначениеЗаполнено(КонтрагентСсылка) Тогда
            СтрокаТаблицы.Контрагент = КонтрагентСсылка;
            МассивСсылокКонтрагентов.Добавить(КонтрагентСсылка);
        Иначе
            СтрокаТаблицы.Комментарий = "Контрагент не найден";
            СтрокаТаблицы.Обработать = Ложь;
        КонецЕсли;
        
    КонецЦикла;
    
    АтрибутыКонтрагентов = ПолучитьАтрибутыКонтрагентов(МассивСсылокКонтрагентов);
    
    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Контрагент) Тогда
            Продолжить;
        КонецЕсли;
        
        Атрибуты = АтрибутыКонтрагентов.Получить(СтрокаТаблицы.Контрагент);
        Если Атрибуты = Неопределено Тогда
            СтрокаТаблицы.Комментарий = "Контрагент найден, но признаки не прочитаны";
            СтрокаТаблицы.Обработать = Ложь;
            Продолжить;
        КонецЕсли;
        
        СтрокаТаблицы.Клиент = ?(Атрибуты.Клиент, "Да", "Нет");
        СтрокаТаблицы.Поставщик = ?(Атрибуты.Поставщик, "Да", "Нет");
        СтрокаТаблицы.ПометкаУдалКонтрагента = ?(Атрибуты.ПометкаУдаления, "Да", "Нет");
        
        Если Атрибуты.ПометкаУдаления Тогда
            СтрокаТаблицы.Комментарий = "Контрагент помечен на удаление";
            СтрокаТаблицы.Обработать = Ложь;
        КонецЕсли;
    КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ПолучитьСоответствиеКонтрагентовПоКодам(МассивКодов)

    Результат = Новый Соответствие;
    Если МассивКодов.Количество() = 0 Тогда
        Возврат Результат;
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   Партнеры.Код КАК Код,
        |   Контрагенты.Ссылка КАК Контрагент
        |ИЗ
        |   Справочник.Партнеры КАК Партнеры
        |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
        |       ПО Контрагенты.Партнер = Партнеры.Ссылка
        |ГДЕ
        |   Партнеры.Код В (&МассивКодов)
        |   И НЕ Партнеры.ПометкаУдаления
        |   И НЕ Контрагенты.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("МассивКодов", МассивКодов);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Если Результат.Получить(Выборка.Код) = Неопределено Тогда
            Результат.Вставить(Выборка.Код, Выборка.Контрагент);
        КонецЕсли;
    КонецЦикла;
    
    Возврат Результат;

КонецФункции

&НаСервере
Функция ПолучитьСоответствиеКонтрагентовПоИННКПП(МассивИНН)

    Результат = Новый Соответствие;
    Если МассивИНН.Количество() = 0 Тогда
        Возврат Результат;
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   Контрагенты.ИНН КАК ИНН,
        |   Контрагенты.КПП КАК КПП,
        |   Контрагенты.Ссылка КАК Контрагент
        |ИЗ
        |   Справочник.Контрагенты КАК Контрагенты
        |ГДЕ
        |   Контрагенты.ИНН В (&МассивИНН)
        |   И НЕ Контрагенты.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("МассивИНН", МассивИНН);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Ключ = СокрЛП(Выборка.ИНН) + "|" + СокрЛП(Выборка.КПП);
        Если Результат.Получить(Ключ) = Неопределено Тогда
            Результат.Вставить(Ключ, Выборка.Контрагент);
        КонецЕсли;
    КонецЦикла;
    
    Возврат Результат;

КонецФункции

&НаСервере
Функция ПолучитьАтрибутыКонтрагентов(МассивСсылокКонтрагентов)

    Результат = Новый Соответствие;
    Если МассивСсылокКонтрагентов.Количество() = 0 Тогда
        Возврат Результат;
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   Контрагенты.Ссылка КАК Контрагент,
        |   Контрагенты.ПометкаУдаления КАК ПометкаУдаления,
        |   ЕСТЬNULL(Партнеры.Клиент, ЛОЖЬ) КАК Клиент,
        |   ЕСТЬNULL(Партнеры.Поставщик, ЛОЖЬ) КАК Поставщик
        |ИЗ
        |   Справочник.Контрагенты КАК Контрагенты
        |       ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
        |       ПО Контрагенты.Партнер = Партнеры.Ссылка
        |ГДЕ
        |   Контрагенты.Ссылка В (&Ссылки)";
    
    Запрос.УстановитьПараметр("Ссылки", МассивСсылокКонтрагентов);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        СтруктАтрибутов = Новый Структура;
        СтруктАтрибутов.Вставить("ПометкаУдаления", Выборка.ПометкаУдаления);
        СтруктАтрибутов.Вставить("Клиент", Выборка.Клиент);
        СтруктАтрибутов.Вставить("Поставщик", Выборка.Поставщик);
        Результат.Вставить(Выборка.Контрагент, СтруктАтрибутов);
    КонецЦикла;
    
    Возврат Результат;

КонецФункции

#КонецОбласти // ЗагрузкаИзExcel

#Область ОбновлениеДоговоров

&НаСервере
Процедура ОбновитьДанныеВ1СНаСервере() // BSLLS:CognitiveComplexity-off

    ВремяНачала = ТекущаяДатаСеанса();
    ЗаписатьПустыеСтрокиВЛог(2);
    ЗаписатьЛог("=== Старт обновления договоров ===");
    
    МенеджерСсылка = ПолучитьМенеджераКучерук();
    Если НЕ ЗначениеЗаполнено(МенеджерСсылка) Тогда
        ЗаписатьЛог("КРИТИЧЕСКАЯ ОШИБКА: менеджер 'Кучерук Алексей Александрович' не найден");
        Сообщить("Менеджер 'Кучерук Алексей Александрович' не найден. Обработка остановлена.");
        Возврат;
    КонецЕсли;
    
    СтатьяДДС_Реализация = ПолучитьСтатьюДДС("Поступление оплаты от клиента");
    СтатьяДДС_Закупка = ПолучитьСтатьюДДС("Оплата поставщику");
    БанковскийСчетОрганизацииВТБ = ПолучитьБанковскийСчетОрганизацииВТБ();
    Если НЕ ЗначениеЗаполнено(БанковскийСчетОрганизацииВТБ) Тогда
        ЗаписатьЛог("КРИТИЧЕСКАЯ ОШИБКА: не найден банковский счет организации с наименованием 'ВТБ'");
        Сообщить("Не найден банковский счет организации 'ВТБ'. Обработка остановлена.");
        Возврат;
    КонецЕсли;
    
    // Пакетно читаем договоры контрагентов в кэш, чтобы не дергать БД на каждую строку.
    МассивКонтрагентовКОбработке = Новый Массив;
    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        Если СтрокаТаблицы.Обработать И ЗначениеЗаполнено(СтрокаТаблицы.Контрагент) Тогда
            МассивКонтрагентовКОбработке.Добавить(СтрокаТаблицы.Контрагент);
        КонецЕсли;
    КонецЦикла;
    КэшДоговоров = ПолучитьДоговорыКонтрагентовПакетом(МассивКонтрагентовКОбработке);
    
    ОбработаноСтрок = 0;
    ОшибокСтрок = 0;
    СозданоДоговоров = 0;
    ОбновленоДоговоров = 0;
    БезИзменений = 0;
    МассивОшибокКонтрагентов = Новый Массив;
    
    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        Если НЕ СтрокаТаблицы.Обработать Тогда
            Продолжить;
        КонецЕсли;
        
        ОбработаноСтрок = ОбработаноСтрок + 1;
        ВремяСтроки = ТекущаяДатаСеанса();
        
        Попытка
            Рез = ОбработатьСтрокуКонтрагента(
                СтрокаТаблицы,
                МенеджерСсылка,
                СтатьяДДС_Реализация,
                СтатьяДДС_Закупка,
                КэшДоговоров,
                БанковскийСчетОрганизацииВТБ
            );
            
            СозданоДоговоров = СозданоДоговоров + Рез.Создано;
            ОбновленоДоговоров = ОбновленоДоговоров + Рез.Обновлено;
            БезИзменений = БезИзменений + Рез.БезИзменений;
            
            СекундСтроки = ТекущаяДатаСеанса() - ВремяСтроки;
            СтрокаТаблицы.Комментарий = ?(Рез.Ошибок > 0, "Частично с ошибками. ", "OK. ")
                + "Создано=" + Строка(Рез.Создано)
                + ", Обновлено=" + Строка(Рез.Обновлено)
                + ", Без изменений=" + Строка(Рез.БезИзменений)
                + ", Ошибок=" + Строка(Рез.Ошибок)
                + ". Время: " + Строка(СекундСтроки) + " сек";
            
            Если Рез.Ошибок = 0 Тогда
                СтрокаТаблицы.Обработать = Ложь;
            Иначе
                ОшибокСтрок = ОшибокСтрок + 1;
                МассивОшибокКонтрагентов.Добавить(
                    СформироватьСтрокуПроблемногоКонтрагента(
                        СтрокаТаблицы,
                        "Ошибок в строке: " + Строка(Рез.Ошибок)
                    )
                );
            КонецЕсли;
            
            ЗаписатьЛог("Строка OK: " + СтрокаТаблицы.НаименованиеКонтрагента
                + " | " + СтрокаТаблицы.Комментарий);
            
        Исключение
            ОшибокСтрок = ОшибокСтрок + 1;
            СтрокаТаблицы.Комментарий = "Ошибка: " + ОписаниеОшибки();
            ЗаписатьЛог("ОШИБКА строки [" + СтрокаТаблицы.НаименованиеКонтрагента + "]: "
                + ОписаниеОшибки());
            МассивОшибокКонтрагентов.Добавить(
                СформироватьСтрокуПроблемногоКонтрагента(СтрокаТаблицы, ОписаниеОшибки())
            );
        КонецПопытки;
    КонецЦикла;
    
    Если МассивОшибокКонтрагентов.Количество() > 0 Тогда
        ЗаписатьПустыеСтрокиВЛог(2);
        ЗаписатьЛог("=== Контрагенты с ошибками (для ручной доработки) ===");
        Для Каждого СтрокаОшибки Из МассивОшибокКонтрагентов Цикл
            ЗаписатьЛог(СтрокаОшибки);
        КонецЦикла;
    КонецЕсли;
    
    СекундВсего = ТекущаяДатаСеанса() - ВремяНачала;
    ИнфоТаймер = "Обработано строк: " + Строка(ОбработаноСтрок)
        + ", Создано договоров: " + Строка(СозданоДоговоров)
        + ", Обновлено договоров: " + Строка(ОбновленоДоговоров)
        + ", Без изменений: " + Строка(БезИзменений)
        + ", Ошибок строк: " + Строка(ОшибокСтрок)
        + ", Время: " + Строка(СекундВсего) + " сек";
    
    ЗаписатьЛог(ИнфоТаймер);
    Сообщить("Обновление завершено. " + ИнфоТаймер);

КонецПроцедуры

&НаСервере
Функция СформироватьСтрокуПроблемногоКонтрагента(СтрокаТаблицы, Причина)

    Наименование = СокрЛП(Строка(СтрокаТаблицы.НаименованиеКонтрагента));
    ИНН = СокрЛП(Строка(СтрокаТаблицы.ИНН));
    Если Наименование = "" Тогда
        Наименование = "<без наименования>";
    КонецЕсли;
    Если ИНН = "" Тогда
        ИНН = "<без ИНН>";
    КонецЕсли;
    
    Возврат "Клиент " + Наименование
        + " | ИНН " + ИНН
        + " | обновление договора не состоялось. "
        + СокрЛП(Строка(Причина));

КонецФункции

&НаСервере
Функция ОбработатьСтрокуКонтрагента(
    СтрокаТаблицы,
    МенеджерСсылка,
    СтатьяДДС_Реализация,
    СтатьяДДС_Закупка,
    КэшДоговоров,
    БанковскийСчетОрганизацииВТБ)

    Результат = Новый Структура;
    Результат.Вставить("Создано", 0);
    Результат.Вставить("Обновлено", 0);
    Результат.Вставить("БезИзменений", 0);
    Результат.Вставить("Ошибок", 0);
    
    Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Контрагент) Тогда
        ВызватьИсключение "Контрагент не заполнен";
    КонецЕсли;
    
    КонтрагентСсылка = СтрокаТаблицы.Контрагент;
    МассивДоговоров = КэшДоговоров.Получить(КонтрагентСсылка);
    Если МассивДоговоров = Неопределено Тогда
        МассивДоговоров = Новый Массив;
    КонецЕсли;
    
    ОбрабатыватьКакКлиента = НРег(СтрокаТаблицы.Клиент) = "да";
    ОбрабатыватьКакПоставщика = НРег(СтрокаТаблицы.Поставщик) = "да";
    
    Если НЕ ОбрабатыватьКакКлиента И НЕ ОбрабатыватьКакПоставщика Тогда
        Для Каждого СтруктДог Из МассивДоговоров Цикл
            Если СтруктДог.ТипДоговора = Перечисления.ТипыДоговоров.СПокупателем Тогда
                ОбрабатыватьКакКлиента = Истина;
            КонецЕсли;
            Если СтруктДог.ТипДоговора = Перечисления.ТипыДоговоров.СПоставщиком Тогда
                ОбрабатыватьКакПоставщика = Истина;
            КонецЕсли;
        КонецЦикла;
        
        Если НЕ ОбрабатыватьКакКлиента И НЕ ОбрабатыватьКакПоставщика Тогда
            ОбрабатыватьКакКлиента = Истина;
            ЗаписатьЛог("Fallback: контрагент '" + СтрокаТаблицы.НаименованиеКонтрагента
                + "' без флагов Клиент/Поставщик и без договоров, обрабатываем как Клиента.");
        Иначе
            ЗаписатьЛог("Fallback: контрагент '" + СтрокаТаблицы.НаименованиеКонтрагента
                + "' обработка по типам найденных договоров.");
        КонецЕсли;
    КонецЕсли;
    
    Если ОбрабатыватьКакКлиента Тогда
        ОбработатьДоговорыТипа(
            КонтрагентСсылка,
            МассивДоговоров,
            Перечисления.ТипыДоговоров.СПокупателем,
            "Реализация",
            МенеджерСсылка,
            СтатьяДДС_Реализация,
            Результат,
            БанковскийСчетОрганизацииВТБ
        );
    КонецЕсли;
    
    Если ОбрабатыватьКакПоставщика Тогда
        ОбработатьДоговорыТипа(
            КонтрагентСсылка,
            МассивДоговоров,
            Перечисления.ТипыДоговоров.СПоставщиком,
            "Закупка",
            МенеджерСсылка,
            СтатьяДДС_Закупка,
            Результат,
            БанковскийСчетОрганизацииВТБ
        );
    КонецЕсли;
    
    Возврат Результат;

КонецФункции

&НаСервере
Функция ПолучитьДоговорыКонтрагентовПакетом(МассивКонтрагентов)

    Результат = Новый Соответствие;
    
    Если МассивКонтрагентов.Количество() = 0 Тогда
        Возврат Результат;
    КонецЕсли;
    
    // Подготовим пустые массивы заранее, чтобы даже для контрагентов без договоров был кэш-ключ.
    Для Каждого КонтрагентСсылка Из МассивКонтрагентов Цикл
        Если Результат.Получить(КонтрагентСсылка) = Неопределено Тогда
            Результат.Вставить(КонтрагентСсылка, Новый Массив);
        КонецЕсли;
    КонецЦикла;
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   Договоры.Контрагент КАК Контрагент,
        |   Договоры.Ссылка КАК Ссылка,
        |   Договоры.ТипДоговора КАК ТипДоговора
        |ИЗ
        |   Справочник.ДоговорыКонтрагентов КАК Договоры
        |ГДЕ
        |   Договоры.Контрагент В (&Контрагенты)
        |   И НЕ Договоры.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("Контрагенты", МассивКонтрагентов);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        МассивДоговоров = Результат.Получить(Выборка.Контрагент);
        Если МассивДоговоров = Неопределено Тогда
            МассивДоговоров = Новый Массив;
            Результат.Вставить(Выборка.Контрагент, МассивДоговоров);
        КонецЕсли;
        
        СтруктДог = Новый Структура;
        СтруктДог.Вставить("Ссылка", Выборка.Ссылка);
        СтруктДог.Вставить("ТипДоговора", Выборка.ТипДоговора);
        МассивДоговоров.Добавить(СтруктДог);
    КонецЦикла;
    
    Возврат Результат;

КонецФункции

&НаСервере
Процедура ОбработатьДоговорыТипа(
    КонтрагентСсылка,
    МассивДоговоров,
    ТипДоговора,
    Назначение,
    МенеджерСсылка,
    СтатьяДДССсылка,
    Результат,
    БанковскийСчетОрганизацииВТБ)

    МассивНужногоТипа = Новый Массив;
    
    Для Каждого СтруктДоговор Из МассивДоговоров Цикл
        Если СтруктДоговор.ТипДоговора = ТипДоговора Тогда
            МассивНужногоТипа.Добавить(СтруктДоговор.Ссылка);
        КонецЕсли;
    КонецЦикла;
    
    // Если договоров нужного типа нет - создаем новый.
    Если МассивНужногоТипа.Количество() = 0 Тогда
        НачатьТранзакцию();
        Попытка
            ВремяДоговора = ТекущаяДатаСеанса();
            НовыйДоговор = СоздатьДоговор(КонтрагентСсылка, ТипДоговора, Назначение);
            Изм = ПривестиДоговорКСтандарту(
                НовыйДоговор,
                КонтрагентСсылка,
                Назначение,
                МенеджерСсылка,
                СтатьяДДССсылка,
                Истина,
                БанковскийСчетОрганизацииВТБ
            );
            Если Изм Тогда
                Результат.Создано = Результат.Создано + 1;
            Иначе
                Результат.Создано = Результат.Создано + 1;
            КонецЕсли;
            ЗафиксироватьТранзакцию(); // BSLLS:CommitTransactionOutsideTryCatch-off
            ЗаписатьЛог("Создан и заполнен договор [" + Назначение + "]: " + Строка(НовыйДоговор)
                + ". Время: " + Строка(ТекущаяДатаСеанса() - ВремяДоговора) + " сек");
        Исключение
            ОтменитьТранзакцию();
            Результат.Ошибок = Результат.Ошибок + 1;
            ЗаписатьЛог("ОШИБКА создания договора [" + Назначение + "]: " + ОписаниеОшибки());
        КонецПопытки;
        
        Возврат;
    КонецЕсли;
    
    // Договоры есть - проходим каждый не удаленный договор нужного типа.
    Для Каждого СсылкаДоговора Из МассивНужногоТипа Цикл
        НачатьТранзакцию();
        Попытка
            ВремяДоговора = ТекущаяДатаСеанса();
            Изменено = ПривестиДоговорКСтандарту(
                СсылкаДоговора,
                КонтрагентСсылка,
                Назначение,
                МенеджерСсылка,
                СтатьяДДССсылка,
                Ложь,
                БанковскийСчетОрганизацииВТБ
            );
            
            Если Изменено Тогда
                Результат.Обновлено = Результат.Обновлено + 1;
                ЗаписатьЛог("Обновлен договор [" + Назначение + "]: " + Строка(СсылкаДоговора)
                    + ". Время: " + Строка(ТекущаяДатаСеанса() - ВремяДоговора) + " сек");
            Иначе
                Результат.БезИзменений = Результат.БезИзменений + 1;
                ЗаписатьЛог("Без изменений договор [" + Назначение + "]: " + Строка(СсылкаДоговора)
                    + ". Время: " + Строка(ТекущаяДатаСеанса() - ВремяДоговора) + " сек");
            КонецЕсли;
            
            ЗафиксироватьТранзакцию(); // BSLLS:CommitTransactionOutsideTryCatch-off
            
        Исключение
            ОтменитьТранзакцию();
            Результат.Ошибок = Результат.Ошибок + 1;
            ЗаписатьЛог("ОШИБКА обработки договора [" + Назначение + "] "
                + Строка(СсылкаДоговора) + ": " + ОписаниеОшибки());
        КонецПопытки;
    КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ПривестиДоговорКСтандарту(
    ДоговорСсылка,
    КонтрагентСсылка,
    Назначение,
    МенеджерСсылка,
    СтатьяДДССсылка,
    ЭтоНовый,
    БанковскийСчетОрганизацииВТБ) Экспорт

    Изменено = Ложь;
    ДоговорОбъект = ДоговорСсылка.ПолучитьОбъект();
    
    // 1) Номер договора
    НомерДоговора = СокрЛП(ДоговорОбъект.Номер);
    Если ЭтоНовый Или НомерДоговора = "" Тогда
        Если НомерДоговора <> "БН" Тогда
            ДоговорОбъект.Номер = "БН";
            НомерДоговора = "БН";
            Изменено = Истина;
        КонецЕсли;
    КонецЕсли;
    Если НомерДоговора = "" Тогда
        НомерДоговора = "БН";
    КонецЕсли;
    
    // 2) Дата договора ("от")
    ДатаДоговора = Неопределено;
    Если ЭтоНовый Тогда
        ДатаДоговора = Дата(2026, 1, 1);
        Если ДоговорОбъект.Дата <> ДатаДоговора Тогда
            ДоговорОбъект.Дата = ДатаДоговора;
            Изменено = Истина;
        КонецЕсли;
    Иначе
        Если НЕ ЗначениеЗаполнено(ДоговорОбъект.Дата) Тогда
            // Если дата пустая - ставим эталонную дату.
            // (в типовых договорах поле Дата обычно заполнено всегда)
            ДатаДоговора = Дата(2026, 1, 1);
            ДоговорОбъект.Дата = ДатаДоговора;
            Изменено = Истина;
        Иначе
            ДатаДоговора = ДоговорОбъект.Дата;
        КонецЕсли;
    КонецЕсли;
    
    Если НЕ ЗначениеЗаполнено(ДатаДоговора) Тогда
        ДатаДоговора = Дата(2026, 1, 1);
    КонецЕсли;
    
    // 3) Наименование договора
    Если НРег(Назначение) = "реализация" Тогда
        ЦелевоеНаименование = "Договор реализации " + НомерДоговора;
    Иначе
        ЦелевоеНаименование = "Договор закупка " + НомерДоговора;
    КонецЕсли;
    
    Если СокрЛП(ДоговорОбъект.Наименование) <> ЦелевоеНаименование Тогда
        ДоговорОбъект.Наименование = ЦелевоеНаименование;
        Изменено = Истина;
    КонецЕсли;
    
    // 4) Действует с / по
    Попытка
        Если ДоговорОбъект.ДатаНачалаДействия <> ДатаДоговора Тогда
            ДоговорОбъект.ДатаНачалаДействия = ДатаДоговора;
            Изменено = Истина;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    Попытка
        Если ЗначениеЗаполнено(ДоговорОбъект.ДатаОкончанияДействия) Тогда
            ДоговорОбъект.ДатаОкончанияДействия = Неопределено;
            Изменено = Истина;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    // 5) Статус - ставим "Действует", кроме "Закрыт"/"Не согласован"
    Попытка
        Если ДоговорОбъект.Статус <> Перечисления.СтатусыДоговоровКонтрагентов.Закрыт
            И ДоговорОбъект.Статус <> Перечисления.СтатусыДоговоровКонтрагентов.НеСогласован Тогда
            Если ДоговорОбъект.Статус <> Перечисления.СтатусыДоговоровКонтрагентов.Действует Тогда
                ДоговорОбъект.Статус = Перечисления.СтатусыДоговоровКонтрагентов.Действует;
                Изменено = Истина;
            КонецЕсли;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    // 6) Наименование для печати
    ТекстПечатного = "Договор поставки " + НомерДоговора + " от "
        + Формат(ДатаДоговора, "ДФ=dd.MM.yyyy");
    Попытка
        Если СокрЛП(ДоговорОбъект.НаименованиеДляПечати) <> ТекстПечатного Тогда
            ДоговорОбъект.НаименованиеДляПечати = ТекстПечатного;
            Изменено = Истина;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    // 7) Менеджер договора (единый менеджер)
    Попытка
        Если ДоговорОбъект.Менеджер <> МенеджерСсылка Тогда
            ДоговорОбъект.Менеджер = МенеджерСсылка;
            Изменено = Истина;
        КонецЕсли;
    Исключение
        ЗаписатьЛог("Предупреждение: не удалось установить менеджера в договоре "
            + Строка(ДоговорСсылка) + ": " + ОписаниеОшибки());
    КонецПопытки;
    
    // 8) Контрагент/Партнер договора - должны соответствовать владельцу
    Если ДоговорОбъект.Контрагент <> КонтрагентСсылка Тогда
        ДоговорОбъект.Контрагент = КонтрагентСсылка;
        Изменено = Истина;
    КонецЕсли;
    
    Попытка
        Если ЗначениеЗаполнено(КонтрагентСсылка.Партнер)
            И ДоговорОбъект.Партнер <> КонтрагентСсылка.Партнер Тогда
            ДоговорОбъект.Партнер = КонтрагентСсылка.Партнер;
            Изменено = Истина;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    // 8.1) Страховка обязательных реквизитов по метаданным
    Попытка
        Если НЕ ЗначениеЗаполнено(ДоговорОбъект.Организация) Тогда
            ОрганизацияСсылка = ПолучитьОрганизацию();
            Если ЗначениеЗаполнено(ОрганизацияСсылка) Тогда
                ДоговорОбъект.Организация = ОрганизацияСсылка;
                Изменено = Истина;
            КонецЕсли;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    Попытка
        Если НЕ ЗначениеЗаполнено(ДоговорОбъект.ВалютаВзаиморасчетов) Тогда
            ВалютаРубль = ПолучитьВалютуРубль();
            Если ЗначениеЗаполнено(ВалютаРубль) Тогда
                ДоговорОбъект.ВалютаВзаиморасчетов = ВалютаРубль;
                Изменено = Истина;
            КонецЕсли;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    // 8.2) Выравниваем хозяйственную операцию по цели договора (скрытый, но важный реквизит).
    Попытка
        Если ДоговорОбъект.ТипДоговора = Перечисления.ТипыДоговоров.СПокупателем Тогда
            Если ДоговорОбъект.ХозяйственнаяОперация <> Перечисления.ХозяйственныеОперации.РеализацияКлиенту Тогда
                ДоговорОбъект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.РеализацияКлиенту;
                Изменено = Истина;
            КонецЕсли;
        ИначеЕсли ДоговорОбъект.ТипДоговора = Перечисления.ТипыДоговоров.СПоставщиком Тогда
            Если ДоговорОбъект.ХозяйственнаяОперация <> Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика Тогда
                ДоговорОбъект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика;
                Изменено = Истина;
            КонецЕсли;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    // 9) Детализация расчетов - По договорам
    Попытка
        Если ДоговорОбъект.ПорядокРасчетов <> Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов Тогда
            ДоговорОбъект.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов;
            Изменено = Истина;
        КонецЕсли;
    Исключение
        ЗаписатьЛог("Предупреждение: не удалось установить ПорядокРасчетов для договора "
            + Строка(ДоговорСсылка) + ": " + ОписаниеОшибки());
    КонецПопытки;
    
    // 9.1) Для детализации "По договорам" обязательно должен существовать ОбъектРасчетов.
    Попытка
        Если ДоговорОбъект.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов Тогда
            СсылкаОбъектаРасчетов = ОбеспечитьОбъектРасчетовДляДоговора(ДоговорОбъект, КонтрагентСсылка);
            Если ЗначениеЗаполнено(СсылкаОбъектаРасчетов)
                И ДоговорОбъект.ОбъектРасчетов <> СсылкаОбъектаРасчетов Тогда
                ДоговорОбъект.ОбъектРасчетов = СсылкаОбъектаРасчетов;
                Изменено = Истина;
            КонецЕсли;
        КонецЕсли;
    Исключение
        ЗаписатьЛог("ОШИБКА подготовки ОбъектаРасчетов для договора "
            + Строка(ДоговорСсылка) + ": " + ОписаниеОшибки());
        ВызватьИсключение;
    КонецПопытки;
    
    // 9.2) Сбрасываем ограничения на вкладке "Расчеты и оформление".
    // По метаданным УТ:
    // - ОграничиватьСуммуЗадолженности (чекбокс "При сумме задолженности более")
    // - ДопустимаяСуммаЗадолженности (порог задолженности)
    // - ЗапрещаетсяПросроченнаяЗадолженность (чекбокс "При наличии просроченной задолженности")
    // Для "Сумма договора фиксированная" отдельного булевого реквизита в объекте нет,
    // поэтому сбрасываем лимит Сумма в 0.
    Попытка
        Если ЗначениеЗаполнено(ДоговорОбъект.Сумма)
            И ДоговорОбъект.Сумма <> 0 Тогда
            ДоговорОбъект.Сумма = 0;
            Изменено = Истина;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    Попытка
        Если ДоговорОбъект.ОграничиватьСуммуЗадолженности Тогда
            ДоговорОбъект.ОграничиватьСуммуЗадолженности = Ложь;
            Изменено = Истина;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    Попытка
        Если ЗначениеЗаполнено(ДоговорОбъект.ДопустимаяСуммаЗадолженности)
            И ДоговорОбъект.ДопустимаяСуммаЗадолженности <> 0 Тогда
            ДоговорОбъект.ДопустимаяСуммаЗадолженности = 0;
            Изменено = Истина;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    Попытка
        Если ДоговорОбъект.ЗапрещаетсяПросроченнаяЗадолженность Тогда
            ДоговорОбъект.ЗапрещаетсяПросроченнаяЗадолженность = Ложь;
            Изменено = Истина;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    // 10) Счет организации:
    //     - если поле уже заполнено, НЕ трогаем;
    //     - если поле пустое (новый/старый договор), заполняем счетом организации ВТБ.
    Попытка
        Если ЗначениеЗаполнено(БанковскийСчетОрганизацииВТБ)
            И НЕ ЗначениеЗаполнено(ДоговорОбъект.БанковскийСчет) Тогда
            ДоговорОбъект.БанковскийСчет = БанковскийСчетОрганизацииВТБ;
            Изменено = Истина;
        КонецЕсли;
    Исключение
        ЗаписатьЛог("Предупреждение: не удалось установить Счет организации для договора "
            + Строка(ДоговорСсылка) + ": " + ОписаниеОшибки());
    КонецПопытки;
    
    // 11) Налогообложение НДС - "Определяется в заказах и накладных"
    Попытка
        Если НЕ ДоговорОбъект.НалогообложениеНДСОпределяетсяВДокументе Тогда
            ДоговорОбъект.НалогообложениеНДСОпределяетсяВДокументе = Истина;
            Изменено = Истина;
        КонецЕсли;
    Исключение
        ЗаписатьЛог("Предупреждение: не удалось установить флаг НалогообложениеНДСОпределяетсяВДокументе для договора "
            + Строка(ДоговорСсылка) + ": " + ОписаниеОшибки());
    КонецПопытки;
    
    Попытка
        Если ДоговорОбъект.НалогообложениеНДС <> Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС Тогда
            ДоговорОбъект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
            Изменено = Истина;
        КонецЕсли;
    Исключение
        ЗаписатьЛог("Предупреждение: не удалось установить НалогообложениеНДС для договора "
            + Строка(ДоговорСсылка) + ": " + ОписаниеОшибки());
    КонецПопытки;
    
    // 11.1) Закупка под деятельность (критично для договоров с целью "Закупка")
    Попытка
        Если ДоговорОбъект.ТипДоговора = Перечисления.ТипыДоговоров.СПоставщиком Тогда
            // Чтобы поле не становилось обязательным на уровне проверки заполнения.
            Если НЕ ДоговорОбъект.ЗакупкаПодДеятельностьОпределяетсяВДокументе Тогда
                ДоговорОбъект.ЗакупкаПодДеятельностьОпределяетсяВДокументе = Истина;
                Изменено = Истина;
            КонецЕсли;
            
            // Дополнительно заполняем само значение (для совместимости с разными сценариями проверок).
            Если НЕ ЗначениеЗаполнено(ДоговорОбъект.ЗакупкаПодДеятельность) Тогда
                Если ЗначениеЗаполнено(ДоговорОбъект.НалогообложениеНДС) Тогда
                    ДоговорОбъект.ЗакупкаПодДеятельность = ДоговорОбъект.НалогообложениеНДС;
                Иначе
                    ДоговорОбъект.ЗакупкаПодДеятельность = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
                КонецЕсли;
                Изменено = Истина;
            КонецЕсли;
        КонецЕсли;
    Исключение
        ЗаписатьЛог("Предупреждение: не удалось установить реквизиты 'Закупка под деятельность' для договора "
            + Строка(ДоговорСсылка) + ": " + ОписаниеОшибки());
    КонецПопытки;
    
    // 12) Статья ДДС
    Попытка
        Если ЗначениеЗаполнено(СтатьяДДССсылка)
            И ДоговорОбъект.СтатьяДвиженияДенежныхСредств <> СтатьяДДССсылка Тогда
            ДоговорОбъект.СтатьяДвиженияДенежныхСредств = СтатьяДДССсылка;
            Изменено = Истина;
        КонецЕсли;
    Исключение
        ЗаписатьЛог("Предупреждение: не удалось установить СтатьюДДС для договора "
            + Строка(ДоговорСсылка) + ": " + ОписаниеОшибки());
    КонецПопытки;
    
    // 13) Для режима "По договорам" обязательно должен быть объект расчетов.
    Попытка
        Если ДоговорОбъект.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов Тогда
            ОбъектРасчетов = ОбеспечитьОбъектРасчетовДляДоговора(ДоговорОбъект, КонтрагентСсылка);
            Если НЕ ЗначениеЗаполнено(ОбъектРасчетов) Тогда
                ВызватьИсключение "Не удалось создать/найти объект расчетов для договора.";
            КонецЕсли;
            
            Если ДоговорОбъект.ОбъектРасчетов <> ОбъектРасчетов Тогда
                ДоговорОбъект.ОбъектРасчетов = ОбъектРасчетов;
                Изменено = Истина;
            КонецЕсли;
        КонецЕсли;
    Исключение
        ЗаписатьЛог("ОШИБКА подготовки объекта расчетов для договора "
            + Строка(ДоговорСсылка) + ": " + ОписаниеОшибки());
        ВызватьИсключение;
    КонецПопытки;
    
    // Сохраняем только если что-то реально изменили
    Если Изменено Тогда
        ДоговорОбъект.Записать();
    КонецЕсли;
    
    Возврат Изменено;

КонецФункции

&НаСервере
Функция СоздатьДоговор(КонтрагентСсылка, ТипДоговора, Назначение)

    НовыйДоговор = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();
    НовыйДоговор.Контрагент = КонтрагентСсылка;
    НовыйДоговор.ТипДоговора = ТипДоговора;
    
    // Если организация известна в базе - ставим первую доступную
    ОрганизацияСсылка = ПолучитьОрганизацию();
    Если ЗначениеЗаполнено(ОрганизацияСсылка) Тогда
        Попытка
            НовыйДоговор.Организация = ОрганизацияСсылка;
        Исключение // BSLLS:MissingCodeTryCatchEx-off
        КонецПопытки;
    КонецЕсли;
    
    // Партнер из контрагента
    Попытка
        Если ЗначениеЗаполнено(КонтрагентСсылка.Партнер) Тогда
            НовыйДоговор.Партнер = КонтрагентСсылка.Партнер;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    // Базовые значения, дальше приведем к стандарту общей функцией.
    Если НРег(Назначение) = "реализация" Тогда
        НовыйДоговор.Наименование = "Договор реализации БН";
    Иначе
        НовыйДоговор.Наименование = "Договор закупка БН";
    КонецЕсли;
    
    НовыйДоговор.Номер = "БН";
    НовыйДоговор.Дата = Дата(2026, 1, 1);
    НовыйДоговор.ВалютаВзаиморасчетов = ПолучитьВалютуРубль();
    
    НовыйДоговор.Записать();
    Возврат НовыйДоговор.Ссылка;

КонецФункции

#КонецОбласти // ОбновлениеДоговоров

#Область Служебные

&НаСервере
Функция ПолучитьМенеджераКучерук()

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Пользователи.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Пользователи КАК Пользователи
        |ГДЕ
        |   Пользователи.Наименование = &Наименование
        |   И НЕ Пользователи.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("Наименование", "Кучерук Алексей Александрович");
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    // Фолбэк - по шаблону
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Пользователи.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Пользователи КАК Пользователи
        |ГДЕ
        |   Пользователи.Наименование ПОДОБНО &Шаблон
        |   И НЕ Пользователи.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("Шаблон", "%Кучерук%");
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    Возврат Справочники.Пользователи.ПустаяСсылка();

КонецФункции

&НаСервере
Функция ПолучитьСтатьюДДС(Наименование)

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   СтатьиДДС.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.СтатьиДвиженияДенежныхСредств КАК СтатьиДДС
        |ГДЕ
        |   СтатьиДДС.Наименование = &Наименование
        |   И НЕ СтатьиДДС.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("Наименование", Наименование);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    ЗаписатьЛог("Предупреждение: статья ДДС не найдена: " + Наименование);
    Возврат Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка();

КонецФункции

&НаСервере
Функция ПолучитьОрганизацию()

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Организации.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Организации КАК Организации
        |ГДЕ
        |   НЕ Организации.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО
        |   Организации.Наименование";
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    Возврат Справочники.Организации.ПустаяСсылка();

КонецФункции

&НаСервере
Функция ПолучитьБанковскийСчетОрганизацииВТБ()

    // Приоритет: фиксированная внутренняя ссылка, переданная пользователем.
    // Сравниваем по ref в навигационной ссылке, чтобы не зависеть от наименования.
    ЦелевойRef = "968800505693481211f04b676f176963";
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   БанковскиеСчета.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.БанковскиеСчетаОрганизаций КАК БанковскиеСчета
        |ГДЕ
        |   НЕ БанковскиеСчета.ПометкаУдаления";
    
    Для Каждого СтрокаВыборки Из Запрос.Выполнить().Выгрузить() Цикл
        Попытка
            НавСсылка = НРег(ПолучитьНавигационнуюСсылку(СтрокаВыборки.Ссылка));
            Если СтрНайти(НавСсылка, "ref=" + ЦелевойRef) > 0 Тогда
                ЗаписатьЛог("Счет организации ВТБ найден по фиксированной ссылке ref=" + ЦелевойRef);
                Возврат СтрокаВыборки.Ссылка;
            КонецЕсли;
        Исключение // BSLLS:MissingCodeTryCatchEx-off
        КонецПопытки;
    КонецЦикла;

    // Фолбэк: поиск по наименованию, если фиксированная ссылка не найдена.
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   БанковскиеСчета.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.БанковскиеСчетаОрганизаций КАК БанковскиеСчета
        |ГДЕ
        |   НЕ БанковскиеСчета.ПометкаУдаления
        |   И БанковскиеСчета.Наименование ПОДОБНО &Шаблон
        |УПОРЯДОЧИТЬ ПО
        |   БанковскиеСчета.Наименование";
    
    Запрос.УстановитьПараметр("Шаблон", "%ВТБ%");
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        ЗаписатьЛог("Счет организации ВТБ найден по шаблону наименования.");
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    ЗаписатьЛог("Счет организации ВТБ не найден ни по ref, ни по наименованию.");
    Возврат Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();

КонецФункции

&НаСервере
Функция ПолучитьВалютуРубль()

    Валюта = Справочники.Валюты.НайтиПоКоду("643");
    Если ЗначениеЗаполнено(Валюта) Тогда
        Возврат Валюта;
    КонецЕсли;
    
    Валюта = Справочники.Валюты.НайтиПоНаименованию("руб.");
    Если ЗначениеЗаполнено(Валюта) Тогда
        Возврат Валюта;
    КонецЕсли;
    
    Возврат Справочники.Валюты.ПустаяСсылка();

КонецФункции

&НаСервере
Функция ОпределитьТипРасчетовДляДоговора(ТипДоговора)

    Если ТипДоговора = Перечисления.ТипыДоговоров.СПокупателем Тогда
        Возврат Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом;
    ИначеЕсли ТипДоговора = Перечисления.ТипыДоговоров.СПоставщиком Тогда
        Возврат Перечисления.ТипыРасчетовСПартнерами.РасчетыСПоставщиком;
    КонецЕсли;
    
    Возврат Неопределено;

КонецФункции

&НаСервере
Функция ОбеспечитьОбъектРасчетовДляДоговора(ДоговорОбъект, КонтрагентСсылка)

    Если НЕ ЗначениеЗаполнено(ДоговорОбъект.Ссылка) Тогда
        Возврат Справочники.ОбъектыРасчетов.ПустаяСсылка();
    КонецЕсли;
    
    // Если уже есть объект расчетов, возвращаем его.
    Если ЗначениеЗаполнено(ДоговорОбъект.ОбъектРасчетов) Тогда
        Возврат ДоговорОбъект.ОбъектРасчетов;
    КонецЕсли;
    
    ТипРасчетов = ОпределитьТипРасчетовДляДоговора(ДоговорОбъект.ТипДоговора);
    Если ТипРасчетов = Неопределено Тогда
        Возврат Справочники.ОбъектыРасчетов.ПустаяСсылка();
    КонецЕсли;
    
    Если НЕ ЗначениеЗаполнено(ДоговорОбъект.ВалютаВзаиморасчетов) Тогда
        ДоговорОбъект.ВалютаВзаиморасчетов = ПолучитьВалютуРубль();
    КонецЕсли;
    
    РеквизитыОР = Новый Структура;
    РеквизитыОР.Вставить("Объект", ДоговорОбъект.Ссылка);
    РеквизитыОР.Вставить("Организация", ДоговорОбъект.Организация);
    РеквизитыОР.Вставить("Контрагент", КонтрагентСсылка);
    РеквизитыОР.Вставить("Партнер", ДоговорОбъект.Партнер);
    РеквизитыОР.Вставить("ТипРасчетов", ТипРасчетов);
    РеквизитыОР.Вставить("ВалютаВзаиморасчетов", ДоговорОбъект.ВалютаВзаиморасчетов);
    РеквизитыОР.Вставить("Договор", ДоговорОбъект.Ссылка);
    РеквизитыОР.Вставить("ПометкаУдаления", Ложь);
    
    Попытка
        Возврат ОбъектыРасчетовСервер.ПроверитьСоздатьОбъектРасчетов(РеквизитыОР);
    Исключение
        ЗаписатьЛог("ОШИБКА при ПроверитьСоздатьОбъектРасчетов для договора "
            + Строка(ДоговорОбъект.Ссылка) + ": " + ОписаниеОшибки());
        Возврат Справочники.ОбъектыРасчетов.ПустаяСсылка();
    КонецПопытки;

КонецФункции

&НаСервере
Процедура ЗаписатьЛог(Текст) Экспорт

    ПутьКЛогу = "D:\1с\КАА\Лог_Этап3_СозданиеИДоЗаполнениеДоговоров.txt"; // BSLLS:UsingHardcodePath-off
    
    Попытка
        Запись = Новый ЗаписьТекста(ПутьКЛогу, КодировкаТекста.UTF8, , Истина);
        СтрокаЛога = Формат(ТекущаяДатаСеанса(), "ДФ=yyyy-MM-dd HH:mm:ss")
            + " | " + Текст;
        Запись.ЗаписатьСтроку(СтрокаЛога);
        Запись.Закрыть();
    Исключение
        Попытка
            Сообщить("ОШИБКА ЗАПИСИ ЛОГА: " + ОписаниеОшибки());
        Исключение // BSLLS:MissingCodeTryCatchEx-off
        КонецПопытки;
    КонецПопытки;

КонецПроцедуры

&НаСервере
Процедура ЗаписатьПустыеСтрокиВЛог(КоличествоСтрок = 2) Экспорт

    ПутьКЛогу = "D:\1с\КАА\Лог_Этап3_СозданиеИДоЗаполнениеДоговоров.txt"; // BSLLS:UsingHardcodePath-off
    
    Если КоличествоСтрок < 1 Тогда
        Возврат;
    КонецЕсли;
    
    Попытка
        Запись = Новый ЗаписьТекста(ПутьКЛогу, КодировкаТекста.UTF8, , Истина);
        Для НомерСтроки = 1 По КоличествоСтрок Цикл
            Запись.ЗаписатьСтроку("");
        КонецЦикла;
        Запись.Закрыть();
    Исключение // BSLLS:MissingCodeTryCatchEx-off
