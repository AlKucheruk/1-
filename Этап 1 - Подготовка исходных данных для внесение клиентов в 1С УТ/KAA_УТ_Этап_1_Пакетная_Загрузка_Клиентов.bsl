// BSLLS-off
// =============================================================================
// Внешняя обработка: KAA_Пакетная_Загрузка_Клиентов
// Версия: 1.0
// Назначение: Пакетная загрузка клиентов из Excel в базу 1С УТ
// =============================================================================
//
// РЕКВИЗИТЫ ФОРМЫ (создать вручную в конфигураторе):
//
//   ТаблицаПредпросмотра - ТаблицаЗначений:
//     Обработать              — Булево
//     НаименованиеКонтрагента — Строка(150)
//     ИНН                     — Строка(12)
//     КПП                     — Строка(9)
//     Email                   — Строка(100)
//     Клиент                  — Строка(3)     ("да" / "нет")
//     Поставщик               — Строка(3)     ("да" / "нет")
//     ПометкаУдаления         — Строка(3)
//     Код                     — Строка(20)
//     НомерРасчетногоСчета    — Строка(34)
//     БИКБанка                — Строка(9)
//     НаименованиеБанка       — Строка(150)
//     СоответствиеИНН         — Булево
//     СоответствиеКПП         — Булево
//     СоответствиеРасчСчет    — Булево
//     СтрокаЗаблокирована     — Булево
//
//   КНОПКИ НА ФОРМЕ:
//     ЗагрузитьПредпросмотр  — связана с командой ЗагрузитьПредпросмотр
//     ЗагрузитьДанныеВ1С     — связана с командой ЗагрузитьДанныеВ1С
//     ВыделитьВсе            — связана с командой ВыделитьВсе
//     СнятьВсеВыделения      — связана с командой СнятьВсеВыделения
//
//   Колонка «Обработать» — крайняя левая, тип Булево.
//     Представление колонки: ФлажокПометки (обычный чек-бокс, НЕ Картинка).
//   Колонки СоответствиеИНН / СоответствиеКПП / СоответствиеРасчСчет —
//     тип Булево, представление: ФлажокПометки (обычный чек-бокс).
//     При желании добавить условное оформление: Истина → фон зелёный.
//   Условное оформление строки: СтрокаЗаблокирована = Истина → фон серый.
//
// =============================================================================

#Область Инициализация_Формы

// ---------------------------------------------------------------------------
// При открытии формы блокируем информационные колонки Соответствие* —
// пользователь не должен их менять вручную.
// Имена элементов формы совпадают с именами колонок таблицы.
// ---------------------------------------------------------------------------
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    
    КолонкиТолькоПросмотр = "СоответствиеИНН,СоответствиеКПП,СоответствиеРасчСчет,СтрокаЗаблокирована";
    Для Каждого ИмяКол Из СтрРазделить(КолонкиТолькоПросмотр, ",") Цикл
        ИмяЭлемента = "ТаблицаПредпросмотра" + ИмяКол;
        Попытка
            Элементы[ИмяЭлемента].ТолькоПросмотр = Истина;
        Исключение // BSLLS:MissingCodeTryCatchEx-off
        КонецПопытки;
    КонецЦикла;
    
КонецПроцедуры

#КонецОбласти // Инициализация_Формы

// =============================================================================

#Область Форма_Команды

// ---------------------------------------------------------------------------
// Кнопка «Загрузить предпросмотр»
// Читает Excel на клиенте (где установлен), передаёт данные на сервер.
// ---------------------------------------------------------------------------
&НаКлиенте
Процедура ЗагрузитьПредпросмотр(Команда)
    
    ДиалогОткрытия = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
    ДиалогОткрытия.Заголовок = "Выберите файл Excel для загрузки";
    ДиалогОткрытия.Фильтр = "Файлы Excel (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*";
    ДиалогОткрытия.МножественныйВыбор = Ложь;
    
    Если НЕ ДиалогОткрытия.Выбрать() Тогда
        Возврат;
    КонецЕсли;
    
    ПутьКФайлу = ДиалогОткрытия.ПолноеИмяФайла;
    
    // Фиксируем время ДО чтения Excel (чтение идёт на клиенте и занимает основное время)
    ВремяСтартаКлиент = ТекущаяДата();
    
    // Чтение Excel выполняется на клиенте — здесь есть Excel.Application
    МассивСтрок = ПрочитатьExcelНаКлиенте(ПутьКФайлу);
    Если МассивСтрок = Неопределено Тогда
        Возврат; // ошибка уже показана внутри функции
    КонецЕсли;
    
    СекундНаКлиенте = ТекущаяДата() - ВремяСтартаКлиент;
    
    // Передаём готовые данные на сервер — COM объекты туда не нужны
    ЗагрузитьПредпросмотрНаСервере(МассивСтрок, ПутьКФайлу, СекундНаКлиенте);
    
КонецПроцедуры

// ---------------------------------------------------------------------------
// Читает xlsx через COM Excel на клиентской машине.
// Возвращает Массив Структур (по одной на каждую строку данных)
// или Неопределено при ошибке валидации / чтения.
// ---------------------------------------------------------------------------
&НаКлиенте
Функция ПрочитатьExcelНаКлиенте(ПутьКФайлу) // BSLLS:CognitiveComplexity-off
    
    ОжидаемыеКолонки = Новый Массив;
    ОжидаемыеКолонки.Добавить("НаименованиеКонтрагента");
    ОжидаемыеКолонки.Добавить("ИНН");
    ОжидаемыеКолонки.Добавить("КПП");
    ОжидаемыеКолонки.Добавить("Email");
    ОжидаемыеКолонки.Добавить("Клиент");
    ОжидаемыеКолонки.Добавить("Поставщик");
    ОжидаемыеКолонки.Добавить("ПометкаУдаления");
    ОжидаемыеКолонки.Добавить("Код");
    ОжидаемыеКолонки.Добавить("НомерРасчетногоСчета");
    ОжидаемыеКолонки.Добавить("БИКБанка");
    ОжидаемыеКолонки.Добавить("НаименованиеБанка");
    
    Excel = Неопределено;
    Книга = Неопределено;
    
    Попытка
        Excel = Новый COMОбъект("Excel.Application");
        Excel.Visible = Ложь;
        Excel.DisplayAlerts = Ложь;
        
        Книга = Excel.Workbooks.Open(ПутьКФайлу);
        Лист = Книга.Sheets(1);
        
        ДиапазонИсп = Лист.UsedRange;
        КолСтрок = ДиапазонИсп.Rows.Count;
        КолКолонок = ДиапазонИсп.Columns.Count;
        НачСтрока = ДиапазонИсп.Row;
        НачКолонка = ДиапазонИсп.Column;
        
        // Читаем заголовки
        СоотвКолонок = Новый Соответствие;
        Для Инд = 0 По КолКолонок - 1 Цикл
            НомКол = НачКолонка + Инд;
            Заголовок = СокрЛП(Строка(Лист.Cells(НачСтрока, НомКол).Value));
            Если ЗначениеЗаполнено(Заголовок) Тогда
                СоотвКолонок.Вставить(Заголовок, НомКол);
            КонецЕсли;
        КонецЦикла;
        
        // Валидация — все нужные колонки должны быть в файле
        Для Каждого ИмяКол Из ОжидаемыеКолонки Цикл
            Если СоотвКолонок.Получить(ИмяКол) = Неопределено Тогда
                Книга.Close(Ложь);
                Excel.Quit();
                Сообщить("Файл не соответствует шаблону. Отсутствует колонка: " + ИмяКол);
                Возврат Неопределено;
            КонецЕсли;
        КонецЦикла;
        
        // Читаем строки данных в Массив Структур (примитивные типы — передаются на сервер)
        Результат = Новый Массив;
        КонечнаяСтрока = НачСтрока + КолСтрок - 1;
        
        Для НомСтр = НачСтрока + 1 По КонечнаяСтрока Цикл
            НоваяСтрока = Новый Структура;
            Для Каждого ИмяКол Из ОжидаемыеКолонки Цикл
                НомКол = СоотвКолонок[ИмяКол];
                НоваяСтрока.Вставить(ИмяКол, СокрЛП(Строка(Лист.Cells(НомСтр, НомКол).Value)));
            КонецЦикла;
            // Пропускаем строки без ИНН
            Если ЗначениеЗаполнено(НоваяСтрока.ИНН) Тогда
                Результат.Добавить(НоваяСтрока);
            КонецЕсли;
        КонецЦикла;
        
        Книга.Close(Ложь);
        Excel.Quit();
        
        Возврат Результат;
        
    Исключение
        ТекстОшибки = ОписаниеОшибки();
        Попытка
            Если Книга <> Неопределено Тогда
                Книга.Close(Ложь);
            КонецЕсли;
            Если Excel <> Неопределено Тогда
                Excel.Quit();
            КонецЕсли;
        Исключение // BSLLS:MissingCodeTryCatchEx-off
        КонецПопытки;
        Сообщить("Ошибка чтения файла Excel: " + ТекстОшибки);
        Возврат Неопределено;
    КонецПопытки;
    
КонецФункции

// ---------------------------------------------------------------------------
// Кнопка «Загрузить данные в 1С»
// Запрашивает подтверждение и запускает обработку отмеченных строк.
// ---------------------------------------------------------------------------
&НаКлиенте
Процедура ЗагрузитьДанныеВ1С(Команда)
    
    КоличествоОтмеченных = 0;
    Для Каждого Строка Из ТаблицаПредпросмотра Цикл
        Если Строка.Обработать Тогда
            КоличествоОтмеченных = КоличествоОтмеченных + 1;
        КонецЕсли;
    КонецЦикла;
    
    Если КоличествоОтмеченных = 0 Тогда
        ПоказатьПредупреждение( , "Нет отмеченных строк для обработки.");
        Возврат;
    КонецЕсли;
    
    ТекстВопроса = "Будет обработано строк: " + КоличествоОтмеченных + ".
        |Продолжить?";
    
    Если Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
        Возврат;
    КонецЕсли;
    
    ЗагрузитьДанныеВ1СНаСервере();
    
КонецПроцедуры

// ---------------------------------------------------------------------------
// Кнопка «Выделить всё» — проставляет Обработать = Истина всем незаблокированным строкам.
// ---------------------------------------------------------------------------
&НаКлиенте
Процедура ВыделитьВсе(Команда)
    
    Для Каждого Строка Из ТаблицаПредпросмотра Цикл
        Если НЕ Строка.СтрокаЗаблокирована Тогда
            Строка.Обработать = Истина;
        КонецЕсли;
    КонецЦикла;
    
КонецПроцедуры

// ---------------------------------------------------------------------------
// Кнопка «Снять все выделения» — снимает Обработать со всех строк.
// ---------------------------------------------------------------------------
&НаКлиенте
Процедура СнятьВсеВыделения(Команда)
    
    Для Каждого Строка Из ТаблицаПредпросмотра Цикл
        Строка.Обработать = Ложь;
    КонецЦикла;
    
КонецПроцедуры

#КонецОбласти // Форма_Команды

// =============================================================================

#Область Загрузка_Excel

// ---------------------------------------------------------------------------
// Серверная точка входа предпросмотра.
// Принимает уже прочитанный на клиенте МассивСтрок (Массив Структур),
// заполняет ТаблицаПредпросмотра и запускает сверку с базой.
// ---------------------------------------------------------------------------
&НаСервере
Процедура ЗагрузитьПредпросмотрНаСервере(МассивСтрок, ПутьКФайлу, СекундExcelНаКлиенте = 0)
    
    ВремяНачала = ТекущаяДатаСеанса();
    ЗаписатьЛог("=== Старт загрузки предпросмотра. Файл: " + ПутьКФайлу + " ===");
    
    ТаблицаПредпросмотра.Очистить();
    
    Для Каждого СтрокаExcel Из МассивСтрок Цикл
        НоваяСтрока = ТаблицаПредпросмотра.Добавить();
        НоваяСтрока.Обработать = Ложь;
        НоваяСтрока.НаименованиеКонтрагента = СтрокаExcel.НаименованиеКонтрагента;
        НоваяСтрока.ИНН = СтрокаExcel.ИНН;
        НоваяСтрока.КПП = СтрокаExcel.КПП;
        НоваяСтрока.Email = СтрокаExcel.Email;
        НоваяСтрока.Клиент = НРег(СтрокаExcel.Клиент);
        НоваяСтрока.Поставщик = НРег(СтрокаExcel.Поставщик);
        НоваяСтрока.ПометкаУдаления = НРег(СтрокаExcel.ПометкаУдаления);
        НоваяСтрока.Код = СтрокаExcel.Код;
        НоваяСтрока.НомерРасчетногоСчета = СтрокаExcel.НомерРасчетногоСчета;
        НоваяСтрока.БИКБанка = СтрокаExcel.БИКБанка;
        НоваяСтрока.НаименованиеБанка = СтрокаExcel.НаименованиеБанка;
        НоваяСтрока.СоответствиеИНН = Ложь;
        НоваяСтрока.СоответствиеКПП = Ложь;
        НоваяСтрока.СоответствиеРасчСчет = Ложь;
        НоваяСтрока.СтрокаЗаблокирована = Ложь;
    КонецЦикла;
    
    ЗаполнитьФлагиСоответствия();
    
    СекундСервер = ТекущаяДатаСеанса() - ВремяНачала;
    СекундВсего = СекундExcelНаКлиенте + СекундСервер;
    ЗаписатьЛог("Загружено строк: " + ТаблицаПредпросмотра.Количество()
        + ". Excel (клиент): " + СекундExcelНаКлиенте + " сек."
        + ", Сервер: " + СекундСервер + " сек."
        + ", Итого: " + СекундВсего + " сек.");
    
КонецПроцедуры

#КонецОбласти // Загрузка_Excel

// =============================================================================

#Область Сверка_С_Базой

// ---------------------------------------------------------------------------
// Пакетная сверка всех строк таблицы с базой УТ.
// Заполняет флаги СоответствиеИНН / СоответствиеКПП / СоответствиеРасчСчет.
// Строки, где все три флага = Истина — блокируются (СтрокаЗаблокирована).
// УстановитьОбработать = Истина — выставить Обработать по умолчанию (из предпросмотра).
//                       = Ложь  — сохранить текущий Обработать (вызов после загрузки).
// ---------------------------------------------------------------------------
&НаСервере
Процедура ЗаполнитьФлагиСоответствия(УстановитьОбработать = Истина)
    
    Если ТаблицаПредпросмотра.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;
    
    МассивИНН = Новый Массив;
    Для Каждого Строка Из ТаблицаПредпросмотра Цикл
        Если ЗначениеЗаполнено(Строка.ИНН) Тогда
            МассивИНН.Добавить(Строка.ИНН);
        КонецЕсли;
    КонецЦикла;
    
    // Два пакетных запроса по всем ИНН сразу
    СоотвИНН_КПП = ПолучитьСоответствиеИНН_КПП(МассивИНН);
    СоотвСчета = ПолучитьСоответствиеСчетов(МассивИНН);
    
    Для Каждого Строка Из ТаблицаПредпросмотра Цикл
        
        ИНН = Строка.ИНН;
        КПП = Строка.КПП;
        
        // У ИП (ИНН 12 цифр) КПП не бывает по определению
        ЭтоИП = СтрДлина(СокрЛП(ИНН)) = 12;
        
        // Флаг ИНН
        МассивКПП = СоотвИНН_КПП.Получить(ИНН);
        ЕстьИНН = МассивКПП <> Неопределено И МассивКПП.Количество() > 0;
        Строка.СоответствиеИНН = ЕстьИНН;
        
        // Флаг КПП
        // Для ИП КПП не применимо — если ИНН совпал, КПП считаем совпавшим автоматически.
        // Для юрлиц — сравниваем явно.
        Если ЕстьИНН Тогда
            Если ЭтоИП Тогда
                Строка.СоответствиеКПП = Истина; // у ИП КПП нет
            Иначе
                Строка.СоответствиеКПП = МассивКПП.Найти(СокрЛП(КПП)) <> Неопределено;
            КонецЕсли;
        Иначе
            Строка.СоответствиеКПП = Ложь;
        КонецЕсли;
        
        // Флаг расчётного счёта — только если ИНН и КПП совпали
        Если Строка.СоответствиеКПП И ЗначениеЗаполнено(Строка.НомерРасчетногоСчета) Тогда
            // Для ИП ключ — только ИНН (КПП пустой), для юрлиц — ИНН|КПП
            КлючИНН_КПП = ИНН + "|" + ?(ЭтоИП, "", СокрЛП(КПП));
            МассивСчетов = СоотвСчета.Получить(КлючИНН_КПП);
            Строка.СоответствиеРасчСчет = МассивСчетов <> Неопределено
                И МассивСчетов.Найти(Строка.НомерРасчетногоСчета) <> Неопределено;
        Иначе
            Строка.СоответствиеРасчСчет = Ложь;
        КонецЕсли;
        
        // Блокировка строки:
        // — для юрлиц: все три флага должны совпасть
        // — для ИП: ИНН совпал И (счёт совпал ИЛИ счёта в файле нет) → добавлять нечего
        Если ЭтоИП Тогда
            Строка.СтрокаЗаблокирована = Строка.СоответствиеИНН
                И (Строка.СоответствиеРасчСчет ИЛИ НЕ ЗначениеЗаполнено(Строка.НомерРасчетногоСчета));
        Иначе
            Строка.СтрокаЗаблокирована = Строка.СоответствиеИНН
                И Строка.СоответствиеКПП
                И Строка.СоответствиеРасчСчет;
        КонецЕсли;
        
        // Управление флагом Обработать:
        // при первичной загрузке — выставляем сами; после сохранения — сохраняем выбор пользователя
        Если Строка.СтрокаЗаблокирована Тогда
            Строка.Обработать = Ложь; // дубль — всегда снимаем
        ИначеЕсли УстановитьОбработать Тогда
            Строка.Обработать = Истина; // первичная загрузка — отмечаем всё
        КонецЕсли;
        
    КонецЦикла;
    
КонецПроцедуры

// Возвращает Соответствие: ИНН -> Массив КПП (из Справочник.Контрагенты в базе УТ).
&НаСервере
Функция ПолучитьСоответствиеИНН_КПП(МассивИНН)
    
    Результат = Новый Соответствие;
    
    Если МассивИНН.Количество() = 0 Тогда
        Возврат Результат;
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   Контрагенты.ИНН  КАК ИНН,
        |   Контрагенты.КПП  КАК КПП
        |ИЗ
        |   Справочник.Контрагенты КАК Контрагенты
        |ГДЕ
        |   Контрагенты.ИНН В (&МассивИНН)
        |   И НЕ Контрагенты.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("МассивИНН", МассивИНН);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Если Результат.Получить(Выборка.ИНН) = Неопределено Тогда
            Результат.Вставить(Выборка.ИНН, Новый Массив);
        КонецЕсли;
        Результат[Выборка.ИНН].Добавить(Выборка.КПП);
    КонецЦикла;
    
    Возврат Результат;
    
КонецФункции

// Возвращает Соответствие: "ИНН|КПП" -> Массив НомеровСчетов (из базы УТ).
&НаСервере
Функция ПолучитьСоответствиеСчетов(МассивИНН)
    
    Результат = Новый Соответствие;
    
    Если МассивИНН.Количество() = 0 Тогда
        Возврат Результат;
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   Контрагенты.ИНН         КАК ИНН,
        |   Контрагенты.КПП         КАК КПП,
        |   Счета.НомерСчета        КАК НомерСчета
        |ИЗ
        |   Справочник.Контрагенты КАК Контрагенты
        |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчетаКонтрагентов КАК Счета
        |       ПО Контрагенты.Ссылка = Счета.Владелец
        |ГДЕ
        |   Контрагенты.ИНН В (&МассивИНН)
        |   И НЕ Контрагенты.ПометкаУдаления
        |   И НЕ Счета.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("МассивИНН", МассивИНН);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Ключ = Выборка.ИНН + "|" + Выборка.КПП;
        Если Результат.Получить(Ключ) = Неопределено Тогда
            Результат.Вставить(Ключ, Новый Массив);
        КонецЕсли;
        Результат[Ключ].Добавить(Выборка.НомерСчета);
    КонецЦикла;
    
    Возврат Результат;
    
КонецФункции

// Ищет контрагента только по ИНН — для ИП (у которых КПП нет).
// Возвращает ссылку первого найденного или ПустаяСсылка.
&НаСервере
Функция НайтиКонтрагентаПоИНН(ИНН)
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Контрагенты.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Контрагенты КАК Контрагенты
        |ГДЕ
        |   Контрагенты.ИНН = &ИНН
        |   И НЕ Контрагенты.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("ИНН", ИНН);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    Возврат Справочники.Контрагенты.ПустаяСсылка();
    
КонецФункции

// Ищет ссылку контрагента по паре ИНН + КПП. Возвращает ПустаяСсылка если не найден.
&НаСервере
Функция НайтиКонтрагентаПоИНН_КПП(ИНН, КПП)
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Контрагенты.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Контрагенты КАК Контрагенты
        |ГДЕ
        |   Контрагенты.ИНН = &ИНН
        |   И Контрагенты.КПП = &КПП
        |   И НЕ Контрагенты.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("ИНН", ИНН);
    Запрос.УстановитьПараметр("КПП", КПП);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    Возврат Справочники.Контрагенты.ПустаяСсылка();
    
КонецФункции

#КонецОбласти // Сверка_С_Базой

// =============================================================================

#Область Загрузка_В_Базу

// ---------------------------------------------------------------------------
// Серверная точка входа второй кнопки.
// Обрабатывает все строки с Обработать = Истина, каждую в транзакции.
// ---------------------------------------------------------------------------
&НаСервере
Процедура ЗагрузитьДанныеВ1СНаСервере() // BSLLS:CognitiveComplexity-off
    
    ВремяНачалаЗагрузки = ТекущаяДатаСеанса();
    ЗаписатьЛог("=== Старт загрузки данных в 1С ===");
    
    ОрганизацияСсылка = ПолучитьОрганизацию();
    Если НЕ ЗначениеЗаполнено(ОрганизацияСсылка) Тогда
        Сообщить("ОШИБКА: не удалось определить организацию. Обработка прервана.");
        ЗаписатьЛог("КРИТИЧЕСКАЯ ОШИБКА: организация не найдена");
        Возврат;
    КонецЕсли;
    
    УспешноОбработано = 0;
    ОшибокОбработки = 0;
    ЛимитСекунд = 2 * 60 * 60; // 2 часа
    ОстановленоПоВремени = Ложь;
    
    Для Каждого Строка Из ТаблицаПредпросмотра Цикл
        
        // Проверяем лимит времени перед каждой новой итерацией
        Если (ТекущаяДатаСеанса() - ВремяНачалаЗагрузки) >= ЛимитСекунд Тогда
            ОстановленоПоВремени = Истина;
            Прервать;
        КонецЕсли;
        
        Если НЕ Строка.Обработать Тогда
            Продолжить;
        КонецЕсли;
        
        НачатьТранзакцию();
        
        Попытка
            
            КонтрагентСсылка = ОбработатьСтроку(Строка, ОрганизацияСсылка);
            
            Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Тогда
                ВызватьИсключение "Не удалось получить / создать контрагента";
            КонецЕсли;
            
            ЗафиксироватьТранзакцию(); // BSLLS:CommitTransactionOutsideTryCatch-off
            
            Строка.Обработать = Ложь; // снимаем флаг после успеха
            УспешноОбработано = УспешноОбработано + 1;
            ЗаписатьЛог("УСПЕХ: " + Строка.НаименованиеКонтрагента + " | ИНН=" + Строка.ИНН);
            
        Исключение
            
            ОтменитьТранзакцию();
            ОшибокОбработки = ОшибокОбработки + 1;
            ТекстОшибки = "ОШИБКА [" + Строка.НаименованиеКонтрагента
                + " | ИНН=" + Строка.ИНН + "]: " + ОписаниеОшибки();
            ЗаписатьЛог(ТекстОшибки);
            Сообщить(ТекстОшибки);
            
        КонецПопытки;
        
    КонецЦикла;
    
    СекундЗагрузки = ТекущаяДатаСеанса() - ВремяНачалаЗагрузки;
    
    Если ОстановленоПоВремени Тогда
        ИтогТекст = "ОБРАБОТКА ПРЕРВАНА по лимиту времени (2 часа)."
            + " Успешно: " + УспешноОбработано
            + ", Ошибок: " + ОшибокОбработки
            + ". Время выполнения: " + СекундЗагрузки + " сек."
            + " Не обработанные строки остались отмеченными — запустите повторно.";
    Иначе
        ИтогТекст = "Обработка завершена. Успешно: " + УспешноОбработано
            + ", Ошибок: " + ОшибокОбработки
            + ". Время выполнения: " + СекундЗагрузки + " сек.";
    КонецЕсли;
    
    ЗаписатьЛог(ИтогТекст);
    Сообщить(ИтогТекст);
    
    // Обновляем только флаги соответствия, НЕ трогая выбор пользователя (Обработать)
    ЗаполнитьФлагиСоответствия(Ложь);
    
КонецПроцедуры

// ---------------------------------------------------------------------------
// Обрабатывает одну строку:
//   — определяет сценарий (новый / филиал / существующий),
//   — создаёт / находит контрагента,
//   — добавляет банковский счёт (если нужно),
//   — создаёт договора (если нужно).
// ---------------------------------------------------------------------------
&НаСервере
Функция ОбработатьСтроку(Строка, ОрганизацияСсылка)
    
    ЗаписатьЛог("Обработка: " + Строка.НаименованиеКонтрагента + " | ИНН=" + Строка.ИНН);
    
    ЭтоИП = СтрДлина(СокрЛП(Строка.ИНН)) = 12;
    
    Если Строка.СоответствиеИНН И Строка.СоответствиеКПП Тогда
        // Контрагент уже есть — только счёт / договора при необходимости
        Если ЭтоИП Тогда
            КонтрагентСсылка = НайтиКонтрагентаПоИНН(Строка.ИНН);
        Иначе
            КонтрагентСсылка = НайтиКонтрагентаПоИНН_КПП(Строка.ИНН, Строка.КПП);
        КонецЕсли;
        ЗаписатьЛог("Найден существующий: " + Строка(КонтрагентСсылка));
        
    ИначеЕсли Строка.СоответствиеИНН И НЕ Строка.СоответствиеКПП Тогда
        Если ЭтоИП Тогда
            // ИП не может иметь КПП и не может иметь «филиалов» — ищем по ИНН
            КонтрагентСсылка = НайтиКонтрагентаПоИНН(Строка.ИНН);
            Если ЗначениеЗаполнено(КонтрагентСсылка) Тогда
                ЗаписатьЛог("ИП найден по ИНН: " + Строка(КонтрагентСсылка));
            Иначе
                ЗаписатьЛог("Создаём нового ИП: ИНН=" + Строка.ИНН);
                КонтрагентСсылка = СоздатьКонтрагента(Строка);
            КонецЕсли;
        Иначе
            // ИНН есть, КПП другой → новый филиал юрлица
            ЗаписатьЛог("Создаём филиал: ИНН=" + Строка.ИНН + ", КПП=" + Строка.КПП);
            КонтрагентСсылка = СоздатьКонтрагента(Строка);
        КонецЕсли;
        
    Иначе
        // Нет ни ИНН в базе — создаём с нуля
        ЗаписатьЛог("Создаём нового: ИНН=" + Строка.ИНН);
        КонтрагентСсылка = СоздатьКонтрагента(Строка);
        
    КонецЕсли;
    
    Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Тогда
        Возврат Справочники.Контрагенты.ПустаяСсылка();
    КонецЕсли;
    
    // Банковский счёт — если расчётный счёт есть в строке и ещё не сошёлся
    Если НЕ Строка.СоответствиеРасчСчет
        И ЗначениеЗаполнено(Строка.НомерРасчетногоСчета) Тогда
        СоздатьБанковскийСчет(КонтрагентСсылка, Строка);
    КонецЕсли;
    
    // Договора
    ДатаДоговора = ТекущаяДатаСеанса();
    
    Если НРег(Строка.Клиент) = "да" Тогда
        НайтиИлиСоздатьДоговор(
            КонтрагентСсылка,
            ОрганизацияСсылка,
            Перечисления.ТипыДоговоров.СПокупателем,
            ДатаДоговора,
            ПолучитьСтатьюДДС("Поступление оплаты от клиента"));
    КонецЕсли;
    
    Если НРег(Строка.Поставщик) = "да" Тогда
        НайтиИлиСоздатьДоговор(
            КонтрагентСсылка,
            ОрганизацияСсылка,
            Перечисления.ТипыДоговоров.СПоставщиком,
            ДатаДоговора,
            ПолучитьСтатьюДДС("Оплата поставщику"));
    КонецЕсли;
    
    Возврат КонтрагентСсылка;
    
КонецФункции

// Создаёт нового партнёра и связанного с ним контрагента.
&НаСервере
Функция СоздатьКонтрагента(Строка)
    
    ВидКонтрагента = ОпределитьВидКонтрагентаПоИНН(Строка.ИНН);
    
    // --- Партнёр ---
    НовыйПартнер = Справочники.Партнеры.СоздатьЭлемент();
    НовыйПартнер.Наименование = Строка.НаименованиеКонтрагента;
    НовыйПартнер.Клиент = НРег(Строка.Клиент) = "да";
    НовыйПартнер.Поставщик = НРег(Строка.Поставщик) = "да";
    НовыйПартнер.ДатаРегистрации = ТекущаяДатаСеанса(); // дата создания карточки
    
    // В УТ у Партнера поле ЮрФизЛицо обычно хранит перечисление КомпанияЧастноеЛицо.
    // Если не заполнить его явно, в карточке может отображаться "текст", а не корректная ссылка перечисления.
    Попытка
        ВидПартнера = ПолучитьКомпанияЧастноеЛицоДляПартнера(ВидКонтрагента);
        Если ВидПартнера <> Неопределено Тогда
            НовыйПартнер.ЮрФизЛицо = ВидПартнера;
        КонецЕсли;
    Исключение
        ЗаписатьЛог("Предупреждение: не удалось задать Партнер.ЮрФизЛицо для ИНН="
            + Строка.ИНН + ": " + ОписаниеОшибки());
    КонецПопытки;
    
    МенеджерСсылка = ПолучитьМенеджераКучерук();
    Если ЗначениеЗаполнено(МенеджерСсылка) Тогда
        Попытка
            НовыйПартнер.ОсновнойМенеджер = МенеджерСсылка;
        Исключение // BSLLS:MissingCodeTryCatchEx-off
        КонецПопытки;
    КонецЕсли;
    
    НовыйПартнер.Записать();
    
    // --- Контрагент ---
    НовыйКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
    НовыйКонтрагент.Наименование = Строка.НаименованиеКонтрагента;
    НовыйКонтрагент.НаименованиеПолное = Строка.НаименованиеКонтрагента;
    НовыйКонтрагент.ИНН = Строка.ИНН;
    НовыйКонтрагент.КПП = Строка.КПП;
    НовыйКонтрагент.Партнер = НовыйПартнер.Ссылка;
    
    // Синхронно заполняем связанные поля "вида контрагента" корректными перечислениями.
    Попытка
        Если ВидКонтрагента <> Неопределено Тогда
            НовыйКонтрагент.ЮрФизЛицо = ВидКонтрагента;
            
            ВидЮрФиз = ПолучитьЮридическоеФизическоеЛицо(ВидКонтрагента);
            Если ВидЮрФиз <> Неопределено Тогда
                НовыйКонтрагент.ЮридическоеФизическоеЛицо = ВидЮрФиз;
            КонецЕсли;
        КонецЕсли;
    Исключение
        ЗаписатьЛог("Предупреждение: не удалось задать вид контрагента для ИНН=" + Строка.ИНН
            + ": " + ОписаниеОшибки());
    КонецПопытки;
    
    // Email-заглушка: ИНН@mail.ru (обходим обязательное поле системы)
    ЗагрузитьEmailКонтрагента(НовыйКонтрагент, Строка.ИНН);
    
    НовыйКонтрагент.Записать();
    
    ЗаписатьЛог("Создан контрагент: " + Строка.НаименованиеКонтрагента
        + " | ИНН=" + Строка.ИНН + " | Партнёр=" + Строка(НовыйПартнер.Ссылка));
    
    Возврат НовыйКонтрагент.Ссылка;
    
КонецФункции

// Добавляет email-заглушку ИНН@mail.ru в табличную часть КонтактнаяИнформация.
&НаСервере
Процедура ЗагрузитьEmailКонтрагента(КонтрагентОбъект, ИНН)
    
    EmailЗаглушка = ИНН + "@mail.ru";
    
    Попытка
        СтрокаКИ = КонтрагентОбъект.КонтактнаяИнформация.Добавить();
        СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
        СтрокаКИ.АдресЭП = EmailЗаглушка;
        СтрокаКИ.Представление = EmailЗаглушка;
    Исключение
        ЗаписатьЛог("Предупреждение: не удалось заполнить email для ИНН=" + ИНН
            + ": " + ОписаниеОшибки());
    КонецПопытки;
    
КонецПроцедуры

// Создаёт банковский счёт контрагента в Справочник.БанковскиеСчетаКонтрагентов.
&НаСервере
Процедура СоздатьБанковскийСчет(КонтрагентСсылка, Строка)
    
    Попытка
        НовыйСчет = Справочники.БанковскиеСчетаКонтрагентов.СоздатьЭлемент();
        НовыйСчет.Владелец = КонтрагентСсылка;
        НовыйСчет.НомерСчета = Строка.НомерРасчетногоСчета;
        НовыйСчет.БИКБанка = Строка.БИКБанка;
        
        Если ЗначениеЗаполнено(Строка.БИКБанка) Тогда
            БанкСсылка = НайтиБанкПоБИК(Строка.БИКБанка);
            Если ЗначениеЗаполнено(БанкСсылка) Тогда
                НовыйСчет.Банк = БанкСсылка;
            КонецЕсли;
        КонецЕсли;
        
        НовыйСчет.Записать();
        ЗаписатьЛог("Создан банковский счёт: " + Строка.НомерРасчетногоСчета
            + " | БИК=" + Строка.БИКБанка);
        
    Исключение
        ЗаписатьЛог("ОШИБКА создания банковского счёта: " + ОписаниеОшибки());
        ВызватьИсключение;
    КонецПопытки;
    
КонецПроцедуры

// Ищет банк в Справочник.КлассификаторБанков по БИК.
&НаСервере
Функция НайтиБанкПоБИК(БИК)
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Банки.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.КлассификаторБанков КАК Банки
        |ГДЕ
        |   Банки.Код = &БИК
        |   И НЕ Банки.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("БИК", БИК);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    ЗаписатьЛог("Предупреждение: банк с БИК=" + БИК + " не найден в классификаторе");
    Возврат Справочники.КлассификаторБанков.ПустаяСсылка();
    
КонецФункции

// ---------------------------------------------------------------------------
// Ищет существующий договор или создаёт новый.
// Адаптировано из рабочего примера в промт-документе.
// ---------------------------------------------------------------------------
&НаСервере
Функция НайтиИлиСоздатьДоговор(КонтрагентСсылка, ОрганизацияСсылка, ТипДоговора, ДатаДокумента, СтатьяДДССсылка)
    
    Если НЕ ЗначениеЗаполнено(КонтрагентСсылка)
        ИЛИ НЕ ЗначениеЗаполнено(ОрганизацияСсылка)
        ИЛИ ТипДоговора = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;
    
    // Ищем существующий договор
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Договоры.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.ДоговорыКонтрагентов КАК Договоры
        |ГДЕ
        |   Договоры.Контрагент   = &Контрагент
        |   И Договоры.Организация = &Организация
        |   И Договоры.ТипДоговора = &ТипДоговора
        |   И НЕ Договоры.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("Контрагент", КонтрагентСсылка);
    Запрос.УстановитьПараметр("Организация", ОрганизацияСсылка);
    Запрос.УстановитьПараметр("ТипДоговора", ТипДоговора);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        ЗаписатьЛог("Найден существующий договор: " + Строка(Выборка.Ссылка));
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    // Создаём новый договор
    Попытка
        НовыйДоговор = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();
        
        НовыйДоговор.Контрагент = КонтрагентСсылка;
        НовыйДоговор.Организация = ОрганизацияСсылка;
        НовыйДоговор.ТипДоговора = ТипДоговора;
        
        // Партнёр
        ПартнерСсылка = ПолучитьПартнераКонтрагента(КонтрагентСсылка);
        Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
            Попытка
                НовыйДоговор.Партнер = ПартнерСсылка;
            Исключение // BSLLS:MissingCodeTryCatchEx-off
            КонецПопытки;
        КонецЕсли;
        
        // Наименование
        Если ТипДоговора = Перечисления.ТипыДоговоров.СПокупателем Тогда
            НовыйДоговор.Наименование = "Договор Реализации автосоздание";
        ИначеЕсли ТипДоговора = Перечисления.ТипыДоговоров.СПоставщиком Тогда
            НовыйДоговор.Наименование = "Договор Закупки автосоздание";
        Иначе
            НовыйДоговор.Наименование = "Договор автосоздание";
        КонецЕсли;
        
        // Статус
        Попытка
            НовыйДоговор.Статус = Перечисления.СтатусыДоговоровКонтрагентов.Действует;
        Исключение
            ЗаписатьЛог("Предупреждение: не удалось установить статус договора: "
                + ОписаниеОшибки());
        КонецПопытки;
        
        // Менеджер
        МенеджерСсылка = ПолучитьМенеджераКучерук();
        Если ЗначениеЗаполнено(МенеджерСсылка) Тогда
            Попытка
                НовыйДоговор.Менеджер = МенеджерСсылка;
            Исключение // BSLLS:MissingCodeTryCatchEx-off
            КонецПопытки;
        КонецЕсли;
        
        // НДС («Определяется в заказах и накладных» = ПродажаОблагаетсяНДС в типовой УТ)
        Попытка
            НовыйДоговор.НалогообложениеНДС =
                Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
        Исключение
            ЗаписатьЛог("Предупреждение: не удалось установить тип НДС: "
                + ОписаниеОшибки());
        КонецПопытки;
        
        // Статья ДДС
        Попытка
            Если ЗначениеЗаполнено(СтатьяДДССсылка) Тогда
                НовыйДоговор.СтатьяДвиженияДенежныхСредств = СтатьяДДССсылка;
            КонецЕсли;
        Исключение
            ЗаписатьЛог("Предупреждение: не удалось установить статью ДДС: "
                + ОписаниеОшибки());
        КонецПопытки;
        
        НовыйДоговор.Записать();
        
        ЗаписатьЛог("Создан договор: " + НовыйДоговор.Наименование);
        Возврат НовыйДоговор.Ссылка;
        
    Исключение
        ЗаписатьЛог("ОШИБКА создания договора: " + ОписаниеОшибки());
        ВызватьИсключение;
    КонецПопытки;
    
КонецФункции

// Возвращает ссылку на Партнёра контрагента через реквизит Партнер.
&НаСервере
Функция ПолучитьПартнераКонтрагента(КонтрагентСсылка)
    
    Попытка
        ПартнерСсылка = КонтрагентСсылка.Партнер;
        Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
            Возврат ПартнерСсылка;
        КонецЕсли;
    Исключение // BSLLS:MissingCodeTryCatchEx-off
    КонецПопытки;
    
    Возврат Справочники.Партнеры.ПустаяСсылка();
    
КонецФункции

// Определяет первую не удалённую организацию (для заполнения договоров).
&НаСервере
Функция ПолучитьОрганизацию()
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Организации.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Организации КАК Организации
        |ГДЕ
        |   НЕ Организации.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО
        |   Организации.Наименование";
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    Возврат Справочники.Организации.ПустаяСсылка();
    
КонецФункции

// Находит пользователя «Кучерук Алексей Александрович» в Справочник.Пользователи.
// Запасной вариант — поиск по шаблону «%Кучерук%».
&НаСервере
Функция ПолучитьМенеджераКучерук()
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Пользователи.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Пользователи КАК Пользователи
        |ГДЕ
        |   Пользователи.Наименование = &Наименование
        |   И НЕ Пользователи.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("Наименование", "Кучерук Алексей Александрович");
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    // Запасной вариант — по фамилии
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Пользователи.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Пользователи КАК Пользователи
        |ГДЕ
        |   Пользователи.Наименование ПОДОБНО &Шаблон
        |   И НЕ Пользователи.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("Шаблон", "%Кучерук%");
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    ЗаписатьЛог("Предупреждение: пользователь «Кучерук» не найден в справочнике Пользователи");
    Возврат Справочники.Пользователи.ПустаяСсылка();
    
КонецФункции

// Ищет статью ДДС по точному наименованию в Справочник.СтатьиДвиженияДенежныхСредств.
&НаСервере
Функция ПолучитьСтатьюДДС(Наименование)
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   СтатьиДДС.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.СтатьиДвиженияДенежныхСредств КАК СтатьиДДС
        |ГДЕ
        |   СтатьиДДС.Наименование = &Наименование
        |   И НЕ СтатьиДДС.ПометкаУдаления";
    
    Запрос.УстановитьПараметр("Наименование", Наименование);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;
    
    ЗаписатьЛог("Предупреждение: статья ДДС «" + Наименование + "» не найдена");
    Возврат Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка();
    
КонецФункции

// Определяет вид контрагента по ИНН:
// 10 символов -> ЮрЛицо, 12 символов -> ИндивидуальныйПредприниматель.
&НаСервере
Функция ОпределитьВидКонтрагентаПоИНН(ИНН)
    
    НормИНН = СокрЛП(ИНН);
    Если СтрДлина(НормИНН) = 10 Тогда
        Возврат Перечисления.ЮрФизЛицо.ЮрЛицо;
    ИначеЕсли СтрДлина(НормИНН) = 12 Тогда
        Возврат Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель;
    КонецЕсли;
    
    Возврат Неопределено;
    
КонецФункции

// Преобразует ЮрФизЛицо контрагента в перечисление Партнера (Компания/ЧастноеЛицо).
&НаСервере
Функция ПолучитьКомпанияЧастноеЛицоДляПартнера(ЗначениеЮрФизЛицоКонтрагента)
    
    Если ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ЮрЛицо
        Или ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент Тогда
        Возврат Перечисления.КомпанияЧастноеЛицо.Компания;
    КонецЕсли;
    
    Если ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо
        Или ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель Тогда
        Возврат Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо;
    КонецЕсли;
    
    Возврат Неопределено;
    
КонецФункции

// Преобразует ЮрФизЛицо в служебное поле Контрагент.ЮридическоеФизическоеЛицо.
&НаСервере
Функция ПолучитьЮридическоеФизическоеЛицо(ЗначениеЮрФизЛицоКонтрагента)
    
    Если ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ЮрЛицо
        Или ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент Тогда
        Возврат Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;
    КонецЕсли;
    
    Если ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо
        Или ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель Тогда
        Возврат Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо;
    КонецЕсли;
    
    Возврат Неопределено;
    
КонецФункции

#КонецОбласти // Загрузка_В_Базу

