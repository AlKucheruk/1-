&НаСервере
Процедура ЗаписатьЛог(Текст) Экспорт
    
    ПутьКФайлу = "D:\1с\КАА\Лог_Обработка_Соглашения.txt"; // BSLLS:UsingHardcodePath-off
    
    Попытка
        Запись = Новый ЗаписьТекста(ПутьКФайлу, КодировкаТекста.UTF8, , Истина); // добавлять в конец
        
        СтрокаЛога = Формат(ТекущаяДатаСеанса(), "ДФ=yyyy-MM-dd HH:mm:ss") + " | " + Текст;
        Запись.ЗаписатьСтроку(СтрокаЛога);
        Запись.Закрыть();
        
    Исключение
        Попытка
            СообщитьПользователю("ОШИБКА ЗАПИСИ ЛОГА: " + ОписаниеОшибки());
        Исключение // BSLLS:MissingCodeTryCatchEx-off
        КонецПопытки;
    КонецПопытки;
    
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьПредпросмотрНаКлиенте()
    ЗагрузитьПредпросмотрНаСервере();
КонецПроцедуры

&НаСервере
Функция ПолучитьСоответствиеДоговоровКонтрагентов(МассивКонтрагентов)
    
    СоответствиеДоговоров = Новый Соответствие;
    
    Если МассивКонтрагентов = Неопределено ИЛИ МассивКонтрагентов.Количество() = 0 Тогда
        Возврат СоответствиеДоговоров;
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |   Договоры.Контрагент КАК Контрагент
        |   , МИНИМУМ(Договоры.Ссылка) КАК ДоговорКонтрагента
        |ИЗ
        |   Справочник.ДоговорыКонтрагентов КАК Договоры
        |ГДЕ
        |   Договоры.Контрагент В(&Контрагенты)
        |   И НЕ Договоры.ПометкаУдаления
        |   И Договоры.ТипДоговора = ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.СПокупателем)
        |СГРУППИРОВАТЬ ПО
        |   Договоры.Контрагент";
    
    Запрос.УстановитьПараметр("Контрагенты", МассивКонтрагентов);
    
    Выборка = Запрос.Выполнить().Выбрать();
    
    Пока Выборка.Следующий() Цикл
        СоответствиеДоговоров.Вставить(Выборка.Контрагент, Выборка.ДоговорКонтрагента);
    КонецЦикла;
    
    Возврат СоответствиеДоговоров;
    
КонецФункции

&НаКлиенте
Процедура ВыбратьВсе(Команда)
    
    Если ТаблицаДанных.Количество() = 0 Тогда
        СообщитьПользователю("Нет данных для выбора");
        Возврат;
    КонецЕсли;
    
    Для Каждого Строка Из ТаблицаДанных Цикл
        Строка.Выбрать = Истина;
    КонецЦикла;
    
КонецПроцедуры

&НаКлиенте
Процедура СнятьВсе(Команда)
    
    Если ТаблицаДанных.Количество() = 0 Тогда
        СообщитьПользователю("Нет данных");
        Возврат;
    КонецЕсли;
    
    Для Каждого Строка Из ТаблицаДанных Цикл
        Строка.Выбрать = Ложь;
    КонецЦикла;
    
КонецПроцедуры


&НаСервере
Процедура ЗагрузитьПредпросмотрНаСервере() // BSLLS:CognitiveComplexity-off
    
    ЗаписатьЛог("=== Старт загрузки предпросмотра ===");
    
    Попытка
        ТаблицаДанных.Очистить();
        ЗаписатьЛог("ТаблицаДанных очищена");
        ЗаписатьЛог("Контрагент: " + Строка(Контрагент));
        ЗаписатьЛог("ДатаНачала: " + Формат(ДатаНачала, "ДФ=yyyy-MM-dd"));
        ЗаписатьЛог("ДатаОкончания: " + Формат(ДатаОкончания, "ДФ=yyyy-MM-dd"));
        ЗаписатьЛог("Ограничить 100 записей: " + ?(Ограничить100, "ДА", "НЕТ"));
        
        Запрос = Новый Запрос;
        
        Если Ограничить100 Тогда
            ТекстВыборки = "ВЫБРАТЬ ПЕРВЫЕ 100";
            ЗаписатьЛог("Применено ограничение ПЕРВЫЕ 100");
        Иначе
            ТекстВыборки = "ВЫБРАТЬ";
            ЗаписатьЛог("Ограничение снято - загружаем ВСЕ документы");
        КонецЕсли;
        
        Запрос.Текст = ТекстВыборки + "
            |    Реализация.Ссылка 				КАК Ссылка
            |    , Реализация.Номер 			КАК Номер
            |    , Реализация.Дата 				КАК Дата
            |    , Реализация.Контрагент 		КАК Контрагент
            |    , Реализация.СуммаДокумента	КАК СуммаДокумента
            |    , Реализация.Соглашение 		КАК Соглашение
            |    , Реализация.Договор 			КАК Договор
            |ИЗ
            |    Документ.РеализацияТоваровУслуг КАК Реализация
            |ГДЕ
            |    Реализация.Проведен
            |    И Реализация.Дата >= &ДатаНачала
            |    И Реализация.Дата <= &ДатаОкончания";
        
        Если ЗначениеЗаполнено(Контрагент) Тогда
            Запрос.Текст = Запрос.Текст + "
                |    И Реализация.Контрагент = &Контрагент";
        КонецЕсли;
        
        Запрос.Текст = Запрос.Текст + "
            |
            |УПОРЯДОЧИТЬ ПО
            |    Реализация.Дата УБЫВ";
        
        Запрос.УстановитьПараметр("ДатаНачала",
            ?(ЗначениеЗаполнено(ДатаНачала), НачалоДня(ДатаНачала), Дата(1, 1, 1)));
        
        Запрос.УстановитьПараметр("ДатаОкончания",
            ?(ЗначениеЗаполнено(ДатаОкончания), КонецДня(ДатаОкончания), Дата(3999, 12, 31))); // BSLLS:MagicNumber-off
        
        Если ЗначениеЗаполнено(Контрагент) Тогда
            Запрос.УстановитьПараметр("Контрагент", Контрагент);
        КонецЕсли;
        
        ЗаписатьЛог("Запрос подготовлен, выполняем...");
        
        Результат = Запрос.Выполнить();
        Выборка = Результат.Выбрать();
        
        ЗаписатьЛог("Запрос выполнен. Найдено строк: " + Строка(Выборка.Количество()));
        
        Пока Выборка.Следующий() Цикл
            НоваяСтрока = ТаблицаДанных.Добавить();
            
            НоваяСтрока.Выбрать = Ложь;
            НоваяСтрока.Реализация = Выборка.Ссылка;
            НоваяСтрока.Заказ = Выборка.Ссылка.ЗаказКлиента;
            НоваяСтрока.Сумма = Выборка.СуммаДокумента;
            НоваяСтрока.Соглашение = Выборка.Соглашение;
            НоваяСтрока.Договор = Выборка.Договор;
            НоваяСтрока.Контрагент = Выборка.Контрагент;
            
            ДоговорКонтрагента = Неопределено;
            Если НЕ ЗначениеЗаполнено(Выборка.Договор)
                И ЗначениеЗаполнено(Выборка.Контрагент)
                И СоответствиеДоговоров.СодержитКлюч(Выборка.Контрагент) Тогда
                
                ДоговорКонтрагента = СоответствиеДоговоров.Получить(Выборка.Контрагент);
            КонецЕсли;
            
            НоваяСтрока.ДоговорКонтрагента = ДоговорКонтрагента;
            
            НоваяСтрока.СФ = Неопределено;
            НоваяСтрока.ТТН = Неопределено;
            НоваяСтрока.Комментарий = "";
            
            Если НЕ ЗначениеЗаполнено(Выборка.Соглашение) Тогда
                НоваяСтрока.Комментарий = "Нет соглашения";
            КонецЕсли;
            
            Если НЕ ЗначениеЗаполнено(Выборка.Договор)
                И НЕ ЗначениеЗаполнено(ДоговорКонтрагента) Тогда
                
                Если ЗначениеЗаполнено(НоваяСтрока.Комментарий) Тогда
                    НоваяСтрока.Комментарий = НоваяСтрока.Комментарий + " | ";
                КонецЕсли;
                
                НоваяСтрока.Комментарий = НоваяСтрока.Комментарий + "Нет договора контрагента";
            КонецЕсли;
            
        КонецЦикла;
        
        ЗаписатьЛог("Завершение загрузки. Обработано строк: " + Строка(ТаблицаДанных.Количество()));
        
    Исключение
        ТекстОшибки = "КРИТИЧЕСКАЯ ОШИБКА: " + ОписаниеОшибки() + Символы.ПС +
            "Подробное описание: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
        
        ЗаписатьЛог(ТекстОшибки);
        СообщитьПользователю(ТекстОшибки);
    КонецПопытки;
    
КонецПроцедуры

#Область Проводка_транзакции_изменения_документов

&НаКлиенте
Процедура ПодтянутьСоглашения(Команда)
    ПодтянутьСоглашенияНаСервере();
КонецПроцедуры

&НаСервере
Процедура ПодтянутьСоглашенияНаСервере() // BSLLS:CognitiveComplexity-off
    
    ЗаписатьЛог("=== Старт применения изменений ===");
    
    Если НЕ ЗначениеЗаполнено(Соглашение) Тогда
        СообщитьПользователю("Не выбрано соглашение!");
        Возврат;
    КонецЕсли;
    
    Для Каждого Строка Из ТаблицаДанных Цикл
        
        Если НЕ Строка.Выбрать Тогда
            Продолжить;
        КонецЕсли;
        
        // === ПРОПУСК ЕСЛИ УЖЕ ВСЁ ЗАПОЛНЕНО ===
        РеализацияОбъект = Строка.Реализация.ПолучитьОбъект();
        
        Если ЗначениеЗаполнено(РеализацияОбъект.Соглашение)
            И ЗначениеЗаполнено(РеализацияОбъект.Договор) Тогда
            
            Если РеализацияОбъект.Соглашение = Соглашение Тогда
                
                Строка.Комментарий = "Пропущено (уже заполнено)";
                ЗаписатьЛог("ПРОПУЩЕНО: " + Строка(Строка.Реализация));
                
                Продолжить;
                
            КонецЕсли;
            
        КонецЕсли;
        
        НачатьТранзакцию();
        
        Попытка
            
            ЗаписатьЛог("Обработка: " + Строка(Строка.Реализация));
            
            ЗаказОбъект = Неопределено;
            Если ЗначениеЗаполнено(РеализацияОбъект.ЗаказКлиента) Тогда
                ЗаказОбъект = РеализацияОбъект.ЗаказКлиента.ПолучитьОбъект();
            КонецЕсли;
            
            СтараяСумма = РеализацияОбъект.СуммаДокумента;
            
            Если ЗначениеЗаполнено(РеализацияОбъект.Договор) Тогда
                ДоговорКУстановке = РеализацияОбъект.Договор;
            Иначе
                ДоговорКУстановке = Строка.ДоговорКонтрагента;
            КонецЕсли;
            
            Если НЕ ЗначениеЗаполнено(ДоговорКУстановке) Тогда
                ВызватьИсключение "Не найден договор";
            КонецЕсли;
            
            // === ОБНОВЛЯЕМ ЗАКАЗ ===
            Если ЗаказОбъект <> Неопределено Тогда
                
                ЗаказОбъект.Соглашение = Соглашение;
                
                ЗаказОбъект.Договор = ДоговорКУстановке;
                
                ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
                
            КонецЕсли;
            
            // === ОБНОВЛЯЕМ РЕАЛИЗАЦИЮ ===
            РеализацияОбъект.Соглашение = Соглашение;
            
            РеализацияОбъект.Договор = ДоговорКУстановке;
            
            РеализацияОбъект.Записать(РежимЗаписиДокумента.Проведение);
            
            // === ПРОВЕРКА СУММЫ ===
            Если РеализацияОбъект.СуммаДокумента <> СтараяСумма Тогда
                ВызватьИсключение "Сумма изменилась!";
            КонецЕсли;
            
            ЗафиксироватьТранзакцию(); // BSLLS:CommitTransactionOutsideTryCatch-off
            
            // === УСПЕХ ===
            Строка.Комментарий = "OK";
            ЗаписатьЛог("УСПЕХ: " + Строка(Строка.Реализация));
            
        Исключение
            
            ОтменитьТранзакцию();
            
            Строка.Комментарий = "Ошибка: " + ОписаниеОшибки();
            ЗаписатьЛог("ОШИБКА: " + ОписаниеОшибки());
            
        КонецПопытки;
        
    КонецЦикла;
    
    СообщитьПользователю("Обработка завершена");
    
КонецПроцедуры

#КонецОбласти //Проводка_транзакции_изменения_документов