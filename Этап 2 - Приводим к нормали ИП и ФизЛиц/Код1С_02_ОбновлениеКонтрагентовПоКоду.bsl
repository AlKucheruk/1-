// BSLLS-off
// =============================================================================
// Внешняя обработка: Обновление контрагентов по коду (Этап 3)
// Назначение:
//   1) Загрузить Excel в таблицу на форме.
//   2) По кнопке "Обновить в 1С" пройти по строкам.
//   3) Найти контрагента по полю Код.
//   4) Сверить и обновить отличающиеся поля (кроме Код).
//   5) Записать изменения и лог.
// =============================================================================
//
// Как назвать реквизиты формы:
//
// 1) ПутьКФайлуExcel               - Строка(500)
//
// 2) ТаблицаПредварительныхДанных  - ТаблицаЗначений, колонки:
//    - Обработать      - Булево
//    - Название_ЕГР    - Строка(250)
//    - ОГРНИП          - Строка(20)
//    - ВидКонтрагента  - Строка(50)
//    - Клиент          - Строка(3)
//    - Поставщик       - Строка(3)
//    - ИНН             - Строка(12)
//    - Код             - Строка(20)
//    - Контрагент      - СправочникСсылка.Контрагенты
//    - Комментарий     - Строка(500)
//
// 3) Команды формы:
//    - ЗагрузитьПредварительныеДанные
//    - ОбновитьВ1С
//    - ВыделитьВсе
//    - СнятьВсе
//    - ОткрытьКарточкуКонтрагента
//
// Кнопки на форме:
//    - "Загрузить предварительные данные" -> ЗагрузитьПредварительныеДанные
//    - "Обновить в 1С"                    -> ОбновитьВ1С
// =============================================================================

#Область Инициализация

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

    Если НЕ ЗначениеЗаполнено(ПутьКФайлуExcel) Тогда
        ПутьКФайлуExcel = "D:\Programming\1С_Создаём контрагентов и договора\Этап 3 - Приводим к нормали ИП и ФизЛиц\Обработанные_Данные_26.04.07222.xlsx";
    КонецЕсли;

КонецПроцедуры

#КонецОбласти // Инициализация

#Область КомандыФормы

&НаКлиенте
Процедура ЗагрузитьПредварительныеДанные(Команда)

    ДиалогОткрытия = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
    ДиалогОткрытия.Заголовок = "Выберите файл Excel";
    ДиалогОткрытия.Фильтр = "Файлы Excel (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*";
    ДиалогОткрытия.МножественныйВыбор = Ложь;

    Если ЗначениеЗаполнено(ПутьКФайлуExcel) Тогда
        ДиалогОткрытия.ПолноеИмяФайла = ПутьКФайлуExcel;
    КонецЕсли;

    Если НЕ ДиалогОткрытия.Выбрать() Тогда
        Возврат;
    КонецЕсли;

    ПутьКФайлуExcel = ДиалогОткрытия.ПолноеИмяФайла;

    ВремяКлиент = ТекущаяДата();
    МассивСтрок = ПрочитатьExcelНаКлиенте(ПутьКФайлуExcel);
    Если МассивСтрок = Неопределено Тогда
        Возврат;
    КонецЕсли;

    СекундКлиент = ТекущаяДата() - ВремяКлиент;
    ЗагрузитьПредварительныеДанныеНаСервере(МассивСтрок, ПутьКФайлуExcel, СекундКлиент);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьВ1С(Команда)

    КоличествоКОбработке = 0;
    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        Если СтрокаТаблицы.Обработать Тогда
            КоличествоКОбработке = КоличествоКОбработке + 1;
        КонецЕсли;
    КонецЦикла;

    Если КоличествоКОбработке = 0 Тогда
        Сообщить("Нет отмеченных строк для обработки.");
        Возврат;
    КонецЕсли;

    ТекстВопроса = "Будет обработано строк: " + Строка(КоличествоКОбработке) + ". Продолжить?";
    Если Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
        Возврат;
    КонецЕсли;

    ОбновитьВ1СНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ВыделитьВсе(Команда)

    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        СтрокаТаблицы.Обработать = Истина;
    КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура СнятьВсе(Команда)

    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        СтрокаТаблицы.Обработать = Ложь;
    КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьКарточкуКонтрагента(Команда)

    ТекСтрока = Элементы.ТаблицаПредварительныхДанных.ТекущиеДанные;
    Если ТекСтрока = Неопределено Тогда
        Сообщить("Не выбрана строка.");
        Возврат;
    КонецЕсли;

    Если НЕ ЕстьПолеКонтрагентВСроке(ТекСтрока) Тогда
        Сообщить("В таблице нет колонки 'Контрагент'. Добавьте колонку типа СправочникСсылка.Контрагенты.");
        Возврат;
    КонецЕсли;

    Если НЕ ЗначениеЗаполнено(ТекСтрока.Контрагент) Тогда
        Сообщить("В строке нет ссылки на контрагента.");
        Возврат;
    КонецЕсли;

    ОткрытьФорму("Справочник.Контрагенты.ФормаЭлемента", Новый Структура("Ключ", ТекСтрока.Контрагент));

КонецПроцедуры

#КонецОбласти // КомандыФормы

#Область ЗагрузкаИзExcel

&НаКлиенте
Функция ПрочитатьExcelНаКлиенте(ПутьКФайлу) // BSLLS:CognitiveComplexity-off

    ОжидаемыеКолонки = Новый Массив;
    ОжидаемыеКолонки.Добавить("Название_ЕГР");
    ОжидаемыеКолонки.Добавить("ОГРНИП");
    ОжидаемыеКолонки.Добавить("ВидКонтрагента");
    ОжидаемыеКолонки.Добавить("Клиент");
    ОжидаемыеКолонки.Добавить("Поставщик");
    ОжидаемыеКолонки.Добавить("ИНН");
    ОжидаемыеКолонки.Добавить("Код");

    Excel = Неопределено;
    Книга = Неопределено;

    Попытка
        Excel = Новый COMОбъект("Excel.Application");
        Excel.Visible = Ложь;
        Excel.DisplayAlerts = Ложь;

        Книга = Excel.Workbooks.Open(ПутьКФайлу);
        Лист = Книга.Sheets(1);
        Диапазон = Лист.UsedRange;

        КолСтрок = Диапазон.Rows.Count;
        КолКолонок = Диапазон.Columns.Count;
        НачСтрока = Диапазон.Row;
        НачКолонка = Диапазон.Column;

        СоответствиеКолонок = Новый Соответствие;
        Для Инд = 0 По КолКолонок - 1 Цикл
            НомерКолонки = НачКолонка + Инд;
            Заголовок = СокрЛП(Строка(Лист.Cells(НачСтрока, НомерКолонки).Text));
            Если ЗначениеЗаполнено(Заголовок) Тогда
                СоответствиеКолонок.Вставить(Заголовок, НомерКолонки);
            КонецЕсли;
        КонецЦикла;

        Для Каждого ИмяКолонки Из ОжидаемыеКолонки Цикл
            Если СоответствиеКолонок.Получить(ИмяКолонки) = Неопределено Тогда
                Книга.Close(Ложь);
                Excel.Quit();
                Сообщить("В файле отсутствует колонка: " + ИмяКолонки);
                Возврат Неопределено;
            КонецЕсли;
        КонецЦикла;

        Результат = Новый Массив;
        КонецДиапазона = НачСтрока + КолСтрок - 1;

        Для НомСтроки = НачСтрока + 1 По КонецДиапазона Цикл
            НоваяСтруктура = Новый Структура;

            Для Каждого ИмяКолонки Из ОжидаемыеКолонки Цикл
                НомерКолонки = СоответствиеКолонок[ИмяКолонки];
                ЗначениеЯчейки = СокрЛП(Строка(Лист.Cells(НомСтроки, НомерКолонки).Text));
                НоваяСтруктура.Вставить(ИмяКолонки, ЗначениеЯчейки);
            КонецЦикла;

            Если ЗначениеЗаполнено(НоваяСтруктура.Код) Тогда
                Результат.Добавить(НоваяСтруктура);
            КонецЕсли;
        КонецЦикла;

        Книга.Close(Ложь);
        Excel.Quit();

        Возврат Результат;

    Исключение
        ТекстОшибки = ОписаниеОшибки();
        Попытка
            Если Книга <> Неопределено Тогда
                Книга.Close(Ложь);
            КонецЕсли;
            Если Excel <> Неопределено Тогда
                Excel.Quit();
            КонецЕсли;
        Исключение // BSLLS:MissingCodeTryCatchEx-off
        КонецПопытки;
        Сообщить("Ошибка чтения Excel: " + ТекстОшибки);
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

&НаСервере
Процедура ЗагрузитьПредварительныеДанныеНаСервере(МассивСтрок, ПутьКФайлу, СекундКлиент = 0)

    ВремяСервер = ТекущаяДатаСеанса();
    ТаблицаПредварительныхДанных.Очистить();
    НайденоПриЗагрузке = 0;
    НеНайденоПриЗагрузке = 0;

    Для Каждого СтрокаExcel Из МассивСтрок Цикл
        СтрокаТаблицы = ТаблицаПредварительныхДанных.Добавить();
        СтрокаТаблицы.Обработать = Истина;
        СтрокаТаблицы.Название_ЕГР = СтрокаExcel.Название_ЕГР;
        СтрокаТаблицы.ОГРНИП = СтрокаExcel.ОГРНИП;
        СтрокаТаблицы.ВидКонтрагента = СтрокаExcel.ВидКонтрагента;
        СтрокаТаблицы.Клиент = НРег(СтрокаExcel.Клиент);
        СтрокаТаблицы.Поставщик = НРег(СтрокаExcel.Поставщик);
        СтрокаТаблицы.ИНН = СтрокаExcel.ИНН;
        СтрокаТаблицы.Код = СтрокаExcel.Код;
        КонтрагентПоИдентификатору = НайтиКонтрагентаПоИдентификатору(СтрокаExcel.Код);
        Если ЕстьПолеКонтрагентВСроке(СтрокаТаблицы) Тогда
            СтрокаТаблицы.Контрагент = КонтрагентПоИдентификатору;
        КонецЕсли;

        Если ЗначениеЗаполнено(КонтрагентПоИдентификатору) Тогда
            НайденоПриЗагрузке = НайденоПриЗагрузке + 1;
            СтрокаТаблицы.Комментарий = "Найден при загрузке (по идентификатору)";
        Иначе
            НеНайденоПриЗагрузке = НеНайденоПриЗагрузке + 1;
            СтрокаТаблицы.Комментарий = "Не найден при загрузке";
        КонецЕсли;
    КонецЦикла;

    СекундСервер = ТекущаяДатаСеанса() - ВремяСервер;
    СекундВсего = СекундКлиент + СекундСервер;

    ЗаписатьЛог("=== Загрузка предварительных данных ===");
    ЗаписатьЛог("Файл: " + ПутьКФайлу);
    ЗаписатьЛог("Загружено строк: " + Строка(ТаблицаПредварительныхДанных.Количество())
        + ", Найдено: " + Строка(НайденоПриЗагрузке)
        + ", Не найдено: " + Строка(НеНайденоПриЗагрузке)
        + ", ВремяКлиент: " + Строка(СекундКлиент)
        + " сек, ВремяСервер: " + Строка(СекундСервер)
        + " сек, Итого: " + Строка(СекундВсего) + " сек");

    Сообщить("Загрузка завершена. Строк: " + Строка(ТаблицаПредварительныхДанных.Количество()));

КонецПроцедуры

#КонецОбласти // ЗагрузкаИзExcel

#Область ОбновлениеПоКоду

&НаСервере
Процедура ОбновитьВ1СНаСервере() // BSLLS:CognitiveComplexity-off

    ВремяНачала = ТекущаяДатаСеанса();
    Обработано = 0;
    Обновлено = 0;
    БезИзменений = 0;
    НеНайдено = 0;
    Ошибок = 0;

    ЗаписатьЛог("=== Старт обновления контрагентов ===");

    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        Если НЕ СтрокаТаблицы.Обработать Тогда
            Продолжить;
        КонецЕсли;

        Обработано = Обработано + 1;
        ВремяСтроки = ТекущаяДатаСеанса();

        Попытка
            КонтрагентСсылка = Неопределено;
            Если ЕстьПолеКонтрагентВСроке(СтрокаТаблицы) Тогда
                КонтрагентСсылка = СтрокаТаблицы.Контрагент;
            КонецЕсли;

            Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Тогда
                КонтрагентСсылка = НайтиКонтрагентаПоИдентификатору(СтрокаТаблицы.Код);
                Если ЗначениеЗаполнено(КонтрагентСсылка) И ЕстьПолеКонтрагентВСроке(СтрокаТаблицы) Тогда
                    СтрокаТаблицы.Контрагент = КонтрагентСсылка;
                КонецЕсли;
            КонецЕсли;

            Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Тогда
                НеНайдено = НеНайдено + 1;
                СтрокаТаблицы.Комментарий = "Не найден по коду";
                ЗаписатьЛог("НЕ НАЙДЕН: Код=" + СтрокаТаблицы.Код);
                Продолжить;
            КонецЕсли;

            Результат = ОбновитьКонтрагентаИПартнера(КонтрагентСсылка, СтрокаТаблицы);
            Если Результат.Изменено Тогда
                Обновлено = Обновлено + 1;
                СтрокаТаблицы.Комментарий = "Обновлено: " + Результат.СписокИзменений;
                ЗаписатьЛог("ОБНОВЛЕНО: Код=" + СтрокаТаблицы.Код + " | " + Результат.СписокИзменений);
            Иначе
                БезИзменений = БезИзменений + 1;
                СтрокаТаблицы.Комментарий = "Без изменений";
                ЗаписатьЛог("БЕЗ ИЗМЕНЕНИЙ: Код=" + СтрокаТаблицы.Код);
            КонецЕсли;

            СтрокаТаблицы.Обработать = Ложь;
            СекундСтроки = ТекущаяДатаСеанса() - ВремяСтроки;
            ЗаписатьЛог("ВРЕМЯ СТРОКИ: Код=" + СтрокаТаблицы.Код + " | " + Строка(СекундСтроки) + " сек");

        Исключение
            Ошибок = Ошибок + 1;
            СтрокаТаблицы.Комментарий = "Ошибка: " + ОписаниеОшибки();
            ЗаписатьЛог("ОШИБКА: Код=" + СтрокаТаблицы.Код + " | " + ОписаниеОшибки());
        КонецПопытки;
    КонецЦикла;

    СекундВсего = ТекущаяДатаСеанса() - ВремяНачала;
    Итог = "Обработка завершена. Обработано: " + Строка(Обработано)
        + ", Обновлено: " + Строка(Обновлено)
        + ", Без изменений: " + Строка(БезИзменений)
        + ", Не найдено: " + Строка(НеНайдено)
        + ", Ошибок: " + Строка(Ошибок)
        + ", Время: " + Строка(СекундВсего) + " сек";

    ЗаписатьЛог(Итог);
    Сообщить(Итог);

КонецПроцедуры

&НаСервере
Функция ОбновитьКонтрагентаИПартнера(КонтрагентСсылка, СтрокаТаблицы)

    Результат = Новый Структура;
    Результат.Вставить("Изменено", Ложь);
    Результат.Вставить("СписокИзменений", "");

    КонтрагентОбъект = КонтрагентСсылка.ПолучитьОбъект();
    Изменения = Новый Массив;

    // Код не меняем - только поиск.
    Если ЗначениеЗаполнено(СтрокаТаблицы.Название_ЕГР) Тогда
        Если СокрЛП(КонтрагентОбъект.Наименование) <> СокрЛП(СтрокаТаблицы.Название_ЕГР) Тогда
            КонтрагентОбъект.Наименование = СтрокаТаблицы.Название_ЕГР;
            Изменения.Добавить("Наименование");
        КонецЕсли;

        Если СокрЛП(КонтрагентОбъект.НаименованиеПолное) <> СокрЛП(СтрокаТаблицы.Название_ЕГР) Тогда
            КонтрагентОбъект.НаименованиеПолное = СтрокаТаблицы.Название_ЕГР;
            Изменения.Добавить("НаименованиеПолное");
        КонецЕсли;
    КонецЕсли;

    Если ЗначениеЗаполнено(СтрокаТаблицы.ОГРНИП) Тогда
        Если СокрЛП(КонтрагентОбъект.РегистрационныйНомер) <> СокрЛП(СтрокаТаблицы.ОГРНИП) Тогда
            КонтрагентОбъект.РегистрационныйНомер = СтрокаТаблицы.ОГРНИП;
            Изменения.Добавить("ОГРНИП->РегистрационныйНомер");
        КонецЕсли;
    КонецЕсли;

    Если ЗначениеЗаполнено(СтрокаТаблицы.ИНН) Тогда
        Если СокрЛП(КонтрагентОбъект.ИНН) <> СокрЛП(СтрокаТаблицы.ИНН) Тогда
            КонтрагентОбъект.ИНН = СтрокаТаблицы.ИНН;
            Изменения.Добавить("ИНН");
        КонецЕсли;
    КонецЕсли;

    НовоеЮрФизЛицо = ПреобразоватьВидКонтрагента(СтрокаТаблицы.ВидКонтрагента, СтрокаТаблицы.ИНН);
    Если НовоеЮрФизЛицо <> Неопределено Тогда
        Если КонтрагентОбъект.ЮрФизЛицо <> НовоеЮрФизЛицо Тогда
            КонтрагентОбъект.ЮрФизЛицо = НовоеЮрФизЛицо;
            Изменения.Добавить("Контрагент.ЮрФизЛицо");
        КонецЕсли;

        // Служебный реквизит (2 значения): ЮридическоеЛицо / ФизическоеЛицо.
        // Для ИП также должен быть "ФизическоеЛицо".
        НовоеЮридическоеФизическоеЛицо = ПолучитьЮридическоеФизическоеЛицо(НовоеЮрФизЛицо);
        Если НовоеЮридическоеФизическоеЛицо <> Неопределено Тогда
            Если КонтрагентОбъект.ЮридическоеФизическоеЛицо <> НовоеЮридическоеФизическоеЛицо Тогда
                КонтрагентОбъект.ЮридическоеФизическоеЛицо = НовоеЮридическоеФизическоеЛицо;
                Изменения.Добавить("Контрагент.ЮридическоеФизическоеЛицо");
            КонецЕсли;
        КонецЕсли;
    Иначе
        ЗаписатьЛог("ПРЕДУПРЕЖДЕНИЕ: не удалось определить Юр/Физ для Код=" + СтрокаТаблицы.Код
            + ", ВидКонтрагента='" + СтрокаТаблицы.ВидКонтрагента + "', ИНН='" + СтрокаТаблицы.ИНН + "'");
    КонецЕсли;

    ПартнерОбъект = Неопределено;
    Если ЗначениеЗаполнено(КонтрагентОбъект.Партнер) Тогда
        ПартнерОбъект = КонтрагентОбъект.Партнер.ПолучитьОбъект();
    КонецЕсли;

    Если ПартнерОбъект <> Неопределено Тогда
        // Рабочее наименование в режиме "Партнеры как контрагенты" берем у Партнера.
        Если ЗначениеЗаполнено(СтрокаТаблицы.Название_ЕГР) Тогда
            Если СокрЛП(ПартнерОбъект.Наименование) <> СокрЛП(СтрокаТаблицы.Название_ЕГР) Тогда
                ПартнерОбъект.Наименование = СтрокаТаблицы.Название_ЕГР;
                Изменения.Добавить("Партнер.Наименование");
            КонецЕсли;

            Если СокрЛП(ПартнерОбъект.НаименованиеПолное) <> СокрЛП(СтрокаТаблицы.Название_ЕГР) Тогда
                ПартнерОбъект.НаименованиеПолное = СтрокаТаблицы.Название_ЕГР;
                Изменения.Добавить("Партнер.НаименованиеПолное");
            КонецЕсли;
        КонецЕсли;

        НовоеКлиент = ПреобразоватьДаНетВБулево(СтрокаТаблицы.Клиент);
        Если НовоеКлиент <> Неопределено И ПартнерОбъект.Клиент <> НовоеКлиент Тогда
            ПартнерОбъект.Клиент = НовоеКлиент;
            Изменения.Добавить("Партнер.Клиент");
        КонецЕсли;

        НовоеПоставщик = ПреобразоватьДаНетВБулево(СтрокаТаблицы.Поставщик);
        Если НовоеПоставщик <> Неопределено И ПартнерОбъект.Поставщик <> НовоеПоставщик Тогда
            ПартнерОбъект.Поставщик = НовоеПоставщик;
            Изменения.Добавить("Партнер.Поставщик");
        КонецЕсли;

        Если НовоеЮрФизЛицо <> Неопределено Тогда
            НовоеКомпанияЧастноеЛицо = ПолучитьКомпанияЧастноеЛицоДляПартнера(НовоеЮрФизЛицо);
            Если НовоеКомпанияЧастноеЛицо <> Неопределено Тогда
                Если ПартнерОбъект.ЮрФизЛицо <> НовоеКомпанияЧастноеЛицо Тогда
                    ПартнерОбъект.ЮрФизЛицо = НовоеКомпанияЧастноеЛицо;
                    Изменения.Добавить("Партнер.ЮрФизЛицо(КомпанияЧастноеЛицо)");
                КонецЕсли;
            КонецЕсли;
        КонецЕсли;
    Иначе
        ЗаписатьЛог("ПРЕДУПРЕЖДЕНИЕ: не найден партнер у контрагента Код=" + СтрокаТаблицы.Код);
    КонецЕсли;

    Если Изменения.Количество() > 0 Тогда
        Если ПартнерОбъект <> Неопределено Тогда
            ПартнерОбъект.Записать();
        КонецЕсли;

        КонтрагентОбъект.Записать();
        Результат.Изменено = Истина;
        Результат.СписокИзменений = СтрСоединить(Изменения, ", ");
    КонецЕсли;

    Возврат Результат;

КонецФункции

&НаСервере
Функция НайтиКонтрагентаПоИдентификатору(ИдентификаторИзФайла)

    Если НЕ ЗначениеЗаполнено(ИдентификаторИзФайла) Тогда
        Возврат Справочники.Контрагенты.ПустаяСсылка();
    КонецЕсли;

    // 1) Основной сценарий для вашей УТ:
    // код уникальный у Партнеров, а у Контрагентов стандартный код отключен.
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Контрагенты.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Партнеры КАК Партнеры
        |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
        |       ПО Контрагенты.Партнер = Партнеры.Ссылка
        |ГДЕ
        |   Партнеры.Код = &Идентификатор
        |   И НЕ Партнеры.ПометкаУдаления
        |   И НЕ Контрагенты.ПометкаУдаления";
    Запрос.УстановитьПараметр("Идентификатор", СокрЛП(ИдентификаторИзФайла));

    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;

    // 2) Fallback:
    // если в файле не код партнера, пробуем регистрационный номер контрагента.
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Контрагенты.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Контрагенты КАК Контрагенты
        |ГДЕ
        |   Контрагенты.РегистрационныйНомер = &Идентификатор
        |   И НЕ Контрагенты.ПометкаУдаления";
    Запрос.УстановитьПараметр("Идентификатор", СокрЛП(ИдентификаторИзФайла));

    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;

    Возврат Справочники.Контрагенты.ПустаяСсылка();

КонецФункции

&НаСервере
Функция ЕстьПолеКонтрагентВСроке(СтрокаТаблицы)

    Попытка
        ЗначениеПоля = СтрокаТаблицы.Контрагент;
        Возврат Истина;
    Исключение
        Возврат Ложь;
    КонецПопытки;

КонецФункции

&НаСервере
Функция ПреобразоватьДаНетВБулево(ЗначениеДаНет)

    Текст = НРег(СокрЛП(ЗначениеДаНет));

    Если Текст = "да" Тогда
        Возврат Истина;
    ИначеЕсли Текст = "нет" Тогда
        Возврат Ложь;
    ИначеЕсли Текст = "" Тогда
        Возврат Неопределено;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

&НаСервере
Функция ПреобразоватьВидКонтрагента(ТекстВида, ИНН = "")

    Норм = НРег(СокрЛП(ТекстВида));
    НормИНН = СокрЛП(ИНН);

    Если СтрНайти(Норм, "ип") > 0 Или СтрНайти(Норм, "индивидуаль") > 0 Тогда
        Возврат Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель;
    КонецЕсли;

    Если СтрНайти(Норм, "физ") > 0 Тогда
        Возврат Перечисления.ЮрФизЛицо.ФизЛицо;
    КонецЕсли;

    Если СтрНайти(Норм, "нерезидент") > 0 Тогда
        Возврат Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент;
    КонецЕсли;

    Если СтрНайти(Норм, "юр") > 0 Тогда
        Возврат Перечисления.ЮрФизЛицо.ЮрЛицо;
    КонецЕсли;

    // Fallback по ИНН, если в файле не удалось однозначно распознать текст вида.
    Если СтрДлина(НормИНН) = 12 Тогда
        Возврат Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель;
    ИначеЕсли СтрДлина(НормИНН) = 10 Тогда
        Возврат Перечисления.ЮрФизЛицо.ЮрЛицо;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

&НаСервере
Функция ПолучитьКомпанияЧастноеЛицоДляПартнера(ЗначениеЮрФизЛицоКонтрагента)

    Если ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ЮрЛицо
        Или ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент Тогда
        Возврат Перечисления.КомпанияЧастноеЛицо.Компания;
    КонецЕсли;

    Если ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо
        Или ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель Тогда
        Возврат Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

&НаСервере
Функция ПолучитьЮридическоеФизическоеЛицо(ЗначениеЮрФизЛицоКонтрагента)

    Если ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ЮрЛицо
        Или ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент Тогда
        Возврат Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;
    КонецЕсли;

    Если ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ФизЛицо
        Или ЗначениеЮрФизЛицоКонтрагента = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель Тогда
        Возврат Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

