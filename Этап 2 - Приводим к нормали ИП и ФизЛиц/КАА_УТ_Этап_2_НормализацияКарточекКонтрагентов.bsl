// BSLLS-off
// =============================================================================
// Внешняя обработка: KAA_ПриведениеКонтрагентовПоКоду
// Назначение: загрузка предварительных данных из Excel и обновление существующих
//             контрагентов в УТ по полю Код.
// =============================================================================
//
// РЕКВИЗИТЫ ФОРМЫ (создать вручную в конфигураторе):
//
//   ПутьКФайлуExcel - Строка(500)
//
//   ТаблицаПредварительныхДанных - ТаблицаЗначений:
//     Обработать        - Булево
//     Название_ЕГР      - Строка(250)
//     ОГРНИП            - Строка(20)
//     ВидКонтрагента    - Строка(50)
//     Клиент            - Строка(3)   // "Да"/"Нет"
//     Поставщик         - Строка(3)   // "Да"/"Нет"
//     ИНН               - Строка(12)
//     Код               - Строка(20)
//     Комментарий       - Строка(500)
//
// КОМАНДЫ ФОРМЫ:
//   ЗагрузитьПредварительныеДанные  (кнопка "Загрузить предварительные данные")
//   ОбновитьВ1С                     (кнопка "Обновить в 1С")
//   ВыделитьВсе
//   СнятьВсе
//
// ПОЛЯ УТ, подтвержденные по XML УТ:
//   Справочник.Контрагенты: Наименование, НаименованиеПолное, ИНН,
//                           РегистрационныйНомер, ЮрФизЛицо, Код, Партнер
//   Справочник.Партнеры: Клиент, Поставщик, ЮрФизЛицо
// =============================================================================

#Область Инициализация

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

    Если НЕ ЗначениеЗаполнено(ПутьКФайлуExcel) Тогда
        ПутьКФайлуExcel = ПолучитьПутьКФайлуПоУмолчанию();
    КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПолучитьПутьКФайлуПоУмолчанию()

    Возврат "D:\Programming\1С_Создаём контрагентов и договора\Обработанные_Данные_26.04.07222.xlsx";

КонецФункции

#КонецОбласти // Инициализация

#Область КомандыФормы

&НаКлиенте
Процедура ЗагрузитьПредварительныеДанные(Команда)

    ДиалогОткрытия = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
    ДиалогОткрытия.Заголовок = "Выберите файл Excel для загрузки";
    ДиалогОткрытия.Фильтр = "Файлы Excel (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*";
    ДиалогОткрытия.МножественныйВыбор = Ложь;

    Если ЗначениеЗаполнено(ПутьКФайлуExcel) Тогда
        ДиалогОткрытия.ПолноеИмяФайла = ПутьКФайлуExcel;
    КонецЕсли;

    Если НЕ ДиалогОткрытия.Выбрать() Тогда
        Возврат;
    КонецЕсли;

    ПутьКФайлуExcel = ДиалогОткрытия.ПолноеИмяФайла;

    ВремяНачалаКлиент = ТекущаяДата();
    МассивСтрок = ПрочитатьExcelНаКлиенте(ПутьКФайлуExcel);
    Если МассивСтрок = Неопределено Тогда
        Возврат;
    КонецЕсли;

    СекундExcelНаКлиенте = ТекущаяДата() - ВремяНачалаКлиент;
    ЗагрузитьПредварительныеДанныеНаСервере(МассивСтрок, ПутьКФайлуExcel, СекундExcelНаКлиенте);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьВ1С(Команда)

    КоличествоКОбработке = 0;
    Для Каждого СтрокаДанных Из ТаблицаПредварительныхДанных Цикл
        Если СтрокаДанных.Обработать Тогда
            КоличествоКОбработке = КоличествоКОбработке + 1;
        КонецЕсли;
    КонецЦикла;

    Если КоличествоКОбработке = 0 Тогда
        Сообщить("Нет отмеченных строк для обновления.");
        Возврат;
    КонецЕсли;

    ТекстВопроса = "Будет обработано строк: " + Строка(КоличествоКОбработке) + ". Продолжить?";
    Если Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
        Возврат;
    КонецЕсли;

    ОбновитьВ1СНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ВыделитьВсе(Команда)

    Для Каждого СтрокаДанных Из ТаблицаПредварительныхДанных Цикл
        СтрокаДанных.Обработать = Истина;
    КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура СнятьВсе(Команда)

    Для Каждого СтрокаДанных Из ТаблицаПредварительныхДанных Цикл
        СтрокаДанных.Обработать = Ложь;
    КонецЦикла;

КонецПроцедуры

#КонецОбласти // КомандыФормы

#Область ЗагрузкаExcel

&НаКлиенте
Функция ПрочитатьExcelНаКлиенте(ПутьКФайлу) // BSLLS:CognitiveComplexity-off

    ОжидаемыеКолонки = Новый Массив;
    ОжидаемыеКолонки.Добавить("Название_ЕГР");
    ОжидаемыеКолонки.Добавить("ОГРНИП");
    ОжидаемыеКолонки.Добавить("ВидКонтрагента");
    ОжидаемыеКолонки.Добавить("Клиент");
    ОжидаемыеКолонки.Добавить("Поставщик");
    ОжидаемыеКолонки.Добавить("ИНН");
    ОжидаемыеКолонки.Добавить("Код");

    Excel = Неопределено;
    Книга = Неопределено;

    Попытка
        Excel = Новый COMОбъект("Excel.Application");
        Excel.Visible = Ложь;
        Excel.DisplayAlerts = Ложь;

        Книга = Excel.Workbooks.Open(ПутьКФайлу);
        Лист = Книга.Sheets(1);
        ДиапазонИсп = Лист.UsedRange;

        КолСтрок = ДиапазонИсп.Rows.Count;
        КолКолонок = ДиапазонИсп.Columns.Count;
        НачСтрока = ДиапазонИсп.Row;
        НачКолонка = ДиапазонИсп.Column;

        СоотвКолонок = Новый Соответствие;
        Для Инд = 0 По КолКолонок - 1 Цикл
            НомКол = НачКолонка + Инд;
            Заголовок = СокрЛП(Строка(Лист.Cells(НачСтрока, НомКол).Text));
            Если ЗначениеЗаполнено(Заголовок) Тогда
                СоотвКолонок.Вставить(Заголовок, НомКол);
            КонецЕсли;
        КонецЦикла;

        Для Каждого ИмяКолонки Из ОжидаемыеКолонки Цикл
            Если СоотвКолонок.Получить(ИмяКолонки) = Неопределено Тогда
                Книга.Close(Ложь);
                Excel.Quit();
                Сообщить("В файле отсутствует колонка: " + ИмяКолонки);
                Возврат Неопределено;
            КонецЕсли;
        КонецЦикла;

        Результат = Новый Массив;
        КонечнаяСтрока = НачСтрока + КолСтрок - 1;

        Для НомСтр = НачСтрока + 1 По КонечнаяСтрока Цикл
            ДанныеСтроки = Новый Структура;
            Для Каждого ИмяКолонки Из ОжидаемыеКолонки Цикл
                НомерКолонки = СоотвКолонок[ИмяКолонки];
                ЗначениеЯчейки = СокрЛП(Строка(Лист.Cells(НомСтр, НомерКолонки).Text));
                ДанныеСтроки.Вставить(ИмяКолонки, ЗначениеЯчейки);
            КонецЦикла;

            Если ЗначениеЗаполнено(ДанныеСтроки.Код) Тогда
                Результат.Добавить(ДанныеСтроки);
            КонецЕсли;
        КонецЦикла;

        Книга.Close(Ложь);
        Excel.Quit();

        Возврат Результат;

    Исключение
        ТекстОшибки = ОписаниеОшибки();
        Попытка
            Если Книга <> Неопределено Тогда
                Книга.Close(Ложь);
            КонецЕсли;
            Если Excel <> Неопределено Тогда
                Excel.Quit();
            КонецЕсли;
        Исключение // BSLLS:MissingCodeTryCatchEx-off
        КонецПопытки;
        Сообщить("Ошибка чтения Excel: " + ТекстОшибки);
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

&НаСервере
Процедура ЗагрузитьПредварительныеДанныеНаСервере(МассивСтрок, ПутьКФайлу, СекундExcelНаКлиенте = 0)

    ВремяНачала = ТекущаяДатаСеанса();
    ТаблицаПредварительныхДанных.Очистить();

    Для Каждого СтрокаExcel Из МассивСтрок Цикл
        НоваяСтрока = ТаблицаПредварительныхДанных.Добавить();
        НоваяСтрока.Обработать = Истина;
        НоваяСтрока.Название_ЕГР = СтрокаExcel.Название_ЕГР;
        НоваяСтрока.ОГРНИП = СтрокаExcel.ОГРНИП;
        НоваяСтрока.ВидКонтрагента = СтрокаExcel.ВидКонтрагента;
        НоваяСтрока.Клиент = НРег(СтрокаExcel.Клиент);
        НоваяСтрока.Поставщик = НРег(СтрокаExcel.Поставщик);
        НоваяСтрока.ИНН = СтрокаExcel.ИНН;
        НоваяСтрока.Код = СтрокаExcel.Код;
        НоваяСтрока.Комментарий = "";
    КонецЦикла;

    СекундСервер = ТекущаяДатаСеанса() - ВремяНачала;
    СекундВсего = СекундExcelНаКлиенте + СекундСервер;

    ЗаписатьЛог("=== Загрузка предварительных данных ===");
    ЗаписатьЛог("Файл: " + ПутьКФайлу);
    ЗаписатьЛог("Строк загружено: " + Строка(ТаблицаПредварительныхДанных.Количество())
        + ", ExcelКлиент: " + Строка(СекундExcelНаКлиенте)
        + " сек, Сервер: " + Строка(СекундСервер)
        + " сек, Итого: " + Строка(СекундВсего) + " сек");

    Сообщить("Предварительные данные загружены. Строк: " + Строка(ТаблицаПредварительныхДанных.Количество()));

КонецПроцедуры

#КонецОбласти // ЗагрузкаExcel

#Область ОбновлениеКонтрагентов

&НаСервере
Процедура ОбновитьВ1СНаСервере() // BSLLS:CognitiveComplexity-off

    ВремяНачала = ТекущаяДатаСеанса();
    ВсегоСтрок = 0;
    Обновлено = 0;
    БезИзменений = 0;
    НеНайдено = 0;
    Ошибок = 0;

    ЗаписатьЛог("=== Старт обновления контрагентов по коду ===");

    Для Каждого СтрокаТаблицы Из ТаблицаПредварительныхДанных Цикл
        Если НЕ СтрокаТаблицы.Обработать Тогда
            Продолжить;
        КонецЕсли;

        ВсегоСтрок = ВсегоСтрок + 1;
        ВремяСтроки = ТекущаяДатаСеанса();

        Попытка
            КонтрагентСсылка = НайтиКонтрагентаПоКоду(СтрокаТаблицы.Код);
            Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Тогда
                НеНайдено = НеНайдено + 1;
                СтрокаТаблицы.Комментарий = "Не найден контрагент по коду";
                ЗаписатьЛог("НЕ НАЙДЕН: Код=" + СтрокаТаблицы.Код);
                Продолжить;
            КонецЕсли;

            РезультатОбновления = ОбновитьКарточкуКонтрагентаПоСтроке(КонтрагентСсылка, СтрокаТаблицы);

            Если РезультатОбновления.Получить("Изменено") Тогда
                Обновлено = Обновлено + 1;
                СтрокаТаблицы.Комментарий = "Обновлено: " + РезультатОбновления.Получить("СписокИзменений");
                ЗаписатьЛог("ОБНОВЛЕНО: Код=" + СтрокаТаблицы.Код + " | " + РезультатОбновления.Получить("СписокИзменений"));
            Иначе
                БезИзменений = БезИзменений + 1;
                СтрокаТаблицы.Комментарий = "Без изменений";
                ЗаписатьЛог("БЕЗ ИЗМЕНЕНИЙ: Код=" + СтрокаТаблицы.Код);
            КонецЕсли;

            СтрокаТаблицы.Обработать = Ложь;
            СекундСтроки = ТекущаяДатаСеанса() - ВремяСтроки;
            ЗаписатьЛог("ВРЕМЯ СТРОКИ: Код=" + СтрокаТаблицы.Код + " | " + Строка(СекундСтроки) + " сек");

        Исключение
            Ошибок = Ошибок + 1;
            СтрокаТаблицы.Комментарий = "Ошибка: " + ОписаниеОшибки();
            ЗаписатьЛог("ОШИБКА: Код=" + СтрокаТаблицы.Код + " | " + ОписаниеОшибки());
        КонецПопытки;
    КонецЦикла;

    СекундВсего = ТекущаяДатаСеанса() - ВремяНачала;

    Итог = "Обновление завершено. Обработано: " + Строка(ВсегоСтрок)
        + ", Обновлено: " + Строка(Обновлено)
        + ", Без изменений: " + Строка(БезИзменений)
        + ", Не найдено: " + Строка(НеНайдено)
        + ", Ошибок: " + Строка(Ошибок)
        + ", Время: " + Строка(СекундВсего) + " сек";

    ЗаписатьЛог(Итог);
    Сообщить(Итог);

КонецПроцедуры

&НаСервере
Функция ОбновитьКарточкуКонтрагентаПоСтроке(КонтрагентСсылка, СтрокаТаблицы)

    Изменено = Ложь;
    СписокИзменений = Новый Массив;

    КонтрагентОбъект = КонтрагентСсылка.ПолучитьОбъект();

    // Код не меняем, используется только для поиска.
    Если ЗначениеЗаполнено(СтрокаТаблицы.Название_ЕГР) Тогда
        Если СокрЛП(КонтрагентОбъект.Наименование) <> СокрЛП(СтрокаТаблицы.Название_ЕГР) Тогда
            КонтрагентОбъект.Наименование = СтрокаТаблицы.Название_ЕГР;
            Изменено = Истина;
            СписокИзменений.Добавить("Наименование");
        КонецЕсли;

        Если СокрЛП(КонтрагентОбъект.НаименованиеПолное) <> СокрЛП(СтрокаТаблицы.Название_ЕГР) Тогда
            КонтрагентОбъект.НаименованиеПолное = СтрокаТаблицы.Название_ЕГР;
            Изменено = Истина;
            СписокИзменений.Добавить("НаименованиеПолное");
        КонецЕсли;
    КонецЕсли;

    Если ЗначениеЗаполнено(СтрокаТаблицы.ОГРНИП) Тогда
        Если СокрЛП(КонтрагентОбъект.РегистрационныйНомер) <> СокрЛП(СтрокаТаблицы.ОГРНИП) Тогда
            КонтрагентОбъект.РегистрационныйНомер = СтрокаТаблицы.ОГРНИП;
            Изменено = Истина;
            СписокИзменений.Добавить("РегистрационныйНомер");
        КонецЕсли;
    КонецЕсли;

    Если ЗначениеЗаполнено(СтрокаТаблицы.ИНН) Тогда
        Если СокрЛП(КонтрагентОбъект.ИНН) <> СокрЛП(СтрокаТаблицы.ИНН) Тогда
            КонтрагентОбъект.ИНН = СтрокаТаблицы.ИНН;
            Изменено = Истина;
            СписокИзменений.Добавить("ИНН");
        КонецЕсли;
    КонецЕсли;

    НовоеЮрФизЛицо = ПреобразоватьВидКонтрагента(СтрокаТаблицы.ВидКонтрагента);
    Если НовоеЮрФизЛицо <> Неопределено Тогда
        Если КонтрагентОбъект.ЮрФизЛицо <> НовоеЮрФизЛицо Тогда
            КонтрагентОбъект.ЮрФизЛицо = НовоеЮрФизЛицо;
            Изменено = Истина;
            СписокИзменений.Добавить("ЮрФизЛицо");
        КонецЕсли;
    КонецЕсли;

    ПартнерОбъект = Неопределено;
    Если ЗначениеЗаполнено(КонтрагентОбъект.Партнер) Тогда
        ПартнерОбъект = КонтрагентОбъект.Партнер.ПолучитьОбъект();
    КонецЕсли;

    Если ПартнерОбъект <> Неопределено Тогда
        НовоеЗначениеКлиент = ПреобразоватьДаНетВБулево(СтрокаТаблицы.Клиент);
        Если НовоеЗначениеКлиент <> Неопределено Тогда
            Если ПартнерОбъект.Клиент <> НовоеЗначениеКлиент Тогда
                ПартнерОбъект.Клиент = НовоеЗначениеКлиент;
                Изменено = Истина;
                СписокИзменений.Добавить("Партнер.Клиент");
            КонецЕсли;
        КонецЕсли;

        НовоеЗначениеПоставщик = ПреобразоватьДаНетВБулево(СтрокаТаблицы.Поставщик);
        Если НовоеЗначениеПоставщик <> Неопределено Тогда
            Если ПартнерОбъект.Поставщик <> НовоеЗначениеПоставщик Тогда
                ПартнерОбъект.Поставщик = НовоеЗначениеПоставщик;
                Изменено = Истина;
                СписокИзменений.Добавить("Партнер.Поставщик");
            КонецЕсли;
        КонецЕсли;

        Если НовоеЮрФизЛицо <> Неопределено Тогда
            Попытка
                Если ПартнерОбъект.ЮрФизЛицо <> НовоеЮрФизЛицо Тогда
                    ПартнерОбъект.ЮрФизЛицо = НовоеЮрФизЛицо;
                    Изменено = Истина;
                    СписокИзменений.Добавить("Партнер.ЮрФизЛицо");
                КонецЕсли;
            Исключение // BSLLS:MissingCodeTryCatchEx-off
            КонецПопытки;
        КонецЕсли;
    Иначе
        ЗаписатьЛог("ПРЕДУПРЕЖДЕНИЕ: у контрагента Код=" + СтрокаТаблицы.Код + " не заполнен Партнер");
    КонецЕсли;

    Если Изменено Тогда
        Если ПартнерОбъект <> Неопределено Тогда
            ПартнерОбъект.Записать();
        КонецЕсли;

        КонтрагентОбъект.Записать();
    КонецЕсли;

    Результат = Новый Структура;
    Результат.Вставить("Изменено", Изменено);
    Результат.Вставить("СписокИзменений", СтрСоединить(СписокИзменений, ", "));
    Возврат Результат;

КонецФункции

&НаСервере
Функция НайтиКонтрагентаПоКоду(КодКонтрагента)

    Если НЕ ЗначениеЗаполнено(КодКонтрагента) Тогда
        Возврат Справочники.Контрагенты.ПустаяСсылка();
    КонецЕсли;

    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Контрагенты.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.Контрагенты КАК Контрагенты
        |ГДЕ
        |   Контрагенты.Код = &Код
        |   И НЕ Контрагенты.ПометкаУдаления";

    Запрос.УстановитьПараметр("Код", СокрЛП(КодКонтрагента));

    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;

    Возврат Справочники.Контрагенты.ПустаяСсылка();

КонецФункции

&НаСервере
Функция ПреобразоватьДаНетВБулево(ТекстДаНет)

    Норм = НРег(СокрЛП(ТекстДаНет));

    Если Норм = "да" Тогда
        Возврат Истина;
    ИначеЕсли Норм = "нет" Тогда
        Возврат Ложь;
    ИначеЕсли Норм = "" Тогда
        Возврат Неопределено;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

&НаСервере
Функция ПреобразоватьВидКонтрагента(ТекстВида)

    Норм = НРег(СокрЛП(ТекстВида));
    Если Норм = "" Тогда
        Возврат Неопределено;
    КонецЕсли;

    Если СтрНайти(Норм, "ип") > 0 Или СтрНайти(Норм, "индивидуаль") > 0 Тогда
        Возврат Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель;
    КонецЕсли;

    Если СтрНайти(Норм, "физ") > 0 Тогда
        Возврат Перечисления.ЮрФизЛицо.ФизЛицо;
    КонецЕсли;

    Если СтрНайти(Норм, "нерезидент") > 0 Тогда
        Возврат Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент;
    КонецЕсли;

    Если СтрНайти(Норм, "юр") > 0 Тогда
        Возврат Перечисления.ЮрФизЛицо.ЮрЛицо;
    КонецЕсли;

    // Если в тексте только "ООО", "АО" и т.п. — считаем юрлицом.
    Возврат Перечисления.ЮрФизЛицо.ЮрЛицо;

КонецФункции

