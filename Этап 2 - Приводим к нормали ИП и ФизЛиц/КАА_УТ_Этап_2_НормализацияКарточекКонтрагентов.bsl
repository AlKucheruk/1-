#Область Логирование

&НаСервере
Процедура ЗаписатьЛог(Текст) Экспорт

    ПутьКФайлу = "D:\1с\КАА\Лог_ПриведениеКонтрагентовПоКоду.txt"; // BSLLS:UsingHardcodePath-off

    Попытка
        Запись = Новый ЗаписьТекста(ПутьКФайлу, КодировкаТекста.UTF8, , Истина);
        СтрокаЛога = Формат(ТекущаяДатаСеанса(), "ДФ=yyyy-MM-dd HH:mm:ss")
            + " | " + Текст;
        Запись.ЗаписатьСтроку(СтрокаЛога);
        Запись.Закрыть();
    Исключение
        Попытка
            Сообщить("ОШИБКА ЗАПИСИ ЛОГА: " + ОписаниеОшибки());
        Исключение // BSLLS:MissingCodeTryCatchEx-off
        КонецПопытки;
    КонецПопытки;

КонецПроцедуры

