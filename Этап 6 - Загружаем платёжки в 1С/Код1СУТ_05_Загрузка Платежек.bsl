            НовСтр.ДокОснование = ТекстДокОснование;
            НовСтр.Назначение   = ТекстНазначение;
            НовСтр.СчетРасчетов = ТекстСчетРасчетов;
            НовСтр.Валюта       = ТекстВалюта;
            НовСтр.СтатьяДДС    = ТекстСтатьяДДС;
            НовСтр.НДС_ИзТекста = ТекстНДС;
            НовСтр.СуммаНДС_ИзТекста = НормализоватьСумму(ТекстСуммаНДС);
            // НовСтр.Договор      = ТекстДоговор;

            // --- Нормализация цифровых реквизитов ---
            НовСтр.НомерПП   = НормализоватьЦифровойКод(ТекстНомерПП);
            НовСтр.ИННОрг    = ДобавитьВедущийНольЕслиНужно(НормализоватьЦифровойКод(?(НомКол_ИННОрг <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_ИННОрг).Текст, "")));
            НовСтр.КППОрг    = НормализоватьЦифровойКод(?(НомКол_КППОрг <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_КППОрг).Текст, ""));
            НовСтр.НашСчет   = НормализоватьЦифровойКод(?(НомКол_НашСчет <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_НашСчет).Текст, ""));
            НовСтр.НашБИК    = НормализоватьЦифровойКод(?(НомКол_НашБИК <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_НашБИК).Текст, ""));
            НовСтр.ИНН       = ДобавитьВедущийНольЕслиНужно(НормализоватьЦифровойКод(?(НомКол_ИНН <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_ИНН).Текст, "")));
            НовСтр.КППКонтр  = НормализоватьЦифровойКод(?(НомКол_КППКонтр <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_КППКонтр).Текст, ""));
            НовСтр.СчетКонтр = НормализоватьЦифровойКод(?(НомКол_СчетКонтр <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_СчетКонтр).Текст, ""));
            НовСтр.БИККонтр  = НормализоватьЦифровойКод(?(НомКол_БИККонтр <= ТабДок.ШиринаТаблицы, ТабДок.Область(НомСтр, НомКол_БИККонтр).Текст, ""));
            
            Попытка// --- Дата ---
                НовСтр.Дата = ПарситьДату(ТекстДата);
            Исключение
                НовСтр.Дата = '00010101';
            КонецПопытки;
            
            // --- Фильтр по дате ---
            Если ЗначениеЗаполнено(ДатаНачалаФильтра)
                И ЗначениеЗаполнено(НовСтр.Дата)
                И НовСтр.Дата <> '00010101'
                И НовСтр.Дата < НачалоДня(ДатаНачалаФильтра) Тогда
                КоличествоПропущено = КоличествоПропущено + 1;
                ТЗ.Удалить(НовСтр);
                Продолжить;
            КонецЕсли;
            
            Если ЗначениеЗаполнено(ДатаОкончанияФильтра)
                И ЗначениеЗаполнено(НовСтр.Дата)
                И НовСтр.Дата <> '00010101'
                И НовСтр.Дата > КонецДня(ДатаОкончанияФильтра) Тогда
                КоличествоПропущено = КоличествоПропущено + 1;
                ТЗ.Удалить(НовСтр);
                Продолжить;
            КонецЕсли;
            
            // --- Фильтр по направлению платежа ---
            НаправлениеВРег = ВРег(НовСтр.НаправлениеДенег);
            ЭтоПриход = СтрНайти(НаправлениеВРег, "ПРИХОД") > 0;
            ЭтоРасход = СтрНайти(НаправлениеВРег, "РАСХОД") > 0;
            
            Если (ЭтоПриход И НЕ ЗагружатьПриходные)
                ИЛИ (ЭтоРасход И НЕ ЗагружатьРасходные) Тогда
                КоличествоПропущено = КоличествоПропущено + 1;
                ТЗ.Удалить(НовСтр);
                Продолжить;
            КонецЕсли;
            
            Попытка// --- Сумма ---
                НовСтр.Сумма = НормализоватьСумму(ТекстСумма);
            Исключение
                НовСтр.Сумма = 0;
            КонецПопытки;
           
            // --- Предсбор ключей для пакетных выборок ---
            ДобавитьУникальноеЗначение(МассивИННКонтрагентов, ИндексИННКонтрагентов, НовСтр.ИНН);
            ДобавитьУникальноеЗначение(МассивИННОрганизаций, ИндексИННОрганизаций, НовСтр.ИННОрг);
            ДобавитьУникальноеЗначение(МассивСчетовОрганизаций, ИндексСчетовОрганизаций, НовСтр.НашСчет);
            ДобавитьУникальноеЗначение(МассивСчетовКонтрагентов, ИндексСчетовКонтрагентов, НовСтр.СчетКонтр);
            ДобавитьУникальноеЗначение(МассивСтатейДДС, ИндексСтатейДДС, НовСтр.СтатьяДДС);
            ДобавитьУникальноеЗначение(МассивУИД, ИндексУИД, НовСтр.УИД);

            КоличествоЗагружено = КоличествоЗагружено + 1;

        КонецЦикла;
        
        // --- Пакетные выборки из базы ---
        СоответствиеКонтрагентов = ПолучитьСоответствиеКонтрагентовПоИНН(МассивИННКонтрагентов);
        СоответствиеОргПоСчетам = ПолучитьСоответствиеОрганизацийПоСчетам(МассивСчетовОрганизаций);
        СоответствиеОргПоИННКПП = ПолучитьСоответствиеОрганизацийПоИННКПП(МассивИННОрганизаций);
        СоответствиеСчетовОрганизаций = ПолучитьСоответствиеСчетовОрганизаций(МассивСчетовОрганизаций);
        СоответствиеСчетовКонтрагентов = ПолучитьСоответствиеСчетовКонтрагентов(МассивСчетовКонтрагентов);
        СоответствиеСтатейДДС = ПолучитьСоответствиеСтатейДДС(МассивСтатейДДС);
        СоответствиеДублей = ПолучитьСоответствиеДублейПоУИД(МассивУИД);
        
        // Кеш договоров: ключ = "КонтрагентСсылка|ТипДоговора", значение = ДоговорСсылка.
        // Позволяет не делать повторных запросов для одного контрагента с одинаковым типом.
        СоответствиеДоговоровПоКлючу = Новый Соответствие;
        
        // --- Обогащение строк предпросмотра из пакетных соответствий ---
        Для Каждого НовСтр Из ТЗ Цикл
            Попытка
                // Контрагент
                НовСтр.КонтрагентСсылка = СоответствиеКонтрагентов.Получить(НовСтр.ИНН);
                Если НовСтр.КонтрагентСсылка = Неопределено Тогда
                    НовСтр.КонтрагентСсылка = Справочники.Контрагенты.ПустаяСсылка();
                КонецЕсли;
                НовСтр.НайденКонтрагент = ЗначениеЗаполнено(НовСтр.КонтрагентСсылка);
                Если НЕ НовСтр.НайденКонтрагент Тогда
                    НовСтр.Комментарий = НовСтр.Комментарий + "Контрагент не найден (ИНН=" + НовСтр.ИНН + "). ";
                КонецЕсли;
                
                // Организация (приоритет: счет -> ИНН/КПП)
                НовСтр.ОрганизацияСсылка = СоответствиеОргПоСчетам.Получить(НовСтр.НашСчет);
                Если НовСтр.ОрганизацияСсылка = Неопределено Тогда
                    КлючОрг = НовСтр.ИННОрг + "|" + НовСтр.КППОрг;
                    НовСтр.ОрганизацияСсылка = СоответствиеОргПоИННКПП.Получить(КлючОрг);
                КонецЕсли;
                Если НовСтр.ОрганизацияСсылка = Неопределено Тогда
                    НовСтр.ОрганизацияСсылка = Справочники.Организации.ПустаяСсылка();
                КонецЕсли;
                НовСтр.НайденаОрганизация = ЗначениеЗаполнено(НовСтр.ОрганизацияСсылка);
                Если НЕ НовСтр.НайденаОрганизация Тогда
                    НовСтр.Комментарий = НовСтр.Комментарий + "Организация не найдена. ";
                КонецЕсли;
                
                // Счет организации
                Если НовСтр.НайденаОрганизация Тогда
                    КлючСчетОрг = Строка(НовСтр.ОрганизацияСсылка) + "|" + НовСтр.НашСчет;
                    НовСтр.БанковскийСчетОрганизации = СоответствиеСчетовОрганизаций.Получить(КлючСчетОрг);
                    Если НовСтр.БанковскийСчетОрганизации = Неопределено Тогда
                        НовСтр.БанковскийСчетОрганизации = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
                    КонецЕсли;
                    НовСтр.НайденСчетОрганизации = ЗначениеЗаполнено(НовСтр.БанковскийСчетОрганизации);
                    Если НЕ НовСтр.НайденСчетОрганизации Тогда
                        НовСтр.Комментарий = НовСтр.Комментарий + "Банк. счёт организации не найден. ";
                    КонецЕсли;
                Иначе
                    НовСтр.НайденСчетОрганизации = Ложь;
                    НовСтр.БанковскийСчетОрганизации = Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка();
                КонецЕсли;
                
                // Счет контрагента
                Если НовСтр.НайденКонтрагент И НЕ ПустаяСтрока(НовСтр.СчетКонтр) Тогда
                    КлючСчетКонтр = Строка(НовСтр.КонтрагентСсылка) + "|" + НовСтр.СчетКонтр;
                    НовСтр.БанковскийСчетКонтрагента = СоответствиеСчетовКонтрагентов.Получить(КлючСчетКонтр);
                    Если НовСтр.БанковскийСчетКонтрагента = Неопределено Тогда
                        НовСтр.БанковскийСчетКонтрагента = Справочники.БанковскиеСчетаКонтрагентов.ПустаяСсылка();
                    КонецЕсли;
                    НовСтр.НайденСчетКонтрагента = ЗначениеЗаполнено(НовСтр.БанковскийСчетКонтрагента);
                Иначе
                    НовСтр.НайденСчетКонтрагента = Ложь;
                    НовСтр.БанковскийСчетКонтрагента = Справочники.БанковскиеСчетаКонтрагентов.ПустаяСсылка();
                КонецЕсли;
                
                // Статья ДДС
                НовСтр.СтатьяДДССсылка = СоответствиеСтатейДДС.Получить(НовСтр.СтатьяДДС);
                Если НовСтр.СтатьяДДССсылка = Неопределено Тогда
                    НовСтр.СтатьяДДССсылка = Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка();
                КонецЕсли;
                НовСтр.НайденаСтатья = ЗначениеЗаполнено(НовСтр.СтатьяДДССсылка);
                Если НЕ НовСтр.НайденаСтатья Тогда
                    НовСтр.Комментарий = НовСтр.Комментарий + "Статья ДДС не найдена. ";
                КонецЕсли;
                
                // Договор — ищем самый ранний не удалённый по типу платежа.
                // Направление: Приход → ТипДоговора=СПокупателем (Реализация),
                //              Расход → ТипДоговора=СПоставщиком (Закупка).
                // Статус действия договора (Действует/Закрыт) НЕ проверяется.
                // Результаты кешируются по паре КонтрагентСсылка+ТипДоговора.
                Если НовСтр.НайденКонтрагент Тогда
                    НаправВРег = ВРег(НовСтр.НаправлениеДенег);
                    ТипДогПоиск = Неопределено;
                    Если СтрНайти(НаправВРег, "ПРИХОД") > 0 Тогда
                        ТипДогПоиск = Перечисления.ТипыДоговоров.СПокупателем;
                    ИначеЕсли СтрНайти(НаправВРег, "РАСХОД") > 0 Тогда
                        ТипДогПоиск = Перечисления.ТипыДоговоров.СПоставщиком;
                    КонецЕсли;
                    
                    Если ТипДогПоиск <> Неопределено Тогда
                        КлючДоговора = Строка(НовСтр.КонтрагентСсылка) + "|" + Строка(ТипДогПоиск);
                        КешЗначение = СоответствиеДоговоровПоКлючу.Получить(КлючДоговора);
                        Если КешЗначение = Неопределено Тогда
                            НайдДог = НайтиДоговорПоТипу(НовСтр.КонтрагентСсылка, ТипДогПоиск);
                            Если НайдДог = Неопределено Тогда
                                НайдДог = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
                            КонецЕсли;
                            СоответствиеДоговоровПоКлючу.Вставить(КлючДоговора, НайдДог);
                            КешЗначение = НайдДог;
                        КонецЕсли;
                        НовСтр.ДоговорСсылка = КешЗначение;
                        НовСтр.НайденДоговор = ЗначениеЗаполнено(НовСтр.ДоговорСсылка);
                    Иначе
                        НовСтр.НайденДоговор = Ложь;
                        НовСтр.ДоговорСсылка = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
                    КонецЕсли;
                    
                    Если НЕ НовСтр.НайденДоговор Тогда
                        НовСтр.Комментарий = НовСтр.Комментарий + "Договор не найден. ";
                    КонецЕсли;
                Иначе
                    НовСтр.НайденДоговор = Ложь;
                    НовСтр.ДоговорСсылка = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
                КонецЕсли;
                
                // Дубли по УИД
                Если ПустаяСтрока(НовСтр.УИД) Тогда
                    НовСтр.ЭтоДубль = Ложь;
                    НовСтр.Комментарий = НовСтр.Комментарий + "УИД пустой. ";
                Иначе
                    СвязанныйДок = СоответствиеДублей.Получить(НовСтр.УИД);
                    НовСтр.ЭтоДубль = (СвязанныйДок <> Неопределено);
                    Если НовСтр.ЭтоДубль Тогда
                        НовСтр.КомментарийДубля = "Загружен " + Формат(СвязанныйДок.ДатаЗагрузки, "ДЛФ=DD") + " из " + СвязанныйДок.ИмяФайла;
                        КоличествоДублей = КоличествоДублей + 1;
                    КонецЕсли;
                КонецЕсли;
                
                // Итоговый статус
                Если НовСтр.ЭтоДубль Тогда
                    НовСтр.Статус = "Дубль";
                ИначеЕсли НовСтр.НайденКонтрагент
                        И НовСтр.НайденаСтатья
                        И НовСтр.НайденаОрганизация
                        И НовСтр.НайденСчетОрганизации
                        И НовСтр.НайденДоговор
                        И ЗначениеЗаполнено(НовСтр.Дата)
                        И НовСтр.Дата <> '00010101'
                        И НовСтр.Сумма > 0
                        И НЕ ПустаяСтрока(НовСтр.УИД) Тогда
                    НовСтр.Статус = "Готов";
                Иначе
                    НовСтр.Статус = "Ошибка";
                    КоличествоОшибок = КоличествоОшибок + 1;
                КонецЕсли;
            Исключение
                НовСтр.Статус = "Ошибка";
                НовСтр.Комментарий = НовСтр.Комментарий + "Ошибка пакетной обработки строки. ";
                КоличествоОшибок = КоличествоОшибок + 1;
            КонецПопытки;
        КонецЦикла;

        Возврат ТЗ;

    КонецФункции

#КонецОбласти //Чтение_Excel_И_Заполнение_таблицы

#Область Вспомогательные_функции_нормализация 
// НОРМАЛИЗАЦИЯ - ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ // BSLLS-off

&НаСервереБезКонтекста
Функция НормализоватьЦифровойКод(ЗначениеЯчейки)
    Если НЕ ЗначениеЗаполнено(ЗначениеЯчейки) Тогда
        Возврат "";
    КонецЕсли;

    Текст = СокрЛП(Строка(ЗначениеЯчейки));
    Текст = СтрЗаменить(Текст, Символ(160), "");
    Текст = СтрЗаменить(Текст, " ", "");

    Если СтрНайти(Текст, ".") > 0 Тогда
        Части = СтрРазделить(Текст, ".");
        Если Части.Количество() = 2 Тогда
            ДробнаяЧасть = Части[1];
            ЕстьТолькоНули = Истина;
            Для Сч = 1 По СтрДлина(ДробнаяЧасть) Цикл
                Если Сред(ДробнаяЧасть, Сч, 1) <> "0" Тогда
                    ЕстьТолькоНули = Ложь;
                    Прервать;
                КонецЕсли;
            КонецЦикла;
            Если ЕстьТолькоНули Тогда
                Текст = Части[0];
            КонецЕсли;
        КонецЕсли;
    КонецЕсли;

    Если СтрНайти(ВРег(Текст), "E") > 0 Тогда
        Попытка
            ЧисловоеЗначение = Число(СтрЗаменить(Текст, "E", "e"));
            Текст = Формат(ЧисловоеЗначение, "ЧДЦ=0; ЧРД=.; ЧГ=0");
            Если СтрНайти(Текст, ".") > 0 Тогда
                Текст = СтрРазделить(Текст, ".")[0];
            КонецЕсли;
        Исключение
        КонецПопытки;
    КонецЕсли;

    Результат = "";
    Для Сч = 1 По СтрДлина(Текст) Цикл
        Симв = Сред(Текст, Сч, 1);
        Если Найти("0123456789", Симв) > 0 Тогда
            Результат = Результат + Симв;
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;
КонецФункции

&НаСервереБезКонтекста
Функция ПарситьДату(ТекстДата)
    Текст = СокрЛП(ТекстДата);
    Если ПустаяСтрока(Текст) Тогда
        Возврат '00010101';
    КонецЕсли;

    Если СтрДлина(Текст) >= 10 И Сред(Текст, 3, 1) = "." И Сред(Текст, 6, 1) = "." Тогда
        День  = Лев(Текст, 2);
        Месяц = Сред(Текст, 4, 2);
        Год   = Сред(Текст, 7, 4);
        Попытка
            Возврат Дата(Год + Месяц + День);
        Исключение
        КонецПопытки;
    КонецЕсли;

    Если СтрДлина(Текст) >= 10 И Сред(Текст, 5, 1) = "-" И Сред(Текст, 8, 1) = "-" Тогда
        Год   = Лев(Текст, 4);
        Месяц = Сред(Текст, 6, 2);
        День  = Сред(Текст, 9, 2);
        Попытка
            Возврат Дата(Год + Месяц + День);
        Исключение
        КонецПопытки;
    КонецЕсли;

    Если СтрДлина(Текст) = 8 Тогда
        Попытка
            Возврат Дата(Текст);
        Исключение
        КонецПопытки;
    КонецЕсли;

    Возврат '00010101';
КонецФункции

