        Выборка = Запрос.Выполнить().Выбрать();
        Пока Выборка.Следующий() Цикл
            Ключ = Строка(Выборка.Владелец) + "|" + Выборка.НомерСчета;
            Если Результат.Получить(Ключ) = Неопределено Тогда
                Результат.Вставить(Ключ, Выборка.Ссылка);
            КонецЕсли;
        КонецЦикла;
        
        Возврат Результат;
    КонецФункции

    &НаСервереБезКонтекста
    Функция НайтиДубльПоУИД(УИД)
        // Возвращает структуру с данными если дубль найден, иначе Неопределено
        Если ПустаяСтрока(СокрЛП(УИД)) Тогда
            Возврат Неопределено;
        КонецЕсли;
        
        Если НЕ ВключенКонтрольДублейПоУИД() Тогда
            Возврат Неопределено;
        КонецЕсли;

        Попытка
            Запрос = Новый Запрос;
            Запрос.Текст =
            "ВЫБРАТЬ ПЕРВЫЕ 1
            |   КАА_СвязиДокументовБП.ДокументУТ КАК ДокументУТ,
            |   КАА_СвязиДокументовБП.ДатаЗагрузки КАК ДатаЗагрузки,
            |   КАА_СвязиДокументовБП.ИмяФайла КАК ИмяФайла
            |ИЗ
            |   РегистрСведений.КАА_СвязиДокументовБП КАК КАА_СвязиДокументовБП
            |ГДЕ
            |   КАА_СвязиДокументовБП.ИдентификаторБП = &ИдентификаторБП";

            Запрос.УстановитьПараметр("ИдентификаторБП", УИД);
            Выборка = Запрос.Выполнить().Выбрать();
            Если Выборка.Следующий() Тогда
                Возврат Новый Структура(
                    "ДокументУТ,ДатаЗагрузки,ИмяФайла",
                    Выборка.ДокументУТ,
                    Выборка.ДатаЗагрузки,
                    Выборка.ИмяФайла
                );
            КонецЕсли;
        Исключение
        КонецПопытки;
        Возврат Неопределено;
    КонецФункции
    
    &НаСервереБезКонтекста
    Функция ПолучитьСоответствиеДублейПоУИД(МассивУИД)
        Результат = Новый Соответствие;
        Если МассивУИД = Неопределено ИЛИ МассивУИД.Количество() = 0 Тогда
            Возврат Результат;
        КонецЕсли;
        
        Если НЕ ВключенКонтрольДублейПоУИД() Тогда
            Возврат Результат;
        КонецЕсли;
        
        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ
        |   КАА_СвязиДокументовБП.ИдентификаторБП КАК ИдентификаторБП,
        |   КАА_СвязиДокументовБП.ДокументУТ КАК ДокументУТ,
        |   КАА_СвязиДокументовБП.ДатаЗагрузки КАК ДатаЗагрузки,
        |   КАА_СвязиДокументовБП.ИмяФайла КАК ИмяФайла
        |ИЗ
        |   РегистрСведений.КАА_СвязиДокументовБП КАК КАА_СвязиДокументовБП
        |ГДЕ
        |   КАА_СвязиДокументовБП.ИдентификаторБП В (&УИД)";
        
        Запрос.УстановитьПараметр("УИД", МассивУИД);
        Выборка = Запрос.Выполнить().Выбрать();
        Пока Выборка.Следующий() Цикл
            Если Результат.Получить(Выборка.ИдентификаторБП) = Неопределено Тогда
                Результат.Вставить(
                    Выборка.ИдентификаторБП,
                    Новый Структура(
                        "ДокументУТ,ДатаЗагрузки,ИмяФайла",
                        Выборка.ДокументУТ,
                        Выборка.ДатаЗагрузки,
                        Выборка.ИмяФайла
                    )
                );
            КонецЕсли;
        КонецЦикла;
        
        Возврат Результат;
    КонецФункции

    &НаСервереБезКонтекста
    Функция ПолучитьСоответствиеСтатейДДС(МассивНаименований)
        Результат = Новый Соответствие;
        Если МассивНаименований = Неопределено ИЛИ МассивНаименований.Количество() = 0 Тогда
            Возврат Результат;
        КонецЕсли;
        
        // Строгое сопоставление по значениям из колонки "СтатьяДДС_УТ".
        // Никакого дополнительного поиска "по похожим" наименованиям не выполняем.
        МассивИменДляПоиска = Новый Массив;
        ИндексИменДляПоиска = Новый Соответствие;
        
        Для Каждого ИсходноеНаименование Из МассивНаименований Цикл
            ИмяСтатьи = СокрЛП(Строка(ИсходноеНаименование));
            Если ПустаяСтрока(ИмяСтатьи) Тогда
                Продолжить;
            КонецЕсли;
            
            Если ИндексИменДляПоиска.Получить(ИмяСтатьи) <> Неопределено Тогда
                Продолжить;
            КонецЕсли;
            
            ИндексИменДляПоиска.Вставить(ИмяСтатьи, Истина);
            МассивИменДляПоиска.Добавить(ИмяСтатьи);
        КонецЦикла;
        
        Если МассивИменДляПоиска.Количество() = 0 Тогда
            Возврат Результат;
        КонецЕсли;
        
        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ
        |   Статьи.Наименование КАК Наименование,
        |   Статьи.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.СтатьиДвиженияДенежныхСредств КАК Статьи
        |ГДЕ
        |   Статьи.Наименование В (&Наименования)
        |   И НЕ Статьи.ПометкаУдаления
        |   И НЕ Статьи.ЭтоГруппа";
        
        Запрос.УстановитьПараметр("Наименования", МассивИменДляПоиска);
        Выборка = Запрос.Выполнить().Выбрать();
        Пока Выборка.Следующий() Цикл
            Если Результат.Получить(Выборка.Наименование) = Неопределено Тогда
                Результат.Вставить(Выборка.Наименование, Выборка.Ссылка);
            КонецЕсли;
        КонецЦикла;
        
        Возврат Результат;
    КонецФункции

// ────────────────────────────────────────────────────────────────────────────
// НайтиДоговорПоТипу — поиск ПЕРВОГО не удалённого договора нужного типа
// для данного контрагента. Договоры упорядочены по дате (самый ранний первый).
// Статус действия (Действует / Закрыт / Расторгнут) НЕ проверяется.
// СОЗДАНИЕ новых договоров не производится — только поиск.
//
// Параметры:
//   КонтрагентСсылка — СправочникСсылка.Контрагенты
//   ТипДоговора      — Перечисления.ТипыДоговоров (СПокупателем | СПоставщиком)
//
// Возвращает: СправочникСсылка.ДоговорыКонтрагентов или Неопределено.
&НаСервереБезКонтекста
Функция НайтиДоговорПоТипу(КонтрагентСсылка, ТипДоговора)
    Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) ИЛИ ТипДоговора = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |   Договор.Ссылка КАК Ссылка
    |ИЗ
    |   Справочник.ДоговорыКонтрагентов КАК Договор
    |ГДЕ
    |   Договор.Контрагент = &Контрагент
    |   И Договор.ТипДоговора = &ТипДоговора
    |   И НЕ Договор.ПометкаУдаления
    |УПОРЯДОЧИТЬ ПО
    |   Договор.Дата ВОЗР";
    
    Запрос.УстановитьПараметр("Контрагент", КонтрагентСсылка);
    Запрос.УстановитьПараметр("ТипДоговора", ТипДоговора);
    
    Попытка
        Выборка = Запрос.Выполнить().Выбрать();
        Если Выборка.Следующий() Тогда
            Возврат Выборка.Ссылка;
        КонецЕсли;
    Исключение
        // не прерываем предпросмотр из-за ошибки поиска договора
    КонецПопытки;
    
    Возврат Неопределено;
КонецФункции

#КонецОбласти  //Поиск_Объектов_В_Базе

// ────────────────────────────────────────────────────────────────────────────
// НайтиКлючАналитикиПоДоговору
// В UT 11 договор в РасшифровкаПлатежа хранится не прямым реквизитом "Договор",
// а через измерение АналитикаУчетаПоПартнерам → Справочник.КлючиАналитикиУчетаПоПартнерам.
// Функция ищет первый не-удалённый ключ аналитики для данного договора.
//
// Параметры:
//   ДоговорСсылка — СправочникСсылка.ДоговорыКонтрагентов
//
// Возвращает: СправочникСсылка.КлючиАналитикиУчетаПоПартнерам или Неопределено
&НаСервереБезКонтекста
Функция НайтиКлючАналитикиПоДоговору(ДоговорСсылка)
    Если НЕ ЗначениеЗаполнено(ДоговорСсылка) Тогда
        Возврат Неопределено;
    КонецЕсли;
    
    Попытка
        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   КлючАналитики.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.КлючиАналитикиУчетаПоПартнерам КАК КлючАналитики
        |ГДЕ
        |   КлючАналитики.Договор = &Договор
        |   И НЕ КлючАналитики.ПометкаУдаления";
        Запрос.УстановитьПараметр("Договор", ДоговорСсылка);
        
        Выборка = Запрос.Выполнить().Выбрать();
        Если Выборка.Следующий() Тогда
            Возврат Выборка.Ссылка;
        КонецЕсли;
    Исключение
        // если справочника нет или поле Договор называется иначе — не блокируем загрузку
    КонецПопытки;
    
    Возврат Неопределено;
КонецФункции

#Область Загрузка_В_Базу_Вспомогательные

    #Область Договор_В_УТ
        // ОБЛАСТЬ: Договор — поиск или создание договора контрагента в 1УТ
    &НаСервере
    Функция НайтиИлиСоздатьДоговор(КонтрагентСсылка, ОрганизацияСсылка, ТипДоговора, ДатаДокумента, СтатьяДДССсылка)
        
        Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) 
            ИЛИ НЕ ЗначениеЗаполнено(ОрганизацияСсылка) 
            ИЛИ ТипДоговора = Неопределено Тогда
            
            Возврат Неопределено;
            
        КонецЕсли;
        
        // --- ИЩЕМ СУЩЕСТВУЮЩИЙ ДОГОВОР---
        Запрос = Новый Запрос;
        Запрос.Текст = 
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   ДоговорыКонтрагентов.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
        |ГДЕ
        |   ДоговорыКонтрагентов.Контрагент = &Контрагент
        |   И ДоговорыКонтрагентов.Организация = &Организация
        |   И ДоговорыКонтрагентов.ТипДоговора = &ТипДоговора
        |   И НЕ ДоговорыКонтрагентов.ПометкаУдаления";
        
        Запрос.УстановитьПараметр("Контрагент", КонтрагентСсылка);
        Запрос.УстановитьПараметр("Организация", ОрганизацияСсылка);
        Запрос.УстановитьПараметр("ТипДоговора", ТипДоговора);
        
        Выборка = Запрос.Выполнить().Выбрать();
        
        Если Выборка.Следующий() Тогда
            Возврат ПривестиДоговорКСтандартуЭтап3Подход(
                Выборка.Ссылка,
                КонтрагентСсылка,
                ОрганизацияСсылка,
                ТипДоговора,
                ДатаДокумента,
                СтатьяДДССсылка);
        КонецЕсли;
    
        // --- СОЗДАЁМ НОВЫЙ ДОГОВОР ---
        Попытка

            НовыйДоговор = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();           
            // базовые поля
            НовыйДоговор.Контрагент   = КонтрагентСсылка;
            НовыйДоговор.Организация  = ОрганизацияСсылка;
            НовыйДоговор.ТипДоговора  = ТипДоговора;           
            
            // --- ПАРТНЁР ---
            ПартнерСсылка = ПолучитьПартнераКонтрагента(КонтрагентСсылка);
            
            Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
                Попытка
                    НовыйДоговор.Партнер = ПартнерСсылка;
                Исключение
                КонецПопытки;
            КонецЕсли;
            
            // --- Устанавливаем дату по формуле ДАТА 01 ЯНВАРЯ ГОДА = году платёжке ---
            ДатаНачалаДоговора = Дата(Год(ДатаДокумента), 1, 1); 
            НовыйДоговор.Дата = Дата(Год(ДатаДокумента), 1, 1);
            НовыйДоговор.ДатаНачалаДействия = НовыйДоговор.Дата;
            
            // --- НАИМЕНОВАНИЕ. ОПРЕДЕЛЯЕМ ТИП (Закупка / Реализация) И в завсисмости от этого отражаем в названии договора---            
            ИмяТипа = "";

            Если ТипДоговора = Перечисления.ТипыДоговоров.СПоставщиком Тогда
                ИмяТипа = "Закупка";
            ИначеЕсли ТипДоговора = Перечисления.ТипыДоговоров.СПокупателем Тогда
                ИмяТипа = "Реализация";
            Иначе
                ИмяТипа = "Прочее";
            КонецЕсли;

            НовыйДоговор.Наименование = "Договор_" + ИмяТипа + "_Авто_" + Формат(ДатаНачалаДоговора, "ДФ=dd.MM.yyyy");
            
            // --- Присваиваем статус ---
            Попытка 
                НовыйДоговор.Статус = Перечисления.СтатусыДоговоровКонтрагентов.Действует;  
            Исключение
                Сообщить("Ошибка создания статуса договора : " + ОписаниеОшибки());  
            КонецПопытки;

            //---Заполняем обязательное поле Тип Налогооблажения
            Попытка
                НовыйДоговор.НалогообложениеНДС = 
                    Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
            Исключение
                Сообщить("Ошибка установки НДС в договоре: " + ОписаниеОшибки());
            КонецПопытки;

            //---Заполняем необязательное поле Статья ДДС. В дальшейшем пригодиться.
            Попытка
                Если ЗначениеЗаполнено(СтатьяДДССсылка) Тогда
                    НовыйДоговор.СтатьяДвиженияДенежныхСредств = СтатьяДДССсылка;
                КонецЕсли;
            Исключение
                Сообщить("Ошибка установки статьи ДДС в договоре: " + ОписаниеОшибки());
            КонецПопытки;

            НовыйДоговор.Записать();
            Возврат ПривестиДоговорКСтандартуЭтап3Подход(
                НовыйДоговор.Ссылка,
                КонтрагентСсылка,
                ОрганизацияСсылка,
                ТипДоговора,
                ДатаДокумента,
                СтатьяДДССсылка);
            
        Исключение           
            Сообщить("Ошибка создания договора: " + ОписаниеОшибки());        
            Возврат Неопределено;           
        КонецПопытки;

    КонецФункции
    
    &НаСервереБезКонтекста
    Функция ПривестиДоговорКСтандартуЭтап3Подход(
        ДоговорСсылка,
        КонтрагентСсылка,
        ОрганизацияСсылка,
        ТипДоговора,
        ДатаДокумента,
        СтатьяДДССсылка)
        
        Если НЕ ЗначениеЗаполнено(ДоговорСсылка) Тогда
            Возврат Неопределено;
        КонецЕсли;
        
        Попытка
            ДоговорОбъект = ДоговорСсылка.ПолучитьОбъект();
            
            ДатаСтандарта = Дата(Год(ДатаДокумента), 1, 1);
            
            Если ДоговорОбъект.Контрагент <> КонтрагентСсылка Тогда
                ДоговорОбъект.Контрагент = КонтрагентСсылка;
            КонецЕсли;
            
            Попытка
                Если ДоговорОбъект.Организация <> ОрганизацияСсылка Тогда
                    ДоговорОбъект.Организация = ОрганизацияСсылка;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            Если ДоговорОбъект.ТипДоговора <> ТипДоговора Тогда
                ДоговорОбъект.ТипДоговора = ТипДоговора;
            КонецЕсли;
            
            Если НЕ ЗначениеЗаполнено(ДоговорОбъект.Номер) Тогда
                ДоговорОбъект.Номер = "БН";
            КонецЕсли;
            
            Если НЕ ЗначениеЗаполнено(ДоговорОбъект.Дата) Тогда
                ДоговорОбъект.Дата = ДатаСтандарта;
            КонецЕсли;
            
            Попытка
                Если НЕ ЗначениеЗаполнено(ДоговорОбъект.ДатаНачалаДействия) Тогда
                    ДоговорОбъект.ДатаНачалаДействия = ДатаСтандарта;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            Попытка
                Если ДоговорОбъект.Статус <> Перечисления.СтатусыДоговоровКонтрагентов.Действует Тогда
                    ДоговорОбъект.Статус = Перечисления.СтатусыДоговоровКонтрагентов.Действует;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            Попытка
                ПартнерСсылка = ПолучитьПартнераКонтрагента(КонтрагентСсылка);
                Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
                    ДоговорОбъект.Партнер = ПартнерСсылка;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            Попытка
                Если ЗначениеЗаполнено(СтатьяДДССсылка) Тогда
                    ДоговорОбъект.СтатьяДвиженияДенежныхСредств = СтатьяДДССсылка;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            // Сбрасываем ограничения на вкладке "Расчеты и оформление".
            // По метаданным УТ:
            // - ОграничиватьСуммуЗадолженности
            // - ДопустимаяСуммаЗадолженности
            // - ЗапрещаетсяПросроченнаяЗадолженность
            // Для "Сумма договора фиксированная" отдельный булевый реквизит отсутствует,
            // поэтому сбрасываем лимит поля Сумма.
            Попытка
                Если ЗначениеЗаполнено(ДоговорОбъект.Сумма)
                    И ДоговорОбъект.Сумма <> 0 Тогда
                    ДоговорОбъект.Сумма = 0;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            Попытка
                Если ДоговорОбъект.ОграничиватьСуммуЗадолженности Тогда
                    ДоговорОбъект.ОграничиватьСуммуЗадолженности = Ложь;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            Попытка
                Если ЗначениеЗаполнено(ДоговорОбъект.ДопустимаяСуммаЗадолженности)
                    И ДоговорОбъект.ДопустимаяСуммаЗадолженности <> 0 Тогда
                    ДоговорОбъект.ДопустимаяСуммаЗадолженности = 0;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            Попытка
                Если ДоговорОбъект.ЗапрещаетсяПросроченнаяЗадолженность Тогда
                    ДоговорОбъект.ЗапрещаетсяПросроченнаяЗадолженность = Ложь;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            ДоговорОбъект.Записать();
            Возврат ДоговорОбъект.Ссылка;
        Исключение
            Возврат ДоговорСсылка;
        КонецПопытки;
        
    КонецФункции

    #КонецОбласти //Договор_В_УТ

    #Область Валюта_руб
    // Функция определяет валюту документа по текстовому наименованию.
    // По умолчанию — российский рубль (RUB).
    //
    // Параметры:
    //   ТекстВалюта - Строка - текстовое наименование валюты из Excel
    //
    // Возвращаемое значение:
    //   СправочникСсылка.Валюты - найденная валюта
    //
        &НаСервереБезКонтекста
        Функция ОпределитьВалюту(ТекстВалюта)
            
            Текст = ВРег(СокрЛП(ТекстВалюта));
            
            // По умолчанию — рубль
            Если ПустаяСтрока(Текст)
                Или Текст = "РУБ."
                Или Текст = "РУБ"
                Или Текст = "RUB"
                Или Текст = "RUR"
                Или Текст = "643" Тогда
                    Результат = Справочники.Валюты.НайтиПоКоду("643");
                    Если НЕ ЗначениеЗаполнено(Результат) Тогда                     Результат = Справочники.Валюты.НайтиПоНаименованию("руб.");
                    КонецЕсли;
                Возврат Результат;
            КонецЕсли;
            
            // Попытка найти по наименованию
            Попытка
                Результат = Справочники.Валюты.НайтиПоНаименованию(СокрЛП(ТекстВалюта));
                Если ЗначениеЗаполнено(Результат) Тогда
                    Возврат Результат;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            // Если ничего не нашли — пробуем по коду
            Попытка
                Результат = Справочники.Валюты.НайтиПоКоду(СокрЛП(ТекстВалюта));
                Если ЗначениеЗаполнено(Результат) Тогда
                    Возврат Результат;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            // Возвращаем рубль по умолчанию
            Возврат Справочники.Валюты.НайтиПоКоду("643");
            
        КонецФункции

