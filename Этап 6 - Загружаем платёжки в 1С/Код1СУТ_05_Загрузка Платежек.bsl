Функция НормализоватьСумму(ТекстСумма)
    Текст = СокрЛП(ТекстСумма);
    Текст = СтрЗаменить(Текст, Символ(160), "");
    Текст = СтрЗаменить(Текст, " ", "");
    Текст = СтрЗаменить(Текст, ",", ".");
    Попытка
        Возврат Число(Текст);
    Исключение
        Возврат 0;
    КонецПопытки;
КонецФункции

&НаСервереБезКонтекста
Функция ДобавитьВедущийНольЕслиНужно(ИНН)
    ИНН = СокрЛП(ИНН);
    Если ПустаяСтрока(ИНН) Тогда
        Возврат ИНН;
    КонецЕсли;
    ДлинаИНН = СтрДлина(ИНН);
    Если ДлинаИНН = 9 Или ДлинаИНН = 11 Тогда
        Возврат "0" + ИНН;
    КонецЕсли;
    Возврат ИНН;
КонецФункции

&НаСервереБезКонтекста
Процедура ДобавитьУникальноеЗначение(МассивЗначений, ИндексЗначений, Значение)
    Если НЕ ЗначениеЗаполнено(Значение) Тогда
        Возврат;
    КонецЕсли;
    
    Ключ = СокрЛП(Строка(Значение));
    Если ПустаяСтрока(Ключ) Тогда
        Возврат;
    КонецЕсли;
    
    Если ИндексЗначений.Получить(Ключ) = Неопределено Тогда
        ИндексЗначений.Вставить(Ключ, Истина);
        МассивЗначений.Добавить(Ключ);
    КонецЕсли;
КонецПроцедуры

