#Область Клиентские_процедуры

    &НаКлиенте
    Процедура ВыбратьФайл(Команда)
        ОписаниеОповещения = Новый ОписаниеОповещения("ВыбратьФайлЗавершение", ЭтаФорма);
        НачатьПомещениеФайла(
            ОписаниеОповещения,
            ,
            ,
            Истина,
            ЭтаФорма.УникальныйИдентификатор);
    КонецПроцедуры

    &НаКлиенте
    Процедура ВыбратьФайлЗавершение(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт
        Если НЕ Результат Тогда
            Возврат;
        КонецЕсли;

        ЭтаФорма.АдресФайла = Адрес;
        ЭтаФорма.ИмяФайла   = ВыбранноеИмяФайла;
    // === ЗАПУСК ТАЙМЕРА ===
    НачалоЗагрузки = ТекущаяУниверсальнаяДатаВМиллисекундах();
    ЗагрузитьПредпросмотрСервер(Адрес, ВыбранноеИмяФайла, НачалоЗагрузки);
        
    КонецПроцедуры

    &НаКлиенте
    Функция ПопыткаУстановитьСвойствоСтроки(СтрокаТаблицы, ИмяСвойства, Значение)
        Попытка
            Выполнить("СтрокаТаблицы." + ИмяСвойства + " = Значение;");
            Возврат Истина;
        Исключение
            Возврат Ложь;
        КонецПопытки;
    КонецФункции

    &НаКлиенте
    Функция СтрокаОтмеченаКЗагрузкеКлиент(СтрокаТаблицы)
        Попытка
            Возврат СтрокаТаблицы.Выбрать;
        Исключение
            // Если в форме нет колонки "Выбрать", сохраняем старое поведение (загружать все строки).
            Возврат Истина;
        КонецПопытки;
    КонецФункции

    &НаКлиенте
    Процедура ВыбратьВсе(Команда)
        
        Если ТаблицаДанных.Количество() = 0 Тогда
            ПоказатьПредупреждение(, "Нет данных для выбора.");
            Возврат;
        КонецЕсли;
        
        Для Каждого СтрокаТаблицы Из ТаблицаДанных Цикл
            ПопыткаУстановитьСвойствоСтроки(СтрокаТаблицы, "Выбрать", Истина);
        КонецЦикла;
        
        Элементы.ТаблицаДанных.Обновить();
        
    КонецПроцедуры

    &НаКлиенте
    Процедура СнятьВсе(Команда)
        
        Если ТаблицаДанных.Количество() = 0 Тогда
            ПоказатьПредупреждение(, "Нет данных для снятия выбора.");
            Возврат;
        КонецЕсли;
        
        Для Каждого СтрокаТаблицы Из ТаблицаДанных Цикл
            ПопыткаУстановитьСвойствоСтроки(СтрокаТаблицы, "Выбрать", Ложь);
        КонецЦикла;
        
        Элементы.ТаблицаДанных.Обновить();
        
    КонецПроцедуры

    &НаКлиенте
    Процедура ЗагрузитьВБазу(Команда)
        
        // Проверяем, что таблица заполнена
        Если ТаблицаДанных.Количество() = 0 Тогда
            ПоказатьПредупреждение(, "Таблица данных пуста. Сначала загрузите файл Excel.");
            Возврат;
        КонецЕсли;
        
        // Подсчитываем количество строк к загрузке
        КоличествоГотовых = 0;
        КоличествоДублей  = 0;
        КоличествоОшибок  = 0;
        КоличествоВыбранных = 0;
        
        Для Каждого СтрокаТаблицы Из ТаблицаДанных Цикл
            Если НЕ СтрокаОтмеченаКЗагрузкеКлиент(СтрокаТаблицы) Тогда
                Продолжить;
            КонецЕсли;
            
            КоличествоВыбранных = КоличествоВыбранных + 1;
            Если        СтрокаТаблицы.Статус = "Готов"  Тогда   КоличествоГотовых = КоличествоГотовых + 1;
            ИначеЕсли   СтрокаТаблицы.Статус = "Дубль"  Тогда   КоличествоДублей = КоличествоДублей + 1;
            ИначеЕсли   СтрокаТаблицы.Статус = "Ошибка" Тогда   КоличествоОшибок = КоличествоОшибок + 1;
            КонецЕсли;
        КонецЦикла;
        
        Если КоличествоВыбранных = 0 Тогда
            ПоказатьПредупреждение(, "Не выбрано ни одной строки для загрузки.");
            Возврат;
        КонецЕсли;
        
        Если КоличествоГотовых = 0 Тогда
            ПоказатьПредупреждение(, "Среди выбранных строк нет статуса ""Готов"" для загрузки."
                + Символы.ПС + "Дублей: " + Строка(КоличествоДублей)
                + Символы.ПС + "Ошибок: " + Строка(КоличествоОшибок));
            Возврат;
        КонецЕсли;
        
        // Запрашиваем подтверждение
        ТекстВопроса = "Выбрано строк: " + Строка(КоличествоВыбранных)
            + Символы.ПС + "Будет создано документов: " + Строка(КоличествоГотовых)
            + Символы.ПС + "Пропущено (дубли): " + Строка(КоличествоДублей)
            + Символы.ПС + "Пропущено (ошибки): " + Строка(КоличествоОшибок)
            + Символы.ПС + Символы.ПС + "Продолжить загрузку?";
        
        ОписаниеОповещения = Новый ОписаниеОповещения(
            "ЗагрузитьВБазуПодтверждение", ЭтотОбъект);
        
        ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет, ,
            КодВозвратаДиалога.Нет, "Загрузка в базу");
        
    КонецПроцедуры
  
    &НаКлиенте
    Процедура ЗагрузитьВБазуПодтверждение(РезультатВопроса, ДополнительныеПараметры) Экспорт
        
        Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
            Возврат;
        КонецЕсли;
            
        Состояние("Загрузка документов в базу...");
        
        // === ЗАПУСК ТАЙМЕРА ===
        НачалоЗагрузки = ТекущаяУниверсальнаяДатаВМиллисекундах();
        ЗагрузитьВБазуСервер(НачалоЗагрузки);

        Элементы.ТаблицаДанных.Обновить();
        
        // Дополнительно показываем время на клиенте (на всякий случай)
        Сообщить("Загрузка в базу завершена.", СтатусСообщения.Информация);
        
    КонецПроцедуры

#КонецОбласти //Клиентские_процедуры

#Область Чтение_Excel_И_Заполнение_таблицы 
// ЧТЕНИЕ EXCEL И ЗАПОЛНЕНИЕ ПРЕДВАРИТЕЛЬНОЙ ТАБЛИЦЫ

    &НаСервереБезКонтекста
    Функция НормализоватьТекстДляСравнения(Текст)
        Результат = ВРег(СокрЛП(Строка(Текст)));
        Результат = СтрЗаменить(Результат, Символ(160), "");
        Результат = СтрЗаменить(Результат, Символы.Таб, "");
        Результат = СтрЗаменить(Результат, " ", "");
        Результат = СтрЗаменить(Результат, "_", "");
        Результат = СтрЗаменить(Результат, "-", "");
        Результат = СтрЗаменить(Результат, ".", "");
        Результат = СтрЗаменить(Результат, """", "");
        Возврат Результат;
    КонецФункции

    &НаСервереБезКонтекста
    Функция НайтиНомерКолонкиПоЗаголовку(ТабДок, НомерСтрокиЗаголовка, ИмяЗаголовка)
        ИскомоеИмя = НормализоватьТекстДляСравнения(ИмяЗаголовка);
        
        Для НомерКолонки = 1 По ТабДок.ШиринаТаблицы Цикл
            ТекстЯчейки = НормализоватьТекстДляСравнения(ТабДок.Область(НомерСтрокиЗаголовка, НомерКолонки).Текст);
            Если ТекстЯчейки = ИскомоеИмя Тогда
                Возврат НомерКолонки;
            КонецЕсли;
        КонецЦикла;
        
        Возврат 0;
    КонецФункции

    &НаСервереБезКонтекста
    Функция СформироватьВариантыЗаголовков(СписокЧерезЗапятую)
        Результат = Новый Массив;
        Для Каждого ЭлементСписка Из СтрРазделить(СписокЧерезЗапятую, ",") Цикл
            Вариант = СокрЛП(ЭлементСписка);
            Если НЕ ПустаяСтрока(Вариант) Тогда
                Результат.Добавить(Вариант);
            КонецЕсли;
        КонецЦикла;
        Возврат Результат;
    КонецФункции

    &НаСервереБезКонтекста
    Функция ОпределитьКолонкуПоВариантам(ТабДок, НомерСтрокиЗаголовка, НомерПоУмолчанию, ВариантыЗаголовков)
        Если ВариантыЗаголовков <> Неопределено Тогда
            Для Каждого ВариантЗаголовка Из ВариантыЗаголовков Цикл
                НайденнаяКолонка = НайтиНомерКолонкиПоЗаголовку(ТабДок, НомерСтрокиЗаголовка, ВариантЗаголовка);
                Если НайденнаяКолонка > 0 Тогда
                    Возврат НайденнаяКолонка;
                КонецЕсли;
            КонецЦикла;
        КонецЕсли;
        
        Возврат НомерПоУмолчанию;
    КонецФункции

    &НаСервере
    Функция ПолучитьЗначениеРеквизитаФормыЕслиЕсть(ИмяРеквизита, ЗначениеПоУмолчанию = Неопределено)
        ЗначениеРеквизита = ЗначениеПоУмолчанию;
        
        Попытка
            Выполнить("ЗначениеРеквизита = " + ИмяРеквизита + ";");
            Возврат ЗначениеРеквизита;
        Исключение
        КонецПопытки;
        
        Попытка
            Выполнить("ЗначениеРеквизита = ЭтаФорма." + ИмяРеквизита + ";");
        Исключение
        КонецПопытки;
        
        Возврат ЗначениеРеквизита;
    КонецФункции

    &НаСервере
    Процедура ЗагрузитьПредпросмотрСервер(Адрес, ИмяФайла, НачальноеВремя = Неопределено)

        ТаблицаДанных.Очистить();
        
        ДатаНачалаФильтра = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("ДатаНачала");
        ДатаОкончанияФильтра = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("ДатаОкончания");
        ЗагружатьПриходные = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("ЗагружатьПриходные", Истина);
        ЗагружатьРасходные = ПолучитьЗначениеРеквизитаФормыЕслиЕсть("ЗагружатьРасходные", Истина);
        
        Если НЕ ЗагружатьПриходные И НЕ ЗагружатьРасходные Тогда
            Сообщить("Не выбран тип платежек для загрузки (ни приходные, ни расходные).", СтатусСообщения.Важное);
            Возврат;
        КонецЕсли;

        Результат = ПрочитатьExcelВТаблицу(
            Адрес,
            ИмяФайла,
            ДатаНачалаФильтра,
            ДатаОкончанияФильтра,
            ЗагружатьПриходные,
            ЗагружатьРасходные
        );

        Если ТипЗнч(Результат) = Тип("Строка") Тогда
            Сообщить(Результат, СтатусСообщения.Важное);
            Возврат;
        КонецЕсли;

        ТЗ = Результат;

        Попытка // соотносим колонки в новой таблице
            Для Каждого Стр Из ТЗ Цикл
                НовСтр = ТаблицаДанных.Добавить();

                НовСтр.НомерСтроки              = Стр.НомерСтроки;
                НовСтр.УИД                      = Стр.УИД;
                НовСтр.ТипДокумента             = Стр.ТипДокумента;
                НовСтр.ОперацияУТ               = Стр.ОперацияУТ;
                НовСтр.Дата                     = Стр.Дата;
                НовСтр.НомерПП                  = Стр.НомерПП;
                НовСтр.Сумма                    = Стр.Сумма;
                НовСтр.Валюта                   = Стр.Валюта;
                НовСтр.Организация              = Стр.Организация;
                НовСтр.ИННОрг                   = Стр.ИННОрг;
                НовСтр.КППОрг                   = Стр.КППОрг;
                НовСтр.НашСчет                  = Стр.НашСчет;
                НовСтр.НашБанк                  = Стр.НашБанк;
                НовСтр.НашБИК                   = Стр.НашБИК;
                НовСтр.Контрагент               = Стр.Контрагент;
                НовСтр.ИНН                      = Стр.ИНН;
                НовСтр.КППКонтр                 = Стр.КППКонтр;
                НовСтр.ДокОснование             = Стр.ДокОснование;
                НовСтр.Назначение               = Стр.Назначение;
                НовСтр.СчетРасчетов             = Стр.СчетРасчетов;
                НовСтр.СчетКонтр                = Стр.СчетКонтр;
                НовСтр.БанкКонтр                = Стр.БанкКонтр;
                НовСтр.БИККонтр                 = Стр.БИККонтр;
                НовСтр.СтатьяДДС                = Стр.СтатьяДДС;
                НовСтр.НаправлениеДенег         = Стр.НаправлениеДенег;
                НовСтр.НайденКонтрагент         = Стр.НайденКонтрагент;
                НовСтр.КонтрагентСсылка         = Стр.КонтрагентСсылка;
                НовСтр.НайденаОрганизация       = Стр.НайденаОрганизация;
                НовСтр.ОрганизацияСсылка        = Стр.ОрганизацияСсылка;
                НовСтр.НайденДоговор            = Стр.НайденДоговор;
                НовСтр.ДоговорСсылка            = Стр.ДоговорСсылка;
                // НДС_ИзТекста и СуммаНДС_ИзТекста могут отсутствовать в реквизитах
                // табличной части формы (зависит от версии .epf-файла) — обёрнуто в Попытка.
                Попытка НовСтр.НДС_ИзТекста      = Стр.НДС_ИзТекста;      Исключение КонецПопытки;
                Попытка НовСтр.СуммаНДС_ИзТекста = Стр.СуммаНДС_ИзТекста; Исключение КонецПопытки;
                НовСтр.НайденаСтатья            = Стр.НайденаСтатья;
                НовСтр.СтатьяДДССсылка          = Стр.СтатьяДДССсылка;
                НовСтр.НайденСчетОрганизации    = Стр.НайденСчетОрганизации;
                НовСтр.БанковскийСчетОрганизации = Стр.БанковскийСчетОрганизации;
                НовСтр.НайденСчетКонтрагента    = Стр.НайденСчетКонтрагента;
                НовСтр.БанковскийСчетКонтрагента = Стр.БанковскийСчетКонтрагента;
                НовСтр.ЭтоДубль                 = Стр.ЭтоДубль;
                НовСтр.КомментарийДубля         = Стр.КомментарийДубля;
                НовСтр.Статус                   = Стр.Статус;
                НовСтр.Комментарий              = Стр.Комментарий;
            КонецЦикла;
        Исключение
            Сообщить("Ошибка при переносе данных в форму: " + ОписаниеОшибки(), СтатусСообщения.Важное);
        КонецПопытки;

        // === ВЫВОД ВРЕМЕНИ ===
        Если НачальноеВремя <> Неопределено Тогда
        ВремяМс = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачальноеВремя;
        Сообщить("Предпросмотр загружен за " + Формат(ВремяМс / 1000, "ЧДЦ=2") + " сек.", 
                СтатусСообщения.Информация);
        КонецЕсли

    КонецПроцедуры

    &НаСервереБезКонтекста
    Функция ПрочитатьExcelВТаблицу(
        Адрес,
        ИмяФайла,
        ДатаНачалаФильтра = Неопределено,
        ДатаОкончанияФильтра = Неопределено,
        ЗагружатьПриходные = Истина,
        ЗагружатьРасходные = Истина
    )

        // --- Получение файла ---
        Попытка
            ДвоичныеДанные = ПолучитьИзВременногоХранилища(Адрес);
        Исключение
            Возврат "ОШИБКА: Не удалось получить файл из хранилища. " + ОписаниеОшибки();
        КонецПопытки;

        ВремФайл = ПолучитьИмяВременногоФайла("xlsx");

        Попытка
            ДвоичныеДанные.Записать(ВремФайл);
        Исключение
            Возврат "ОШИБКА: Не удалось записать временный файл. " + ОписаниеОшибки();
        КонецПопытки;

        // --- Чтение Excel ---
        ТабДок = Новый ТабличныйДокумент;
        Попытка
            ТабДок.Прочитать(ВремФайл, СпособЧтенияЗначенийТабличногоДокумента.Значение);
        Исключение
            Попытка УдалитьФайлы(ВремФайл); Исключение КонецПопытки;
            Возврат "ОШИБКА: Не удалось прочитать Excel. " + ОписаниеОшибки();
        КонецПопытки;

        Попытка УдалитьФайлы(ВремФайл); Исключение КонецПопытки;

        // --- Структура таблицы значений ---
        ТЗ = Новый ТаблицаЗначений;

        // Служебные
        ТЗ.Колонки.Добавить("НомерСтроки",               Новый ОписаниеТипов("Число",  , , Новый КвалификаторыЧисла(6, 0)));
        ТЗ.Колонки.Добавить("УИД",                       Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(150)));
        ТЗ.Колонки.Добавить("ТипДокумента",              Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)));
        ТЗ.Колонки.Добавить("ОперацияУТ",                Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(150)));

        // Основные реквизиты документа
        ТЗ.Колонки.Добавить("Дата",                      Новый ОписаниеТипов("Дата"));
        ТЗ.Колонки.Добавить("НомерПП",                   Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(50)));
        ТЗ.Колонки.Добавить("Сумма",                     Новый ОписаниеТипов("Число",  , , Новый КвалификаторыЧисла(15, 2)));
        ТЗ.Колонки.Добавить("Валюта",                    Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(20)));

        // Наша организация
        ТЗ.Колонки.Добавить("Организация",               Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(250)));
