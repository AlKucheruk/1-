    #Область Попытаться_Создать_Счет_Контрагента
    
    &НаСервереБезКонтекста
    Функция ЭтоСчетЗаглушка(НомерСчета)
        НомерСчета = НормализоватьЦифровойКод(НомерСчета);
        Если ПустаяСтрока(НомерСчета) Тогда
            Возврат Истина;
        КонецЕсли;
        
        Если СтрДлина(НомерСчета) <> 20 Тогда
            Возврат Истина;
        КонецЕсли;
        
        Если НомерСчета = "00000000000000000000"
            ИЛИ НомерСчета = "11111111111111111111"
            ИЛИ НомерСчета = "22222222222222222222"
            ИЛИ НомерСчета = "33333333333333333333"
            ИЛИ НомерСчета = "99999999999999999999"
            ИЛИ НомерСчета = "12345678901234567890" Тогда
            Возврат Истина;
        КонецЕсли;
        
        Возврат Ложь;
    КонецФункции
    
    &НаСервереБезКонтекста
    Функция ЛевДополнитьНулями(СтрокаЧисла, ДлинаСтроки)
        Результат = СокрЛП(Строка(СтрокаЧисла));
        Пока СтрДлина(Результат) < ДлинаСтроки Цикл
            Результат = "0" + Результат;
        КонецЦикла;
        Если СтрДлина(Результат) > ДлинаСтроки Тогда
            Результат = Прав(Результат, ДлинаСтроки);
        КонецЕсли;
        Возврат Результат;
    КонецФункции
    
    &НаСервереБезКонтекста
    Функция СгенерироватьТехническийСчет(КлючДетерминизма)
        Источник = НормализоватьЦифровойКод(КлючДетерминизма);
        Если ПустаяСтрока(Источник) Тогда
            Источник = "1";
        КонецЕсли;
        
        Хеш = 0;
        Для Инд = 1 По СтрДлина(Источник) Цикл
            Симв = Сред(Источник, Инд, 1);
            Хеш = (Хеш * 131 + Число(Симв)) % 1000000000000000;
        КонецЦикла;
        
        Возврат "99999" + ЛевДополнитьНулями(Строка(Хеш), 15);
    КонецФункции
    
    &НаСервереБезКонтекста
    Функция НайтиСчетКонтрагентаПоНомеруГлобально(НомерСчета)
        Если ПустаяСтрока(НомерСчета) Тогда
            Возврат Неопределено;
        КонецЕсли;
        
        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   БанковскиеСчетаКонтрагентов.Ссылка КАК Ссылка,
        |   БанковскиеСчетаКонтрагентов.Владелец КАК Владелец
        |ИЗ
        |   Справочник.БанковскиеСчетаКонтрагентов КАК БанковскиеСчетаКонтрагентов
        |ГДЕ
        |   БанковскиеСчетаКонтрагентов.НомерСчета = &НомерСчета
        |   И НЕ БанковскиеСчетаКонтрагентов.ПометкаУдаления";
        
        Запрос.УстановитьПараметр("НомерСчета", НомерСчета);
        Выборка = Запрос.Выполнить().Выбрать();
        Если Выборка.Следующий() Тогда
            Возврат Новый Структура("Ссылка,Владелец", Выборка.Ссылка, Выборка.Владелец);
        КонецЕсли;
        
        Возврат Неопределено;
    КонецФункции

    // Функция пытается создать банковский счёт контрагента, если он не найден.
    //
    // Параметры:
    //   КонтрагентСсылка - СправочникСсылка.Контрагенты - контрагент
    //   НомерСчета       - Строка - номер расчётного счёта
    //   БИК              - Строка - БИК банка контрагента
    //
    // Возвращаемое значение:
    //   СправочникСсылка.БанковскиеСчетаКонтрагентов - созданный счёт, или пустая ссылка
    //
    &НаСервереБезКонтекста
    Функция ПопытатьсяСоздатьСчетКонтрагента(КонтрагентСсылка, НомерСчета, БИК, КлючДетерминизма = "", БылаЗаглушка = Ложь)
        
        Если НЕ ЗначениеЗаполнено(КонтрагентСсылка) Тогда
            Возврат Справочники.БанковскиеСчетаКонтрагентов.ПустаяСсылка();
        КонецЕсли;
        
        НомерСчета = НормализоватьЦифровойКод(НомерСчета);
        Если ПустаяСтрока(НомерСчета) Тогда
            БылаЗаглушка = Истина;
        КонецЕсли;
        
        Если БылаЗаглушка ИЛИ ЭтоСчетЗаглушка(НомерСчета) Тогда
            НомерСчета = СгенерироватьТехническийСчет(КлючДетерминизма);
        КонецЕсли;
        
        Для ПопыткаНомера = 1 По 5 Цикл
            НайденныйСчет = НайтиСчетКонтрагентаПоНомеруГлобально(НомерСчета);
            Если НайденныйСчет = Неопределено Тогда
                Прервать;
            КонецЕсли;
            
            Если НайденныйСчет.Владелец = КонтрагентСсылка Тогда
                Возврат НайденныйСчет.Ссылка;
            КонецЕсли;
            
            НомерСчета = СгенерироватьТехническийСчет(КлючДетерминизма + Строка(ПопыткаНомера));
        КонецЦикла;
        
        Попытка
            НовыйСчет = Справочники.БанковскиеСчетаКонтрагентов.СоздатьЭлемент();
            НовыйСчет.Владелец   = КонтрагентСсылка;
            НовыйСчет.НомерСчета = НомерСчета;
            НовыйСчет.Наименование = "р/с " + НомерСчета;
            
            // Для части конфигураций реквизит валюты является обязательным.
            Попытка
                ВалютаРубль = Справочники.Валюты.НайтиПоКоду("643");
                Если ЗначениеЗаполнено(ВалютаРубль) Тогда
                    НовыйСчет.ВалютаДенежныхСредств = ВалютаРубль;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            // Пытаемся найти банк по БИК
            Если НЕ ПустаяСтрока(БИК) Тогда
                Попытка
                    БанкСсылка = Справочники.КлассификаторБанков.НайтиПоКоду(БИК);
                    Если ЗначениеЗаполнено(БанкСсылка) Тогда
                        НовыйСчет.Банк = БанкСсылка;
                    КонецЕсли;
                Исключение
                КонецПопытки;
            КонецЕсли;
            
            Попытка
                Если ЗначениеЗаполнено(НовыйСчет.Банк) Тогда
                    НовыйСчет.БИКБанка = БИК;
                КонецЕсли;
            Исключение
            КонецПопытки;
            
            НовыйСчет.Записать();

            Возврат НовыйСчет.Ссылка;
        Исключение
            Возврат Справочники.БанковскиеСчетаКонтрагентов.ПустаяСсылка();
        КонецПопытки;
        
    КонецФункции

    #КонецОбласти //Попытаться_Создать_Счет_Контрагента

    #Область Распределение_денег
    // ОБЛАСТЬ: Распределение денег — распределение по расчётным документам (FIFO)
    // ────────────────────────────────────────────────────────────────────────────
    // Для поступлений: ищет "Реализация товаров и услуг" по договору с долгом
    // Для списаний: ищет "Поступление товаров" или "Акты" по договору с долгом
    // Распределяет сумму по FIFO (сначала самые ранние документы)
    // Остаток — как аванс
    // ────────────────────────────────────────────────────────────────────────────
    // Процедура распределяет денежные средства по расчётным документам (FIFO).
    // Заполняет табличную часть "РасшифровкаПлатежа" документа.
    //
    // Для поступлений от клиентов:
    //   - Ищет документы "Реализация товаров и услуг" по договору с остатком долга
    //   - Сортирует по дате (сначала самые ранние)
    //   - Заполняет строки табличной части, распределяя сумму
    //   - Если денег больше чем долг — остаток как аванс
    //
    // Для списаний (оплата поставщикам):
    //   - Ищет "Поступление товаров" по договору с остатком долга
    //   - Распределяет по FIFO
    //   - Остаток как аванс поставщику
    //
    // Параметры:
    //   ДокОбъект       - ДокументОбъект - создаваемый документ (с ТЧ РасшифровкаПлатежа)
    //   ДоговорСсылка   - СправочникСсылка.ДоговорыКонтрагентов - договор
    //   СуммаДокумента  - Число - сумма для распределения
    //   ЭтоПоступление  - Булево - Истина для поступления, Ложь для списания
    //   ПартнерСсылка   - СправочникСсылка.Партнеры - партнёр контрагента
    //   СтатьяДДССсылка - СправочникСсылка.СтатьиДвиженияДенежныхСредств - статья ДДС
    //
    // Возвращаемое значение:
    //   Строка - информация о результате распределения
    //
    &НаСервереБезКонтекста
    // ── ЗаполнитьСтрокуРасшифровкиПоFIFO ────────────────────────────────────
    // Заполняет одну строку РасшифровкаПлатежа реквизитами платежа.
    //
    // В UT 11 договор передаётся через КлючАналитики (АналитикаУчетаПоПартнерам),
    // а НЕ через прямой реквизит "Договор" в РасшифровкаПлатежа (его нет).
    // ОснованиеПлатежа тоже отсутствует: используем ОбъектРасчетов.
    //
    // Параметры:
    //   СтрокаРасшифровки   — строка ТЧ РасшифровкаПлатежа
    //   СуммаКРаспределению — числовая сумма этой строки
    //   ДоговорСсылка       — ссылка на договор (используется только как fallback-инфо)
    //   ОбъектРасчетов      — документ-основание, при авансе = Неопределено
    //   ПартнерСсылка       — ссылка на партнёра
    //   СтатьяДДССсылка     — ссылка на статью ДДС
    //   ЭтоАванс            — Истина если авансовая строка
    //   СтавкаНДС           — Перечисления.СтавкиНДС (Неопределено = не устанавливать)
    //   СуммаНДС            — числовая сумма НДС (0 = не устанавливать)
    //   КлючАналитики       — СправочникСсылка.КлючиАналитикиУчетаПоПартнерам
    //                         (найденный заранее через НайтиКлючАналитикиПоДоговору)
    Процедура ЗаполнитьСтрокуРасшифровкиПоFIFO(
        СтрокаРасшифровки,
        СуммаКРаспределению,
        ДоговорСсылка,
        ОбъектРасчетов  = Неопределено,
        ПартнерСсылка   = Неопределено,
        СтатьяДДССсылка = Неопределено,
        ЭтоАванс        = Ложь,
        СтавкаНДС       = Неопределено,
        СуммаНДС        = 0,
        КлючАналитики   = Неопределено
    )
        ОшибкиПолей = "";
        
        СтрокаРасшифровки.Сумма = СуммаКРаспределению;
        СтрокаРасшифровки.СуммаВзаиморасчетов = СуммаКРаспределению;
        
        // ── ОбъектРасчетов ────────────────────────────────────────────────────
        // Для конкретного документа привязываем DocumentRef.
        // ОснованиеПлатежа в UT11 РасшифровкаПлатежа не существует — не пытаемся.
        Если ЗначениеЗаполнено(ОбъектРасчетов) И НЕ ЭтоАванс Тогда
            Попытка
                СтрокаРасшифровки.ОбъектРасчетов = ОбъектРасчетов;
            Исключение
                ОшибкиПолей = ОшибкиПолей + "[ОбъектРасчетов]: " + ОписаниеОшибки() + "; ";
            КонецПопытки;
        КонецЕсли;
        
        // ── АналитикаУчетаПоПартнерам ────────────────────────────────────────
        // КЛЮЧЕВОЕ поле UT11: именно через него движения регистра РасчетыСПоставщиками/
        // РасчетыСКлиентами привязываются к конкретному договору.
        // Прямого реквизита "Договор" в РасшифровкаПлатежа нет.
        Если ЗначениеЗаполнено(КлючАналитики) Тогда
            Попытка
                СтрокаРасшифровки.АналитикаУчетаПоПартнерам = КлючАналитики;
            Исключение
                ОшибкиПолей = ОшибкиПолей + "[АналитикаУчетаПоПартнерам]: " + ОписаниеОшибки() + "; ";
            КонецПопытки;
        КонецЕсли;
        
        Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
            Попытка
                СтрокаРасшифровки.Партнер = ПартнерСсылка;
            Исключение
                ОшибкиПолей = ОшибкиПолей + "[Партнер]: " + ОписаниеОшибки() + "; ";
            КонецПопытки;
        КонецЕсли;
        
        Если ЗначениеЗаполнено(СтатьяДДССсылка) Тогда
            Попытка
                СтрокаРасшифровки.СтатьяДвиженияДенежныхСредств = СтатьяДДССсылка;
            Исключение
                ОшибкиПолей = ОшибкиПолей + "[СтатьяДДС]: " + ОписаниеОшибки() + "; ";
            КонецПопытки;
        КонецЕсли;
        
        // НДС ─────────────────────────────────────────────────────────────────
        // Защита от Неопределено: ТипЗнч проверяем перед сравнением
        Если СтавкаНДС <> Неопределено Тогда
            Попытка
                СтрокаРасшифровки.СтавкаНДС = СтавкаНДС;
            Исключение
                ОшибкиПолей = ОшибкиПолей + "[СтавкаНДС]: " + ОписаниеОшибки() + "; ";
            КонецПопытки;
        КонецЕсли;
        
        Если ТипЗнч(СуммаНДС) = Тип("Число") И СуммаНДС > 0 Тогда
            Попытка
                СтрокаРасшифровки.СуммаНДС = СуммаНДС;
            Исключение
                ОшибкиПолей = ОшибкиПолей + "[СуммаНДС]: " + ОписаниеОшибки() + "; ";
            КонецПопытки;
        КонецЕсли;
        
        // Выводим все ошибки полей в одном сообщении (для диагностики)
        Если НЕ ПустаяСтрока(ОшибкиПолей) Тогда
            Сообщить("РасшифровкаПлатежа — ошибки установки полей: " + ОшибкиПолей);
        КонецЕсли;
        
    КонецПроцедуры
    
    &НаСервереБезКонтекста
    Функция РаспределитьДеньгиПоДокументам(ДокОбъект, ДоговорСсылка, СуммаДокумента, ЭтоПоступление, ПартнерСсылка = Неопределено, СтатьяДДССсылка = Неопределено, СтавкаНДС = Неопределено, ОбщаяСуммаНДС = 0)
        
        Если НЕ ЗначениеЗаполнено(ДоговорСсылка) Или СуммаДокумента <= 0 Тогда
            Возврат "Нет данных для распределения (договор или сумма пусты). ";
        КонецЕсли;
        
        // Защита от Неопределено: НДС-параметры должны быть числами
        Если ТипЗнч(ОбщаяСуммаНДС) <> Тип("Число") Тогда ОбщаяСуммаНДС = 0; КонецЕсли;
        
        // Ключ аналитики — именно через него UT11 привязывает строку расшифровки к договору
        // в регистрах РасчетыСПоставщиками / РасчетыСКлиентами.
        КлючАналитики = НайтиКлючАналитикиПоДоговору(ДоговорСсылка);
        Если НЕ ЗначениеЗаполнено(КлючАналитики) Тогда
            Сообщить("FIFO: ключ аналитики для договора не найден — деньги будут записаны без привязки к договору. "
                + "Проверьте Справочник.КлючиАналитикиУчетаПоПартнерам.");
        КонецЕсли;
        
        // ── ДИАГНОСТИКА ПОЛЕЙ РасшифровкаПлатежа (выводится один раз) ──────
        // Позволяет видеть в логе реальные BSL-имена реквизитов ТЧ для данной версии UT.
        Попытка
            МетаДок = Метаданные.НайтиПоТипу(ТипЗнч(ДокОбъект));
            МетаТЧ  = МетаДок.ТабличныеЧасти.Найти("РасшифровкаПлатежа");
            Если МетаТЧ <> Неопределено Тогда
                СписокПолей = "";
                Для Каждого Рекв Из МетаТЧ.Реквизиты Цикл
                    СписокПолей = СписокПолей + Рекв.Имя + "; ";
                КонецЦикла;
                Сообщить("[ДИАГНОСТИКА] Поля РасшифровкаПлатежа (" + МетаДок.Имя + "): " + СписокПолей);
            КонецЕсли;
        Исключение
        КонецПопытки;
        
        ДокОбъект.РасшифровкаПлатежа.Очистить();
        
        // ── FIFO-запросы ────────────────────────────────────────────────────────
        // В UT 11 регистры РасчетыСКлиентами / РасчетыСПоставщиками НЕ имеют
        // прямого реквизита "Договор" или "ДоговорДокумента".
        // Связь с договором хранится через измерение АналитикаУчетаПоПартнерам
        // (CatalogRef.КлючиАналитикиУчетаПоПартнерам), у которого есть атрибут
        // АналитикаУчетаПоПартнерам.Договор.
        //
        // Для FIFO читаем ДВИЖЕНИЯ (не остатки), группируем по Регистратору
        // и оставляем только те, у которых суммарный остаток > 0 (должны деньги нам).
        // УПОРЯДОЧИТЬ ПО дате — старейшие документы закрываются первыми.
        // ─────────────────────────────────────────────────────────────────────
        Попытка
            Если ЭтоПоступление Тогда
                // Приход денег: клиент нам должен (РасчетыСКлиентами, тип СПокупателем)
                ТекстЗапроса =
                // ИМЕЯ (HAVING) не работает с базовыми движениями в ряде версий 1С —
                // фильтрация Долг > 0 выполняется в BSL-цикле ниже.
                "ВЫБРАТЬ
                |   Движения.Регистратор КАК ОбъектРасчетов,
                |   СУММА(Движения.Сумма) КАК Долг,
                |   МИНИМУМ(Движения.Период) КАК ДатаДокумента
                |ИЗ
                |   РегистрНакопления.РасчетыСКлиентами КАК Движения
                |ГДЕ
                |   Движения.АналитикаУчетаПоПартнерам.Договор = &Договор
                |СГРУППИРОВАТЬ ПО
                |   Движения.Регистратор
                |УПОРЯДОЧИТЬ ПО
                |   ДатаДокумента ВОЗР,
                |   ОбъектРасчетов";
            Иначе
                // Расход денег: мы должны поставщику (РасчетыСПоставщиками, тип СПоставщиком)
                ТекстЗапроса =
                // ИМЕЯ (HAVING) не работает с базовыми движениями в ряде версий 1С —
                // фильтрация Долг > 0 выполняется в BSL-цикле ниже.
                "ВЫБРАТЬ
                |   Движения.Регистратор КАК ОбъектРасчетов,
                |   СУММА(Движения.Сумма) КАК Долг,
                |   МИНИМУМ(Движения.Период) КАК ДатаДокумента
                |ИЗ
                |   РегистрНакопления.РасчетыСПоставщиками КАК Движения
                |ГДЕ
                |   Движения.АналитикаУчетаПоПартнерам.Договор = &Договор
                |СГРУППИРОВАТЬ ПО
                |   Движения.Регистратор
                |УПОРЯДОЧИТЬ ПО
                |   ДатаДокумента ВОЗР,
                |   ОбъектРасчетов";
            КонецЕсли;
            
            Запрос = Новый Запрос;
            Запрос.Текст = ТекстЗапроса;
            Запрос.УстановитьПараметр("Договор", ДоговорСсылка);
            
            РезультатЗапроса = Запрос.Выполнить();
            
            Выборка = РезультатЗапроса.Выбрать();
            ОстатокСуммы = СуммаДокумента;
            ОстатокНДС   = ОбщаяСуммаНДС; // остаток НДС для пропорционального распределения
            КоличествоРаспределено = 0;
            
            Пока Выборка.Следующий() И ОстатокСуммы > 0 Цикл
                СуммаКРаспределению = Мин(ОстатокСуммы, Выборка.Долг);
                Если СуммаКРаспределению <= 0 Тогда
                    Продолжить;
                КонецЕсли;
                
                // Пропорциональная доля НДС для этой строки
                СуммаНДССтроки = 0;
                Если ОбщаяСуммаНДС > 0 И СуммаДокумента > 0 Тогда
                    СуммаНДССтроки = Окр(ОбщаяСуммаНДС * СуммаКРаспределению / СуммаДокумента, 2);
                    ОстатокНДС = ОстатокНДС - СуммаНДССтроки;
                КонецЕсли;
                
                НоваяСтрока = ДокОбъект.РасшифровкаПлатежа.Добавить();
                ЗаполнитьСтрокуРасшифровкиПоFIFO(
                    НоваяСтрока,
                    СуммаКРаспределению,
                    ДоговорСсылка,
                    Выборка.ОбъектРасчетов,
                    ПартнерСсылка,
                    СтатьяДДССсылка,
                    Ложь,           // ЭтоАванс
                    СтавкаНДС,
                    СуммаНДССтроки,
                    КлючАналитики   // АналитикаУчетаПоПартнерам — ключ договора в UT11
                );
                
                ОстатокСуммы = ОстатокСуммы - СуммаКРаспределению;
                КоличествоРаспределено = КоличествоРаспределено + 1;
            КонецЦикла;
            
            // Остаток суммы направляем как аванс в рамках того же договора.
            // НДС остатка — весь ОстатокНДС, если аванс есть.
            Если ОстатокСуммы > 0 Тогда
                НоваяСтрока = ДокОбъект.РасшифровкаПлатежа.Добавить();
                ЗаполнитьСтрокуРасшифровкиПоFIFO(
                    НоваяСтрока,
                    ОстатокСуммы,
                    ДоговорСсылка,
                    Неопределено,   // ОбъектРасчетов
                    ПартнерСсылка,
                    СтатьяДДССсылка,
                    Истина,         // ЭтоАванс
                    СтавкаНДС,
                    ?(ТипЗнч(ОстатокНДС) = Тип("Число") И ОстатокНДС > 0, ОстатокНДС, 0),
                    КлючАналитики   // АналитикаУчетаПоПартнерам — ключ договора в UT11
                );
            КонецЕсли;
            
            ТекстРезультата = "Распределено по " + Строка(КоличествоРаспределено) + " документам. ";
            Если ОстатокСуммы > 0 Тогда
                ТекстРезультата = ТекстРезультата + "Остаток " + Формат(ОстатокСуммы, "ЧДЦ=2") + " руб. как аванс.";
            КонецЕсли;
            
            Возврат ТекстРезультата;
            
        Исключение
            Возврат "Ошибка распределения денег: " + ОписаниеОшибки();
        КонецПопытки;
        
    КонецФункции

    #КонецОбласти // Распределение_денег

    #Область Автозаполнение_обязательных_полей
// ОБЛАСТЬ: Автозаполнение обязательных полей
// ────────────────────────────────────────────────────────────────────────────
// - ОчередностьПлатежа = 5 (для списаний)
// - СтатьяРасходов = "Импорт из банка" (создать если нет)
// - Налог = "Единый налоговый платеж" (для налоговых операций)
// ────────────────────────────────────────────────────────────────────────────
// Функция находит или создаёт статью расходов "Импорт из банка" в справочнике СтатьиРасходов.
//
// Возвращаемое значение:
//   СправочникСсылка.СтатьиРасходов - найденная или созданная статья
//
&НаСервереБезКонтекста
Функция ПолучитьСтатьюРасходовИмпортИзБанка()
    
    Попытка
        // Сначала ищем существующую статью
        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   СтатьиРасходов.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.СтатьиРасходов КАК СтатьиРасходов
        |ГДЕ
        |   СтатьиРасходов.Наименование = &Наименование
        |   И НЕ СтатьиРасходов.ПометкаУдаления";
        
        Запрос.УстановитьПараметр("Наименование", "Импорт из банка");
        Выборка = Запрос.Выполнить().Выбрать();
        
        Если Выборка.Следующий() Тогда
            Возврат Выборка.Ссылка;
        КонецЕсли;
        
        // Не нашли — создаём новую
        НоваяСтатья = Справочники.СтатьиРасходов.СоздатьЭлемент();
        НоваяСтатья.Наименование = "Импорт из банка";
        НоваяСтатья.Записать();
        
        Возврат НоваяСтатья.Ссылка;
    Исключение
        Возврат Неопределено;
    КонецПопытки;
    
КонецФункции

// Функция находит вид налога "Единый налоговый платеж".
//
// Возвращаемое значение:
//   СправочникСсылка.ВидыНалоговВзносов - найденный вид налога или Неопределено
//
&НаСервереБезКонтекста
Функция ПолучитьНалогЕНП()
    
    Попытка
        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   ВидыНалоговВзносов.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.ВидыНалоговВзносов КАК ВидыНалоговВзносов
        |ГДЕ
        |   ВидыНалоговВзносов.Наименование ПОДОБНО &Наименование
        |   И НЕ ВидыНалоговВзносов.ПометкаУдаления";
        
        Запрос.УстановитьПараметр("Наименование", "%Единый налоговый платеж%");
        Выборка = Запрос.Выполнить().Выбрать();
        
        Если Выборка.Следующий() Тогда
            Возврат Выборка.Ссылка;
        КонецЕсли;
        
        // Пробуем альтернативные наименования
        Запрос.УстановитьПараметр("Наименование", "%ЕНП%");
        Выборка = Запрос.Выполнить().Выбрать();
        
        Если Выборка.Следующий() Тогда
            Возврат Выборка.Ссылка;
        КонецЕсли;
        
    Исключение
    КонецПопытки;
    
    Возврат Неопределено;
    
КонецФункции

// Процедура заполняет обязательные поля документа Списание:
//   - ОчередностьПлатежа = 5
//   - СтатьяРасходов = "Импорт из банка"
//   - ТипНалога (Налог) = "Единый налоговый платеж" для налоговых операций
//
// Параметры:
//   ДокОбъект    - ДокументОбъект.СписаниеБезналичныхДенежныхСредств
//   ХозОперация  - Перечисления.ХозяйственныеОперации - хозяйственная операция
//
// Возвращаемое значение:
//   Строка - информация о заполненных полях
//
&НаСервереБезКонтекста
Функция ЗаполнитьОбязательныеПоляСписания(ДокОбъект, ХозОперация)
    
    ТекстЛог = "";
    
    Попытка
        // 1. Очередность платежа = 5 (для всех списаний)
        Попытка
            ДокОбъект.ОчередностьПлатежа = 5;
            ТекстЛог = ТекстЛог + "Очередность=5; ";
        Исключение
        КонецПопытки;
        
        // 2. Статья расходов = "Импорт из банка"
        Попытка
            СтатьяРасходов = ПолучитьСтатьюРасходовИмпортИзБанка();
            Если ЗначениеЗаполнено(СтатьяРасходов) Тогда
                ДокОбъект.СтатьяРасходов = СтатьяРасходов;
                ТекстЛог = ТекстЛог + "СтатьяРасходов=ИмпортИзБанка; ";
            КонецЕсли;
        Исключение
        КонецПопытки;
        
        // 3. Налог = "Единый налоговый платеж" для налоговых операций
        //    (Перечисление в бюджет, Перечисление налога)
        ЭтоНалоговаяОперация = Ложь;
        Попытка
            ЭтоНалоговаяОперация = (ХозОперация = Перечисления.ХозяйственныеОперации.ПеречислениеВБюджет);
        Исключение
        КонецПопытки;
        
        Если ЭтоНалоговаяОперация Тогда
            Попытка
                НалогЕНП = ПолучитьНалогЕНП();
                Если ЗначениеЗаполнено(НалогЕНП) Тогда
                    ДокОбъект.ТипНалога = НалогЕНП;
                    ТекстЛог = ТекстЛог + "Налог=ЕНП; ";
                Иначе
                    ТекстЛог = ТекстЛог + "Налог ЕНП не найден в справочнике; ";
                КонецЕсли;
            Исключение
            КонецПопытки;
        КонецЕсли;
        
    Исключение
        ТекстЛог = ТекстЛог + "Ошибка автозаполнения: " + ОписаниеОшибки() + "; ";
    КонецПопытки;
    
    Возврат ТекстЛог;
    
КонецФункции

// Процедура заполняет обязательные поля документа Поступление:
//   - СтатьяРасходов = "Импорт из банка" (если есть реквизит)
//
// Параметры:
//   ДокОбъект    - ДокументОбъект.ПоступлениеБезналичныхДенежныхСредств
//
// Возвращаемое значение:
//   Строка - информация о заполненных полях
//
&НаСервереБезКонтекста
Функция ЗаполнитьОбязательныеПоляПоступления(ДокОбъект)
    
    ТекстЛог = "";
    
    Попытка
        // Статья расходов = "Импорт из банка"
        Попытка
            СтатьяРасходов = ПолучитьСтатьюРасходовИмпортИзБанка();
            Если ЗначениеЗаполнено(СтатьяРасходов) Тогда
                ДокОбъект.СтатьяРасходов = СтатьяРасходов;
                ТекстЛог = ТекстЛог + "СтатьяРасходов=ИмпортИзБанка; ";
            КонецЕсли;
        Исключение
        КонецПопытки;       
    Исключение
    КонецПопытки;
    
    Возврат ТекстЛог;
    
КонецФункции

#КонецОбласти // Автозаполнение_обязательных_полей

#КонецОбласти // Загрузка_В_Базу_Вспомогательные

#Область ЛогикаДоговоров

// ────────────────────────────────────────────────────────────────────────────
// ОпределитьСтавкуНДСПоТексту — маппинг строки из НДС_ИзТекста
// в значение перечисления СтавкиНДС.
//
// Входные форматы (из 03_modefide.py):
//   "Без НДС" → БезНДС
//   "20%"     → НДС20 / Ставка20
//   "18%"     → НДС18 / Ставка18
//   "10%"     → НДС10 / Ставка10
//   "7%"      → НДС7  / Ставка7
//   "5%"      → НДС5  / Ставка5
//
// Возвращает: значение ПеречисленияСсылка.СтавкиНДС или Неопределено.
&НаСервереБезКонтекста
Функция ОпределитьСтавкуНДСПоТексту(ТекстНДС)
    Если НЕ ЗначениеЗаполнено(ТекстНДС) Тогда
        Возврат Неопределено;
    КонецЕсли;
    
    Текст = ВРег(СокрЛП(ТекстНДС));
    
    Если Текст = "БЕЗ НДС" ИЛИ Текст = "0%" ИЛИ Текст = "0" Тогда
        Попытка Возврат Перечисления.СтавкиНДС.БезНДС; Исключение КонецПопытки;
        Попытка Возврат Перечисления.СтавкиНДС.НДС0;   Исключение КонецПопытки;
        Возврат Неопределено;
    КонецЕсли;
    
    // Извлекаем число из текста (например "20%" → 20)
    СтавкаЧисло = 0;
    Если СтрНайти(Текст, "20") > 0 Тогда
        СтавкаЧисло = 20;
    ИначеЕсли СтрНайти(Текст, "18") > 0 Тогда
        СтавкаЧисло = 18;
    ИначеЕсли СтрНайти(Текст, "10") > 0 Тогда
        СтавкаЧисло = 10;
    ИначеЕсли СтрНайти(Текст, "7%") > 0 ИЛИ Текст = "7" Тогда
        СтавкаЧисло = 7;
    ИначеЕсли СтрНайти(Текст, "5%") > 0 ИЛИ Текст = "5" Тогда
        СтавкаЧисло = 5;
    КонецЕсли;
    
    Если СтавкаЧисло > 0 Тогда
        ИмяСтавки = Строка(СтавкаЧисло);
        // Пробуем разные варианты имён в зависимости от релиза конфигурации
        Попытка Возврат Перечисления.СтавкиНДС["НДС" + ИмяСтавки];    Исключение КонецПопытки;
        Попытка Возврат Перечисления.СтавкиНДС["Ставка" + ИмяСтавки]; Исключение КонецПопытки;
        Попытка Возврат Перечисления.СтавкиНДС["НДС_" + ИмяСтавки];   Исключение КонецПопытки;
    КонецЕсли;
    
    Возврат Неопределено;
КонецФункции

// Определяет тип договора по операции из Excel
&НаСервере
Функция ОпределитьТипДоговораПоОперации(ОперацияУТ)
	
	ОперацияУТ = СокрЛП(ОперацияУТ);
	
	// --- Приход ---
	Если ОперацияУТ = "ПоступлениеОплатыОтКлиента" Тогда
		Возврат Перечисления.ТипыДоговоров.СПокупателем;
		
	ИначеЕсли ОперацияУТ = "ВозвратДенежныхСредствОтПоставщика" Тогда
		Возврат Перечисления.ТипыДоговоров.СПоставщиком;
		
	ИначеЕсли ОперацияУТ = "ПоступлениеДенежныхСредствПоДепозитам" Тогда
		Возврат Перечисления.ТипыДоговоров.СПокупателем; // банк как покупатель
		
	ИначеЕсли ОперацияУТ = "ПрочееПоступлениеДенежныхСредств" Тогда
		Возврат Перечисления.ТипыДоговоров.СПокупателем;
		
	// --- Расход ---
	ИначеЕсли ОперацияУТ = "ОплатаПоставщику" Тогда
		Возврат Перечисления.ТипыДоговоров.СПоставщиком;
		
	ИначеЕсли ОперацияУТ = "ВозвратОплатыПокупателю" Тогда
		Возврат Перечисления.ТипыДоговоров.СПокупателем;
		
	ИначеЕсли ОперацияУТ = "ПеречислениеВБюджет" Тогда
		Возврат Неопределено; // договор не нужен
		
	ИначеЕсли ОперацияУТ = "ПрочееСписаниеДенежныхСредств" Тогда
		Возврат Перечисления.ТипыДоговоров.СПоставщиком;
		
	Иначе
		// Неизвестная операция — по умолчанию как раньше
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

#КонецОбласти // ЛогикаДоговоров

#Область Проверки_И_Подготовка_Загрузки

&НаСервереБезКонтекста
Функция ПостроитьЧастотуСчетовКонтрагентов(Таблица)
    Частота = Новый Соответствие;
    
    Для Каждого СтрокаДанных Из Таблица Цикл
        НомерСчета = НормализоватьЦифровойКод(СтрокаДанных.СчетКонтр);
        Если ПустаяСтрока(НомерСчета) Тогда
            Продолжить;
        КонецЕсли;
        
        ТекущееКоличество = Частота.Получить(НомерСчета);
        Если ТекущееКоличество = Неопределено Тогда
            Частота.Вставить(НомерСчета, 1);
        Иначе
            Частота.Вставить(НомерСчета, ТекущееКоличество + 1);
        КонецЕсли;
    КонецЦикла;
    
    Возврат Частота;
КонецФункции

&НаСервереБезКонтекста
Функция ПодготовитьНомерСчетаДляСоздания(СтрокаДанных, ЧастотаСчетов, БылаЗаглушка = Ложь)
    НомерСчета = НормализоватьЦифровойКод(СтрокаДанных.СчетКонтр);
    
    Если ПустаяСтрока(НомерСчета) Тогда
        БылаЗаглушка = Истина;
    КонецЕсли;
    
    КоличествоПовторов = ЧастотаСчетов.Получить(НомерСчета);
    Если КоличествоПовторов = Неопределено Тогда
        КоличествоПовторов = 0;
    КонецЕсли;
    
    Если ЭтоСчетЗаглушка(НомерСчета) ИЛИ КоличествоПовторов > 1 Тогда
        БылаЗаглушка = Истина;
        КлючДетерминизма = Строка(СтрокаДанных.ИНН)
            + "|" + Строка(СтрокаДанных.КППКонтр)
            + "|" + Строка(СтрокаДанных.УИД)
            + "|" + Строка(СтрокаДанных.КонтрагентСсылка);
        НомерСчета = СгенерироватьТехническийСчет(КлючДетерминизма);
    КонецЕсли;
    
    Возврат Новый Структура("НомерСчета,БылаЗаглушка", НомерСчета, БылаЗаглушка);
КонецФункции

&НаСервереБезКонтекста
Функция ПроверитьСсылочныеТипыСтроки(СтрокаДанных)
    Если ТипЗнч(СтрокаДанных.КонтрагентСсылка) <> Тип("СправочникСсылка.Контрагенты") Тогда
        Возврат "КонтрагентСсылка имеет неверный тип.";
    КонецЕсли;
    
    Если ТипЗнч(СтрокаДанных.ОрганизацияСсылка) <> Тип("СправочникСсылка.Организации") Тогда
        Возврат "ОрганизацияСсылка имеет неверный тип.";
    КонецЕсли;
    
    Если ТипЗнч(СтрокаДанных.БанковскийСчетОрганизации) <> Тип("СправочникСсылка.БанковскиеСчетаОрганизаций") Тогда
        Возврат "БанковскийСчетОрганизации имеет неверный тип.";
    КонецЕсли;
    
    Если ТипЗнч(СтрокаДанных.БанковскийСчетКонтрагента) <> Тип("СправочникСсылка.БанковскиеСчетаКонтрагентов") Тогда
        Возврат "БанковскийСчетКонтрагента имеет неверный тип.";
    КонецЕсли;
    
    Если ТипЗнч(СтрокаДанных.СтатьяДДССсылка) <> Тип("СправочникСсылка.СтатьиДвиженияДенежныхСредств") Тогда
        Возврат "СтатьяДДССсылка имеет неверный тип.";
    КонецЕсли;
    
    Возврат "";
КонецФункции

&НаСервереБезКонтекста
Функция ПроверитьФинальныеИнварианты(ДокОбъект, СтрокаДанных, ДоговорСсылка)
    Если ДокОбъект.Контрагент <> СтрокаДанных.КонтрагентСсылка Тогда
        Возврат "Контрагент документа изменился относительно входной строки.";
    КонецЕсли;
    
    Если Окр(ДокОбъект.СуммаДокумента, 2) <> Окр(СтрокаДанных.Сумма, 2) Тогда
        Возврат "Сумма документа не совпадает со входной суммой.";
    КонецЕсли;
    
    СуммаРасшифровки = 0;
    Для Каждого СтрокаРасшифровки Из ДокОбъект.РасшифровкаПлатежа Цикл
        СуммаРасшифровки = СуммаРасшифровки + СтрокаРасшифровки.Сумма;
        
        Если ЗначениеЗаполнено(ДоговорСсылка) Тогда
            Попытка
                Если ЗначениеЗаполнено(СтрокаРасшифровки.Договор)
                    И СтрокаРасшифровки.Договор <> ДоговорСсылка Тогда
                    Возврат "Распределение вышло за рамки договора.";
                КонецЕсли;
            Исключение
            КонецПопытки;
        КонецЕсли;
    КонецЦикла;
    
    Если Окр(СуммаРасшифровки, 2) <> Окр(ДокОбъект.СуммаДокумента, 2) Тогда
        Возврат "Сумма расшифровки не равна сумме документа.";
    КонецЕсли;
    
    Возврат "";
КонецФункции

#КонецОбласти // Проверки_И_Подготовка_Загрузки

#Область Загрузка_В_Базу

&НаСервере
Функция СтрокаОтмеченаКЗагрузкеСервер(СтрокаТаблицы)
    Попытка
        Возврат СтрокаТаблицы.Выбрать;
    Исключение
        // Если в форме нет колонки "Выбрать", сохраняем старое поведение (загружать все строки).
        Возврат Истина;
    КонецПопытки;
КонецФункции

&НаСервере
Процедура ЗагрузитьВБазуСервер(НачальноеВремя = Неопределено)
    
    КоличествоСоздано     = 0;
    КоличествоОшибок      = 0;
    КоличествоПропущено   = 0;
    СписокОшибок          = Новый Массив;
    ИмяФайлаИсточника     = ЭтаФорма.ИмяФайла;
    ЧастотаСчетовКонтрагентов = ПостроитьЧастотуСчетовКонтрагентов(ТаблицаДанных);
    
    // ── Батч-логирование ───────────────────────────────────────────────────
    // Каждые РазмерБанча обработанных строк выводится сводка в журнал.
    РазмерБанча          = 10;
    НомерБанча           = 0;
    ОбработаноВБанче     = 0;
    НачалоБанча          = ТекущаяУниверсальнаяДатаВМиллисекундах();
    
    Для Каждого СтрокаДанных Из ТаблицаДанных Цикл
        
        Если НЕ СтрокаОтмеченаКЗагрузкеСервер(СтрокаДанных) Тогда
            Продолжить;
        КонецЕсли;
        
        Если СтрокаДанных.Статус <> "Готов" Тогда
            КоличествоПропущено = КоличествоПропущено + 1;
            Продолжить;
        КонецЕсли;
        
        Попытка
            ЭтапОбработки = "Повторная проверка дубля по УИД";
            Если НЕ ПустаяСтрока(СтрокаДанных.УИД) Тогда
                ДубльВоВремяЗаписи = НайтиДубльПоУИД(СтрокаДанных.УИД);
                Если ДубльВоВремяЗаписи <> Неопределено Тогда
                    СтрокаДанных.Статус = "Дубль";
                    СтрокаДанных.КомментарийДубля = "Повторная проверка: уже загружен " 
                        + Формат(ДубльВоВремяЗаписи.ДатаЗагрузки, "ДЛФ=DD")
                        + " из " + ДубльВоВремяЗаписи.ИмяФайла;
                    КоличествоПропущено = КоличествоПропущено + 1;
                    Продолжить;
                КонецЕсли;
            КонецЕсли;
            
            ЭтапОбработки = "Проверка типов ссылочных реквизитов";
            ОшибкаТипа = ПроверитьСсылочныеТипыСтроки(СтрокаДанных);
            Если НЕ ПустаяСтрока(ОшибкаТипа) Тогда
                ВызватьИсключение ОшибкаТипа;
            КонецЕсли;
            
            ЭтапОбработки = "Определение типа документа";
            
            НаправлениеВРег = ВРег(СокрЛП(СтрокаДанных.НаправлениеДенег));
            ЭтоПоступление = (СтрНайти(НаправлениеВРег, "ПРИХОД") > 0);
            ЭтоСписание    = (СтрНайти(НаправлениеВРег, "РАСХОД") > 0);
            
            Если НЕ ЭтоПоступление И НЕ ЭтоСписание Тогда
                КоличествоОшибок = КоличествоОшибок + 1;
                СписокОшибок.Добавить("Строка " + СтрокаДанных.НомерСтроки + ": не определён тип документа");
                СтрокаДанных.Статус = "Ошибка";
                СтрокаДанных.Комментарий = СтрокаДанных.Комментарий + "Не определён тип документа. ";
                Продолжить;
            КонецЕсли;
            
            ЭтапОбработки = "Определение хозяйственной операции";
            ХозОперация = Неопределено;
            Если ЗначениеЗаполнено(СтрокаДанных.ОперацияУТ) Тогда
                Попытка
                    ХозОперация = Перечисления.ХозяйственныеОперации[СтрокаДанных.ОперацияУТ];
                Исключение
                    Для Каждого ЗначениеПереч Из Метаданные.Перечисления.ХозяйственныеОперации.ЗначенияПеречисления Цикл
                        Если ВРег(СокрЛП(ЗначениеПереч.Синоним)) = ВРег(СокрЛП(СтрокаДанных.ОперацияУТ)) Тогда
                            ХозОперация = Перечисления.ХозяйственныеОперации[ЗначениеПереч.Имя];
                            Прервать;
                        КонецЕсли;
                    КонецЦикла;
                КонецПопытки;
            КонецЕсли;
            
            Если НЕ ЗначениеЗаполнено(ХозОперация) Тогда
                СтрокаДанных.Комментарий = СтрокаДанных.Комментарий 
                    + "Не удалось определить хозяйственную операцию (" + СтрокаДанных.ОперацияУТ + "). ";
            КонецЕсли;
            
            ВалютаДокумента = ОпределитьВалюту(СтрокаДанных.Валюта);
            
            // ── Договор ──────────────────────────────────────────────────────────
            // Используем договор, найденный на этапе предпросмотра (НайтиДоговорПоТипу).
            // НайтиИлиСоздатьДоговор здесь НЕ вызывается: строка не может иметь
            // статус "Готов" без заполненного НайденДоговор=Истина.
            // Новые договоры в рамках загрузки платёжек автоматически НЕ создаются.
            ДоговорСсылка = СтрокаДанных.ДоговорСсылка;
            Если НЕ ЗначениеЗаполнено(ДоговорСсылка) Тогда
                СтрокаДанных.Комментарий = СтрокаДанных.Комментарий
                    + "Договор не заполнен (пропущен контроль предпросмотра). ";
            КонецЕсли;

            ПартнерСсылка = ПолучитьПартнераКонтрагента(СтрокаДанных.КонтрагентСсылка);
            
            СчетКонтрагентаСсылка = СтрокаДанных.БанковскийСчетКонтрагента;
            Если НЕ ЗначениеЗаполнено(СчетКонтрагентаСсылка) И ЗначениеЗаполнено(СтрокаДанных.КонтрагентСсылка) Тогда
                ПодготовкаСчета = ПодготовитьНомерСчетаДляСоздания(СтрокаДанных, ЧастотаСчетовКонтрагентов);
                СчетКонтрагентаСсылка = ПопытатьсяСоздатьСчетКонтрагента(
                    СтрокаДанных.КонтрагентСсылка,
                    ПодготовкаСчета.НомерСчета,
                    СтрокаДанных.БИККонтр,
                    Строка(СтрокаДанных.ИНН) + "|" + Строка(СтрокаДанных.КППКонтр) + "|" + Строка(СтрокаДанных.УИД),
                    ПодготовкаСчета.БылаЗаглушка);
                
                Если ПодготовкаСчета.БылаЗаглушка И ЗначениеЗаполнено(СчетКонтрагентаСсылка) Тогда
                    СтрокаДанных.Комментарий = СтрокаДанных.Комментарий + "Счет-заглушка заменен техсчетом. ";
                КонецЕсли;
            КонецЕсли;
            
            ЭтапОбработки = "Создание документа";
            НачатьТранзакцию();
            
            Если ЭтоПоступление Тогда
                ДокОбъект = Документы.ПоступлениеБезналичныхДенежныхСредств.СоздатьДокумент();
                ЗаполнитьОбязательныеПоляПоступления(ДокОбъект);
            Иначе
                ДокОбъект = Документы.СписаниеБезналичныхДенежныхСредств.СоздатьДокумент();
                ЗаполнитьОбязательныеПоляСписания(ДокОбъект, ХозОперация);
            КонецЕсли;
            
            ЭтапОбработки = "Заполнение реквизитов";
            ДокОбъект.Дата                     = СтрокаДанных.Дата;
            ДокОбъект.Организация              = СтрокаДанных.ОрганизацияСсылка;
            ДокОбъект.БанковскийСчет           = СтрокаДанных.БанковскийСчетОрганизации;
            ДокОбъект.ХозяйственнаяОперация    = ХозОперация;
            ДокОбъект.СуммаДокумента           = СтрокаДанных.Сумма;
            ДокОбъект.Контрагент               = СтрокаДанных.КонтрагентСсылка;
            ДокОбъект.Валюта                   = ВалютаДокумента;
            ДокОбъект.ТипПлатежногоДокумента   = Перечисления.ТипыПлатежныхДокументов.ПлатежноеПоручение;
            ДокОбъект.НазначениеПлатежа        = СтрокаДанных.Назначение;
            ДокОбъект.НомерВходящегоДокумента  = СтрокаДанных.НомерПП;
            ДокОбъект.ДатаВходящегоДокумента   = СтрокаДанных.Дата;
            ДокОбъект.Комментарий              = "Автообмен";
            ДокОбъект.ПроведеноБанком          = Истина;
            ДокОбъект.ДатаПроведенияБанком     = СтрокаДанных.Дата;
            ДокОбъект.ИмяКонтрагента           = СтрокаДанных.Контрагент;
            
            Если ЗначениеЗаполнено(ДоговорСсылка) Тогда
                ДокОбъект.Договор = ДоговорСсылка;
            КонецЕсли;
            Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
                ДокОбъект.Партнер = ПартнерСсылка;
            КонецЕсли;
            Если ЗначениеЗаполнено(СчетКонтрагентаСсылка) Тогда
                ДокОбъект.БанковскийСчетКонтрагента = СчетКонтрагентаСсылка;
                
                // В разных релизах УТ реквизиты отправителя/получателя могут быть обязательны.
                Если ЭтоПоступление Тогда
                    Попытка ДокОбъект.БанковскийСчетОтправитель = СчетКонтрагентаСсылка; Исключение КонецПопытки;
                Иначе
                    Попытка ДокОбъект.БанковскийСчетПолучатель = СчетКонтрагентаСсылка; Исключение КонецПопытки;
                КонецЕсли;
            КонецЕсли;
            
            ЭтапОбработки = "Установка статьи ДДС";
            Если ЗначениеЗаполнено(СтрокаДанных.СтатьяДДССсылка) Тогда
                Попытка
                    ДокОбъект.СтатьяДвиженияДенежныхСредств = СтрокаДанных.СтатьяДДССсылка;
                Исключение
                    СтрокаДанных.Комментарий = СтрокаДанных.Комментарий + "Не удалось установить статью ДДС. ";
                КонецПопытки;
            Иначе
                СтрокаДанных.Комментарий = СтрокаДанных.Комментарий + "Статья ДДС не заполнена. ";
            КонецЕсли;

            ЭтапОбработки = "Заполнение РасшифровкаПлатежа";
            
            // ══════════════════════════════════════════════════════════════════
            // ВЕТКА А (АКТИВНА): простой подход из копии файла.
            // Одна строка расшифровки = вся сумма. Договор через заголовок документа.
            // Tryblock-ы для полей, которых может не быть в данной версии UT.
            // ══════════════════════════════════════════════════════════════════
            Попытка
                ДокОбъект.РасшифровкаПлатежа.Очистить();
                
                НоваяСтрока = ДокОбъект.РасшифровкаПлатежа.Добавить();
                НоваяСтрока.Сумма               = СтрокаДанных.Сумма;
                НоваяСтрока.СуммаВзаиморасчетов = СтрокаДанных.Сумма;
                
                Если ЗначениеЗаполнено(СтрокаДанных.СтатьяДДССсылка) Тогда
                    НоваяСтрока.СтатьяДвиженияДенежныхСредств = СтрокаДанных.СтатьяДДССсылка;
                    ДокОбъект.СтатьяДвиженияДенежныхСредств   = СтрокаДанных.СтатьяДДССсылка;
                КонецЕсли;
                
                Если ЭтоПоступление Тогда
                    // Платёж от клиента: ставим Партнер и пробуем ОснованиеПлатежа = Договор
                    Если ЗначениеЗаполнено(ПартнерСсылка) Тогда
                        Попытка НоваяСтрока.Партнер = ПартнерСсылка; Исключение КонецПопытки;
                    КонецЕсли;
                    Если ЗначениеЗаполнено(ДоговорСсылка) Тогда
                        Попытка НоваяСтрока.ОснованиеПлатежа = ДоговорСсылка; Исключение КонецПопытки;
                    КонецЕсли;
                Иначе
                    // Оплата поставщику: Контрагент + Договор + СтатьяРасходов
                    Если ЗначениеЗаполнено(СтрокаДанных.КонтрагентСсылка) Тогда
                        Попытка НоваяСтрока.Контрагент = СтрокаДанных.КонтрагентСсылка; Исключение КонецПопытки;
                    КонецЕсли;
                    Если ЗначениеЗаполнено(ДоговорСсылка) Тогда
                        Попытка НоваяСтрока.Договор = ДоговорСсылка; Исключение КонецПопытки;
                    КонецЕсли;
                    Попытка
                        СтатьяРасх = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоНаименованию("Прочие расходы");
                        Если ЗначениеЗаполнено(СтатьяРасх) Тогда
                            НоваяСтрока.СтатьяРасходов = СтатьяРасх;
                        КонецЕсли;
                    Исключение
                    КонецПопытки;
                КонецЕсли;
                
            Исключение
                СтрокаДанных.Комментарий = СтрокаДанных.Комментарий + "Ошибка заполнения расшифровки платежа. ";
            КонецПопытки;
            
            // ══════════════════════════════════════════════════════════════════
            // ВЕТКА Б (ЗАКОММЕНТИРОВАНА): FIFO + АналитикаУчетаПоПартнерам.
            // Чтобы включить — раскомментировать блок ниже и закомментировать Ветку А.
            // ══════════════════════════════════════════════════════════════════
            //
            // // Определяем ставку НДС из поля НДС_ИзТекста (может отсутствовать в форме)
            // ТекстНДС = "";
            // Попытка ТекстНДС = СтрокаДанных.НДС_ИзТекста; Исключение КонецПопытки;
            // СтавкаНДСДокумента = ОпределитьСтавкуНДСПоТексту(ТекстНДС);
            // СуммаНДСДокумента = 0;
            // Попытка
            //     СуммаНДСДокумента = СтрокаДанных.СуммаНДС_ИзТекста;
            // Исключение
            //     Если НЕ ПустаяСтрока(ТекстНДС) И ВРег(ТекстНДС) <> "БЕЗ НДС" Тогда
            //         Попытка
            //             Ставка = Число(СтрЗаменить(ТекстНДС, "%", ""));
            //             Если Ставка > 0 Тогда
            //                 СуммаНДСДокумента = Окр(СтрокаДанных.Сумма * Ставка / (100 + Ставка), 2);
            //             КонецЕсли;
            //         Исключение
            //         КонецПопытки;
            //     КонецЕсли;
            // КонецПопытки;
            // Если ТипЗнч(СуммаНДСДокумента) <> Тип("Число") Тогда СуммаНДСДокумента = 0; КонецЕсли;
            //
            // Попытка
            //     ТекстРаспределения = РаспределитьДеньгиПоДокументам(
            //         ДокОбъект, ДоговорСсылка, СтрокаДанных.Сумма, ЭтоПоступление,
            //         ПартнерСсылка, СтрокаДанных.СтатьяДДССсылка,
            //         СтавкаНДСДокумента, СуммаНДСДокумента);
            //     Если ЗначениеЗаполнено(ТекстРаспределения) Тогда
            //         СтрокаДанных.Комментарий = СтрокаДанных.Комментарий + ТекстРаспределения;
            //     КонецЕсли;
            // Исключение
            //     СтрокаДанных.Комментарий = СтрокаДанных.Комментарий + "Ошибка заполнения расшифровки платежа. ";
            // КонецПопытки;
            //
            // // Резервная строка расшифровки: если РаспределитьДеньгиПоДокументам вернул пустую ТЧ
            // Если ДокОбъект.РасшифровкаПлатежа.Количество() = 0 Тогда
            //     КлючАналитикиРезерв = НайтиКлючАналитикиПоДоговору(ДоговорСсылка);
            //     НоваяСтрока = ДокОбъект.РасшифровкаПлатежа.Добавить();
            //     ЗаполнитьСтрокуРасшифровкиПоFIFO(
            //         НоваяСтрока, СтрокаДанных.Сумма, ДоговорСсылка, Неопределено,
            //         ПартнерСсылка, СтрокаДанных.СтатьяДДССсылка, Истина,
            //         СтавкаНДСДокумента, СуммаНДСДокумента, КлючАналитикиРезерв);
            // КонецЕсли;
            
            ЭтапОбработки = "Финальный контроль";
            ОшибкаИнвариантов = ПроверитьФинальныеИнварианты(ДокОбъект, СтрокаДанных, ДоговорСсылка);
            Если НЕ ПустаяСтрока(ОшибкаИнвариантов) Тогда
                ВызватьИсключение ОшибкаИнвариантов;
            КонецЕсли;

            ЭтапОбработки = "Запись и проведение";
            ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
            
            ЭтапОбработки = "Финальный контроль после записи";
            ДокОбъектПослеЗаписи = ДокОбъект.Ссылка.ПолучитьОбъект();
            ОшибкаИнвариантов = ПроверитьФинальныеИнварианты(ДокОбъектПослеЗаписи, СтрокаДанных, ДоговорСсылка);
            Если НЕ ПустаяСтрока(ОшибкаИнвариантов) Тогда
                ВызватьИсключение ОшибкаИнвариантов;
            КонецЕсли;
            
            ЭтапОбработки = "Запись связи БП-УТ";
            ЗаписатьСвязьДокумента(ДокОбъект.Ссылка, СтрокаДанных.УИД, ИмяФайлаИсточника);
            ЗафиксироватьТранзакцию();
            
            СтрокаДанных.Статус = "Загружено";
            СтрокаДанных.Комментарий = СтрокаДанных.Комментарий 
                + "Документ " + Строка(ДокОбъект.Ссылка) + " создан и проведён. ";
            
            КоличествоСоздано = КоличествоСоздано + 1;
            ОбработаноВБанче  = ОбработаноВБанче + 1;
            
        Исключение
            Попытка ОтменитьТранзакцию(); Исключение КонецПопытки;
            
            ТекстОшибки = ОписаниеОшибки();
            КоличествоОшибок = КоличествоОшибок + 1;
            ОбработаноВБанче = ОбработаноВБанче + 1;
            СтрокаДанных.Статус = "Ошибка";
            СтрокаДанных.Комментарий = СтрокаДанных.Комментарий 
                + "Ошибка на этапе [" + ЭтапОбработки + "]: " + ТекстОшибки;
            
            СписокОшибок.Добавить("Строка " + СтрокаДанных.НомерСтроки + ": " + ТекстОшибки);
        КонецПопытки;
        
        // ── Батч-лог ─────────────────────────────────────────────────────────
        Если ОбработаноВБанче >= РазмерБанча Тогда
            НомерБанча = НомерБанча + 1;
            ВремяБанчаСек = (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоБанча) / 1000;
            Сообщить("[Банч " + Строка(НомерБанча) + "] "
                + "Создано: " + КоличествоСоздано
                + " | Ошибок: " + КоличествоОшибок
                + " | Пропущено: " + КоличествоПропущено
                + " | За " + Формат(ВремяБанчаСек, "ЧДЦ=2") + " сек.",
                СтатусСообщения.Информация);
            ОбработаноВБанче = 0;
            НачалоБанча = ТекущаяУниверсальнаяДатаВМиллисекундах();
        КонецЕсли;
        
    КонецЦикла;
    
    // Финальный лог незакрытого батча (если строк меньше РазмерБанча)
    Если ОбработаноВБанче > 0 Тогда
        НомерБанча = НомерБанча + 1;
        ВремяБанчаСек = (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоБанча) / 1000;
        Сообщить("[Банч " + Строка(НомерБанча) + " — финальный] "
            + "Создано: " + КоличествоСоздано
            + " | Ошибок: " + КоличествоОшибок
            + " | За " + Формат(ВремяБанчаСек, "ЧДЦ=2") + " сек.",
            СтатусСообщения.Информация);
    КонецЕсли;
    
    // === ИТОГ С ВРЕМЕНЕМ ===
    ТекстИтога = "Загрузка завершена." + Символы.ПС +
                 "Создано: " + КоличествоСоздано + Символы.ПС +
                 "Пропущено: " + КоличествоПропущено + Символы.ПС +
                 "Ошибок: " + КоличествоОшибок;

    Если НачальноеВремя <> Неопределено Тогда
        ВремяСек = (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачальноеВремя) / 1000;
        ТекстИтога = ТекстИтога + Символы.ПС + 
                     "Время выполнения: " + Формат(ВремяСек, "ЧДЦ=2") + " сек.";
    КонецЕсли;

    // Более заметное сообщение на сервере
    Сообщить(ТекстИтога, СтатусСообщения.Важное);
    
КонецПроцедуры

#КонецОбласти